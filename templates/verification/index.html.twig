<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Account - OpenSquadron</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0c111d;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --primary-accent: #0ea5e9;
            --primary-hover: #0284c7;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .auth-container {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            text-align: center;
        }

        .logo {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--primary-accent), #3b82f6);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        .logo svg {
            width: 24px;
            height: 24px;
            color: white;
            stroke-width: 2.5;
        }

        h1 {
            font-size: 24px;
            margin: 0 0 10px;
            font-weight: 600;
        }
        
        p {
            color: var(--text-muted);
            margin-bottom: 25px;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--glass-border);
            padding: 12px 15px;
            border-radius: 8px;
            color: #fff;
            font-size: 15px;
            box-sizing: border-box;
            transition: all 0.3s;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-accent);
            box-shadow: 0 0 0 2px rgba(14, 165, 233, 0.2);
        }

        .btn {
            width: 100%;
            background: var(--primary-accent);
            color: #fff;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        .btn:hover {
            background: var(--primary-hover);
        }

        .alert {
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            text-align: left;
        }
        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
        }
        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <h1>Verify Account</h1>
        <p>Please enter your email and the 6-digit code sent to your inbox.</p>

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        <form action="{{ path('app_verify') }}" method="POST">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" name="email" id="email" class="form-control" required placeholder="you@example.com">
            </div>
            
            <div class="form-group">
                <label for="code">Verification Code</label>
                <input type="text" name="code" id="code" class="form-control" required placeholder="123456" pattern="\d{6}" maxlength="6" style="text-align: center; letter-spacing: 4px; font-weight: 700;">
            </div>

            <button type="submit" class="btn">Verify & Activate</button>
        </form>

        <form action="{{ path('app_verify_resend') }}" method="POST" id="resend-form" style="margin-top: 15px;">
            <input type="hidden" name="email" id="resend-email-input">
            <p style="margin: 0; font-size: 13px;">Didn't receive the code? <button type="button" onclick="submitResend()" style="background: none; border: none; color: var(--primary-accent); cursor: pointer; padding: 0; font-size: 13px; font-weight: 500; text-decoration: underline;">Resend Email</button></p>
        </form>

        <script>
            function submitResend() {
                var emailVal = document.getElementById('email').value;
                if (!emailVal) {
                    alert('Please enter your email address first to resend the code.');
                    document.getElementById('email').focus();
                    return;
                }
                document.getElementById('resend-email-input').value = emailVal;
                document.getElementById('resend-form').submit();
            }
        </script>
    </div>
</body>
</html>

    function onAiProviderChange() {
        const provider = document.getElementById('ai-provider').value;
        const modelInput = document.getElementById('ai-model');
        const apiKeyGroup = document.getElementById('ai-apiKey-group');
        const apiKeyInput = document.getElementById('ai-apiKey');
        const apiKeyLabel = document.getElementById('ai-apiKey-label');
        const endpointInput = document.getElementById('ai-apiEndpoint');
        const modelHint = document.getElementById('ai-model-hint');
        const endpointLabel = document.getElementById('ai-apiEndpoint-label');
        const endpointHint = document.getElementById('ai-apiEndpoint-hint');

        const defaults = PROVIDER_DEFAULTS[provider] || PROVIDER_DEFAULTS.custom;
        const defaultModel = defaults.placeholder;
        const defaultEndpoint = defaults.endpoint;
        const hintText = defaults.hint;

        if (!modelInput.value || Object.values(PROVIDER_DEFAULTS).some(d => d.models.includes(modelInput.value) || d.placeholder === modelInput.value)) {
            modelInput.value = '';
        }

        modelInput.placeholder = defaultModel;

        // Dynamic API Key field visibility and requirements
        if (provider === 'ollama') {
            if (apiKeyGroup) apiKeyGroup.style.display = 'none';
            if (apiKeyInput) apiKeyInput.required = false;
        } else {
            if (apiKeyGroup) apiKeyGroup.style.display = 'flex';
            if (provider === 'lmstudio') {
                if (apiKeyInput) {
                    apiKeyInput.required = false;
                    apiKeyInput.placeholder = 'lm-studio (automatically defaulted if empty)';
                }
                if (apiKeyLabel) {
                    apiKeyLabel.innerHTML = 'API Key <small style="font-weight:400; opacity: 0.6;">(Optional)</small>';
                }
            } else {
                if (apiKeyInput) {
                    apiKeyInput.required = true;
                    apiKeyInput.placeholder = 'Enter API Key/Token';
                }
                if (apiKeyLabel) {
                    apiKeyLabel.innerHTML = 'API Key <span>*</span>';
                }
            }
        }

        // Dynamic Endpoint field requirements
        if (provider === 'custom' || provider === 'ollama') {
            endpointInput.placeholder = 'e.g. http://localhost:11434/v1';
            endpointInput.required = true;
            if (endpointLabel) {
                endpointLabel.innerHTML = 'Custom API Endpoint <span>*</span>';
            }
            if (endpointHint) {
                if (provider === 'ollama') {
                    endpointHint.innerHTML = 'Required for Ollama (Local) provider. Enter your local endpoint base URL (e.g. <code>http://localhost:11434/v1</code>).';
                } else {
                    endpointHint.innerHTML = 'Required for compatible custom providers. Enter your local or custom proxy endpoint base URL.';
                }
                endpointHint.style.color = '#38bdf8'; // Highlight for guidance
            }
        } else {
            endpointInput.placeholder = defaultEndpoint || 'Leave empty for official API';
            endpointInput.required = false;
            if (endpointLabel) {
                endpointLabel.innerHTML = 'Custom API Endpoint <small style="font-weight:400; opacity: 0.6;">(Optional)</small>';
            }
            if (endpointHint) {
                if (provider === 'ollamacloud') {
                    endpointHint.innerHTML = 'Official Ollama Cloud endpoint. Leave empty to use official API (defaults to <code>https://ollama.com/v1</code>).';
                } else {
                    endpointHint.innerHTML = 'Required for custom proxies or local endpoints. Leave empty to use provider\'s official API endpoint.';
                }
                endpointHint.style.color = ''; // Reset color
            }
        }

        if (modelHint) {
            modelHint.textContent = hintText;
        }

        const searchInput = document.getElementById('ai-model-search');
        if (searchInput) searchInput.value = '';
        if (typeof updateModelDropdownOptions === 'function') {
            updateModelDropdownOptions();
        }
    }

    function fetchModelsFromApi() {
        const provider = document.getElementById('ai-provider').value;
        const apiKey = document.getElementById('ai-apiKey').value.trim();
        const endpoint = document.getElementById('ai-apiEndpoint').value.trim();
        const btn = document.getElementById('btn-fetch-models');

        if (!apiKey && provider !== 'ollama' && provider !== 'lmstudio') {
            showToast('Please enter an API Key first to fetch models!', 'error');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;margin-right:6px;animation:spin 1s linear infinite;"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg><span>Fetching...</span>';

        const formData = new FormData();
        formData.append('provider', provider);
        formData.append('apiKey', apiKey);
        formData.append('apiEndpoint', endpoint);

        fetch('{{ path('app_ai_models_fetch') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success && Array.isArray(data.models)) {
                // Map the models format to what the autocomplete dropdown expects
                currentFetchedModels = data.models.map(m => m.id || m);
                showToast(`Successfully fetched ${data.models.length} models!`, 'success');
                updateModelDropdownOptions();
                
                // Automatically show dropdown menu
                const dropdownMenu = document.getElementById('ai-model-dropdown');
                if (dropdownMenu) dropdownMenu.style.display = 'flex';
                document.getElementById('ai-model-search').focus();
            } else {
                showToast('Failed to fetch models: ' + (data.error || 'Check credentials'), 'error');
            }
        })
        .catch(err => {
            showToast('Fetch error: ' + err.message, 'error');
        })
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;margin-right:6px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg><span>Fetch Models</span>';
        });
    }

    function initModelDropdown() {
        const modelInput = document.getElementById('ai-model');
        const dropdownMenu = document.getElementById('ai-model-dropdown');
        const searchInput = document.getElementById('ai-model-search');

        if (!modelInput || !dropdownMenu || !searchInput) return;

        modelInput.addEventListener('focus', () => {
            updateModelDropdownOptions();
            dropdownMenu.style.display = 'flex';
        });

        // Hide dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.custom-dropdown-container') && e.target !== modelInput) {
                dropdownMenu.style.display = 'none';
            }
        });

        searchInput.addEventListener('input', () => {
            updateModelDropdownOptions(searchInput.value.trim().toLowerCase());
        });
    }

    function updateModelDropdownOptions(query = '') {
        const provider = document.getElementById('ai-provider').value;
        const optionsList = document.getElementById('ai-model-options');
        if (!optionsList) return;

        optionsList.innerHTML = '';

        // Combine static default models for the provider and any dynamically fetched ones
        const staticList = (PROVIDER_DEFAULTS[provider] || PROVIDER_DEFAULTS.custom).models;
        const allModelsSet = new Set([...currentFetchedModels, ...staticList]);
        const allModels = Array.from(allModelsSet);

        const filtered = allModels.filter(m => m.toLowerCase().includes(query));

        if (filtered.length === 0) {
            const noOptions = document.createElement('div');
            noOptions.className = 'custom-dropdown-option';
            noOptions.style.opacity = '0.5';
            noOptions.style.cursor = 'default';
            noOptions.textContent = 'No models found';
            optionsList.appendChild(noOptions);
            return;
        }

        filtered.forEach(modelName => {
            const opt = document.createElement('div');
            opt.className = 'custom-dropdown-option';
            opt.textContent = modelName;
            opt.addEventListener('click', () => {
                document.getElementById('ai-model').value = modelName;
                document.getElementById('ai-model-dropdown').style.display = 'none';
            });
            optionsList.appendChild(opt);
        });
    }


    // ─────────── Modular Context Builder ───────────
    let currentModules = [];
    let faqTargetModuleIndex = null;    // Which FAQ block the modal is editing
    let faqModalPendingItems = [];      // Items staged in the modal

    function renderModules() {
        const container = document.getElementById('context-modules-container');
        if (!container) return;

        container.innerHTML = '';

        if (currentModules.length === 0) {
            const empty = document.createElement('div');
            empty.style.cssText = 'text-align:center; color:var(--text-muted); font-size:13px; padding:24px;';
            empty.textContent = 'No blocks added yet. Use the buttons below to start building your context.';
            container.appendChild(empty);
            return;
        }

        currentModules.forEach((mod, index) => {
            const card = document.createElement('div');
            card.style.cssText = 'background:rgba(15,23,42,0.45); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:14px; display:flex; flex-direction:column; gap:10px; position:relative;';

            // ── Delete button — created FIRST, never touched by innerHTML after this ──
            const delBtn = document.createElement('button');
            delBtn.type = 'button';
            delBtn.title = 'Remove block';
            delBtn.style.cssText = 'position:absolute; top:10px; right:10px; background:transparent; border:none; color:#ef4444; cursor:pointer; padding:4px; border-radius:4px; display:flex; align-items:center; justify-content:center; z-index:2;';
            delBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;pointer-events:none;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
            delBtn.onmouseover = () => { delBtn.style.background = 'rgba(239,68,68,0.12)'; };
            delBtn.onmouseout  = () => { delBtn.style.background = 'transparent'; };
            delBtn.onclick = () => removeModule(index);
            card.appendChild(delBtn);

            // ── Helper: create a label row div ──
            function makeLabel(svgPath, labelText, color, extraSpan) {
                const d = document.createElement('div');
                d.style.cssText = `font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.6px; color:${color}; display:flex; align-items:center; gap:6px; padding-right:28px;`;
                d.innerHTML = svgPath;
                const t = document.createTextNode(' ' + labelText);
                d.appendChild(t);
                if (extraSpan) {
                    const s = document.createElement('span');
                    s.style.cssText = 'font-weight:400; font-size:10px; text-transform:none; letter-spacing:0; color:#64748b;';
                    s.textContent = extraSpan;
                    d.appendChild(s);
                }
                return d;
            }

            if (mod.type === 'text') {
                card.style.borderLeftColor = 'rgba(100,116,139,0.4)';
                card.appendChild(makeLabel(
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="4 7 4 4 20 4 20 7"></polyline><line x1="9" y1="20" x2="15" y2="20"></line><line x1="12" y1="4" x2="12" y2="20"></line></svg>',
                    'Rich Text', '#94a3b8', null
                ));
                const ta = document.createElement('textarea');
                ta.className = 'form-control';
                ta.style.cssText = 'min-height:80px; font-size:13px; resize:vertical;';
                ta.placeholder = 'Enter static knowledge text here...';
                ta.value = mod.content || '';
                ta.oninput = () => updateModule(index, 'content', ta.value);
                card.appendChild(ta);
            }
            else if (mod.type === 'faq') {
                card.style.borderColor = 'rgba(168,85,247,0.25)';
                card.style.background  = 'rgba(88,28,135,0.08)';
                const items = mod.items || [];
                const countLabel = items.length === 0 ? 'Empty — click to add pairs' : `${items.length} Q&A pair${items.length !== 1 ? 's' : ''}`;

                const labelDiv = makeLabel(
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>',
                    'FAQ Block', '#c084fc', null
                );
                const countSpan = document.createElement('span');
                countSpan.style.cssText = 'font-weight:400; color:#a855f7; font-size:10px; text-transform:none; letter-spacing:0;';
                countSpan.textContent = '(' + countLabel + ')';
                labelDiv.appendChild(countSpan);
                card.appendChild(labelDiv);

                if (items.length > 0) {
                    const preview = document.createElement('div');
                    preview.style.cssText = 'display:flex; flex-direction:column; gap:6px; max-height:160px; overflow-y:auto;';
                    items.forEach(item => {
                        const row = document.createElement('div');
                        row.style.cssText = 'background:rgba(0,0,0,0.2); border-radius:6px; padding:8px 10px; font-size:12px;';
                        const qd = document.createElement('div');
                        qd.style.cssText = 'color:#c084fc; font-weight:600; margin-bottom:3px;';
                        qd.textContent = 'Q: ' + (item.q || '');
                        const ad = document.createElement('div');
                        ad.style.cssText = 'color:#94a3b8;';
                        ad.textContent = 'A: ' + (item.a || '');
                        row.appendChild(qd); row.appendChild(ad);
                        preview.appendChild(row);
                    });
                    card.appendChild(preview);
                }

                const editBtn = document.createElement('button');
                editBtn.type = 'button';
                editBtn.style.cssText = 'align-self:flex-start; background:rgba(168,85,247,0.12); border:1px solid rgba(168,85,247,0.3); color:#c084fc; border-radius:8px; padding:6px 14px; font-size:12px; cursor:pointer; font-weight:600; display:flex; align-items:center; gap:6px;';
                editBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;pointer-events:none;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>';
                editBtn.appendChild(document.createTextNode(items.length > 0 ? 'Edit FAQs' : 'Create FAQs'));
                editBtn.onclick = () => openFaqModal(index);
                card.appendChild(editBtn);
            }
            else if (mod.type === 'api') {
                card.style.borderLeftColor = 'rgba(6,182,212,0.3)';
                card.appendChild(makeLabel(
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>',
                    'Saved API', '#67e8f9', '— data fetched on Save'
                ));
                const sel = document.createElement('select');
                sel.className = 'form-control';
                sel.style.cssText = 'font-size:13px; height:36px;';
                let opts = '<option value="">-- Select Saved API --</option>';
                {% if httpApis is defined %}
                    {% for api in httpApis %}
                        opts += `<option value="{{ api.id }}" ${mod.apiId == '{{ api.id }}' ? 'selected' : ''}>{{ api.name|escape('js') }}</option>`;
                    {% endfor %}
                {% endif %}
                sel.innerHTML = opts;
                sel.onchange = () => updateModule(index, 'apiId', sel.value);
                card.appendChild(sel);
            }
            else if (mod.type === 'web') {
                card.style.borderLeftColor = 'rgba(34,197,94,0.3)';
                card.appendChild(makeLabel(
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line></svg>',
                    'Web Scraper', '#86efac', '— scraped on Save'
                ));
                const row = document.createElement('div');
                row.style.cssText = 'display:flex; gap:8px; flex-wrap:wrap; padding-right:28px;';
                const urlIn = document.createElement('input');
                urlIn.type = 'text'; urlIn.className = 'form-control';
                urlIn.placeholder = 'Target URL';
                urlIn.style.cssText = 'font-size:13px; height:36px; flex:2; min-width:200px;';
                urlIn.value = mod.url || '';
                urlIn.oninput = () => updateModule(index, 'url', urlIn.value);
                const selIn = document.createElement('input');
                selIn.type = 'text'; selIn.className = 'form-control';
                selIn.placeholder = 'CSS Selector (optional)';
                selIn.style.cssText = 'font-size:13px; height:36px; flex:1; min-width:140px;';
                selIn.value = mod.selector || '';
                selIn.oninput = () => updateModule(index, 'selector', selIn.value);
                row.appendChild(urlIn); row.appendChild(selIn);
                card.appendChild(row);
            }
            else if (mod.type === 'ecommerce') {
                card.style.borderLeftColor = 'rgba(251,191,36,0.3)';
                card.appendChild(makeLabel(
                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>',
                    'eCommerce Catalog', '#fcd34d', null
                ));
                const desc = document.createElement('div');
                desc.style.cssText = 'font-size:12px; color:var(--text-muted);';
                desc.textContent = 'Automatically imports all active products, prices, and stock levels when you Save.';
                card.appendChild(desc);
            }

            container.appendChild(card);
        });

        const el = document.getElementById('ctx-modulesData');
        if (el) el.value = JSON.stringify(currentModules);
    }

    function addContextModule(type) {
        currentModules.push({ type: type, items: type === 'faq' ? [] : undefined });
        renderModules();
        if (type === 'faq') {
            openFaqModal(currentModules.length - 1);
        }
    }
    window.addContextModule = addContextModule;

    function removeModule(index) {
        currentModules.splice(index, 1);
        renderModules();
    }
    window.removeModule = removeModule;

    function updateModule(index, field, value) {
        if (currentModules[index]) {
            currentModules[index][field] = value;
            const el = document.getElementById('ctx-modulesData');
            if (el) el.value = JSON.stringify(currentModules);
        }
    }
    window.updateModule = updateModule;

    document.addEventListener('DOMContentLoaded', () => {
        if (document.getElementById('context-modules-container')) renderModules();
    });

    // ─────────── FAQ Creator Modal Logic ───────────
    function openFaqModal(moduleIndex) {
        faqTargetModuleIndex = moduleIndex;
        faqModalPendingItems = JSON.parse(JSON.stringify(currentModules[moduleIndex]?.items || []));

        // Reset modal state
        switchFaqTab('manual');
        renderManualPairs();

        const modal = document.getElementById('faq-creator-modal');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    window.openFaqModal = openFaqModal;

    function closeFaqModal() {
        document.getElementById('faq-creator-modal').style.display = 'none';
        document.body.style.overflow = '';
        faqTargetModuleIndex = null;
        faqModalPendingItems = [];
    }
    window.closeFaqModal = closeFaqModal;

    function switchFaqTab(tab) {
        document.querySelectorAll('.faq-tab').forEach(btn => {
            const isActive = btn.getAttribute('data-tab') === tab;
            btn.style.borderBottom = isActive ? '2px solid #c084fc' : '2px solid transparent';
            btn.style.color = isActive ? '#c084fc' : '#64748b';
        });
        document.querySelectorAll('.faq-tab-content').forEach(el => {
            el.style.display = 'none';
        });
        const activeEl = document.getElementById('faq-tab-' + tab);
        if (activeEl) activeEl.style.display = 'block';
    }
    window.switchFaqTab = switchFaqTab;

    function renderManualPairs() {
        const container = document.getElementById('faq-manual-pairs');
        if (!container) return;
        container.innerHTML = '';
        faqModalPendingItems.forEach((item, i) => {
            const row = document.createElement('div');
            row.style.cssText = 'background:rgba(0,0,0,0.2); border-radius:8px; padding:10px; display:flex; flex-direction:column; gap:6px; position:relative;';
            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.title = 'Remove this pair';
            removeBtn.style.cssText = 'position:absolute; top:20px; right:20px; background:transparent; border:none; color:#ef4444; cursor:pointer; padding:4px; border-radius:4px; display:flex; align-items:center; justify-content:center; z-index:2;';
            removeBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
            removeBtn.onmouseover = () => { removeBtn.style.background = 'rgba(239,68,68,0.12)'; };
            removeBtn.onmouseout = () => { removeBtn.style.background = 'transparent'; };
            removeBtn.onclick = () => { faqModalPendingItems.splice(i, 1); renderManualPairs(); };
            const qIn = document.createElement('input');
            qIn.type = 'text'; qIn.className = 'form-control'; qIn.placeholder = 'Question'; qIn.value = item.q || '';
            qIn.style.cssText = 'font-size:13px; height:36px; padding-right: 28px;';
            qIn.oninput = () => { faqModalPendingItems[i].q = qIn.value; };
            const aIn = document.createElement('textarea');
            aIn.className = 'form-control'; aIn.placeholder = 'Answer'; aIn.value = item.a || '';
            aIn.style.cssText = 'font-size:13px; min-height:60px; resize:vertical;';
            aIn.oninput = () => { faqModalPendingItems[i].a = aIn.value; };
            row.appendChild(removeBtn); row.appendChild(qIn); row.appendChild(aIn);
            container.appendChild(row);
        });
    }

    function addManualFaqPair() {
        faqModalPendingItems.push({ q: '', a: '' });
        renderManualPairs();
    }
    window.addManualFaqPair = addManualFaqPair;

    function generateFaqsFromSource(source) {
        const btnId = 'faq-btn-' + source;
        const btn = document.getElementById(btnId);
        if (btn) { btn.disabled = true; btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;margin-right:6px;animation:spin 1s linear infinite;"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>Generating...'; }

        const formData = new FormData();
        formData.append('source', source);

        if (source === 'text') {
            const text = document.getElementById('faq-text-input').value.trim();
            if (!text) { showToast('Please paste some text first.', 'error'); if (btn) { btn.disabled = false; btn.innerHTML = 'Generate FAQs with AI'; } return; }
            formData.append('contextData', text);
        } else if (source === 'api') {
            const apiId = document.getElementById('faq-api-select').value;
            if (!apiId) { showToast('Please select a saved API.', 'error'); if (btn) { btn.disabled = false; btn.innerHTML = 'Execute API & Generate FAQs'; } return; }
            formData.append('apiId', apiId);
        } else if (source === 'web') {
            const url = document.getElementById('faq-web-url').value.trim();
            const selector = document.getElementById('faq-web-selector').value.trim();
            if (!url) { showToast('Please enter a URL.', 'error'); if (btn) { btn.disabled = false; btn.innerHTML = 'Scrape & Generate FAQs'; } return; }
            formData.append('url', url);
            formData.append('selector', selector);
        }

        fetch('{{ path('app_ai_generate_faqs') }}', { method: 'POST', body: formData })
        .then(res => res.json())
        .then(data => {
            if (data.success && Array.isArray(data.items) && data.items.length > 0) {
                faqModalPendingItems = [...faqModalPendingItems, ...data.items];
                renderManualPairs();
                switchFaqTab('manual');
                showToast(`${data.items.length} FAQ pair(s) generated!`, 'success');
            } else {
                showToast(data.error || 'No FAQs could be generated.', 'error');
            }
        })
        .catch(err => showToast('Error: ' + err.message, 'error'))
        .finally(() => {
            if (btn) {
                btn.disabled = false;
                const labels = { text: 'Generate FAQs with AI', api: 'Execute API & Generate FAQs', web: 'Scrape & Generate FAQs', ecommerce: 'Generate from Catalog' };
                btn.innerHTML = labels[source] || 'Generate';
            }
        });
    }
    window.generateFaqsFromSource = generateFaqsFromSource;


    function commitFaqsToBlock() {
        if (faqTargetModuleIndex === null) return;

        // Collect from manual tab inputs (they are bound via oninput, so faqModalPendingItems is already up-to-date)
        const validItems = faqModalPendingItems.filter(i => i.q && i.a);

        if (validItems.length === 0) {
            showToast('No valid FAQ pairs to add. Please fill in both Q and A fields.', 'error');
            return;
        }

        currentModules[faqTargetModuleIndex].items = validItems;
        renderModules();
        closeFaqModal();
        showToast(`${validItems.length} FAQ pair(s) saved to block!`, 'success');
    }
    window.commitFaqsToBlock = commitFaqsToBlock;

    // Close modal on backdrop click
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('faq-creator-modal');
        if (modal) {
            modal.addEventListener('click', e => {
                if (e.target === modal) closeFaqModal();
            });
        }
    });
</script>
{% endblock %}

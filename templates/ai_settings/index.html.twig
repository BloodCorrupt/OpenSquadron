    function saveAiApiConfig(event) {
        event.preventDefault();

        const provider = document.getElementById('ai-provider').value;
        const apiKeyInput = document.getElementById('ai-apiKey');
        const apiKey = apiKeyInput.value.trim();
        const endpointInput = document.getElementById('ai-apiEndpoint');
        const endpointValue = endpointInput.value.trim();

        // Robust client-side validation
        if (!apiKey && provider !== 'ollama' && provider !== 'lmstudio') {
            showToast('API Key/Token is required!', 'error');
            apiKeyInput.focus();
            apiKeyInput.style.borderColor = 'rgba(239, 68, 68, 0.5)';
            apiKeyInput.style.boxShadow = '0 0 0 2px rgba(239, 68, 68, 0.2)';
            
            const resetApiKeyError = () => {
                apiKeyInput.style.borderColor = '';
                apiKeyInput.style.boxShadow = '';
                apiKeyInput.removeEventListener('input', resetApiKeyError);
            };
            apiKeyInput.addEventListener('input', resetApiKeyError);
            return;
        }

        if ((provider === 'custom' || provider === 'ollama') && !endpointValue) {
            showToast(provider === 'ollama' 
                ? 'Custom API Endpoint is required for Ollama (Local) provider!'
                : 'Custom API Endpoint is required for OpenAI Compatible (Custom) provider!', 'error');
            endpointInput.focus();
            endpointInput.style.borderColor = 'rgba(239, 68, 68, 0.5)';
            endpointInput.style.boxShadow = '0 0 0 2px rgba(239, 68, 68, 0.2)';
            
            const resetEndpointError = () => {
                endpointInput.style.borderColor = '';
                endpointInput.style.boxShadow = '';
                endpointInput.removeEventListener('input', resetEndpointError);
            };
            endpointInput.addEventListener('input', resetEndpointError);
            return;
        }

        const btn = document.getElementById('btn-save-ai-api');
        btn.disabled = true;
        btn.innerHTML = '<span>Saving...</span>';

        const form = document.getElementById('ai-api-config-form');
        const formData = new FormData(form);
        const activeCheckbox = document.getElementById('ai-isActive') || document.getElementById('ai-isActive-custom');
        if (activeCheckbox) {
            formData.set('isActive', activeCheckbox.checked ? '1' : '0');
        }

        fetch('{{ path('app_ai_settings_save') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('API Configuration saved successfully!', 'success');
            } else {
                showToast('Failed to save API configuration: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => {
            showToast('Save error: ' + err.message, 'error');
        })
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg> <span>Save API Configuration</span>';
        });
    }


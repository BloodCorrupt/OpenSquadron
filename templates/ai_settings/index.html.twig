{% extends 'base.html.twig' %}

{% block title %}AI Settings - OpenSquadron{% endblock %}

{% block stylesheets %}
<style>
    /* Two-column layout */
    .manager-shell {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 30px;
        margin-top: 20px;
        min-height: calc(100vh - 180px);
    }

    /* Left Nav Sidebar Panel */
    .manager-nav {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        height: fit-content;
    }
    .manager-nav .nav-header {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.6px;
        margin-bottom: 12px;
        padding-left: 10px;
    }
    .manager-nav .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 12px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.2s;
        border: 1px solid transparent;
        cursor: pointer;
        user-select: none;
    }
    .manager-nav .nav-item:hover {
        color: var(--text-main);
        background: rgba(255, 255, 255, 0.03);
    }
    .manager-nav .nav-item.is-active {
        color: var(--text-main);
        background: rgba(6, 182, 212, 0.1);
        border-color: rgba(6, 182, 212, 0.2);
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.05);
    }
    .manager-nav .nav-item-icon {
        font-size: 18px;
    }
    .manager-nav .nav-item-status {
        margin-left: auto;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.05);
    }
    .manager-nav .nav-item.is-active .nav-item-status {
        background: rgba(6, 182, 212, 0.2);
        color: var(--primary-accent);
    }

    /* Right Content Panel */
    .manager-content-pane {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(4px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed var(--glass-border);
        padding-bottom: 18px;
    }
    .content-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .content-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    /* Form Styles */
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #e2e8f0;
    }
    .form-label span {
        color: var(--primary-accent);
    }
    .form-control {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 10px 14px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: all 0.2s;
        height: 42px;
        box-sizing: border-box;
    }
    textarea.form-control {
        height: auto;
        resize: vertical;
        line-height: 1.5;
    }
    .form-control:focus {
        border-color: var(--primary-accent);
        box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
    }
    select.form-control option {
        background-color: #0f172a !important;
        color: #f8fafc !important;
    }
    .form-hint {
        font-size: 12px;
        color: #64748b;
        margin: 4px 0 0 0;
    }

    /* Switch toggle component */
    .switch-toggle {
        position: relative;
        display: inline-block;
        width: 44px;
        min-width: 44px;
        height: 24px;
        max-height: 24px;
        flex-shrink: 0;
        padding: 0;
        box-sizing: border-box;
    }
    .switch-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.1);
        transition: .3s;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
    }
    .slider-round:before {
        position: absolute;
        content: "";
        height: 16px;
        width: 16px;
        left: 3px;
        top: 0;
        bottom: 0;
        margin: auto 0;
        background-color: white;
        transition: .3s;
        border-radius: 50%;
    }
    .switch-toggle input:checked + .slider-round {
        background-color: var(--primary-accent);
    }
    .switch-toggle input:checked + .slider-round:before {
        transform: translateX(20px);
    }

    /* Custom searchable dropdown */
    .custom-dropdown-container {
        position: relative;
        flex-grow: 1;
    }
    .custom-dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1000;
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        margin-top: 5px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
        max-height: 250px;
        overflow: hidden;
        flex-direction: column;
    }
    .custom-dropdown-search-wrapper {
        padding: 8px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .custom-dropdown-options-list {
        overflow-y: auto;
        max-height: 190px;
    }
    .custom-dropdown-option {
        padding: 10px 14px;
        font-size: 13px;
        color: #cbd5e1;
        cursor: pointer;
        transition: all 0.15s;
    }
    .custom-dropdown-option:hover {
        background: rgba(6, 182, 212, 0.15);
        color: #fff;
    }

    /* Toast component */
    .fb-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        padding: 14px 20px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        display: none;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        animation: toastSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes toastSlideIn {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .fb-toast.toast-success {
        background: rgba(16, 185, 129, 0.9);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .fb-toast.toast-error {
        background: rgba(239, 68, 68, 0.9);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    /* Buttons */
    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent;
        color: #fff;
        text-decoration: none;
        user-select: none;
    }
    .btn-create {
        background: linear-gradient(135deg, var(--primary-accent) 0%, #0891b2 100%);
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.2);
    }
    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(6, 182, 212, 0.3);
    }

    @media (max-width: 768px) {
        .manager-shell {
            grid-template-columns: 1fr !important;
            gap: 16px !important;
        }
        .manager-content-pane {
            padding: 16px 12px !important;
            gap: 16px !important;
        }
        #ai-api-config-form > div, #ai-context-form > div {
            padding: 14px !important;
        }
        #context-list-view > div:last-child {
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch;
        }
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
</style>
{% endblock %}

{% block body %}
<div class="manager-shell">
    {# ───────── Left Sidebar Navigation ───────── #}
    <div class="manager-nav">
        <div class="sidebar-mobile-toggle">
            <span>
                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke-width: 2.5;"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                Menu Options
            </span>
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="nav-header">AI Settings</div>
        
        <div class="nav-item is-active" data-tab-target="api-config" onclick="switchAiSubtab('api-config')">
            <span class="nav-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
            </span>
            <span>API Configuration</span>
        </div>

        <div class="nav-item" data-tab-target="context-agent" onclick="switchAiSubtab('context-agent')">
            <span class="nav-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M6 11V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"></path></svg>
            </span>
            <span>Context Manager</span>
        </div>
    </div>

    {# ───────── Right Content Pane ───────── #}
    <div class="manager-content-pane">
        <div class="content-header" style="margin-bottom: 20px;">
            <div>
                <h1 class="content-title">
                    <span id="ai-settings-title-icon"><svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg></span>
                    <span id="ai-settings-title-text">API Configuration</span>
                </h1>
                <div class="content-subtitle" id="ai-settings-title-desc">Configure global AI provider integration (OpenAI, Gemini, Moonshot, OpenRouter).</div>
            </div>
        </div>

        <!-- Inner Content Area containing sub-panes -->
        <div class="ai-agent-subpane-container" style="width: 100%; display: flex; flex-direction: column; gap: 20px;">
            
            <!-- Sub-pane 1: API Configuration -->
            <div class="ai-agent-subpane" id="ai-subpane-api-config" style="display: block; width: 100%;">
                <div style="background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.2); border-radius: 12px; padding: 16px 20px; font-size: 13px; color: #94a3b8; line-height: 1.5; margin-bottom: 20px;">
                    <strong style="color: var(--primary-accent); display:inline-flex; align-items:center; gap:5px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg> Open Nature:</strong> Connect to any provider: OpenAI, Google Gemini, Moonshot (Kimi), OpenRouter, or a custom self-hosted proxy/endpoint.
                </div>

                <form id="ai-api-config-form" onsubmit="saveAiApiConfig(event)" style="display: flex; flex-direction: column; gap: 24px; width: 100%;">
                    <!-- Fake credentials fields to bypass browser autocomplete/autofill -->
                    <input type="text" name="fake_username_remembered" style="display:none" aria-hidden="true" autocomplete="off" />
                    <input type="password" name="fake_password_remembered" style="display:none" aria-hidden="true" autocomplete="off" />
                    <input type="hidden" name="configType" value="api" />

                    <div style="background: rgba(15, 23, 42, 0.2); border: 1px solid var(--glass-border); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 16px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px; margin-bottom: 4px;">
                            <h3 style="font-size: 14px; font-weight: 600; color: #f8fafc; margin: 0; display: flex; align-items: center; gap: 8px;">
                                <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
                                {% if app.user and app.user.accountType in ['super_admin', 'reseller'] %}
                                    <span>Global API Configuration</span>
                                {% else %}
                                    <span>API Configuration</span>
                                {% endif %}
                            </h3>
                            {% if app.user and app.user.accountType in ['super_admin', 'reseller'] %}
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="font-size: 12px; color: var(--text-muted);">Global Active State:</span>
                                <label class="switch-toggle" style="margin: 0;">
                                    <input type="checkbox" name="isActive" id="ai-isActive" {% if aiSetting.isActive() %}checked{% endif %}>
                                    <span class="slider-round"></span>
                                </label>
                            </div>
                            {% endif %}
                        </div>

                    {% if app.user and app.user.accountType != 'super_admin' %}
                        <div style="background: rgba(15, 23, 42, 0.2); border: 1px solid var(--glass-border); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 16px; margin-bottom: 16px;">
                            <div style="display: flex; align-items: center; justify-content: space-between;">
                                <div>
                                    <h3 style="font-size: 14px; font-weight: 600; color: #f8fafc; margin: 0 0 4px 0;">Use Custom AI Credentials</h3>
                                    <p style="font-size: 12px; color: #94a3b8; margin: 0;">If disabled, the system will use the default server global AI settings.</p>
                                </div>
                                <label class="switch-toggle" style="margin: 0;">
                                    <input type="checkbox" name="useCustom" id="useCustomToggle" onchange="toggleCustomSettings()" {% if isUsingCustom %}checked{% endif %}>
                                    <span class="slider-round"></span>
                                </label>
                            </div>
                        </div>

                        <div id="global-settings-notice" style="display: {% if isUsingCustom %}none{% else %}block{% endif %}; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 12px; padding: 16px 20px; font-size: 13px; color: #e2e8f0; line-height: 1.5;">
                            {% if hasGlobalSetting %}
                                <strong style="color: #10b981;">Using Global Server Settings:</strong> The global AI credentials are fully configured and ready for your workspace to use. You do not need to configure your own unless you wish to use a different provider or API key.
                            {% else %}
                                <strong style="color: #ef4444;">No Global Server Settings:</strong> The global AI credentials are not configured yet. Please configure your own custom credentials below to use AI features.
                            {% endif %}
                        </div>
                    {% else %}
                        <input type="hidden" name="useCustom" value="true">
                    {% endif %}

                    <div id="custom-credentials-section" style="{% if app.user and app.user.accountType != 'super_admin' and not isUsingCustom %}display: none;{% endif %} display: flex; flex-direction: column; gap: 16px;">
                        
                        {% if app.user and app.user.accountType not in ['super_admin', 'reseller'] %}
                        <div style="display: flex; justify-content: flex-end; align-items: center; gap: 10px; margin-bottom: 8px;">
                            <span style="font-size: 12px; color: var(--text-muted);">Account Active State:</span>
                            <label class="switch-toggle" style="margin: 0;">
                                <input type="checkbox" name="isActive" id="ai-isActive-custom" {% if aiSetting.isActive() %}checked{% endif %}>
                                <span class="slider-round"></span>
                            </label>
                        </div>
                        {% endif %}

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label" for="ai-provider">AI Provider <span>*</span></label>
                                <select id="ai-provider" name="provider" class="form-control" onchange="onAiProviderChange()">
                                    <option value="openai" {% if aiSetting.provider == 'openai' %}selected{% endif %}>OpenAI</option>
                                    <option value="gemini" {% if aiSetting.provider == 'gemini' %}selected{% endif %}>Google Gemini</option>
                                    <option value="kimi" {% if aiSetting.provider == 'kimi' %}selected{% endif %}>Moonshot (Kimi)</option>
                                    <option value="deepseek" {% if aiSetting.provider == 'deepseek' %}selected{% endif %}>DeepSeek</option>
                                    <option value="openrouter" {% if aiSetting.provider == 'openrouter' %}selected{% endif %}>OpenRouter</option>
                                    <option value="ollama" {% if aiSetting.provider == 'ollama' %}selected{% endif %}>Ollama (Local)</option>
                                    <option value="lmstudio" {% if aiSetting.provider == 'lmstudio' %}selected{% endif %}>LM Studio (Local)</option>
                                    <option value="ollamacloud" {% if aiSetting.provider == 'ollamacloud' %}selected{% endif %}>Ollama (Cloud)</option>
                                    <option value="custom" {% if aiSetting.provider == 'custom' %}selected{% endif %}>OpenAI Compatible (Custom)</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="ai-model">Model</label>
                                <div style="display: flex; gap: 10px; position: relative;">
                                    <div class="custom-dropdown-container">
                                        <input type="text" id="ai-model" name="model" class="form-control" value="{{ aiSetting.model }}" placeholder="gpt-4o-mini" autocomplete="off" style="width: 100%;">
                                        <div id="ai-model-dropdown" class="custom-dropdown-menu">
                                            <div class="custom-dropdown-search-wrapper">
                                                <input type="text" id="ai-model-search" class="form-control" placeholder="Search models..." autocomplete="off" style="padding: 6px 10px; font-size: 13px; height: 32px; background: rgba(0,0,0,0.3);">
                                            </div>
                                            <div id="ai-model-options" class="custom-dropdown-options-list">
                                                <!-- Dynamic options -->
                                            </div>
                                        </div>
                                    </div>
                                    <button type="button" class="btn-action btn-secondary-action" id="btn-fetch-models" onclick="fetchModelsFromApi()" style="padding: 0 16px; white-space: nowrap; height: 42px; font-size: 13px; display: flex; align-items: center; gap: 6px; margin: 0; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #f8fafc; border-radius: 8px;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                        <span>Fetch Models</span>
                                    </button>
                                </div>
                                <p class="form-hint" id="ai-model-hint">e.g. gpt-4o-mini, gemini-1.5-flash. Click "Fetch Models" to pull dynamically.</p>
                            </div>
                        </div>

                        <div class="form-group" id="ai-apiKey-group">
                            <label class="form-label" for="ai-apiKey" id="ai-apiKey-label">API Key <span>*</span></label>
                            <input type="text" id="ai-apiKey" name="apiKey" class="form-control" value="{{ aiSetting.apiKey }}" placeholder="Enter API Key/Token" autocomplete="off" data-lpignore="true" data-form-type="other" style="-webkit-text-security: disc;">
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="ai-apiEndpoint" id="ai-apiEndpoint-label">Custom API Endpoint <small style="font-weight:400; opacity: 0.6;">(Optional)</small></label>
                            <input type="text" id="ai-apiEndpoint" name="apiEndpoint" class="form-control" value="{{ aiSetting.apiEndpoint }}" placeholder="Override default API endpoint if needed" autocomplete="off">
                            <p class="form-hint" id="ai-apiEndpoint-hint">Required for custom proxies. Leave empty to use provider's official API endpoint.</p>
                        </div>
                        </div>
                    </div>

                    <div style="display: flex; justify-content: flex-end; margin-top: 10px;">
                        <button type="submit" class="btn-action btn-create" id="btn-save-ai-api">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                            <span>Save API Configuration</span>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Sub-pane 2: Context Manager -->
            <div class="ai-agent-subpane" id="ai-subpane-context-agent" style="display: none; width: 100%;">
                
                <!-- List View of Contexts -->
                <div id="context-list-view">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 15px; flex-wrap: wrap;">
                        <div style="background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.2); border-radius: 12px; padding: 12px 18px; font-size: 13px; color: #94a3b8; line-height: 1.5; flex-grow: 1; margin: 0;">
                            <strong style="color: var(--primary-accent); display:inline-flex; align-items:center; gap:5px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg> Context Manager:</strong> Create multiple custom context profiles for your AI assistant. You can activate one active context profile at a time to ground your bot's answers.
                        </div>
                        <button type="button" class="btn-action btn-create" onclick="showCreateContextForm()" style="margin: 0; font-size: 13px; padding: 12px 20px; white-space: nowrap; display: flex; align-items: center; gap: 6px; height: 42px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            <span>Create Context</span>
                        </button>
                    </div>

                    <!-- Context Profiles List Table -->
                    <div style="background: rgba(15, 23, 42, 0.2); border: 1px solid var(--glass-border); border-radius: 12px; overflow: hidden; width: 100%;">
                        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14px;">
                            <thead>
                                <tr style="border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.02);">
                                    <th style="padding: 14px 20px; font-weight: 600; color: var(--text-muted);">Context Name</th>
                                    <th style="padding: 14px 20px; font-weight: 600; color: var(--text-muted);">Agent Role</th>
                                    <th style="padding: 14px 20px; font-weight: 600; color: var(--text-muted);">Status</th>
                                    <th style="padding: 14px 20px; font-weight: 600; color: var(--text-muted); text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="context-list-tbody">
                                {% if contexts is empty %}
                                    <tr>
                                        <td colspan="4" style="padding: 40px 20px; text-align: center; color: var(--text-muted);">
                                            No contexts created yet. Click "Create Context" to get started.
                                        </td>
                                    </tr>
                                {% else %}
                                    {% for ctx in contexts %}
                                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);" id="context-row-{{ ctx.id }}">
                                            <td style="padding: 14px 20px; font-weight: 500; color: #fff;">
                                                {{ ctx.name }}
                                            </td>
                                            <td style="padding: 14px 20px; color: var(--text-muted);">
                                                {{ ctx.agentRole|default('-') }}
                                            </td>
                                            <td style="padding: 14px 20px;">
                                                <label class="switch-toggle" style="margin: 0;">
                                                    <input type="checkbox" class="context-active-checkbox" data-context-id="{{ ctx.id }}" {% if ctx.isActive %}checked{% endif %} onchange="toggleContextActive({{ ctx.id }}, this.checked)">
                                                    <span class="slider-round"></span>
                                                </label>
                                            </td>
                                            <td style="padding: 14px 20px; text-align: right;">
                                                <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                                    <button type="button" class="btn-action btn-edit-context" 
                                                            data-ctx-id="{{ ctx.id }}"
                                                            data-ctx-name="{{ ctx.name|default('')|e('html_attr') }}"
                                                            data-ctx-role="{{ ctx.agentRole|default('')|e('html_attr') }}"
                                                            data-ctx-instruction="{{ ctx.systemInstruction|default('')|e('html_attr') }}"
                                                            data-ctx-data="{{ ctx.contextData|default('')|e('html_attr') }}"
                                                            data-ctx-modules="{{ ctx.modulesData ? ctx.modulesData|json_encode|e('html_attr') : '[]' }}"
                                                            style="padding: 6px 12px; font-size: 12px; height: 30px; margin: 0; background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.2); color: var(--primary-accent); display: flex; align-items: center; gap: 4px; border-radius: 8px; border: 1px solid var(--glass-border); cursor: pointer;">
                                                        <svg viewBox="0 0 24 24" style="width:12px; height:12px; stroke: currentColor; fill: none; stroke-width: 2;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                                        <span>Edit</span>
                                                    </button>
                                                    <button type="button" class="btn-action btn-danger-action" onclick="deleteContext({{ ctx.id }})" style="padding: 6px 12px; font-size: 12px; height: 30px; margin: 0; background: rgba(239,68,68,0.1); border-color: rgba(239, 68, 68, 0.2); color: #f87171; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 4px; border: 1px solid rgba(239,68,68,0.2);">
                                                        <svg viewBox="0 0 24 24" style="width:12px; height:12px; stroke: currentColor; fill: none; stroke-width: 2;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                                        <span>Delete</span>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Create/Edit Form View -->
                <div id="context-form-view" style="display: none;">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <h3 style="font-size: 14px; font-weight: 600; color: #f8fafc; margin: 0; display: flex; align-items: center; gap: 8px;" id="context-form-title">
                            <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M6 11V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"></path></svg>
                            <span>Create Context Profile</span>
                        </h3>
                        <button type="button" class="btn-action btn-secondary-action" onclick="hideContextForm()" style="margin: 0; padding: 8px 16px; font-size: 13px; height: 34px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc;">
                            Cancel
                        </button>
                    </div>

                    <form id="ai-context-form" onsubmit="submitContextForm(event)" style="display: flex; flex-direction: column; gap: 24px; width: 100%;">
                        <input type="hidden" name="id" id="ctx-id" value="" />

                        <div style="background: rgba(15, 23, 42, 0.2); border: 1px solid var(--glass-border); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 16px;">
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label" for="ctx-name">Context Name <span>*</span></label>
                                    <input type="text" id="ctx-name" name="name" class="form-control" placeholder="e.g. Sarah Support" required>
                                    <p class="form-hint">A descriptive name for this context/agent persona.</p>
                                </div>

                                <div class="form-group">
                                    <label class="form-label" for="ctx-agentRole">Agent Role <small style="font-weight:400; opacity: 0.6;">(Optional)</small></label>
                                    <input type="text" id="ctx-agentRole" name="agentRole" class="form-control" placeholder="e.g. Lead Support Agent">
                                    <p class="form-hint">Defines the bot agent's professional persona and tone.</p>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="ctx-systemInstruction">Base Prompt (Instructions) <small style="font-weight:400; opacity: 0.6;">(Optional)</small></label>
                                <textarea id="ctx-systemInstruction" name="systemInstruction" class="form-control" style="min-height: 100px;" placeholder="e.g. You are a helpful support agent for OpenSquadron. Answer brief and politely."></textarea>
                                <p class="form-hint">General behavioral rules and guidelines for the AI.</p>
                            </div>

                            <div class="form-group">
                                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 8px;">
                                    <label class="form-label" style="margin-bottom: 0;">Context Builder <small style="font-weight:400; opacity: 0.6;">(Modular Blocks)</small></label>
                                </div>
                                
                                <p class="form-hint" style="margin-bottom: 16px;">Build your AI's knowledge base by stacking blocks. Each block is a separate, distinct source of context.</p>
                                
                                <input type="hidden" id="ctx-modulesData" name="modulesData" value="[]">
                                <input type="hidden" id="ctx-contextData" name="contextData" value="">
                                
                                <div id="context-modules-container" style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px;">
                                    <!-- Modules will be injected here via JS -->
                                </div>
                                
                                <div style="background: rgba(0,0,0,0.2); border: 1px dashed rgba(255,255,255,0.1); border-radius: 8px; padding: 14px; text-align: center;">
                                    <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Add a new block</div>
                                    <div style="display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;">
                                        <button type="button" class="btn-action btn-secondary" onclick="addContextModule('text')" style="font-size: 11px; height: 32px; margin: 0; display: flex; align-items: center; gap: 4px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px; height:13px;"><polyline points="4 7 4 4 20 4 20 7"></polyline><line x1="9" y1="20" x2="15" y2="20"></line><line x1="12" y1="4" x2="12" y2="20"></line></svg>
                                            Rich Text
                                        </button>
                                        <button type="button" class="btn-action btn-secondary" onclick="addContextModule('faq')" style="font-size: 11px; height: 32px; margin: 0; display: flex; align-items: center; gap: 4px; border-color: rgba(168,85,247,0.3); color: #c084fc; background: rgba(168,85,247,0.07);">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px; height:13px;"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                                            FAQ
                                        </button>
                                        <button type="button" class="btn-action btn-secondary" onclick="addContextModule('api')" style="font-size: 11px; height: 32px; margin: 0; display: flex; align-items: center; gap: 4px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px; height:13px;"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                                            Saved API
                                        </button>
                                        <button type="button" class="btn-action btn-secondary" onclick="addContextModule('web')" style="font-size: 11px; height: 32px; margin: 0; display: flex; align-items: center; gap: 4px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px; height:13px;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                            Web Scraper
                                        </button>
                                        <button type="button" class="btn-action btn-secondary" onclick="addContextModule('ecommerce')" style="font-size: 11px; height: 32px; margin: 0; display: flex; align-items: center; gap: 4px;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px; height:13px;"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                                            eCommerce
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 10px;">
                            <button type="button" class="btn-action btn-secondary-action" onclick="hideContextForm()" style="height: 48px; margin: 0; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc;">
                                Cancel
                            </button>
                            <button type="submit" class="btn-action btn-create" id="btn-save-context" style="margin: 0;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                                <span>Save Context</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ───────── FAQ Creator Modal ───────── -->
<div id="faq-creator-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.7); backdrop-filter:blur(4px); align-items:center; justify-content:center;">
    <div style="background: linear-gradient(145deg, #0f172a, #1e293b); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; width: min(640px, 96vw); max-height: 88vh; display: flex; flex-direction: column; box-shadow: 0 25px 80px rgba(0,0,0,0.6);">
        
        <!-- Modal Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.08);">
            <div style="display:flex; align-items:center; gap: 10px;">
                <div style="width:32px; height:32px; border-radius:8px; background:rgba(168,85,247,0.15); border:1px solid rgba(168,85,247,0.3); display:flex; align-items:center; justify-content:center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#c084fc" stroke-width="2" style="width:16px; height:16px;"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </div>
                <div>
                    <div style="font-size: 15px; font-weight: 700; color: #f8fafc;">FAQ Creator</div>
                    <div style="font-size: 11px; color: var(--text-muted);">Create Q&amp;A pairs to add to your FAQ block</div>
                </div>
            </div>
            <button type="button" onclick="closeFaqModal()" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#94a3b8; width:32px; height:32px; border-radius:8px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <!-- Tabs -->
        <div style="display:flex; gap:0; border-bottom: 1px solid rgba(255,255,255,0.08);">
            <button type="button" class="faq-tab active" data-tab="manual" onclick="switchFaqTab('manual')" style="flex:1; padding: 11px 8px; font-size: 11px; font-weight:600; border:none; cursor:pointer; background:transparent; border-bottom: 2px solid #c084fc; color:#c084fc; transition: all 0.2s;">Manual</button>
            <button type="button" class="faq-tab" data-tab="text" onclick="switchFaqTab('text')" style="flex:1; padding: 11px 8px; font-size: 11px; font-weight:600; border:none; cursor:pointer; background:transparent; border-bottom: 2px solid transparent; color:#64748b; transition: all 0.2s;">From Text</button>
            <button type="button" class="faq-tab" data-tab="api" onclick="switchFaqTab('api')" style="flex:1; padding: 11px 8px; font-size: 11px; font-weight:600; border:none; cursor:pointer; background:transparent; border-bottom: 2px solid transparent; color:#64748b; transition: all 0.2s;">From API</button>
            <button type="button" class="faq-tab" data-tab="web" onclick="switchFaqTab('web')" style="flex:1; padding: 11px 8px; font-size: 11px; font-weight:600; border:none; cursor:pointer; background:transparent; border-bottom: 2px solid transparent; color:#64748b; transition: all 0.2s;">From Web</button>
            <button type="button" class="faq-tab" data-tab="ecommerce" onclick="switchFaqTab('ecommerce')" style="flex:1; padding: 11px 8px; font-size: 11px; font-weight:600; border:none; cursor:pointer; background:transparent; border-bottom: 2px solid transparent; color:#64748b; transition: all 0.2s;">Catalog</button>
        </div>

        <!-- Tab Content -->
        <div style="flex:1; overflow-y:auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 14px;">
            
            <!-- Manual Tab -->
            <div id="faq-tab-manual" class="faq-tab-content">
                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px;">Add Q&amp;A pairs manually. Click + to add more rows.</p>
                <div id="faq-manual-pairs" style="display:flex; flex-direction:column; gap:10px;"></div>
                <button type="button" onclick="addManualFaqPair()" style="margin-top: 10px; background: rgba(168,85,247,0.1); border: 1px dashed rgba(168,85,247,0.3); color:#c084fc; border-radius: 8px; padding: 8px 14px; font-size: 12px; cursor:pointer; width:100%; display:flex; align-items:center; justify-content:center; gap:6px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    Add Row
                </button>
            </div>

            <!-- From Text Tab -->
            <div id="faq-tab-text" class="faq-tab-content" style="display:none;">
                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Paste raw text and let AI generate FAQ pairs from it.</p>
                <textarea id="faq-text-input" class="form-control" style="min-height: 120px; font-size: 13px;" placeholder="Paste any raw business info, product details, policies, etc..."></textarea>
                <button type="button" onclick="generateFaqsFromSource('text')" id="faq-btn-text" class="btn-action btn-create" style="margin-top: 10px; width: 100%; height: 40px; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; margin-right:6px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    Generate FAQs with AI
                </button>
            </div>

            <!-- From API Tab -->
            <div id="faq-tab-api" class="faq-tab-content" style="display:none;">
                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Execute a saved HTTP API and generate FAQs from the response.</p>
                <select id="faq-api-select" class="form-control" style="font-size: 13px; height: 40px;">
                    <option value="">-- Select Saved API --</option>
                    {% if httpApis is defined %}
                        {% for api in httpApis %}
                            <option value="{{ api.id }}">{{ api.name }} ({{ api.method }})</option>
                        {% endfor %}
                    {% endif %}
                </select>
                <button type="button" onclick="generateFaqsFromSource('api')" id="faq-btn-api" class="btn-action btn-create" style="margin-top: 10px; width: 100%; height: 40px; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; margin-right:6px;"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                    Execute API & Generate FAQs
                </button>
            </div>

            <!-- From Web Tab -->
            <div id="faq-tab-web" class="faq-tab-content" style="display:none;">
                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Scrape a webpage and generate FAQs from the content.</p>
                <input type="text" id="faq-web-url" class="form-control" placeholder="URL (e.g. https://example.com/about)" style="font-size: 13px; height: 40px; margin-bottom: 8px;" autocomplete="off">
                <input type="text" id="faq-web-selector" class="form-control" placeholder="CSS Selector (optional, e.g. .main-content)" style="font-size: 13px; height: 40px;" autocomplete="off">
                <button type="button" onclick="generateFaqsFromSource('web')" id="faq-btn-web" class="btn-action btn-create" style="margin-top: 10px; width: 100%; height: 40px; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; margin-right:6px;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line></svg>
                    Scrape & Generate FAQs
                </button>
            </div>

            <!-- From eCommerce Tab -->
            <div id="faq-tab-ecommerce" class="faq-tab-content" style="display:none;">
                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">Automatically generate FAQs from your active product catalog.</p>
                <div style="background: rgba(6,182,212,0.05); border: 1px solid rgba(6,182,212,0.15); border-radius: 8px; padding: 14px; font-size: 12px; color: #94a3b8; line-height: 1.6;">
                    This will fetch all your active products and ask AI to create common customer FAQ pairs (e.g. "What does X cost?", "Is X in stock?").
                </div>
                <button type="button" onclick="generateFaqsFromSource('ecommerce')" id="faq-btn-ecommerce" class="btn-action btn-create" style="margin-top: 10px; width: 100%; height: 40px; justify-content: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; margin-right:6px;"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                    Generate from Catalog
                </button>
            </div>

        </div>

        <!-- Modal Footer -->
        <div style="display:flex; justify-content:flex-end; gap:10px; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.08);">
            <button type="button" onclick="closeFaqModal()" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#94a3b8; padding: 0 18px; height: 40px; border-radius: 10px; cursor:pointer; font-size: 13px;">Cancel</button>
            <button type="button" id="faq-modal-add-btn" onclick="commitFaqsToBlock()" class="btn-action btn-create" style="margin:0; height:40px; padding: 0 20px; font-size: 13px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; margin-right:6px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add to Block
            </button>
        </div>
    </div>
</div>

<div class="fb-toast" id="fb-toast"></div>
{% endblock %}

{% block javascripts %}
<script>
    function showToast(message, type = 'success') {
        const toast = document.getElementById('fb-toast');
        toast.className = 'fb-toast ' + (type === 'success' ? 'toast-success' : 'toast-error');
        toast.textContent = message;
        toast.style.display = 'flex';
        setTimeout(() => {
            toast.style.display = 'none';
        }, 4000);
    }

    // ───────── AI Sub-Tab Switcher Logic ─────────
    function switchAiSubtab(subtabId) {
        // Toggle active nav-item highlight
        document.querySelectorAll('.manager-nav .nav-item').forEach(el => {
            if (el.getAttribute('data-tab-target') === subtabId) {
                el.classList.add('is-active');
            } else {
                el.classList.remove('is-active');
            }

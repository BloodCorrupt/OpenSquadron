    function editContext(btn) {
        try {
            console.log('Editing context for:', btn);
            document.getElementById('context-list-view').style.display = 'none';
            document.getElementById('context-form-view').style.display = 'block';
            document.getElementById('context-form-title').innerHTML = '<svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M6 11V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"></path></svg> <span>Edit Context Profile</span>';
            
            document.getElementById('ctx-id').value = btn.getAttribute('data-ctx-id') || '';
            document.getElementById('ctx-name').value = btn.getAttribute('data-ctx-name') || '';
            document.getElementById('ctx-agentRole').value = btn.getAttribute('data-ctx-role') || '';
            
            let systemInstructionEl = document.getElementById('ctx-systemInstruction');
            if (systemInstructionEl) {
                systemInstructionEl.value = btn.getAttribute('data-ctx-instruction') || '';
            } else {
                console.warn('ctx-systemInstruction element not found');
            }
            
            let contextDataEl = document.getElementById('ctx-contextData');
            if (contextDataEl) {
                contextDataEl.value = btn.getAttribute('data-ctx-data') || '';
            }
            
            let modulesStr = btn.getAttribute('data-ctx-modules') || '[]';
            try {
                currentModules = JSON.parse(modulesStr);
            } catch(e) {
                currentModules = [];
            }

            // Backward compatibility: If no modules but contextData exists, wrap it in a text block
            let oldContextData = btn.getAttribute('data-ctx-data') || '';
            if (currentModules.length === 0 && oldContextData.trim() !== '') {
                currentModules.push({ type: 'text', content: oldContextData });
            }

            document.getElementById('ctx-modulesData').value = JSON.stringify(currentModules);
            renderModules();
        } catch(err) {
            console.error('editContext Error:', err);
            alert('Error editing context: ' + err.message);
        }
    }


        fetch('/ai-settings/context/' + id + '/delete', {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Context profile deleted successfully!', 'success');
                const row = document.getElementById('context-row-' + id);
                if (row) {
                    row.remove();
                }
                const tbody = document.getElementById('context-list-tbody');
                if (tbody && tbody.children.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="4" style="padding: 40px 20px; text-align: center; color: var(--text-muted);">No contexts created yet. Click "Create Context" to get started.</td></tr>`;

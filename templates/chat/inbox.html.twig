    function filterSubscribers() {
        const searchQuery = document.getElementById('subscriberSearch').value.toLowerCase().trim();
        const connectionFilter = document.getElementById('connectionFilter').value;
        
        const items = document.querySelectorAll('.subscriber-item');
        items.forEach(item => {
            const name = item.getAttribute('data-name') || '';
            const phone = item.getAttribute('data-phone') || '';
            const connId = item.getAttribute('data-connection-id') || '';
            
            const matchesSearch = name.includes(searchQuery) || phone.includes(searchQuery);
            const matchesConnection = !connectionFilter || connId === connectionFilter;
            
            if (matchesSearch && matchesConnection) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    }

    function renderSubscriberList(data) {
        const container = document.getElementById('subscriber-list-container');
        if (!container) return;
        
        if (data.length === 0) {
            container.innerHTML = `
                <div style="padding: 20px; text-align: center; color: #888; font-size: 14px;">
                    No subscribers yet. When someone messages your WhatsApp number, they will appear here.
                </div>
            `;
            return;
        }
        
        let html = '';
        data.forEach(sub => {
            const isActive = sub.id === activeSubscriberId;
            const channel = sub.channel || 'whatsapp';
            let name = sub.name;
            if (!name) {
                name = channel === 'facebook' ? 'PSID: ' + sub.phoneNumber : sub.phoneNumber;
            }
            const phone = sub.phoneNumber || '';
            
            let lastMsgHtml = '';
            if (sub.lastMessage) {
                let preview = sub.lastMessage.content || '';
                if (sub.lastMessage.type === 'image') {
                    preview = '📷 Photo';
                } else if (sub.lastMessage.type === 'audio') {
                    preview = '🎵 Voice message';
                }
                
                if (preview.length > 30) {
                    preview = preview.substring(0, 27) + '...';
                }
                
                const prefix = sub.lastMessage.direction === 'outbound' ? 'You: ' : '';
                lastMsgHtml = `
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-top: 4px;">
                        <div class="subscriber-phone" style="max-width: 75%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            ${prefix}${preview}
                        </div>
                        <div style="font-size: 11px; color: var(--text-muted);">${sub.lastMessage.timestamp}</div>
                    </div>
                `;
            } else {
                lastMsgHtml = `<div class="subscriber-phone">${phone}</div>`;
            }
            
            let badgeHtml = '';
            if (channel === 'facebook') {
                badgeHtml = `
                    <span style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #3b82f6; background: rgba(59, 130, 246, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(59, 130, 246, 0.25); flex-shrink: 0;">
                        <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                        FB
                    </span>
                `;
            } else {
                badgeHtml = `
                    <span style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #10b981; background: rgba(16, 185, 129, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(16, 185, 129, 0.25); flex-shrink: 0;">
                        <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                        WA
                    </span>
                `;
            }
            
            html += `
                <a href="/inbox/${sub.id}" 
                   class="subscriber-item ${isActive ? 'active' : ''}" 
                   data-id="${sub.id}"
                   data-name="${name.toLowerCase()}"
                   data-phone="${phone.toLowerCase()}"
                   data-connection-id="${sub.connectionId || ''}"
                   onclick="selectSubscriber(event, ${sub.id}, '${name.replace(/'/g, "\\'")}', '${phone}')">
                    <div class="subscriber-name" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <span>${name}</span>

                    data.notes.forEach(note => {
                        const div = document.createElement('div');
                        div.className = 'note-item';
                        div.innerHTML = `
                            <div class="note-meta">
                                <span>${escapeHtml(note.operatorName)}</span>
                                <span>${escapeHtml(note.createdAt)}</span>
                            </div>
                            <div class="note-text">${escapeHtml(note.text)}</div>
                        `;
                        notesContainer.appendChild(div);
                    });
                    notesContainer.scrollTop = notesContainer.scrollHeight;
                }
            } else {
                alert('Error adding note: ' + data.error);
            }
        })
        .catch(err => console.error(err));
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function escapeJs(str) {
        if (!str) return '';
        return str.replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '\\"');
    }

    function goBackToList() {
        const container = document.querySelector('.inbox-container');
        if (container) {
            container.classList.remove('mobile-chat-active');
        }
        activeSubscriberId = null;
        window.history.pushState(null, '', '/inbox');
        
        const rightSidebar = document.getElementById('inbox-right-sidebar');
        if (rightSidebar) {
            rightSidebar.classList.remove('is-open');
        }
    }

    function toggleRightSidebar() {
        const rightSidebar = document.getElementById('inbox-right-sidebar');
        if (rightSidebar) {
            rightSidebar.classList.toggle('is-open');
        }
    }

    // Close right sidebar when clicking outside on mobile
    document.addEventListener('click', function(e) {
        if (window.innerWidth <= 768) {
            const rightSidebar = document.getElementById('inbox-right-sidebar');
            const infoBtn = e.target.closest('.mobile-info-btn');
            if (rightSidebar && rightSidebar.classList.contains('is-open')) {
                if (!rightSidebar.contains(e.target) && !infoBtn) {
                    rightSidebar.classList.remove('is-open');
                }
            }
        }
    });

    // High frequency synchronization
    setInterval(function() {
        refreshSidebar();
        if (activeSubscriberId) {
            syncNewMessages();
        }
    }, 2000);
</script>
{% endblock %}

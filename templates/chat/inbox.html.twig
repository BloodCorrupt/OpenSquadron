{% extends 'base.html.twig' %}

{% block title %}Shared Inbox{% endblock %}

{% block max_width %}100%{% endblock %}

{% block stylesheets %}
<style>
    body .content-container {
        padding: 0 !important;
        max-width: 100% !important;
        margin: 0 !important;
        height: 100% !important;
        overflow: hidden !important;
    }
    
    .inbox-container {
        display: flex;
        height: 100% !important;
        background: linear-gradient(135deg, #0b0f19 0%, #111827 50%, #1e1b4b 100%) !important;
        border-radius: 0 !important;
        overflow: hidden;
        border: none !important;
        box-shadow: none !important;
    }
    
    .inbox-sidebar {
        width: 320px;
        border-right: 1px solid var(--glass-border);
        display: flex;
        flex-direction: column;
        background: rgba(15, 23, 42, 0.4) !important;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    
    .inbox-header {
        padding: 20px 24px;
        background: rgba(15, 23, 42, 0.6) !important;
        border-bottom: 1px solid var(--glass-border);
        font-weight: 700;
        font-size: 18px;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .subscriber-list {
        overflow-y: auto;
        flex: 1;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .subscriber-list::-webkit-scrollbar {
        width: 6px;
    }
    .subscriber-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    
    .subscriber-item {
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border-left: 3px solid transparent;
        position: relative;
    }
    
    .subscriber-item:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(6, 182, 212, 0.3);
        transform: translateY(-1px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    }
    
    .subscriber-item.active {
        background: rgba(6, 182, 212, 0.12);
        border-color: var(--primary-accent);
        border-left: 3px solid var(--primary-accent);
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.2);
    }
    
    .subscriber-name {
        font-weight: 600;
        margin-bottom: 6px;
        color: #fff;
        font-size: 15px;
    }
    
    .subscriber-phone {
        font-size: 13px;
        color: var(--text-muted);
    }
    
    /* Sidebar Filter and Search box glassmorphic visual upgrades */
    .sidebar-filters {
        padding: 16px 20px !important;
        background: rgba(15, 23, 42, 0.3) !important;
        border-bottom: 1px solid var(--glass-border) !important;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    
    .sidebar-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        width: 100%;
    }
    
    .sidebar-input-wrapper svg.left-icon {
        position: absolute;
        left: 14px;
        pointer-events: none;
        stroke: rgba(255, 255, 255, 0.35);
        transition: stroke 0.3s;
    }
    
    .sidebar-input-wrapper svg.right-icon {
        position: absolute;
        right: 14px;
        pointer-events: none;
        stroke: rgba(255, 255, 255, 0.35);
        transition: stroke 0.3s;
    }
    
    .sidebar-filter-select, .sidebar-search-input {
        width: 100%;
        padding: 10px 16px 10px 38px !important;
        background: rgba(255, 255, 255, 0.02) !important;
        border: 1px solid var(--glass-border) !important;
        border-radius: 12px !important;
        color: #fff !important;
        font-size: 13px !important;
        outline: none !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        cursor: pointer;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
    }
    
    .sidebar-filter-select:hover, .sidebar-search-input:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        border-color: rgba(6, 182, 212, 0.25) !important;
    }
    
    .sidebar-filter-select:focus, .sidebar-search-input:focus {
        border-color: var(--primary-accent) !important;
        background: rgba(255, 255, 255, 0.08) !important;
        box-shadow: 0 0 12px rgba(6, 182, 212, 0.2) !important;
    }
    
    .sidebar-input-wrapper .custom-glass-select-trigger {
        padding-left: 38px !important;
    }
    .sidebar-input-wrapper .right-icon {
        display: none !important;
    }
    
    .sidebar-input-wrapper:focus-within svg.left-icon {
        stroke: var(--primary-accent);
    }
    
    .inbox-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: transparent;
        position: relative;
    }
    
    .chat-header {
        padding: 16px 24px;
        background: rgba(15, 23, 42, 0.5) !important;
        border-bottom: 1px solid var(--glass-border);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 15px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    .chat-messages::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    
    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 15px;
        line-height: 1.5;
        position: relative;
        word-wrap: break-word;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .message-inbound {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        align-self: flex-start;
        border-top-left-radius: 4px;
        border: 1px solid var(--glass-border);
    }
    
    .message-outbound {
        background: linear-gradient(135deg, var(--primary-accent), #0284c7);
        color: #fff;
        align-self: flex-end;
        border-top-right-radius: 4px;
    }
    
    .message-time {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.6);
        float: right;
        margin-left: 15px;
        margin-top: 8px;
    }
    
    .chat-input-area {
        padding: 16px 20px;
        background: rgba(15, 23, 42, 0.5) !important;
        border-top: 1px solid var(--glass-border);
        display: flex;
        gap: 12px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-sizing: border-box;
    }
    .chat-input-area * {
        box-sizing: border-box;
    }
    
    .chat-input {
        flex: 1;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        padding: 14px 20px;
        border-radius: 24px;
        font-size: 15px;
        color: #fff;
        outline: none;
        transition: border-color 0.3s;
    }
    .chat-input:focus {
        border-color: var(--primary-accent);
    }
    
    .attachment-btn {
        background: rgba(0, 0, 0, 0.2);
        color: var(--text-muted);
        border: 1px solid var(--glass-border);
        border-radius: 50%;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .attachment-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    
    .send-btn {
        background: linear-gradient(135deg, var(--primary-accent), #0284c7);
        color: white;
        border: none;
        border-radius: 50%;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
    }
    
    .send-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(6, 182, 212, 0.5);
    }
    
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--text-muted);
        text-align: center;
    }
    
    #connectionFilter:focus, #subscriberSearch:focus {
        border-color: var(--primary-accent) !important;
        background: rgba(255, 255, 255, 0.08) !important;
        box-shadow: 0 0 0 2px rgba(6, 182, 212, 0.2);
    }
    #connectionFilter option {
        background: #15151e !important;
        color: #fff;
    }

    /* Right Sidebar styling */
    .inbox-right-sidebar {
        width: 300px;
        border-left: 1px solid var(--glass-border);
        display: flex;
        flex-direction: column;
        background: rgba(15, 23, 42, 0.4) !important;
        overflow-y: auto;
        padding: 20px;
        gap: 20px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    .inbox-right-sidebar,
    .inbox-right-sidebar * {
        box-sizing: border-box;
    }
    .inbox-right-sidebar::-webkit-scrollbar {
        width: 6px;
    }
    .inbox-right-sidebar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    
    .sidebar-section {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }
    
    .sidebar-section-title {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--primary-accent);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .sidebar-field-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 600;
    }
    
    .sidebar-input, .sidebar-select {
        width: 100%;
        padding: 8px 12px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        color: #fff;
        font-size: 13px;
        outline: none;
        transition: border-color 0.3s;
    }
    .sidebar-input:focus, .sidebar-select:focus {
        border-color: var(--primary-accent);
    }
    .sidebar-select option {
        background: #15151e !important;
        color: #fff;
    }
    
    /* Flex row layout fix for inputs inside rows with buttons */
    .sidebar-flex-row {
        display: flex !important;
        gap: 8px !important;
        width: 100% !important;
        align-items: center !important;
    }
    .sidebar-flex-row .sidebar-input {
        flex: 1 !important;
        min-width: 0 !important;
        width: auto !important;
    }
    
    /* Tags style */
    .tag-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 6px;
    }
    .chat-tag {
        background: rgba(6, 182, 212, 0.15);
        border: 1px solid rgba(6, 182, 212, 0.3);
        color: #22d3ee;
        font-size: 11px;
        padding: 3px 8px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .chat-tag .remove-tag {
        cursor: pointer;
        color: #ef4444;
        font-weight: 700;
    }
    
    /* Attributes list style */
    .attributes-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .attribute-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0, 0, 0, 0.1);
        border: 1px solid var(--glass-border);
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 12px;
    }
    .attribute-key {
        color: var(--text-muted);
        font-weight: 600;
        word-break: break-all;
    }
    .attribute-value {
        color: #fff;
        word-break: break-all;
        text-align: right;
    }
    .attribute-remove {
        cursor: pointer;
        color: #ef4444;
        margin-left: 6px;
        font-weight: bold;
    }
    
    /* Notes style */
    .notes-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 200px;
        overflow-y: auto;
        padding-right: 4px;
    }
    .notes-list::-webkit-scrollbar {
        width: 4px;
    }
    .notes-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    .note-item {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 10px;
        font-size: 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .note-meta {
        display: flex;
        justify-content: space-between;
        color: var(--text-muted);
        font-size: 10px;
    }
    .note-text {
        color: #ddd;
        white-space: pre-wrap;
        line-height: 1.4;
    }
    
    @media (max-width: 768px) {
        .inbox-sidebar {
            width: 100% !important;
            border-right: none !important;
        }
        .inbox-main {
            width: 100% !important;
            display: none !important;
            min-width: 0 !important;
        }
        .inbox-container.mobile-chat-active .inbox-sidebar {
            display: none !important;
        }
        .inbox-container.mobile-chat-active .inbox-main {
            display: flex !important;
        }
        
        .mobile-back-btn {
            display: flex !important;
            margin-right: 2px !important;
            padding: 2px !important;
        }
        .mobile-info-btn {
            display: flex !important;
            margin-left: 0 !important; /* Let it sit right next to the timer */
            padding: 4px !important;
            flex-shrink: 0 !important;
        }
        
        .inbox-right-sidebar {
            position: fixed !important;
            top: 56px !important;
            bottom: 0 !important;
            right: -320px !important;
            width: 300px !important;
            height: auto !important;
            z-index: 1050 !important;
            transition: right 0.3s ease-in-out !important;
            box-shadow: -5px 0 25px rgba(0,0,0,0.5) !important;
            border-left: 1px solid var(--glass-border) !important;
            display: flex !important;
        }
        .inbox-right-sidebar.is-open {
            right: 0 !important;
        }
        
        .mobile-sidebar-close-row {
            display: flex !important;
        }

        /* Responsive chat header adjustments */
        .chat-header {
            padding: 10px 12px !important;
            gap: 8px !important;
        }
        .chat-header #chat-header-avatar {
            width: 32px !important;
            height: 32px !important;
            font-size: 14px !important;
        }
        .chat-header #chat-header-name {
            font-size: 14px !important;
        }
        .chat-header #chat-header-phone {
            font-size: 11px !important;
        }
        .chat-header #chat-window-timer {
            padding: 3px 6px !important;
            gap: 4px !important;
            font-size: 10px !important;
            margin-left: auto !important;
            white-space: nowrap !important;
            flex-shrink: 0 !important;
        }
        .chat-header #chat-window-timer-text {
            white-space: nowrap !important;
        }
        .chat-header #chat-window-timer svg {
            width: 12px !important;
            height: 12px !important;
        }
        .chat-header .badge-text {
            display: none !important;
        }
        .chat-header .channel-badge-pill {
            padding: 2px 4px !important;
            gap: 0 !important;
        }

        /* Responsive chat input area and button adjustments to fix spacing & overflow */
        .chat-input-area {
            padding: 10px 10px !important;
            gap: 6px !important;
            width: 100% !important;
            min-width: 0 !important;
            box-sizing: border-box !important;
        }
        .chat-input-area .attachment-btn,
        .chat-input-area .send-btn {
            width: 36px !important;
            height: 36px !important;
            flex-shrink: 0 !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        .chat-input-area .attachment-btn svg,
        .chat-input-area .send-btn svg {
            width: 18px !important;
            height: 18px !important;
        }
        .chat-input-area .chat-input {
            padding: 8px 14px !important;
            font-size: 14px !important;
            min-width: 0 !important; /* Allow the input to shrink below default browser sizes */
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="inbox-container {% if activeSubscriber %}mobile-chat-active{% endif %}">
    <!-- Sidebar -->
    <div class="inbox-sidebar">
        <div class="inbox-header" style="border-bottom: none;">
            Chats
        </div>
        
        <!-- Filter and Search Area -->
        <div class="sidebar-filters">
            <div class="sidebar-input-wrapper">
                <!-- Connected Channel Link Icon -->
                <svg class="left-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                <select id="connectionFilter" onchange="filterSubscribers()" class="sidebar-filter-select">
                    <option value="" style="background: #111;">All Connected Accounts</option>
                    {% if whatsappConnections is not empty %}
                        <optgroup label="WhatsApp" style="background: #111; color: var(--text-muted);">
                            {% for conn in whatsappConnections %}
                                <option value="whatsapp-{{ conn.id }}" style="background: #111;">{{ conn.label ?: conn.phoneNumber }}</option>
                            {% endfor %}
                        </optgroup>
                    {% endif %}
                    {% if facebookConnections is not empty %}
                        <optgroup label="Facebook (Beta)" style="background: #111; color: var(--text-muted);">
                            {% for conn in facebookConnections %}
                                <option value="facebook-{{ conn.id }}" style="background: #111;">{{ conn.label ?: conn.pageName ?: conn.pageId }}</option>
                            {% endfor %}
                        </optgroup>
                    {% endif %}
                </select>
                <svg class="right-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
            
            <div class="sidebar-input-wrapper">
                <svg class="left-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="subscriberSearch" oninput="filterSubscribers()" placeholder="Search by name or phone..." class="sidebar-search-input" autocomplete="off">
            </div>
        </div>
        
        <div class="subscriber-list" id="subscriber-list-container">
            {% for sub in subscribers %}
                {% set name = sub.name ?: (sub.channel == 'facebook' ? 'PSID: ' ~ sub.psid : sub.phoneNumber) %}
                {% set phone = sub.phoneNumber ?: sub.psid %}
                <a href="{{ path('app_inbox_chat', {'id': sub.id}) }}" 
                   class="subscriber-item {% if activeSubscriber and activeSubscriber.id == sub.id %}active{% endif %}"
                   data-id="{{ sub.id }}"
                   data-name="{{ name|lower }}"
                   data-phone="{{ phone|lower }}"
                   data-connection-id="{% if sub.channel == 'facebook' %}{{ sub.facebookConnection ? 'facebook-' ~ sub.facebookConnection.id : '' }}{% else %}{{ sub.whatsAppConnection ? 'whatsapp-' ~ sub.whatsAppConnection.id : '' }}{% endif %}"
                   onclick="selectSubscriber(event, {{ sub.id }}, '{{ name|escape('js') }}', '{{ phone|escape('js') }}')">
                    <div class="subscriber-name" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <span>{{ name }}</span>
                        {% if sub.channel == 'facebook' %}
                            <span style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #3b82f6; background: rgba(59, 130, 246, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(59, 130, 246, 0.25); flex-shrink: 0;">
                                <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                                FB
                            </span>
                        {% else %}
                            <span style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #10b981; background: rgba(16, 185, 129, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(16, 185, 129, 0.25); flex-shrink: 0;">
                                <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                                WA
                            </span>
                        {% endif %}
                    </div>
                    
                    {% set lastMessage = sub.messages|last %}
                    {% if lastMessage %}
                        {% set preview = lastMessage.content %}
                        {% if lastMessage.type == 'image' %}
                            {% set preview = '📷 Photo' %}
                        {% elseif lastMessage.type == 'audio' %}
                            {% set preview = '🎵 Voice message' %}
                        {% endif %}
                        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-top: 4px;">
                            <div class="subscriber-phone" style="max-width: 75%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                {% if lastMessage.direction == 'outbound' %}You: {% endif %}{{ preview }}
                            </div>
                            <div style="font-size: 11px; color: var(--text-muted);">{{ lastMessage.timestamp|date('H:i', 'UTC') }}</div>
                        </div>
                    {% else %}
                        <div class="subscriber-phone">{{ phone }}</div>
                    {% endif %}
                </a>
            {% else %}
                <div style="padding: 20px; text-align: center; color: #888; font-size: 14px;">
                    No subscribers yet. When someone messages your WhatsApp number, they will appear here.
                </div>
            {% endfor %}
        </div>
    </div>
    
    <!-- Main Chat Area -->
    <div class="inbox-main">
        <div id="empty-state" class="empty-state" style="{% if activeSubscriber %}display: none;{% else %}display: flex;{% endif %} flex: 1; align-items: center; justify-content: center; color: #888; font-size: 16px; width: 100%; height: 100%;">
            Select a chat from the sidebar to start messaging.
        </div>

        <div id="chat-container" style="{% if activeSubscriber %}display: flex;{% else %}display: none;{% endif %} flex-direction: column; height: 100%; width: 100%;">
            <div class="chat-header">
                <!-- Mobile Back Button -->
                <button class="mobile-back-btn" onclick="goBackToList()" style="display: none; background: none; border: none; color: #fff; cursor: pointer; padding: 4px; margin-right: 8px; align-items: center; justify-content: center; outline: none; -webkit-tap-highlight-color: transparent;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                </button>
                <div id="chat-header-avatar" style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-accent), var(--secondary-accent)); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 18px; box-shadow: 0 2px 10px rgba(6, 182, 212, 0.3); flex-shrink: 0;">
                    {{ activeSubscriber ? (activeSubscriber.name ? activeSubscriber.name|slice(0, 1)|upper : '#') : '' }}
                </div>
                <div style="display: flex; flex-direction: column; justify-content: center; height: 44px; flex: 1; min-width: 0; margin-right: 8px;">
                    <div style="display: flex; align-items: center; gap: 8px; min-width: 0;">
                        <div id="chat-header-name" style="font-weight: 700; color: #fff; font-size: 16px; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0;">{{ activeSubscriber ? (activeSubscriber.name ?: (activeSubscriber.channel == 'facebook' ? 'PSID: ' ~ activeSubscriber.psid : activeSubscriber.phoneNumber)) : '' }}</div>
                        <div id="chat-header-badge" style="display: {% if activeSubscriber %}inline-flex{% else %}none{% endif %}; min-width: 0; flex-shrink: 0;">
                            {% if activeSubscriber and activeSubscriber.channel == 'facebook' %}
                                <span class="channel-badge-pill" style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #3b82f6; background: rgba(59, 130, 246, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(59, 130, 246, 0.25); flex-shrink: 0;">
                                    <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                                    <span class="badge-text">Facebook (Beta)</span>
                                </span>
                            {% elseif activeSubscriber %}
                                <span class="channel-badge-pill" style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #10b981; background: rgba(16, 185, 129, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(16, 185, 129, 0.25); flex-shrink: 0;">
                                    <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                                    <span class="badge-text">WhatsApp</span>
                                </span>
                            {% endif %}
                        </div>
                    </div>
                    <div id="chat-header-phone" style="font-size: 13px; color: var(--primary-accent); line-height: 1.2; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ activeSubscriber ? (activeSubscriber.phoneNumber ?: activeSubscriber.psid) : '' }}</div>
                </div>
                
                <!-- 24h Countdown Timer Pill -->
                <div id="chat-window-timer" style="margin-left: auto; display: {% if activeSubscriber and chatWindow.isOpen %}flex{% else %}none{% endif %}; align-items: center; gap: 6px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.25); border-radius: 20px; padding: 6px 14px; font-size: 12px; color: #34d399; font-weight: 600; font-family: 'Courier New', Courier, monospace; animation: pulse-timer 2s infinite ease-in-out; backdrop-filter: blur(5px);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="animation: spin-timer 10s infinite linear; flex-shrink: 0;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    <span id="chat-window-timer-text">24h 00m 00s</span>
                </div>
                
                <!-- Mobile Info Toggle Button -->
                <button class="mobile-info-btn" onclick="toggleRightSidebar()" style="display: none; background: none; border: none; color: #fff; cursor: pointer; padding: 4px; align-items: center; justify-content: center; outline: none; -webkit-tap-highlight-color: transparent;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary-accent);"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                </button>
            </div>
            
            <div class="chat-messages" id="chat-messages">
                {% if activeSubscriber %}
                    {% for message in messages %}
                        <div class="message-bubble {% if message.direction == 'inbound' %}message-inbound{% else %}message-outbound{% endif %}" data-message-id="{{ message.id }}">
                            {% if message.type == 'image' and message.mediaUrl %}
                                <a href="/{{ message.mediaUrl }}" target="_blank">
                                    <img src="/{{ message.mediaUrl }}" style="max-width: 100%; max-height: 250px; border-radius: 8px; margin-bottom: 8px; cursor: pointer;">
                                </a>
                            {% elseif message.type == 'audio' and message.mediaUrl %}
                                <audio controls style="max-width: 100%; margin-bottom: 8px;">
                                    <source src="/{{ message.mediaUrl }}">
                                </audio>
                            {% endif %}
                            
                            {% if message.content %}
                                <div>{{ message.content|nl2br }}</div>
                            {% endif %}
                            <div class="message-time">{{ message.timestamp|date('H:i', 'UTC') }}</div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
            
            <!-- 24-hour warning banner -->
            <div id="chat-window-warning" style="{% if activeSubscriber and not chatWindow.isOpen %}display: flex;{% else %}display: none;{% endif %} background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; padding: 10px 16px; margin: 10px 24px 0 24px; font-size: 13px; color: #fca5a5; align-items: center; gap: 10px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #ef4444; flex-shrink: 0;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                <span>The 24-hour customer service window has expired. You can only respond using approved message templates.</span>
            </div>

            <div class="chat-input-area">
                <button class="attachment-btn" onclick="openTemplateModal()" title="Send Template">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                </button>
                <input type="file" id="media-upload" accept="image/*,audio/*" style="display: none;" onchange="handleFileSelect(this)">
                <button id="media-upload-btn" class="attachment-btn" onclick="document.getElementById('media-upload').click()" title="Attach File" {% if activeSubscriber and not chatWindow.isOpen %}disabled style="opacity: 0.5; cursor: not-allowed;"{% endif %}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                </button>
                <div id="file-preview" style="display: none; align-items: center; background: rgba(0,0,0,0.4); padding: 5px 10px; border-radius: 20px; font-size: 12px; color: #fff; gap: 10px;">
                    <span id="file-name">file.jpg</span>
                    <button onclick="clearFile()" style="background: none; border: none; color: #ff4444; cursor: pointer; padding: 0;">&times;</button>
                </div>
                <input type="text" id="message-input" class="chat-input" placeholder="{% if activeSubscriber and not chatWindow.isOpen %}Window expired. Choose a template message...{% else %}Type a message...{% endif %}" autocomplete="off" onkeypress="if(event.keyCode == 13) sendMessage()" {% if activeSubscriber and not chatWindow.isOpen %}disabled{% endif %}>
                <button id="chat-send-btn" class="send-btn" onclick="sendMessage()" {% if activeSubscriber and not chatWindow.isOpen %}disabled style="opacity: 0.5; cursor: not-allowed; box-shadow: none;"{% endif %}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </div>
        </div>
    </div>
    
    <!-- Right Sidebar -->
    <div class="inbox-right-sidebar" id="inbox-right-sidebar" style="{% if activeSubscriber %}display: flex;{% else %}display: none;{% endif %}">
        <!-- Mobile Sidebar Close Row -->
        <div class="mobile-sidebar-close-row" style="display: none; justify-content: flex-end; width: 100%;">
            <button onclick="toggleRightSidebar()" style="background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 4px; outline: none;">
                Close &times;
            </button>
        </div>
        <!-- Section 1: Contact Profile Header -->
        <div class="sidebar-section">
            <div class="sidebar-section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                Contact Profile & Hub
            </div>
            <div style="font-size: 12px; color: var(--text-muted); line-height: 1.4;">
                Manage conversation details, tags, custom attributes, action flows, and staff notes.
            </div>
        </div>

        <!-- Section 2: Assigned Operator -->
        <div class="sidebar-section">
            <label class="sidebar-field-label">Assigned Operator</label>
            <select id="operatorSelect" onchange="updateAssignedOperator()" class="sidebar-select">
                <option value="">Select Operator</option>
                {% for op in operators|default([]) %}
                    <option value="{{ op.id }}" {% if activeSubscriber and activeSubscriber.assignedOperator and activeSubscriber.assignedOperator.id == op.id %}selected{% endif %}>{{ op.name ?: op.email }}</option>
                {% endfor %}
            </select>
        </div>

        <!-- Section 3: Conversation Tags -->
        <div class="sidebar-section">
            <label class="sidebar-field-label">Conversation Tags</label>
            <div class="sidebar-flex-row">
                <input type="text" id="newTagInput" class="sidebar-input" placeholder="Add tag..." onkeypress="if(event.keyCode == 13) addTag()" style="padding: 6px 10px;">
                <button onclick="addTag()" style="background: rgba(6, 182, 212, 0.2); border: 1px solid rgba(6, 182, 212, 0.4); color: #22d3ee; border-radius: 8px; padding: 6px 12px; cursor: pointer; font-size: 12px; font-weight: 600; outline: none; display: flex; align-items: center; justify-content: center; height: 32px;">Add</button>
            </div>
            <div class="tag-container" id="tagContainer">
                {% if activeSubscriber %}
                    {% for tag in activeSubscriber.tags|default([]) %}
                        <span class="chat-tag" data-tag-value="{{ tag|escape('html_attr') }}">
                            {{ tag }}
                            <span class="remove-tag" onclick="removeTag('{{ tag|escape('js') }}')">&times;</span>
                        </span>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- Section 4: Campaign Flow -->
        <div class="sidebar-section">
            <label class="sidebar-field-label">Campaign Flow</label>
            <select id="flowSelect" onchange="updateAssignedFlow()" class="sidebar-select">
                <option value="">Select Action Flow</option>
            </select>
        </div>

        <!-- Section 5: Contact Attributes -->
        <div class="sidebar-section">
            <label class="sidebar-field-label">Contact Attributes</label>
            <div class="attributes-list" id="attributesContainer">
                {% if activeSubscriber %}
                    {% for key, val in activeSubscriber.customAttributes|default([]) %}
                        <div class="attribute-item" data-attr-key="{{ key|escape('html_attr') }}">
                            <span class="attribute-key">{{ key }}</span>
                            <div style="display: flex; align-items: center;">
                                <span class="attribute-value">{{ val }}</span>
                                <span class="attribute-remove" onclick="removeAttribute('{{ key|escape('js') }}')">&times;</span>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
            
            <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px; border-top: 1px solid var(--glass-border); padding-top: 10px;">
                <input type="text" id="newAttrKey" class="sidebar-input" placeholder="Property name..." style="padding: 6px 10px;">
                <div class="sidebar-flex-row">
                    <input type="text" id="newAttrVal" class="sidebar-input" placeholder="Value..." style="padding: 6px 10px;">
                    <button onclick="addAttribute()" style="background: rgba(6, 182, 212, 0.2); border: 1px solid rgba(6, 182, 212, 0.4); color: #22d3ee; border-radius: 8px; padding: 6px 12px; cursor: pointer; font-size: 12px; font-weight: 600; outline: none; height: 32px; display: flex; align-items: center; justify-content: center;">Set</button>
                </div>
            </div>
        </div>

        <!-- Section 6: Operator Notes -->
        <div class="sidebar-section">
            <label class="sidebar-field-label">Operator Notes</label>
            <div class="notes-list" id="notesContainer">
                {% if activeSubscriber %}
                    {% for note in activeSubscriber.notes|default([]) %}
                        <div class="note-item">
                            <div class="note-meta">
                                <span>{{ note.operatorName }}</span>
                                <span>{{ note.createdAt }}</span>
                            </div>
                            <div class="note-text">{{ note.text }}</div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px; border-top: 1px solid var(--glass-border); padding-top: 10px;">
                <textarea id="newNoteText" class="sidebar-input" placeholder="Write staff note..." rows="2" style="resize: none; font-family: inherit;"></textarea>
                <button onclick="addNote()" style="background: linear-gradient(135deg, var(--primary-accent), #0284c7); border: none; color: #fff; border-radius: 8px; padding: 6px 12px; cursor: pointer; font-size: 12px; font-weight: 600; text-align: center; box-shadow: 0 2px 10px rgba(6, 182, 212, 0.2); outline: none;">Add Note</button>
            </div>
        </div>
    </div>
</div>

<!-- Template Modal -->
<div id="templateModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
    <div style="background: var(--bg-gradient-end); border: 1px solid var(--glass-border); border-radius: 16px; width: 90%; max-width: 500px; padding: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="margin: 0; color: #fff; font-size: 18px;">Send Message Template</h3>
            <button onclick="closeTemplateModal()" style="background: none; border: none; color: #fff; cursor: pointer;">&times;</button>
        </div>
        
        <div style="max-height: 400px; overflow-y: auto;">
            {% for template in templates|default([]) %}
                <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 10px; cursor: pointer; border: 1px solid var(--glass-border);"
                     onclick="sendTemplate('{{ template.name }}', '{{ template.language }}')"
                     onmouseover="this.style.background='rgba(255,255,255,0.05)'"
                     onmouseout="this.style.background='rgba(0,0,0,0.2)'">
                    <div style="color: #fff; font-weight: 600; margin-bottom: 5px;">{{ template.name }} <span style="font-size: 11px; background: rgba(16,185,129,0.2); color: var(--secondary-accent); padding: 2px 6px; border-radius: 4px;">{{ template.language }}</span></div>
                    
                    {% set bodyText = '' %}
                    {% for comp in template.components %}
                        {% if comp.type == 'BODY' %}
                            {% set bodyText = comp.text %}
                        {% endif %}
                    {% endfor %}
                    <div style="color: #aaa; font-size: 13px;">{{ bodyText }}</div>
                </div>
            {% else %}
                <div style="color: #888; text-align: center; padding: 20px;">No approved templates available.</div>
            {% endfor %}
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
    const whatsappFlows = [
        {% for f in whatsappFlows|default([]) %}
            { id: {{ f.id }}, name: "{{ f.name|escape('js') }}" },
        {% endfor %}
    ];
    const facebookFlows = [
        {% for f in facebookFlows|default([]) %}
            { id: {{ f.id }}, name: "{{ f.name|escape('js') }}" },
        {% endfor %}
    ];

    let activeSubscriberId = {{ activeSubscriber ? activeSubscriber.id : 'null' }};
    let lastMessageId = 0;
    let subscribersCacheJson = '';
    
    // Global Unix epoch offset for clock-skew compensation
    let chatWindowExpiresAtTimestamp = {% if activeSubscriber and chatWindow.isOpen and chatWindow.expiresAtTimestamp %}{{ chatWindow.expiresAtTimestamp }}{% else %}null{% endif %};
    let serverTimeSec = {{ serverTimestamp|default('null') }};
    let localToServerOffset = serverTimeSec ? (serverTimeSec * 1000 - Date.now()) : 0;
    
    let chatWindowTimerInterval = null;

    const messagesContainer = document.getElementById('chat-messages');

    // Scroll to bottom on load
    if (messagesContainer) {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    updateLastMessageId();

    function updateLastMessageId() {
        const bubbles = document.querySelectorAll('.message-bubble[data-message-id]');
        bubbles.forEach(bubble => {
            const id = parseInt(bubble.getAttribute('data-message-id'), 10);
            if (id > lastMessageId) {
                lastMessageId = id;
            }
        });
    }

    function handleFileSelect(input) {
        const file = input.files[0];
        if (file) {
            document.getElementById('file-preview').style.display = 'flex';
            document.getElementById('file-name').innerText = file.name;
        }
    }

    function clearFile() {
        document.getElementById('media-upload').value = '';
        document.getElementById('file-preview').style.display = 'none';
    }

    function renderMessage(msg) {
        const bubble = document.createElement('div');
        bubble.className = `message-bubble ${msg.direction === 'inbound' ? 'message-inbound' : 'message-outbound'}`;
        bubble.setAttribute('data-message-id', msg.id);
        
        let mediaHtml = '';
        if (msg.type === 'image' && msg.mediaUrl) {
            mediaHtml = `<a href="${msg.mediaUrl}" target="_blank"><img src="${msg.mediaUrl}" style="max-width: 100%; max-height: 250px; border-radius: 8px; margin-bottom: 8px; cursor: pointer;"></a>`;
        } else if (msg.type === 'audio' && msg.mediaUrl) {
            mediaHtml = `<audio controls style="max-width: 100%; margin-bottom: 8px;"><source src="${msg.mediaUrl}"></audio>`;
        }
        
        let contentHtml = '';
        if (msg.content) {
            contentHtml = `<div>${msg.content.replace(/\n/g, '<br>')}</div>`;
        }
        
        bubble.innerHTML = mediaHtml + contentHtml + `<div class="message-time">${msg.timeOnly || ''}</div>`;
        return bubble;
    }

    function selectSubscriber(event, id, name, phone) {
        if (event) {
            event.preventDefault();
        }
        
        activeSubscriberId = id;
        
        // Update active class in sidebar
        document.querySelectorAll('.subscriber-item').forEach(item => {
            if (parseInt(item.getAttribute('data-id'), 10) === id) {
                item.classList.add('active');
            } else {
                item.classList.remove('active');
            }
        });
        
        // Force list re-render cache refresh on next poll
        subscribersCacheJson = ''; 
        
        // Toggle view containers
        document.getElementById('empty-state').style.display = 'none';
        document.getElementById('chat-container').style.display = 'flex';
        document.getElementById('inbox-right-sidebar').style.display = 'flex';
        
        // Add mobile active class to container
        const container = document.querySelector('.inbox-container');
        if (container) {
            container.classList.add('mobile-chat-active');
        }
        
        // Hide badge temporarily until loaded
        const badgeEl = document.getElementById('chat-header-badge');
        if (badgeEl) {
            badgeEl.style.display = 'none';
        }
        
        // Update header details
        document.getElementById('chat-header-avatar').innerText = name ? name.charAt(0).toUpperCase() : '#';
        document.getElementById('chat-header-name').innerText = name || phone;
        document.getElementById('chat-header-phone').innerText = phone;
        
        // Clear chat content and show loading state
        messagesContainer.innerHTML = '<div style="color: var(--text-muted); text-align: center; margin: 20px auto;">Loading chat messages...</div>';
        
        // Update URL state without page reload
        window.history.pushState(null, '', `/inbox/${id}`);
        
        // Load messages
        loadChatArea(id);
        
        // Load subscriber right sidebar details
        loadSubscriberDetails(id);
    }

    function loadChatArea(id) {
        fetch(`/inbox/api/messages/${id}`)
        .then(res => res.json())
        .then(messages => {
            if (activeSubscriberId !== id) return;
            
            messagesContainer.innerHTML = '';
            lastMessageId = 0;
            
            if (messages.length === 0) {
                messagesContainer.innerHTML = '<div style="color: var(--text-muted); text-align: center; margin: 20px auto;">No messages in this chat.</div>';
            } else {
                messages.forEach(msg => {
                    const bubble = renderMessage(msg);
                    messagesContainer.appendChild(bubble);
                    if (msg.id > lastMessageId) {
                        lastMessageId = msg.id;
                    }
                });
            }
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        })
        .catch(err => {
            console.error('Error loading messages:', err);
            messagesContainer.innerHTML = '<div style="color: #ef4444; text-align: center; margin: 20px auto;">Failed to load messages.</div>';
        });
    }

    function sendMessage() {
        const input = document.getElementById('message-input');
        const fileInput = document.getElementById('media-upload');
        const content = input.value.trim();
        const file = fileInput.files[0];
        
        if (!activeSubscriberId) return;
        if (!content && !file) return;
        
        input.disabled = true;
        
        const formData = new FormData();
        formData.append('subscriber_id', activeSubscriberId);
        formData.append('content', content);
        if (file) {
            formData.append('media', file);
        }
        
        fetch('{{ path('app_inbox_send') }}', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                input.value = '';
                clearFile();
                
                if (activeSubscriberId === data.message.subscriber_id || data.message.id) {
                    if (!document.querySelector(`.message-bubble[data-message-id="${data.message.id}"]`)) {
                        const bubble = renderMessage({
                            id: data.message.id,
                            type: data.message.type,
                            content: data.message.content,
                            mediaUrl: data.message.mediaUrl,
                            timeOnly: 'Just now',
                            direction: 'outbound'
                        });
                        
                        const emptyPlaceholder = messagesContainer.querySelector('div[style*="text-align: center"]');
                        if (emptyPlaceholder) {
                            emptyPlaceholder.remove();
                        }
                        
                        messagesContainer.appendChild(bubble);
                        messagesContainer.scrollTop = messagesContainer.scrollHeight;
                        
                        if (data.message.id > lastMessageId) {
                            lastMessageId = data.message.id;
                        }
                    }
                }
                refreshSidebar();
            } else {
                alert('Error sending message: ' + data.error);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to send message.');
        })
        .finally(() => {
            input.disabled = false;
            input.focus();
        });
    }


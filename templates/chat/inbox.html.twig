    function addAttribute() {
        if (!activeSubscriberId) return;
        const keyInput = document.getElementById('newAttrKey');
        const valInput = document.getElementById('newAttrVal');
        const key = keyInput.value.trim();
        const val = valInput.value.trim();
        
        if (!key || !val) return;
        
        keyInput.value = '';
        valInput.value = '';
        
        // Optimistic UI update
        const attrsContainer = document.getElementById('attributesContainer');
        let existing = attrsContainer.querySelector(`[data-attr-key="${key}"]`);
        if (existing) {
            existing.remove();
        }
        
        const div = document.createElement('div');
        div.className = 'attribute-item';
        div.setAttribute('data-attr-key', key);
        div.innerHTML = `
            <span class="attribute-key">${escapeHtml(key)}</span>
            <div style="display: flex; align-items: center;">
                <span class="attribute-value">${escapeHtml(val)}</span>
                <span class="attribute-remove" onclick="removeAttribute('${escapeJs(key)}')">&times;</span>
            </div>
        `;
        attrsContainer.appendChild(div);
        
        const formData = new FormData();
        formData.append('key', key);
        formData.append('value', val);
        
        fetch(`/inbox/api/subscriber/${activeSubscriberId}/attribute`, {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                alert('Error setting custom attribute: ' + data.error);
            }
        })
        .catch(err => console.error(err));
    }

    function removeAttribute(key) {
        if (!activeSubscriberId) return;
        
        const attrsContainer = document.getElementById('attributesContainer');
        const existing = attrsContainer.querySelector(`[data-attr-key="${key}"]`);
        if (existing) {
            existing.remove();
        }
        
        const formData = new FormData();
        formData.append('key', key);
        formData.append('delete', '1');
        
        fetch(`/inbox/api/subscriber/${activeSubscriberId}/attribute`, {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                alert('Error removing attribute: ' + data.error);
            }
        })
        .catch(err => console.error(err));
    }


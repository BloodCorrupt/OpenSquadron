    function refreshSidebar() {
        fetch('/inbox/api/subscribers')
        .then(res => res.json())
        .then(data => {
            const jsonString = JSON.stringify(data);
            if (jsonString !== subscribersCacheJson) {
                subscribersCacheJson = jsonString;
                renderSubscriberList(data);
            }
        })
        .catch(err => console.error('Error syncing subscribers:', err));
    }

    function syncNewMessages() {
        if (!activeSubscriberId) return;
        const currentSubId = activeSubscriberId;
        fetch(`/inbox/api/messages/${currentSubId}?after_id=${lastMessageId}`)
        .then(res => res.json())
        .then(newMessages => {
            if (activeSubscriberId !== currentSubId) return;
            
            if (newMessages && newMessages.length > 0) {
                const emptyPlaceholder = messagesContainer.querySelector('div[style*="text-align: center"]');
                if (emptyPlaceholder) {
                    emptyPlaceholder.remove();
                }
                
                let hasNewInbound = false;
                newMessages.forEach(msg => {
                    if (!document.querySelector(`.message-bubble[data-message-id="${msg.id}"]`)) {
                        const bubble = renderMessage(msg);
                        messagesContainer.appendChild(bubble);
                        if (msg.direction === 'inbound') {
                            hasNewInbound = true;
                        }
                    }
                    if (msg.id > lastMessageId) {
                        lastMessageId = msg.id;
                    }
                });
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
                
                if (hasNewInbound) {
                    loadSubscriberDetails(currentSubId);
                }
            }
        })
        .catch(err => console.error('Error syncing new messages:', err));
    }

    function startChatWindowTimer() {
        if (chatWindowTimerInterval) {
            clearInterval(chatWindowTimerInterval);
            chatWindowTimerInterval = null;
        }

        const timerPill = document.getElementById('chat-window-timer');
        const timerText = document.getElementById('chat-window-timer-text');

        function updateCountdown() {
            if (!activeSubscriberId || !chatWindowExpiresAtTimestamp) {
                if (timerPill) timerPill.style.display = 'none';
                if (chatWindowTimerInterval) {
                    clearInterval(chatWindowTimerInterval);
                    chatWindowTimerInterval = null;
                }
                return;
            }

            const expiresTimeMs = chatWindowExpiresAtTimestamp * 1000;
            const correctedNow = Date.now() + localToServerOffset;
            const remaining = expiresTimeMs - correctedNow;

            if (remaining <= 0) {
                if (timerPill) timerPill.style.display = 'none';
                chatWindowExpiresAtTimestamp = null;
                if (chatWindowTimerInterval) {
                    clearInterval(chatWindowTimerInterval);
                    chatWindowTimerInterval = null;
                }
                
                // Real-time visual and functional input lockdown
                const warningBanner = document.getElementById('chat-window-warning');
                const mediaUploadBtn = document.getElementById('media-upload-btn');
                const messageInput = document.getElementById('message-input');
                const sendBtn = document.getElementById('chat-send-btn');
                
                if (warningBanner) warningBanner.style.display = 'flex';
                if (mediaUploadBtn) {
                    mediaUploadBtn.disabled = true;
                    mediaUploadBtn.style.opacity = '0.5';
                    mediaUploadBtn.style.cursor = 'not-allowed';
                }
                if (messageInput) {
                    messageInput.disabled = true;
                    messageInput.placeholder = 'Window expired. Choose a template message...';
                }
                if (sendBtn) {
                    sendBtn.disabled = true;
                    sendBtn.style.opacity = '0.5';
                    sendBtn.style.cursor = 'not-allowed';
                    sendBtn.style.boxShadow = 'none';
                }
                return;
            }

            const hours = Math.floor(remaining / (1000 * 60 * 60));
            const minutes = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((remaining % (1000 * 60)) / 1000);

            const displayStr = `${hours.toString().padStart(2, '0')}h ${minutes.toString().padStart(2, '0')}m ${seconds.toString().padStart(2, '0')}s`;
            if (timerText) timerText.textContent = displayStr;
            if (timerPill && timerPill.style.display === 'none') {
                timerPill.style.display = 'flex';
            }
        }

        updateCountdown();
        chatWindowTimerInterval = setInterval(updateCountdown, 1000);
    }

    // Load subscriber details on initial load if active subscriber exists
    if (activeSubscriberId) {
        loadSubscriberDetails(activeSubscriberId);
        startChatWindowTimer();
    }

    function loadSubscriberDetails(id) {
        fetch(`/inbox/api/subscriber/${id}/details`)
        .then(res => res.json())
        .then(sub => {
            if (activeSubscriberId !== id) return;
            
            // Handle chat window status
            const chatWindow = sub.chatWindow;
            const warningBanner = document.getElementById('chat-window-warning');
            const mediaUploadBtn = document.getElementById('media-upload-btn');
            const messageInput = document.getElementById('message-input');
            const sendBtn = document.getElementById('chat-send-btn');
            
            if (sub.serverTimestamp) {
                localToServerOffset = sub.serverTimestamp * 1000 - Date.now();
            }
            
            if (chatWindow && !chatWindow.isOpen) {
                warningBanner.style.display = 'flex';
                mediaUploadBtn.disabled = true;
                mediaUploadBtn.style.opacity = '0.5';
                mediaUploadBtn.style.cursor = 'not-allowed';
                messageInput.disabled = true;
                messageInput.placeholder = 'Window expired. Choose a template message...';
                sendBtn.disabled = true;
                sendBtn.style.opacity = '0.5';
                sendBtn.style.cursor = 'not-allowed';
                sendBtn.style.boxShadow = 'none';
                chatWindowExpiresAtTimestamp = null;
            } else {
                warningBanner.style.display = 'none';
                mediaUploadBtn.disabled = false;
                mediaUploadBtn.style.opacity = '1';
                mediaUploadBtn.style.cursor = 'pointer';
                messageInput.disabled = false;
                messageInput.placeholder = 'Type a message...';
                sendBtn.disabled = false;
                sendBtn.style.opacity = '1';
                sendBtn.style.cursor = 'pointer';
                sendBtn.style.boxShadow = '';
                chatWindowExpiresAtTimestamp = chatWindow ? chatWindow.expiresAtTimestamp : null;
            }
            startChatWindowTimer();
            
            // Update channel header badge dynamically
            const headerBadgeContainer = document.getElementById('chat-header-badge');
            if (headerBadgeContainer) {
                headerBadgeContainer.style.display = 'inline-flex';
                if (sub.channel === 'facebook') {
                    headerBadgeContainer.innerHTML = `
                        <span class="channel-badge-pill" style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #3b82f6; background: rgba(59, 130, 246, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(59, 130, 246, 0.25); flex-shrink: 0;">
                            <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                            <span class="badge-text">Facebook (Beta)</span>
                        </span>
                    `;
                } else {
                    headerBadgeContainer.innerHTML = `
                        <span class="channel-badge-pill" style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; font-weight: bold; color: #10b981; background: rgba(16, 185, 129, 0.12); padding: 2px 6px; border-radius: 12px; border: 1px solid rgba(16, 185, 129, 0.25); flex-shrink: 0;">
                            <svg viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                            <span class="badge-text">WhatsApp</span>
                        </span>
                    `;
                }
            }

            // Fallback logic for name/phone details
            const displayName = sub.name || (sub.channel === 'facebook' ? 'PSID: ' + sub.psid : sub.phoneNumber);
            const displayPhone = sub.phoneNumber || sub.psid || '';
            document.getElementById('chat-header-name').innerText = displayName;
            document.getElementById('chat-header-phone').innerText = displayPhone;
            document.getElementById('chat-header-avatar').innerText = displayName ? displayName.charAt(0).toUpperCase() : '#';
            
            // Set operator
            document.getElementById('operatorSelect').value = sub.assignedOperatorId || '';
            
            // Rebuild flow options dynamically based on channel
            const flowSelect = document.getElementById('flowSelect');
            flowSelect.innerHTML = '<option value="">Select Action Flow</option>';
            const targetFlows = sub.channel === 'facebook' ? facebookFlows : whatsappFlows;
            targetFlows.forEach(f => {
                const opt = document.createElement('option');
                opt.value = f.id;
                opt.textContent = f.name;
                flowSelect.appendChild(opt);
            });
            flowSelect.value = sub.assignedFlowId || '';
            
            // Render tags
            const tagContainer = document.getElementById('tagContainer');
            tagContainer.innerHTML = '';
            if (sub.tags && sub.tags.length > 0) {
                sub.tags.forEach(tag => {
                    const span = document.createElement('span');
                    span.className = 'chat-tag';
                    span.setAttribute('data-tag-value', tag);
                    span.innerHTML = `${escapeHtml(tag)} <span class="remove-tag" onclick="removeTag('${escapeJs(tag)}')">&times;</span>`;
                    tagContainer.appendChild(span);
                });
            }
            
            // Render custom attributes
            const attrsContainer = document.getElementById('attributesContainer');
            attrsContainer.innerHTML = '';
            if (sub.customAttributes) {
                Object.entries(sub.customAttributes).forEach(([key, val]) => {
                    const div = document.createElement('div');
                    div.className = 'attribute-item';
                    div.setAttribute('data-attr-key', key);
                    div.innerHTML = `
                        <span class="attribute-key">${escapeHtml(key)}</span>
                        <div style="display: flex; align-items: center;">
                            <span class="attribute-value">${escapeHtml(val)}</span>
                            <span class="attribute-remove" onclick="removeAttribute('${escapeJs(key)}')">&times;</span>
                        </div>
                    `;
                    attrsContainer.appendChild(div);
                });
            }
            
            // Render notes
            const notesContainer = document.getElementById('notesContainer');
            notesContainer.innerHTML = '';
            if (sub.notes && sub.notes.length > 0) {
                sub.notes.forEach(note => {
                    const div = document.createElement('div');
                    div.className = 'note-item';
                    div.innerHTML = `
                        <div class="note-meta">
                            <span>${escapeHtml(note.operatorName)}</span>
                            <span>${escapeHtml(note.createdAt)}</span>
                        </div>
                        <div class="note-text">${escapeHtml(note.text)}</div>
                    `;
                    notesContainer.appendChild(div);
                });
                notesContainer.scrollTop = notesContainer.scrollHeight;
            }
        })
        .catch(err => console.error('Error loading subscriber details:', err));
    }

    function updateAssignedOperator() {
        if (!activeSubscriberId) return;
        const select = document.getElementById('operatorSelect');
        const operatorId = select.value;
        
        select.disabled = true;
        
        const formData = new FormData();
        formData.append('operator_id', operatorId);
        
        fetch(`/inbox/api/subscriber/${activeSubscriberId}/assign-operator`, {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                alert('Error updating operator: ' + data.error);
            }
        })
        .catch(err => console.error(err))
        .finally(() => {
            select.disabled = false;
        });
    }

    function addTag() {
        if (!activeSubscriberId) return;
        const input = document.getElementById('newTagInput');
        const val = input.value.trim();
        if (!val) return;
        
        input.value = '';
        
        // Get current tags from local state
        const tags = [];
        document.querySelectorAll('#tagContainer .chat-tag').forEach(span => {
            tags.push(span.getAttribute('data-tag-value'));
        });
        
        if (tags.includes(val)) return;
        tags.push(val);
        
        saveTags(tags);
    }

    function removeTag(tag) {
        if (!activeSubscriberId) return;
        
        const tags = [];
        document.querySelectorAll('#tagContainer .chat-tag').forEach(span => {
            const t = span.getAttribute('data-tag-value');
            if (t !== tag) {
                tags.push(t);
            }
        });
        
        saveTags(tags);
    }

    function saveTags(tagsArray) {
        const tagContainer = document.getElementById('tagContainer');
        
        // Update tags list UI immediately for instant feedback
        tagContainer.innerHTML = '';
        tagsArray.forEach(tag => {
            const span = document.createElement('span');
            span.className = 'chat-tag';
            span.setAttribute('data-tag-value', tag);
            span.innerHTML = `${escapeHtml(tag)} <span class="remove-tag" onclick="removeTag('${escapeJs(tag)}')">&times;</span>`;
            tagContainer.appendChild(span);
        });
        
        const formData = new FormData();
        tagsArray.forEach(tag => {
            formData.append('tags[]', tag);
        });
        
        fetch(`/inbox/api/subscriber/${activeSubscriberId}/tags`, {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                alert('Error updating tags: ' + data.error);
            }
        })
        .catch(err => console.error(err));
    }


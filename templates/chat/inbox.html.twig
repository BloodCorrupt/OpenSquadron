{% extends 'base.html.twig' %}

{% block title %}Shared Inbox{% endblock %}

{% block max_width %}100%{% endblock %}

{% block stylesheets %}
<style>
    .inbox-container {
        display: flex;
        height: calc(100vh - 160px);
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--glass-border);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    }
    
    .inbox-sidebar {
        width: 320px;
        border-right: 1px solid var(--glass-border);
        display: flex;
        flex-direction: column;
        background: rgba(0, 0, 0, 0.2);
    }
    
    .inbox-header {
        padding: 20px 24px;
        background: rgba(0, 0, 0, 0.3);
        border-bottom: 1px solid var(--glass-border);
        font-weight: 700;
        font-size: 18px;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .subscriber-list {
        overflow-y: auto;
        flex: 1;
    }
    .subscriber-list::-webkit-scrollbar {
        width: 6px;
    }
    .subscriber-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    
    .subscriber-item {
        padding: 16px 24px;
        border-bottom: 1px solid var(--glass-border);
        cursor: pointer;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        transition: background 0.2s, padding-left 0.2s;
        border-left: 3px solid transparent;
    }
    
    .subscriber-item:hover {
        background: rgba(255, 255, 255, 0.05);
        padding-left: 28px;
    }
    
    .subscriber-item.active {
        background: rgba(6, 182, 212, 0.1);
        border-left-color: var(--primary-accent);
    }
    
    .subscriber-name {
        font-weight: 600;
        margin-bottom: 6px;
        color: #fff;
        font-size: 15px;
    }
    
    .subscriber-phone {
        font-size: 13px;
        color: var(--text-muted);
    }
    
    .inbox-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: transparent;
        position: relative;
    }
    
    .chat-header {
        padding: 16px 24px;
        background: rgba(0, 0, 0, 0.3);
        border-bottom: 1px solid var(--glass-border);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    .chat-messages::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    
    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 15px;
        line-height: 1.5;
        position: relative;
        word-wrap: break-word;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .message-inbound {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        align-self: flex-start;
        border-top-left-radius: 4px;
        border: 1px solid var(--glass-border);
    }
    
    .message-outbound {
        background: linear-gradient(135deg, var(--primary-accent), #0284c7);
        color: #fff;
        align-self: flex-end;
        border-top-right-radius: 4px;
    }
    
    .message-time {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.6);
        float: right;
        margin-left: 15px;
        margin-top: 8px;
    }
    
    .chat-input-area {
        padding: 20px 24px;
        background: rgba(0, 0, 0, 0.3);
        border-top: 1px solid var(--glass-border);
        display: flex;
        gap: 15px;
    }
    
    .chat-input {
        flex: 1;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        padding: 14px 20px;
        border-radius: 24px;
        font-size: 15px;
        color: #fff;
        outline: none;
        transition: border-color 0.3s;
    }
    .chat-input:focus {
        border-color: var(--primary-accent);
    }
    
    .attachment-btn {
        background: rgba(0, 0, 0, 0.2);
        color: var(--text-muted);
        border: 1px solid var(--glass-border);
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .attachment-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    
    .send-btn {
        background: linear-gradient(135deg, var(--primary-accent), #0284c7);
        color: white;
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
    }
    
    .send-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(6, 182, 212, 0.5);
    }
    
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: var(--text-muted);
        text-align: center;
    }
</style>
{% endblock %}

{% block body %}
<div class="inbox-container">
    <!-- Sidebar -->
    <div class="inbox-sidebar">
        <div class="inbox-header">
            Chats
        </div>
        <div class="subscriber-list">
            {% for sub in subscribers %}
                <a href="{{ path('app_inbox_chat', {'id': sub.id}) }}" class="subscriber-item {% if activeSubscriber and activeSubscriber.id == sub.id %}active{% endif %}">
                    <div class="subscriber-name">{{ sub.name ?: sub.phoneNumber }}</div>
                    <div class="subscriber-phone">{{ sub.phoneNumber }}</div>
                </a>
            {% else %}
                <div style="padding: 20px; text-align: center; color: #888; font-size: 14px;">
                    No subscribers yet. When someone messages your WhatsApp number, they will appear here.
                </div>
            {% endfor %}
        </div>
    </div>
    
    <!-- Main Chat Area -->
    <div class="inbox-main">
        {% if activeSubscriber %}
            <div class="chat-header">
                <div style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-accent), var(--secondary-accent)); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 18px; box-shadow: 0 2px 10px rgba(6, 182, 212, 0.3);">
                    {{ activeSubscriber.name ? activeSubscriber.name|first|upper : '#' }}
                </div>
                <div>
                    <div style="font-weight: 700; color: #fff; font-size: 16px;">{{ activeSubscriber.name ?: activeSubscriber.phoneNumber }}</div>
                    <div style="font-size: 13px; color: var(--primary-accent);">{{ activeSubscriber.phoneNumber }}</div>
                </div>
            </div>
            
            <div class="chat-messages" id="chat-messages">
                {% for message in messages %}
                    <div class="message-bubble {% if message.direction == 'inbound' %}message-inbound{% else %}message-outbound{% endif %}">
                        {% if message.type == 'image' and message.mediaUrl %}
                            <a href="/{{ message.mediaUrl }}" target="_blank">
                                <img src="/{{ message.mediaUrl }}" style="max-width: 100%; max-height: 250px; border-radius: 8px; margin-bottom: 8px; cursor: pointer;">
                            </a>
                        {% elseif message.type == 'audio' and message.mediaUrl %}
                            <audio controls style="max-width: 100%; margin-bottom: 8px;">
                                <source src="/{{ message.mediaUrl }}">
                            </audio>
                        {% endif %}
                        
                        {% if message.content %}
                            <div>{{ message.content|nl2br }}</div>
                        {% endif %}
                        <div class="message-time">{{ message.timestamp|date('H:i') }}</div>
                    </div>
                {% endfor %}
            </div>
            
            <div class="chat-input-area">
                <button class="attachment-btn" onclick="openTemplateModal()" title="Send Template" style="margin-right: 10px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                </button>
                <input type="file" id="media-upload" accept="image/*,audio/*" style="display: none;" onchange="handleFileSelect(this)">
                <button class="attachment-btn" onclick="document.getElementById('media-upload').click()" title="Attach File">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                </button>
                <div id="file-preview" style="display: none; align-items: center; background: rgba(0,0,0,0.4); padding: 5px 10px; border-radius: 20px; font-size: 12px; color: #fff; gap: 10px;">
                    <span id="file-name">file.jpg</span>
                    <button onclick="clearFile()" style="background: none; border: none; color: #ff4444; cursor: pointer; padding: 0;">&times;</button>
                </div>
                <input type="text" id="message-input" class="chat-input" placeholder="Type a message..." autocomplete="off" onkeypress="if(event.keyCode == 13) sendMessage()">
                <button class="send-btn" onclick="sendMessage()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </div>
        {% else %}
            <div style="flex: 1; display: flex; align-items: center; justify-content: center; color: #888; font-size: 16px;">
                Select a chat from the sidebar to start messaging.
            </div>
        {% endif %}
    </div>
</div>

<!-- Template Modal -->
<div id="templateModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
    <div style="background: var(--bg-gradient-end); border: 1px solid var(--glass-border); border-radius: 16px; width: 90%; max-width: 500px; padding: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="margin: 0; color: #fff; font-size: 18px;">Send Message Template</h3>
            <button onclick="closeTemplateModal()" style="background: none; border: none; color: #fff; cursor: pointer;">&times;</button>
        </div>
        
        <div style="max-height: 400px; overflow-y: auto;">
            {% for template in templates|default([]) %}
                <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 10px; cursor: pointer; border: 1px solid var(--glass-border);"
                     onclick="sendTemplate('{{ template.name }}', '{{ template.language }}')"
                     onmouseover="this.style.background='rgba(255,255,255,0.05)'"
                     onmouseout="this.style.background='rgba(0,0,0,0.2)'">
                    <div style="color: #fff; font-weight: 600; margin-bottom: 5px;">{{ template.name }} <span style="font-size: 11px; background: rgba(16,185,129,0.2); color: var(--secondary-accent); padding: 2px 6px; border-radius: 4px;">{{ template.language }}</span></div>
                    
                    {% set bodyText = '' %}
                    {% for comp in template.components %}
                        {% if comp.type == 'BODY' %}
                            {% set bodyText = comp.text %}
                        {% endif %}
                    {% endfor %}
                    <div style="color: #aaa; font-size: 13px;">{{ bodyText }}</div>
                </div>
            {% else %}
                <div style="color: #888; text-align: center; padding: 20px;">No approved templates available.</div>
            {% endfor %}
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{% if activeSubscriber %}
<script>
    // Scroll to bottom on load
    const messagesContainer = document.getElementById('chat-messages');
    messagesContainer.scrollTop = messagesContainer.scrollHeight;

    function handleFileSelect(input) {
        const file = input.files[0];
        if (file) {
            document.getElementById('file-preview').style.display = 'flex';
            document.getElementById('file-name').innerText = file.name;
        }
    }

    function clearFile() {
        document.getElementById('media-upload').value = '';
        document.getElementById('file-preview').style.display = 'none';
    }

    function sendMessage() {
        const input = document.getElementById('message-input');
        const fileInput = document.getElementById('media-upload');
        const content = input.value.trim();
        const file = fileInput.files[0];
        const subscriberId = {{ activeSubscriber.id }};
        
        if (!content && !file) return;
        
        // Disable input while sending
        input.disabled = true;
        
        const formData = new FormData();
        formData.append('subscriber_id', subscriberId);
        formData.append('content', content);
        if (file) {
            formData.append('media', file);
        }
        
        fetch('{{ path('app_inbox_send') }}', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                input.value = '';
                clearFile();
                
                // Add message to UI
                const bubble = document.createElement('div');
                bubble.className = 'message-bubble message-outbound';
                
                let mediaHtml = '';
                if (data.message.type === 'image' && data.message.mediaUrl) {
                    mediaHtml = `<a href="${data.message.mediaUrl}" target="_blank"><img src="${data.message.mediaUrl}" style="max-width: 100%; max-height: 250px; border-radius: 8px; margin-bottom: 8px;"></a>`;
                } else if (data.message.type === 'audio' && data.message.mediaUrl) {
                    mediaHtml = `<audio controls style="max-width: 100%; margin-bottom: 8px;"><source src="${data.message.mediaUrl}"></audio>`;
                }
                
                let textHtml = data.message.content ? `<div>${data.message.content.replace(/\n/g, "<br>")}</div>` : '';
                
                bubble.innerHTML = mediaHtml + textHtml + '<div class="message-time">Just now</div>';
                
                messagesContainer.appendChild(bubble);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            } else {
                alert('Error sending message: ' + data.error);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to send message.');
        })
        .finally(() => {
            input.disabled = false;
            input.focus();
        });
    }

    function openTemplateModal() {
        document.getElementById('templateModal').style.display = 'flex';
    }

    function closeTemplateModal() {
        document.getElementById('templateModal').style.display = 'none';
    }

    function sendTemplate(templateName, languageCode) {
        closeTemplateModal();
        const subscriberId = {{ activeSubscriber.id|default('null') }};
        if (!subscriberId) return;

        const formData = new FormData();
        formData.append('subscriber_id', subscriberId);
        formData.append('template_name', templateName);
        formData.append('language_code', languageCode);

        fetch('{{ path('app_inbox_send_template') }}', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const bubble = document.createElement('div');
                bubble.className = 'message-bubble message-outbound';
                bubble.innerHTML = `<div>${data.message.content}</div><div class="message-time">Just now</div>`;
                messagesContainer.appendChild(bubble);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            } else {
                alert('Error sending template: ' + data.error);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to send template.');
        });
    }
    
    // Simple polling to refresh the page every 10 seconds to show new messages
    // For a production app, use WebSockets (Mercure) or an AJAX fetch instead of a full reload.
    setInterval(function() {
        // Only reload if user isn't typing
        if (document.getElementById('message-input').value.trim() === '') {
            window.location.reload();
        }
    }, 10000);
</script>
{% endif %}
{% endblock %}

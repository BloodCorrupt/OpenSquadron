{% extends 'base.html.twig' %}

{% block title %}2FA Backup Codes - OpenSquadron{% endblock %}

{% block body %}
<style>
    .form-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 35px;
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }
    .form-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 15px;
    }
    .form-title svg {
        width: 24px;
        height: 24px;
        stroke: var(--primary-accent);
    }
    .codes-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin: 25px 0;
    }
    .code-box {
        background: rgba(0, 0, 0, 0.2);
        border: 1px dashed var(--glass-border);
        padding: 12px;
        text-align: center;
        font-family: monospace;
        font-size: 18px;
        letter-spacing: 2px;
        border-radius: 8px;
        color: var(--primary-accent);
        font-weight: bold;
    }
    .warning-box {
        background: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.3);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        color: #fbd38d;
    }
    .warning-box h4 {
        margin: 0 0 10px 0;
        color: #f6ad55;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .info-box {
        background: rgba(6, 182, 212, 0.1);
        border: 1px solid rgba(6, 182, 212, 0.3);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        color: #c4f1f9;
    }
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 35px;
        border-top: 1px solid var(--glass-border);
        padding-top: 20px;
    }
</style>

<div class="header">
    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
    <h1>Security Settings</h1>
</div>

<div class="form-card">
    <div class="form-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        <span>2FA Backup Codes</span>
    </div>

    {% if generated %}
        <div class="warning-box">
            <h4>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                Save these codes NOW
            </h4>
            <p style="margin: 0; font-size: 14px;">These codes will only be shown to you once. If you lose them, you will not be able to view them again. Please copy or download them and store them in a secure place (like a password manager).</p>
        </div>

        <div class="codes-grid">
            {% for code in backup_codes %}
                <div class="code-box">{{ code }}</div>
            {% endfor %}
        </div>
        
        <div class="form-actions" style="justify-content: space-between;">
            <a href="{{ path('app_accounts_edit_self') }}" class="btn" style="color: var(--text-muted);">Back to Profile</a>
            <button onclick="window.print()" class="btn btn-primary">Print / Save as PDF</button>
        </div>
    {% else %}
        {% if has_existing %}
            <div class="info-box">
                <h4 style="margin: 0 0 10px 0; color: #00b5d8;">Backup Codes Active</h4>
                <p style="margin: 0; font-size: 14px;">You currently have backup codes configured for your account. If you generate new ones, the old ones will become invalid immediately.</p>
            </div>
        {% else %}
            <p style="color: var(--text-muted); margin-bottom: 20px;">You do not have any backup codes configured. Backup codes allow you to access your account if you lose access to your authenticator app.</p>
        {% endif %}

        <form action="{{ path('app_generate_backup_codes') }}" method="POST">
            <div class="form-actions" style="justify-content: space-between;">
                <a href="{{ path('app_accounts_edit_self') }}" class="btn" style="color: var(--text-muted);">Back to Profile</a>
                <button type="submit" class="btn btn-primary">
                    {% if has_existing %}Generate NEW Codes{% else %}Generate Backup Codes{% endif %}
                </button>
            </div>
        </form>
    {% endif %}
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Security & Access - OpenSquadron{% endblock %}

{% block body %}
<div class="header">
    <h1>
        <svg class="title-icon" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        Security & Access
    </h1>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
    <!-- Left Column: Password Update & 2FA -->
    <div style="display: flex; flex-direction: column; gap: 30px;">
        <!-- Change Password Card -->
        <div class="card">
            <h2 class="card-title">
                <svg class="title-icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Update Passphrase
            </h2>
            <form onsubmit="event.preventDefault(); alert('Passphrase updated successfully (Mockup)!');">
                <div class="form-group">
                    <label for="current_password">Current Passphrase</label>
                    <input type="password" id="current_password" class="form-control" placeholder="••••••••" required>
                </div>
                <div class="form-group">
                    <label for="new_password">New Passphrase</label>
                    <input type="password" id="new_password" class="form-control" placeholder="Minimum 8 characters" required>
                </div>
                <div class="form-group">
                    <label for="confirm_password">Confirm New Passphrase</label>
                    <input type="password" id="confirm_password" class="form-control" placeholder="Verify your passphrase" required>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%;">Commit Passphrase Change</button>
            </form>
        </div>

        <!-- 2FA Setup Card -->
        <div class="card">
            <h2 class="card-title">
                <svg class="title-icon" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                Two-Factor Authentication (2FA)
            </h2>
            <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 10px; border: 1px solid var(--glass-border);">
                <div>
                    <h3 style="margin: 0; font-size: 15px; color: #fff;">Authenticator App</h3>
                    <p style="margin: 5px 0 0 0; font-size: 12px; color: var(--text-muted);">Use Google Authenticator or Authy to secure your sessions.</p>
                </div>
                <label class="switch" style="position: relative; display: inline-block; width: 44px; height: 24px;">
                    <input type="checkbox" onchange="alert('2FA features are in simulation mode!')" style="opacity: 0; width: 0; height: 0;">
                    <span style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.1); transition: .4s; border-radius: 24px; border: 1px solid var(--glass-border);"></span>
                </label>
            </div>
        </div>
    </div>

    <!-- Right Column: Active Sessions -->
    <div class="card" style="display: flex; flex-direction: column;">
        <h2 class="card-title">
            <svg class="title-icon" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            Active Login Sessions
        </h2>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: -15px; margin-bottom: 25px;">
            The sessions below are currently logged in with credentials corresponding to this operator identity.
        </p>
        
        <div style="display: flex; flex-direction: column; gap: 15px;">
            <!-- Session 1 -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; background: rgba(6, 182, 212, 0.05); border: 1px solid rgba(6, 182, 212, 0.2); border-radius: 12px;">
                <div style="display: flex; gap: 12px; align-items: center;">
                    <div style="width: 10px; height: 10px; background: var(--secondary-accent); border-radius: 50%; box-shadow: 0 0 8px var(--secondary-accent);"></div>
                    <div>
                        <div style="font-weight: 600; color: #fff; font-size: 14px;">Windows 11 PC (This Browser)</div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">IP: 192.168.1.144 &bull; Active Now</div>
                    </div>
                </div>
                <span style="font-size: 12px; font-weight: 600; color: var(--secondary-accent); background: rgba(16, 185, 129, 0.1); padding: 4px 8px; border-radius: 4px;">CURRENT</span>
            </div>

            <!-- Session 2 -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--glass-border); border-radius: 12px;">
                <div style="display: flex; gap: 12px; align-items: center;">
                    <div style="width: 10px; height: 10px; background: var(--text-muted); border-radius: 50%;"></div>
                    <div>
                        <div style="font-weight: 600; color: #fff; font-size: 14px;">Apple iPhone 15 Pro</div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">IP: 172.56.21.90 &bull; 2 hours ago</div>
                    </div>
                </div>
                <button onclick="alert('Session revoked!')" class="btn" style="padding: 6px 12px; font-size: 11px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--error-color); border-radius: 6px; text-transform: none; letter-spacing: 0;">Revoke</button>
            </div>

            <!-- Session 3 -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--glass-border); border-radius: 12px;">
                <div style="display: flex; gap: 12px; align-items: center;">
                    <div style="width: 10px; height: 10px; background: var(--text-muted); border-radius: 50%;"></div>
                    <div>
                        <div style="font-weight: 600; color: #fff; font-size: 14px;">Linux Server &bull; Chrome Core</div>
                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">IP: 34.201.88.109 &bull; 3 days ago</div>
                    </div>
                </div>
                <button onclick="alert('Session revoked!')" class="btn" style="padding: 6px 12px; font-size: 11px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--error-color); border-radius: 6px; text-transform: none; letter-spacing: 0;">Revoke</button>
            </div>
        </div>
    </div>
</div>

<style>
/* Custom switch slider helper */
.switch input:checked + span {
    background-color: var(--primary-accent) !important;
}
.switch span::before {
    position: absolute;
    content: "";
    height: 16px;
    width: 16px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
}
.switch input:checked + span::before {
    transform: translateX(20px);
}
</style>
{% endblock %}

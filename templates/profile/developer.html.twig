{% extends 'base.html.twig' %}

{% block title %}API & Webhooks - OpenSquadron{% endblock %}

{% block body %}
<div class="header">
    <h1>
        <svg class="title-icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
        API & Webhooks Console
    </h1>
</div>

<div class="settings-grid uneven">
    <!-- Left Column: API Keys Manager -->
    <div style="display: flex; flex-direction: column; gap: 30px;">
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                <h2 class="card-title" style="margin: 0;">
                    <svg class="title-icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    API Credentials
                </h2>
                <button onclick="generateApiKey()" class="btn btn-primary" style="padding: 10px 18px; font-size: 13px; text-transform: none; letter-spacing: 0;">Generate New Key</button>
            </div>
            <p style="color: var(--text-muted); font-size: 14px; margin-top: -15px; margin-bottom: 25px;">
                Use these developer tokens to authorize REST API web queries connecting to your OpenSquadron resources. Keep them extremely secret.
            </p>
            
            <div style="display: flex; flex-direction: column; gap: 15px;" id="api_keys_container">
                <!-- Key 1 -->
                <div style="padding: 15px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--glass-border); border-radius: 12px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <div style="font-weight: 600; color: #fff; font-size: 14px;">Production API Token &bull; Active</div>
                        <div style="font-family: monospace; font-size: 13px; color: var(--text-muted); margin-top: 6px; display: flex; align-items: center; gap: 8px;">
                            <span id="key_val">os_live_••••••••••••••••••••••••only</span>
                            <button onclick="toggleKeyVisibility()" style="background: none; border: none; cursor: pointer; color: var(--primary-accent); padding: 0; font-size: 11px;">[Show]</button>
                        </div>
                    </div>
                    <button onclick="copyApiKey()" class="btn" style="padding: 8px 14px; font-size: 12px; background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.2); color: var(--primary-accent); border-radius: 6px; text-transform: none; letter-spacing: 0;">Copy</button>
                </div>
            </div>
        </div>

        <!-- Documentation Card -->
        <div class="card">
            <h2 class="card-title">
                <svg class="title-icon" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                Developer API Quickstart
            </h2>
            <p style="color: var(--text-muted); font-size: 14px; margin-top: -15px; margin-bottom: 20px;">
                Authorise requests by transmitting your credentials in the authorization header:
            </p>
            <pre style="background: rgba(0, 0, 0, 0.3); border: 1px solid var(--glass-border); padding: 15px; border-radius: 8px; color: var(--primary-accent); font-family: monospace; font-size: 13px; overflow-x: auto; margin: 0;">curl -X POST https://opensquadron.io/api/v1/messages \
  -H "Authorization: Bearer os_live_your_api_key" \
  -H "Content-Type: application/json" \
  -d '{"recipient": "+1234567890", "body": "Hello World"}'</pre>
        </div>
    </div>

    <!-- Right Column: Webhook Setup -->
    <div class="card">
        <h2 class="card-title">
            <svg class="title-icon" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
            Outbound Webhooks
        </h2>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: -15px; margin-bottom: 25px;">
            Set up an endpoint URL to receive real-time JSON payloads whenever new inbound WhatsApp messages are triggered.
        </p>
        
        <form onsubmit="event.preventDefault(); alert('Webhook configuration saved successfully!');">
            <div class="form-group">
                <label for="webhook_url">Payload Destination URL</label>
                <input type="url" id="webhook_url" class="form-control" placeholder="https://api.yourdomain.com/webhooks/incoming" required>
            </div>
            
            <div class="form-group">
                <label for="webhook_secret">Signing Secret Key</label>
                <input type="text" id="webhook_secret" class="form-control" value="whsec_dummy_webhook_signing_secret_for_local_testing" readonly style="font-family: monospace;">
            </div>

            <div class="form-group">
                <label>Trigger Events</label>
                <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 10px;">
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-muted); cursor: pointer;">
                        <input type="checkbox" checked style="accent-color: var(--primary-accent);">
                        <code>message.received</code> (WhatsApp Inbound)
                    </label>
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-muted); cursor: pointer;">
                        <input type="checkbox" checked style="accent-color: var(--primary-accent);">
                        <code>message.sent</code> (Outbound updates)
                    </label>
                    <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-muted); cursor: pointer;">
                        <input type="checkbox" style="accent-color: var(--primary-accent);">
                        <code>subscriber.created</code> (New contacts)
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Save Webhook Configuration</button>
        </form>
    </div>
</div>

<script>
var keyHidden = true;
var actualKey = "os_live_dummy_api_key_for_console_use_only";
var censoredKey = "os_live_••••••••••••••••••••••••only";

function toggleKeyVisibility() {
    var keyEl = document.getElementById("key_val");
    var btn = keyEl.nextElementSibling;
    if (keyHidden) {
        keyEl.textContent = actualKey;
        btn.textContent = "[Hide]";
        keyHidden = false;
    } else {
        keyEl.textContent = censoredKey;
        btn.textContent = "[Show]";
        keyHidden = true;
    }
}

function copyApiKey() {
    navigator.clipboard.writeText(actualKey).then(function() {
        alert("API Token copied to clipboard successfully!");
    });
}

function generateApiKey() {
    if (confirm("Are you sure you want to generate a new API token? This will invalidate the previous key.")) {
        actualKey = "os_live_" + Math.random().toString(16).substr(2, 8) + Math.random().toString(16).substr(2, 8) + Math.random().toString(16).substr(2, 8) + Math.random().toString(16).substr(2, 8);
        censoredKey = actualKey.substr(0, 8) + "••••••••••••••••••••••••" + actualKey.substr(actualKey.length - 4);
        keyHidden = true;
        document.getElementById("key_val").textContent = censoredKey;
        document.getElementById("key_val").nextElementSibling.textContent = "[Show]";
        alert("New API key generated successfully!");
    }
}
</script>
{% endblock %}

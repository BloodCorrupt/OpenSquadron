            Store Settings
        </button>
    </div>

    {# ═══════════════════ Products Tab ═══════════════════ #}
    <div class="ecom-tab-panel active" id="ecomPanelProducts">
        <div class="ecom-header-row">
            <div class="ecom-header-title">Product Catalog</div>
            <button class="ecom-btn-primary" onclick="openProductPanel()">

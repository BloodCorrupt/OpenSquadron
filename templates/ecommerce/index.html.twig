{% block javascripts %}
<script>
    // ═══════════════════ Data Stores ═══════════════════
    let ecomProducts = [];
    let ecomOrders = [];
    let currentProductImages = [];

    // ═══════════════════ Tab Switching ═══════════════════
    function switchEcomTab(tab) {
        document.querySelectorAll('.ecom-tab').forEach((t, i) => {
            t.classList.toggle('active', 
                (tab === 'products' && i === 0) || 
                (tab === 'orders' && i === 1) || 
                (tab === 'settings' && i === 2)
            );
        });
        document.getElementById('ecomPanelProducts').classList.toggle('active', tab === 'products');
        document.getElementById('ecomPanelOrders').classList.toggle('active', tab === 'orders');
        document.getElementById('ecomPanelSettings').classList.toggle('active', tab === 'settings');

        if (tab === 'settings') {
            loadStoreSettings();
        }
    }

    // ═══════════════════ Store Settings ═══════════════════

    async function loadStoreSettings() {
        try {
            const res = await fetch('/ecommerce/settings');
            const data = await res.json();
            if (data.settings) {
                document.getElementById('settingCheckoutEnabled').checked = data.settings.checkoutEnabled;
                document.getElementById('settingPaymentInstructions').value = data.settings.paymentInstructions || '';
                document.getElementById('settingGlobalExternalUrl').value = data.settings.globalExternalUrl || '';
            }
        } catch (e) {
            console.error('Failed to load settings', e);
        }
    }

    async function saveStoreSettings() {
        const btn = document.getElementById('settingsSaveBtn');
        const origText = btn.innerHTML;
        btn.disabled = true; 
        btn.textContent = 'Saving...';

        const payload = {
            checkoutEnabled: document.getElementById('settingCheckoutEnabled').checked,
            paymentInstructions: document.getElementById('settingPaymentInstructions').value,
            globalExternalUrl: document.getElementById('settingGlobalExternalUrl').value
        };

        try {
            const res = await fetch('/ecommerce/settings/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (data.success) {
                showToast('Settings saved successfully!', 'success');
            } else {
                showToast('Failed to save settings.', 'error');
            }
        } catch (e) {
            showToast('Error saving settings.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origText;
        }
    }

    // ═══════════════════ Products ═══════════════════

    async function loadProducts() {
        try {
            const res = await fetch('/ecommerce/products');
            const data = await res.json();
            ecomProducts = data.products || [];
            renderProducts();
            updateStats();
        } catch (e) { console.error('Failed to load products', e); }
    }

    function renderProducts() {
        const grid = document.getElementById('productGrid');
        const empty = document.getElementById('productsEmpty');
        if (ecomProducts.length === 0) {
            grid.innerHTML = '';
            grid.appendChild(empty);
            empty.style.display = 'block';
            return;
        }
        empty.style.display = 'none';
        grid.innerHTML = ecomProducts.map(p => {
            const stockClass = p.stock === 0 ? 'unlimited' : (p.stock > 0 ? 'in-stock' : 'out-of-stock');
            const stockLabel = p.stock === 0 ? 'Unlimited' : `${p.stock} in stock`;
            const statusClass = 'ecom-badge-' + p.status;
            const imgHtml = p.imageUrl
                ? `<img src="${escHtml(p.imageUrl)}" alt="${escHtml(p.name)}" loading="lazy">`
                : `<div class="no-image"><svg viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>No image</div>`;
            return `
            <div class="ecom-product-card" data-id="${p.id}">
                <div class="ecom-product-img">
                    ${imgHtml}
                    <span class="ecom-product-badge ${statusClass}">${p.status}</span>
                </div>
                <div class="ecom-product-body">
                    <div class="ecom-product-name">${escHtml(p.name)}</div>
                    <div class="ecom-product-desc">${escHtml(p.description || '')}</div>
                    <div class="ecom-product-meta">
                        <span class="ecom-product-price">${escHtml(p.currency)} ${parseFloat(p.price).toFixed(2)}</span>
                        <span class="ecom-product-stock ${stockClass}">${stockLabel}</span>
                    </div>
                    <div class="ecom-product-actions">
                        <button class="ecom-btn-publish" onclick="openPublishPanel(${p.id})">
                            <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                            Post
                        </button>
                        <button class="ecom-btn-edit" onclick="editProduct(${p.id})">
                            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            Edit
                        </button>
                        <button class="ecom-btn-delete" onclick="deleteProduct(${p.id})">
                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                        </button>
                    </div>
                </div>
            </div>`;
        }).join('');
    }

    function openProductPanel(product = null) {
        document.getElementById('productFormId').value = product ? product.id : '';
        document.getElementById('productPanelTitle').textContent = product ? 'Edit Product' : 'Add Product';
        document.getElementById('productName').value = product ? product.name : '';
        document.getElementById('productDesc').value = product ? (product.description || '') : '';
        document.getElementById('productPrice').value = product ? product.price : '';
        document.getElementById('productCurrency').value = product ? product.currency : 'USD';
        document.getElementById('productSku').value = product ? (product.sku || '') : '';
        document.getElementById('productExternalUrl').value = product ? (product.externalUrl || '') : '';
        document.getElementById('productStock').value = product ? product.stock : '0';
        document.getElementById('productCategory').value = product ? (product.category || '') : '';
        document.getElementById('productStatus').value = product ? product.status : 'active';
        
        currentProductImages = [];
        if (product && product.imageUrl) currentProductImages.push(product.imageUrl);
        if (product && product.galleryUrls) currentProductImages = currentProductImages.concat(product.galleryUrls);
        
        document.getElementById('productUploadStatus').textContent = '';
        renderProductImages();

        document.getElementById('productOverlay').classList.add('is-open');
        document.getElementById('productPanel').classList.add('is-open');
    }

    function closeProductPanel() {
        document.getElementById('productOverlay').classList.remove('is-open');
        document.getElementById('productPanel').classList.remove('is-open');
    }

    function editProduct(id) {
        const p = ecomProducts.find(x => x.id === id);
        if (p) openProductPanel(p);
    }

    async function saveProduct() {
        const btn = document.getElementById('productSaveBtn');
        btn.disabled = true; btn.textContent = 'Saving...';

        const payload = {
            id: document.getElementById('productFormId').value || null,
            name: document.getElementById('productName').value,
            description: document.getElementById('productDesc').value,
            price: document.getElementById('productPrice').value || '0',
            currency: document.getElementById('productCurrency').value || 'USD',
            sku: document.getElementById('productSku').value,
            externalUrl: document.getElementById('productExternalUrl').value,
            stock: parseInt(document.getElementById('productStock').value) || 0,
            category: document.getElementById('productCategory').value,
            status: document.getElementById('productStatus').value,
            imageUrl: currentProductImages.length > 0 ? currentProductImages[0] : null,
            galleryUrls: currentProductImages.length > 1 ? currentProductImages.slice(1) : [],
        };

        try {
            const res = await fetch('/ecommerce/products/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (data.error) { showToast(data.error, 'error'); return; }
            showToast('Product saved successfully!', 'success');
            closeProductPanel();
            loadProducts();
        } catch (e) {
            showToast('Failed to save product.', 'error');
        } finally {
            btn.disabled = false; btn.textContent = 'Save Product';
        }
    }

    async function deleteProduct(id) {
        if (!confirm('Delete this product? This cannot be undone.')) return;
        try {
            await fetch(`/ecommerce/products/${id}/delete`, { method: 'POST' });
            showToast('Product deleted.', 'success');
            loadProducts();
        } catch (e) { showToast('Failed to delete product.', 'error'); }
    }

    // ═══════════════════ Image Upload (R2 / Local) ═══════════════════

    /**
     * Fix EXIF orientation client-side using Canvas API.
     * Modern browsers auto-apply EXIF rotation when drawing to canvas,
     * so the exported blob has correct pixel orientation with no EXIF metadata.
     */
    function fixImageOrientation(file) {
        return new Promise((resolve) => {
            if (!file.type.startsWith('image/')) { resolve(file); return; }
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                canvas.width = img.naturalWidth;
                canvas.height = img.naturalHeight;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0);
                canvas.toBlob((blob) => {
                    const fixedName = file.name.replace(/\.[^.]+$/, '.jpg');
                    const fixedFile = new File([blob], fixedName, { type: 'image/jpeg' });
                    resolve(fixedFile);
                    URL.revokeObjectURL(img.src);
                }, 'image/jpeg', 0.92);
            };
            img.onerror = () => { resolve(file); };
            img.src = URL.createObjectURL(file);
        });
    }

    async function handleProductImageUpload(input) {
        const files = Array.from(input.files);
        if (files.length === 0) return;
        const status = document.getElementById('productUploadStatus');
        status.textContent = `Uploading ${files.length} image(s)...`;

        for (const rawFile of files) {
            try {
                // Fix EXIF orientation in browser before uploading
                const file = await fixImageOrientation(rawFile);

                // Try R2 presigned upload first
                const presignRes = await fetch('/settings/media/presign', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filename: file.name, contentType: file.type, prefix: 'products' })
                });
                const presignData = await presignRes.json();

                if (presignData.error === 'R2_NOT_CONFIGURED') {
                    // Fall back to local upload
                    const formData = new FormData();
                    formData.append('file', file);
                    formData.append('prefix', 'products');
                    const localRes = await fetch('/settings/media/upload-local', { method: 'POST', body: formData });
                    const localData = await localRes.json();
                    if (localData.publicUrl) {
                        currentProductImages.push(localData.publicUrl);
                        renderProductImages();
                    }
                    continue;
                }

                if (presignData.uploadUrl && presignData.publicUrl) {
                    // Upload to R2
                    await fetch(presignData.uploadUrl, { method: 'PUT', body: file, headers: { 'Content-Type': file.type } });
                    currentProductImages.push(presignData.publicUrl);
                    renderProductImages();
                }
            } catch (e) {
                console.error('Upload error for', rawFile.name, e);
            }
        }
        status.textContent = 'Upload complete.';
        input.value = ''; // reset input
    }

    function removeProductImage(index) {
        currentProductImages.splice(index, 1);
        renderProductImages();
    }

    function renderProductImages() {
        const preview = document.getElementById('productImagePreview');
        if (currentProductImages.length === 0) {
            preview.innerHTML = '';
            preview.style.display = 'none';
            return;
        }
        preview.style.display = 'flex';
        preview.innerHTML = currentProductImages.map((url, i) => `
            <div class="ecom-preview-thumb">
                <img src="${escHtml(url)}" alt="Preview">
                <button class="ecom-preview-remove" onclick="removeProductImage(${i})" type="button" title="Remove">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
        `).join('');
    }

    // ═══════════════════ Publish ═══════════════════

    function openPublishPanel(productId) {
        const p = ecomProducts.find(x => x.id === productId);
        if (!p) return;
        document.getElementById('publishProductId').value = productId;
        // Pre-fill caption
        let caption = `${p.name}\n${p.currency} ${parseFloat(p.price).toFixed(2)}`;
        if (p.description) caption += `\n\n${p.description}`;
        document.getElementById('publishMessage').value = caption;
        // Reset selections
        document.querySelectorAll('#publishConnList input[type="checkbox"]').forEach(cb => { cb.checked = false; cb.closest('.ecom-conn-item').classList.remove('selected'); });
        document.getElementById('publishNowToggle').checked = true;
        document.getElementById('publishScheduleFields').classList.remove('visible');

        document.getElementById('publishOverlay').classList.add('is-open');
        document.getElementById('publishPanel').classList.add('is-open');
    }

    function closePublishPanel() {
        document.getElementById('publishOverlay').classList.remove('is-open');
        document.getElementById('publishPanel').classList.remove('is-open');
    }

    function toggleConnSelection(el) {
        const cb = el.querySelector('input[type="checkbox"]');
        cb.checked = !cb.checked;
        el.classList.toggle('selected', cb.checked);
    }

    function togglePublishSchedule() {
        const isNow = document.getElementById('publishNowToggle').checked;
        document.getElementById('publishScheduleFields').classList.toggle('visible', !isNow);
    }

    async function generateAiCaption() {
        const productId = document.getElementById('publishProductId').value;
        const prompt = document.getElementById('publishAiPrompt').value.trim();
        if (!prompt) {
            showToast('Please enter an AI prompt.', 'error');
            return;
        }

        const btn = document.getElementById('btnGenerateCaption');
        const origText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Generating...';

        try {
            const res = await fetch('/ecommerce/api/generate-caption', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, prompt })
            });
            const data = await res.json();
            if (data.error) {
                showToast(data.error, 'error');
            } else if (data.caption) {
                document.getElementById('publishMessage').value = data.caption;
                showToast('Caption generated!', 'success');
            }
        } catch (e) {
            showToast('Failed to generate caption.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origText;
        }
    }

    async function publishProduct() {
        const btn = document.getElementById('publishBtn');
        btn.disabled = true; btn.innerHTML = 'Publishing...';

        const productId = document.getElementById('publishProductId').value;
        const message = document.getElementById('publishMessage').value;
        const publishNow = document.getElementById('publishNowToggle').checked;
        const scheduledTime = document.getElementById('publishScheduleTime').value;
        const timezone = document.getElementById('publishTimezone').value;

        // Gather selected connections grouped by channel
        const checkboxes = document.querySelectorAll('#publishConnList input[type="checkbox"]:checked');
        if (checkboxes.length === 0) {
            showToast('Please select at least one page.', 'error');
            btn.disabled = false; btn.innerHTML = 'Publish';
            return;
        }

        // Group by channel
        const byChannel = {};
        checkboxes.forEach(cb => {
            const ch = cb.dataset.channel;
            if (!byChannel[ch]) byChannel[ch] = [];
            byChannel[ch].push(parseInt(cb.dataset.id));
        });

        let allResults = [];
        for (const [channel, ids] of Object.entries(byChannel)) {
            try {
                const res = await fetch(`/ecommerce/products/${productId}/publish`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        connectionIds: ids, channel, message, publishNow, scheduledTime, timezone
                    })
                });
                const data = await res.json();
                if (data.error) { showToast(data.error, 'error'); continue; }
                allResults.push(...(data.results || []));
            } catch (e) {
                showToast(`Failed to publish to ${channel}.`, 'error');
            }
        }

        const published = allResults.filter(r => r.status === 'published').length;
        const scheduled = allResults.filter(r => r.status === 'scheduled').length;
        const errors = allResults.filter(r => r.status === 'error').length;
        let msg = '';
        if (published > 0) msg += `${published} published. `;
        if (scheduled > 0) msg += `${scheduled} scheduled. `;
        if (errors > 0) msg += `${errors} failed.`;
        showToast(msg || 'Done!', errors > 0 ? 'error' : 'success');

        closePublishPanel();
        btn.disabled = false; btn.innerHTML = `<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:#fff;fill:none;vertical-align:middle;margin-right:6px;stroke-width:2"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg> Publish`;
    }

    // ═══════════════════ Orders ═══════════════════

    async function loadOrders() {
        try {
            const res = await fetch('/ecommerce/orders');
            const data = await res.json();
            ecomOrders = data.orders || [];
            renderOrders();
            updateStats();
        } catch (e) { console.error('Failed to load orders', e); }
    }

    function renderOrders() {
        const wrap = document.getElementById('ordersTableWrap');
        const empty = document.getElementById('ordersEmpty');
        if (ecomOrders.length === 0) {
            wrap.innerHTML = '';
            wrap.appendChild(empty);
            empty.style.display = 'block';
            return;
        }
        empty.style.display = 'none';
        const statusOptions = ['pending','approved','confirmed','delivered','completed','cancelled'];
        wrap.innerHTML = `
        <table class="ecom-orders-table">
            <thead><tr>
                <th>Order #</th><th>Customer</th><th>Items</th><th>Total</th><th>Status</th><th>Channel</th><th>Date</th><th>Actions</th>
            </tr></thead>
            <tbody>
                ${ecomOrders.map(o => {
                    const itemsSummary = (o.items || []).map(i => `${i.productName || 'Item'} ×${i.qty || 1}`).join(', ');
                    const statusOpts = statusOptions.map(s => `<option value="${s}" ${s === o.status ? 'selected' : ''}>${s}</option>`).join('');
                    return `<tr>
                        <td style="font-weight:600;color:var(--primary-accent)">${escHtml(o.orderNumber)}</td>
                        <td>${escHtml(o.customerName)}</td>
                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escHtml(itemsSummary)}">${escHtml(itemsSummary) || '—'}</td>
                        <td style="font-weight:600">${escHtml(o.currency)} ${parseFloat(o.totalAmount).toFixed(2)}</td>
                        <td><span class="ecom-status-badge ecom-status-${o.status}">${o.status}</span></td>
                        <td>${o.channel ? escHtml(o.channel) : '—'}</td>
                        <td style="font-size:12px;color:var(--text-muted)">${o.createdAt ? o.createdAt.substring(0, 10) : ''}</td>
                        <td>
                            <div class="ecom-order-actions">
                                <select onchange="updateOrderStatus(${o.id}, this.value)">${statusOpts}</select>
                                <button onclick="editOrder(${o.id})" title="Edit">✎</button>
                                <button onclick="deleteOrder(${o.id})" title="Delete" style="color:#ef4444">✕</button>
                            </div>
                        </td>
                    </tr>`;
                }).join('')}
            </tbody>
        </table>`;
    }

    function openOrderPanel(order = null) {
        document.getElementById('orderFormId').value = order ? order.id : '';
        document.getElementById('orderPanelTitle').textContent = order ? 'Edit Order' : 'New Order';
        document.getElementById('orderCustomerName').value = order ? order.customerName : '';
        document.getElementById('orderCustomerContact').value = order ? (order.customerContact || '') : '';
        document.getElementById('orderChannel').value = order ? (order.channel || '') : '';
        document.getElementById('orderCurrency').value = order ? order.currency : 'USD';
        document.getElementById('orderShippingAddress').value = order ? (order.shippingAddress || '') : '';
        document.getElementById('orderNotes').value = order ? (order.notes || '') : '';

        // Populate items
        const list = document.getElementById('orderItemsList');
        list.innerHTML = '';
        if (order && order.items && order.items.length > 0) {
            order.items.forEach(item => addOrderItemRow(item));
        } else {
            addOrderItemRow();
        }
        recalcOrderTotal();

        document.getElementById('orderOverlay').classList.add('is-open');
        document.getElementById('orderPanel').classList.add('is-open');
    }

    function closeOrderPanel() {
        document.getElementById('orderOverlay').classList.remove('is-open');
        document.getElementById('orderPanel').classList.remove('is-open');
    }

    function editOrder(id) {
        const o = ecomOrders.find(x => x.id === id);
        if (o) openOrderPanel(o);
    }

    function addOrderItemRow(item = null) {
        const list = document.getElementById('orderItemsList');
        const row = document.createElement('div');
        row.className = 'ecom-order-item-row';
        const productOptions = ecomProducts.map(p =>
            `<option value="${p.id}" data-price="${p.price}" data-name="${escHtml(p.name)}" ${item && item.productId == p.id ? 'selected' : ''}>${escHtml(p.name)} (${p.currency} ${parseFloat(p.price).toFixed(2)})</option>`
        ).join('');
        row.innerHTML = `
            <select class="order-item-product" onchange="onOrderItemProductChange(this)">
                <option value="">Select product...</option>
                ${productOptions}
            </select>
            <input type="number" class="order-item-qty" min="1" value="${item ? (item.qty || 1) : 1}" placeholder="Qty" onchange="recalcOrderTotal()">
            <input type="number" class="order-item-price" step="0.01" value="${item ? (item.unitPrice || 0) : ''}" placeholder="Price" onchange="recalcOrderTotal()">
            <button class="ecom-order-item-remove" onclick="this.closest('.ecom-order-item-row').remove(); recalcOrderTotal()">
                <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        `;
        list.appendChild(row);
    }

    function onOrderItemProductChange(select) {
        const opt = select.selectedOptions[0];
        if (opt && opt.dataset.price) {
            select.closest('.ecom-order-item-row').querySelector('.order-item-price').value = parseFloat(opt.dataset.price).toFixed(2);
            recalcOrderTotal();
        }
    }

    function recalcOrderTotal() {
        let total = 0;
        document.querySelectorAll('.ecom-order-item-row').forEach(row => {
            const qty = parseFloat(row.querySelector('.order-item-qty').value) || 0;
            const price = parseFloat(row.querySelector('.order-item-price').value) || 0;
            total += qty * price;
        });
        document.getElementById('orderTotalValue').textContent = total.toFixed(2);
    }

    async function saveOrder() {
        const btn = document.getElementById('orderSaveBtn');
        btn.disabled = true; btn.textContent = 'Saving...';

        const items = [];
        document.querySelectorAll('.ecom-order-item-row').forEach(row => {
            const sel = row.querySelector('.order-item-product');
            const opt = sel.selectedOptions[0];
            const productId = sel.value;
            if (!productId) return;
            items.push({
                productId: parseInt(productId),
                productName: opt ? opt.dataset.name : '',
                qty: parseInt(row.querySelector('.order-item-qty').value) || 1,
                unitPrice: parseFloat(row.querySelector('.order-item-price').value) || 0,
                currency: document.getElementById('orderCurrency').value || 'USD'
            });
        });

        let total = 0;
        items.forEach(i => total += i.qty * i.unitPrice);

        const payload = {
            id: document.getElementById('orderFormId').value || null,
            customerName: document.getElementById('orderCustomerName').value,
            customerContact: document.getElementById('orderCustomerContact').value,
            channel: document.getElementById('orderChannel').value,
            currency: document.getElementById('orderCurrency').value || 'USD',
            items: items,
            totalAmount: total.toFixed(2),
            shippingAddress: document.getElementById('orderShippingAddress').value,
            notes: document.getElementById('orderNotes').value,
            status: 'pending',
        };

        try {
            const res = await fetch('/ecommerce/orders/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (data.error) { showToast(data.error, 'error'); return; }
            showToast('Order saved successfully!', 'success');
            closeOrderPanel();
            loadOrders();
        } catch (e) {
            showToast('Failed to save order.', 'error');
        } finally {
            btn.disabled = false; btn.textContent = 'Save Order';
        }
    }

    async function updateOrderStatus(id, status) {
        try {
            const res = await fetch(`/ecommerce/orders/${id}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            const data = await res.json();
            if (data.error) { showToast(data.error, 'error'); return; }
            showToast(`Order status updated to "${status}".`, 'success');
            loadOrders();
        } catch (e) { showToast('Failed to update status.', 'error'); }
    }

    async function deleteOrder(id) {
        if (!confirm('Delete this order?')) return;
        try {
            await fetch(`/ecommerce/orders/${id}/delete`, { method: 'POST' });
            showToast('Order deleted.', 'success');
            loadOrders();
        } catch (e) { showToast('Failed to delete order.', 'error'); }
    }

    // ═══════════════════ Stats ═══════════════════

    function updateStats() {
        document.getElementById('statTotalProducts').textContent = ecomProducts.length;
        document.getElementById('statActiveProducts').textContent = ecomProducts.filter(p => p.status === 'active').length;
        document.getElementById('statTotalOrders').textContent = ecomOrders.length;

        const delivered = ecomOrders.filter(o => o.status === 'delivered');
        let revenue = 0;
        delivered.forEach(o => revenue += parseFloat(o.totalAmount) || 0);
        document.getElementById('statRevenue').textContent = revenue.toFixed(2);
    }

    // ═══════════════════ Utilities ═══════════════════

    function escHtml(str) {
        if (!str) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    // ═══════════════════ Init ═══════════════════

    document.addEventListener('DOMContentLoaded', function() {
        loadProducts();
        loadOrders();
    });
</script>
{% endblock %}

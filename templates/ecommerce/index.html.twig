{% extends 'base.html.twig' %}

{% block title %}eCommerce Hub - OpenSquadron{% endblock %}

{% block stylesheets %}
<style>
    /* ═══════════════════════ eCommerce Hub Styles ═══════════════════════ */

    .ecom-hub { padding: 24px 32px; height: 100%; overflow-y: auto; }

    /* ── Stats Bar ── */
    .ecom-stats-bar {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;
        margin-bottom: 28px;
    }
    .ecom-stat-card {
        background: var(--glass-bg); backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border); border-radius: 16px;
        padding: 20px 24px; display: flex; align-items: center; gap: 16px;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .ecom-stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
    .ecom-stat-icon {
        width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .ecom-stat-icon svg { width: 24px; height: 24px; stroke: #fff; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .ecom-stat-icon.products { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
    .ecom-stat-icon.active-prod { background: linear-gradient(135deg, #10b981, #34d399); }
    .ecom-stat-icon.orders { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
    .ecom-stat-icon.revenue { background: linear-gradient(135deg, #06b6d4, #22d3ee); }
    .ecom-stat-value { font-size: 26px; font-weight: 700; color: var(--text-header); line-height: 1; }
    .ecom-stat-label { font-size: 12px; color: var(--text-muted); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

    /* ── Tab Navigation ── */
    .ecom-tabs {
        display: flex; gap: 4px; margin-bottom: 24px;
        background: var(--glass-bg); backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border); border-radius: 12px;
        padding: 4px; width: fit-content;
    }
    .ecom-tab {
        padding: 10px 24px; border-radius: 10px; font-size: 14px; font-weight: 500;
        color: var(--text-muted); cursor: pointer; transition: all 0.25s ease;
        border: none; background: transparent; white-space: nowrap;
    }
    .ecom-tab:hover { color: var(--text-main); background: rgba(255,255,255,0.04); }
    .ecom-tab.active {
        background: linear-gradient(135deg, rgba(6,182,212,0.15), rgba(16,185,129,0.1));
        color: var(--primary-accent); font-weight: 600;
        box-shadow: 0 2px 12px rgba(6,182,212,0.12);
    }
    .ecom-tab-panel { display: none; }
    .ecom-tab-panel.active { display: block; }

    /* ── Header Row ── */
    .ecom-header-row {
        display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 12px;
    }
    .ecom-header-title { font-size: 20px; font-weight: 700; color: var(--text-header); }
    .ecom-btn-primary {
        display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; border-radius: 12px;
        background: linear-gradient(135deg, #06b6d4, #10b981); color: #fff; font-weight: 600;
        font-size: 14px; border: none; cursor: pointer; transition: all 0.25s ease;
        box-shadow: 0 4px 16px rgba(6,182,212,0.25);
    }
    .ecom-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(6,182,212,0.35); }
    .ecom-btn-primary svg { width: 18px; height: 18px; stroke: #fff; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }

    /* ── Product Grid ── */
    .ecom-product-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;
    }
    .ecom-product-card {
        background: var(--glass-bg); backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border); border-radius: 16px;
        overflow: hidden; transition: transform 0.25s ease, box-shadow 0.25s ease;
        display: flex; flex-direction: column;
    }
    .ecom-product-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.2); }
    .ecom-product-img {
        width: 100%; height: 200px; object-fit: cover; background: rgba(0,0,0,0.2);
        display: flex; align-items: center; justify-content: center; overflow: hidden;
    }
    .ecom-product-img img { width: 100%; height: 100%; object-fit: cover; }
    .ecom-product-img .no-image {
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
        width: 100%; height: 100%; color: var(--text-muted); font-size: 13px;
        background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(139,92,246,0.04));
    }
    .ecom-product-img .no-image svg { width: 36px; height: 36px; opacity: 0.4; stroke: var(--text-muted); fill: none; }
    .ecom-product-body { padding: 18px; flex: 1; display: flex; flex-direction: column; }
    .ecom-product-name { font-size: 16px; font-weight: 600; color: var(--text-header); margin-bottom: 6px; }
    .ecom-product-desc { font-size: 12px; color: var(--text-muted); margin-bottom: 12px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .ecom-product-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .ecom-product-price { font-size: 20px; font-weight: 700; background: linear-gradient(135deg, #06b6d4, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ecom-product-stock { font-size: 11px; padding: 3px 10px; border-radius: 8px; font-weight: 600; }
    .ecom-product-stock.in-stock { background: rgba(16,185,129,0.15); color: #10b981; }
    .ecom-product-stock.unlimited { background: rgba(6,182,212,0.15); color: #06b6d4; }
    .ecom-product-stock.out-of-stock { background: rgba(239,68,68,0.15); color: #ef4444; }

    .ecom-product-actions { display: flex; gap: 8px; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--glass-border); }
    .ecom-product-actions button {
        flex: 1; padding: 8px 12px; border-radius: 8px; font-size: 12px; font-weight: 600;
        border: none; cursor: pointer; transition: all 0.2s ease; display: flex; align-items: center; justify-content: center; gap: 5px;
    }
    .ecom-product-actions button svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
    .ecom-btn-publish { background: linear-gradient(135deg, rgba(6,182,212,0.15), rgba(16,185,129,0.1)); color: var(--primary-accent); }
    .ecom-btn-publish:hover { background: linear-gradient(135deg, rgba(6,182,212,0.3), rgba(16,185,129,0.2)); }
    .ecom-btn-edit { background: rgba(255,255,255,0.06); color: var(--text-muted); }
    .ecom-btn-edit:hover { background: rgba(255,255,255,0.1); color: var(--text-main); }
    .ecom-btn-delete { background: rgba(239,68,68,0.1); color: #ef4444; }
    .ecom-btn-delete:hover { background: rgba(239,68,68,0.2); }

    .ecom-product-badge {
        position: absolute; top: 12px; right: 12px; padding: 3px 10px; border-radius: 8px;
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .ecom-badge-active { background: rgba(16,185,129,0.2); color: #10b981; }
    .ecom-badge-draft { background: rgba(245,158,11,0.2); color: #f59e0b; }
    .ecom-badge-archived { background: rgba(107,114,128,0.2); color: #6b7280; }
    .ecom-product-img { position: relative; }

    /* ── Orders Table ── */
    .ecom-orders-table {
        width: 100%; border-collapse: separate; border-spacing: 0;
        background: var(--glass-bg); backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border); border-radius: 16px; overflow: hidden;
    }
    .ecom-orders-table th {
        padding: 14px 18px; text-align: left; font-size: 11px; text-transform: uppercase;
        letter-spacing: 0.8px; color: var(--text-muted); font-weight: 600;
        border-bottom: 1px solid var(--glass-border); background: rgba(0,0,0,0.15);
    }
    .ecom-orders-table td {
        padding: 14px 18px; font-size: 13px; color: var(--text-main);
        border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle;
    }
    .ecom-orders-table tr:last-child td { border-bottom: none; }
    .ecom-orders-table tr:hover td { background: rgba(255,255,255,0.02); }

    .ecom-status-badge {
        padding: 4px 12px; border-radius: 8px; font-size: 11px; font-weight: 600;
        display: inline-block; text-transform: capitalize;
    }
    .ecom-status-pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .ecom-status-approved { background: rgba(6,182,212,0.15); color: #06b6d4; }
    .ecom-status-confirmed { background: rgba(59,130,246,0.15); color: #3b82f6; }
    .ecom-status-delivered { background: rgba(139,92,246,0.15); color: #8b5cf6; }
    .ecom-status-completed { background: rgba(16,185,129,0.15); color: #10b981; }
    .ecom-status-cancelled { background: rgba(239,68,68,0.15); color: #ef4444; }

    .ecom-order-actions { display: flex; gap: 6px; }
    .ecom-order-actions button, .ecom-order-actions select {
        padding: 5px 10px; border-radius: 6px; font-size: 11px; border: 1px solid var(--glass-border);
        background: rgba(255,255,255,0.04); color: var(--text-main); cursor: pointer; transition: all 0.2s;
    }
    .ecom-order-actions button:hover { background: rgba(255,255,255,0.08); }
    .ecom-order-actions select { appearance: none; padding-right: 20px; }

    /* ── Slide Panel (Product Form / Order Form / Publish) ── */
    .ecom-overlay {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: rgba(0,0,0,0.45); backdrop-filter: blur(4px);
        z-index: 1000; opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
    }
    .ecom-overlay.is-open { opacity: 1; pointer-events: auto; }

    .ecom-panel {
        position: fixed; top: 0; right: -560px; width: 520px; max-width: 90vw; height: 100vh;
        background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(24px);
        border-left: 1px solid var(--glass-border); box-shadow: -10px 0 50px rgba(0,0,0,0.5);
        z-index: 1001; transition: right 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex; flex-direction: column;
    }
    body[data-theme="light"] .ecom-panel { background: rgba(255, 255, 255, 0.95); }
    .ecom-panel.is-open { right: 0; }

    .ecom-panel-header {
        padding: 22px 28px; border-bottom: 1px solid var(--glass-border);
        display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;
    }
    .ecom-panel-title { font-size: 18px; font-weight: 700; color: var(--text-header); }
    .ecom-panel-close {
        background: none; border: none; color: var(--text-muted); cursor: pointer;
        transition: color 0.2s; padding: 4px; line-height: 1;
    }
    .ecom-panel-close:hover { color: #ef4444; }
    .ecom-panel-close svg { width: 22px; height: 22px; stroke: currentColor; fill: none; }
    .ecom-panel-body { padding: 24px 28px; overflow-y: auto; flex: 1; }

    .ecom-form-group { margin-bottom: 18px; }
    .ecom-form-label { display: block; font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .ecom-form-input, .ecom-form-select, .ecom-form-textarea {
        width: 100%; padding: 10px 14px; border-radius: 10px; font-size: 14px;
        background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border);
        color: var(--text-main); transition: border-color 0.2s; font-family: 'Inter', sans-serif;
        box-sizing: border-box;
    }
    .ecom-form-input:focus, .ecom-form-select:focus, .ecom-form-textarea:focus {
        outline: none; border-color: var(--primary-accent);
    }
    .ecom-form-textarea { min-height: 80px; resize: vertical; }
    .ecom-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .ecom-form-submit {
        width: 100%; padding: 12px; border-radius: 12px; font-size: 14px; font-weight: 700;
        background: linear-gradient(135deg, #06b6d4, #10b981); color: #fff;
        border: none; cursor: pointer; transition: all 0.25s; margin-top: 8px;
        box-shadow: 0 4px 20px rgba(6,182,212,0.25);
    }
    .ecom-form-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 28px rgba(6,182,212,0.35); }
    .ecom-form-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    /* ── Glass Upload Button (R2) ── */
    .ecom-upload-zone {
        border: 2px dashed rgba(6,182,212,0.3); border-radius: 12px; padding: 20px;
        text-align: center; cursor: pointer; transition: all 0.25s;
        background: linear-gradient(135deg, rgba(6,182,212,0.04), rgba(16,185,129,0.02));
    }
    .ecom-upload-zone:hover { border-color: rgba(6,182,212,0.6); background: linear-gradient(135deg, rgba(6,182,212,0.08), rgba(16,185,129,0.04)); }
    .ecom-upload-zone svg { width: 32px; height: 32px; stroke: var(--primary-accent); fill: none; margin-bottom: 8px; }
    .ecom-upload-zone .upload-text { font-size: 13px; color: var(--text-muted); }
    .ecom-upload-zone .upload-hint { font-size: 11px; color: var(--text-muted); opacity: 0.6; margin-top: 4px; }
    .ecom-upload-preview { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 8px; }
    .ecom-preview-thumb {
        position: relative; width: 80px; height: 80px; border-radius: 8px; overflow: hidden;
        border: 1px solid var(--glass-border);
    }
    .ecom-preview-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .ecom-preview-remove {
        position: absolute; top: 4px; right: 4px; width: 20px; height: 20px;
        background: rgba(239,68,68,0.9); color: white; border: none; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; cursor: pointer;
        padding: 0; line-height: 1;
    }
    .ecom-preview-remove svg { width: 12px; height: 12px; stroke: currentColor; fill: none; margin: 0; }
    .ecom-upload-status { font-size: 11px; color: var(--primary-accent); margin-top: 6px; min-height: 16px; }

    /* ── Publish Modal Extras ── */
    .ecom-conn-list { max-height: 200px; overflow-y: auto; }
    .ecom-conn-item {
        display: flex; align-items: center; gap: 10px; padding: 10px 14px;
        border-radius: 10px; margin-bottom: 6px; cursor: pointer;
        background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border);
        transition: all 0.2s;
    }
    .ecom-conn-item:hover { background: rgba(255,255,255,0.06); }
    .ecom-conn-item.selected { border-color: var(--primary-accent); background: rgba(6,182,212,0.08); }
    .ecom-conn-item input[type="checkbox"] { accent-color: var(--primary-accent); width: 16px; height: 16px; }
    .ecom-conn-name { font-size: 13px; font-weight: 500; color: var(--text-main); }
    .ecom-conn-channel { font-size: 10px; padding: 2px 8px; border-radius: 6px; font-weight: 600; text-transform: uppercase; }
    .ecom-conn-channel.fb { background: rgba(59,130,246,0.15); color: #3b82f6; }
    .ecom-conn-channel.ig { background: rgba(236,72,153,0.15); color: #ec4899; }

    .ecom-schedule-toggle {
        display: flex; align-items: center; gap: 10px; padding: 12px 0;
    }
    .ecom-schedule-toggle label { font-size: 13px; color: var(--text-main); cursor: pointer; }
    .ecom-schedule-fields { display: none; margin-top: 8px; }
    .ecom-schedule-fields.visible { display: block; }

    /* ── Toggle Switch ── */
    .ecom-toggle { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
    .ecom-toggle input { opacity: 0; width: 0; height: 0; }
    .ecom-toggle-slider {
        position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(255,255,255,0.1); border-radius: 24px; transition: 0.3s;
    }
    .ecom-toggle-slider:before {
        position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px;
        background: #fff; border-radius: 50%; transition: 0.3s;
    }
    .ecom-toggle input:checked + .ecom-toggle-slider { background: linear-gradient(135deg, #06b6d4, #10b981); }
    .ecom-toggle input:checked + .ecom-toggle-slider:before { transform: translateX(20px); }

    /* ── Empty State ── */
    .ecom-empty {
        text-align: center; padding: 60px 20px; color: var(--text-muted);
    }
    .ecom-empty svg { width: 64px; height: 64px; stroke: var(--text-muted); fill: none; opacity: 0.3; margin-bottom: 16px; }
    .ecom-empty-title { font-size: 18px; font-weight: 600; color: var(--text-header); margin-bottom: 8px; }
    .ecom-empty-desc { font-size: 13px; max-width: 400px; margin: 0 auto; line-height: 1.6; }

    /* ── Order Items Builder ── */
    .ecom-order-items-list { margin-bottom: 12px; }
    .ecom-order-item-row {
        display: grid; grid-template-columns: 1fr 80px 90px 32px; gap: 8px; align-items: center; margin-bottom: 8px;
    }
    .ecom-order-item-row select, .ecom-order-item-row input {
        padding: 8px 10px; border-radius: 8px; font-size: 13px;
        background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border);
        color: var(--text-main); box-sizing: border-box; width: 100%;
    }
    .ecom-order-item-remove {
        width: 28px; height: 28px; border-radius: 6px; border: none;
        background: rgba(239,68,68,0.1); color: #ef4444; cursor: pointer;
        display: flex; align-items: center; justify-content: center; transition: all 0.2s;
    }
    .ecom-order-item-remove:hover { background: rgba(239,68,68,0.2); }
    .ecom-order-item-remove svg { width: 14px; height: 14px; }
    .ecom-add-item-btn {
        display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px;
        border-radius: 8px; font-size: 12px; font-weight: 600; border: 1px dashed var(--glass-border);
        background: transparent; color: var(--primary-accent); cursor: pointer; transition: all 0.2s;
    }
    .ecom-add-item-btn:hover { border-color: var(--primary-accent); background: rgba(6,182,212,0.06); }

    .ecom-order-total {
        display: flex; justify-content: space-between; align-items: center;
        padding: 12px 14px; border-radius: 10px; background: rgba(6,182,212,0.06);
        font-weight: 600; color: var(--text-header); margin-top: 8px; font-size: 15px;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .ecom-hub { padding: 16px; }
        .ecom-stats-bar { grid-template-columns: 1fr 1fr; }
        .ecom-product-grid { grid-template-columns: 1fr; }
        .ecom-panel { width: 100vw; max-width: 100vw; }
        .ecom-form-row { grid-template-columns: 1fr; }
        .ecom-orders-table { display: block; overflow-x: auto; }
    }
</style>
{% endblock %}

{% block body %}
<div class="ecom-hub" id="ecomHub">

    {# ── Stats Bar ── #}
    <div class="ecom-stats-bar">
        <div class="ecom-stat-card">
            <div class="ecom-stat-icon products">
                <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            </div>
            <div>
                <div class="ecom-stat-value" id="statTotalProducts">0</div>
                <div class="ecom-stat-label">Total Products</div>
            </div>
        </div>
        <div class="ecom-stat-card">
            <div class="ecom-stat-icon active-prod">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <div>
                <div class="ecom-stat-value" id="statActiveProducts">0</div>
                <div class="ecom-stat-label">Active Products</div>
            </div>
        </div>
        <div class="ecom-stat-card">
            <div class="ecom-stat-icon orders">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
            </div>
            <div>
                <div class="ecom-stat-value" id="statTotalOrders">0</div>
                <div class="ecom-stat-label">Total Orders</div>
            </div>
        </div>
        <div class="ecom-stat-card">
            <div class="ecom-stat-icon revenue">
                <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
            <div>
                <div class="ecom-stat-value" id="statRevenue">0</div>
                <div class="ecom-stat-label">Revenue (Delivered)</div>
            </div>
        </div>
    </div>

    {# ── Tabs ── #}
    <div class="ecom-tabs">
        <button class="ecom-tab active" onclick="switchEcomTab('products')">
            <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;fill:none;vertical-align:middle;margin-right:4px;stroke-width:2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line></svg>
            Products
        </button>
        <button class="ecom-tab" onclick="switchEcomTab('orders')">
            <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;fill:none;vertical-align:middle;margin-right:4px;stroke-width:2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            Orders

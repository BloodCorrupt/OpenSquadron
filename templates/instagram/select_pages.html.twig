{% extends 'base.html.twig' %}

{% block title %}Select Facebook Page{% endblock %}

{% block stylesheets %}
<style>
    .select-pages-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .page-header h1 {
        margin: 0;
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    .page-header p {
        color: var(--text-muted);
        margin-top: 10px;
        font-size: 15px;
    }

    .pages-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .page-card {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 24px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }
    .page-card:hover {
        background: rgba(15, 23, 42, 0.6);
        border-color: var(--primary-accent);
        box-shadow: 0 10px 30px rgba(6, 182, 212, 0.15);
        transform: translateY(-4px);
    }

    .page-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-accent), var(--secondary-accent));
        opacity: 0;
        transition: opacity 0.3s;
    }
    .page-card:hover::before {
        opacity: 1;
    }

    .page-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(16, 185, 129, 0.1));
        border: 1px solid rgba(6, 182, 212, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-accent);
        font-weight: 700;
        font-size: 20px;
        margin-bottom: 16px;
    }

    .page-title {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin: 0 0 6px 0;
        line-height: 1.3;
    }

    .page-category {
        font-size: 12px;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.04);
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 16px;
    }

    .page-meta {
        font-size: 11px;
        color: var(--text-muted);
        margin-bottom: 24px;
        font-family: monospace;
    }

    .select-btn {
        width: 100%;
        padding: 12px 20px;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid var(--glass-border);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .page-card:hover .select-btn {
        background: linear-gradient(135deg, var(--primary-accent), var(--secondary-accent));
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
    }

    .no-pages-warning {
        text-align: center;
        padding: 50px 30px;
        background: rgba(15, 23, 42, 0.3);
        border: 1px dashed var(--glass-border);
        border-radius: 16px;
        margin-bottom: 40px;
    }
    .no-pages-warning h3 {
        font-size: 18px;
        color: #fff;
        margin-bottom: 10px;
    }
    .no-pages-warning p {
        color: var(--text-muted);
        max-width: 500px;
        margin: 0 auto 20px auto;
        font-size: 14px;
    }

    .actions-bar {
        display: flex;
        justify-content: center;
        gap: 16px;
    }
    .cancel-link {
        padding: 12px 24px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
    }
    .cancel-link:hover {
        background: rgba(255, 255, 255, 0.07);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.15);
    }
</style>
{% endblock %}

{% block body %}
<div class="select-pages-container">

    <div class="page-header">
        <h1>
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:28px; height:28px;"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            Select Instagram Accounts
        </h1>
        <p>Choose the Instagram Professional Account you want to connect</p>
    </div>

    {% if igAccounts is empty %}
        <div class="no-pages-warning">
            <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:48px; height:48px; display: inline-block; margin-bottom: 16px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            <h3>No Instagram Accounts Found</h3>
            <p>We couldn't find any Instagram Professional Accounts associated with this login. Please make sure you explicitly selected your Instagram Professional Account during the Meta authorization dialog, and that you have granted all permissions.</p>
            <a href="{{ path('instagram_connect_show') }}" class="cancel-link" style="display: inline-block; margin-top: 10px;">Back to Credentials</a>
        </div>
    {% else %}

        {% if igAccounts is not empty %}
            <h2 style="color: #fff; margin-bottom: 20px; font-size: 20px;">Instagram Accounts</h2>
            <div class="pages-grid">
                {% for account in igAccounts %}
                    <div class="page-card">
                        <div>
                            <div class="page-avatar" style="background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); color: #fff;">
                                {% if account.profile_picture_url %}
                                    <img src="{{ account.profile_picture_url }}" alt="{{ account.username }}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;">
                                {% else %}
                                    {{ account.username|slice(0,1)|upper }}
                                {% endif %}
                            </div>
                            <h3 class="page-title">{{ account.username }}</h3>
                            {% if account.name %}
                                <span class="page-category">{{ account.name }}</span>
                            {% endif %}
                            <div class="page-meta">ID: {{ account.id }}</div>
                        </div>
                        <form method="post" action="{{ path('instagram_connect_instagram_submit') }}">
                            <input type="hidden" name="accountId" value="{{ account.id }}">
                            <button type="submit" class="select-btn" style="background: rgba(220, 39, 67, 0.1); border-color: rgba(220, 39, 67, 0.3); color: #fff;">Connect Instagram</button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="actions-bar">
            <a href="{{ path('instagram_connect_show') }}" class="cancel-link">
                Cancel & Start Over
            </a>
        </div>
    {% endif %}

</div>
{% endblock %}

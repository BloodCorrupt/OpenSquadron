{% extends 'base.html.twig' %}

{% block title %}WhatsApp Connection Setup{% endblock %}

{% block body %}
<div style="background: white; border-radius: 8px; padding: 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); max-width: 900px; margin: 0 auto;">
    
    <div style="text-align: center; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px;">
        <h1 style="margin:0; color: #111; font-size: 26px; font-weight: 600;">Connect WhatsApp Business (Alternative)</h1>
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#ff6b6b"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg>
    </div>
    <div style="text-align: center; margin-bottom: 25px;">
        <p style="color: #888; margin-top: 0; font-size: 15px;">Connect your WhatsApp account</p>
    </div>

    <a href="#" style="display: block; background: #011e41; color: white; text-align: center; padding: 15px; border-radius: 6px; text-decoration: none; font-weight: bold; margin-bottom: 30px; font-size: 15px;">
        ▶ How to setup WhatsApp cloud API, create, and connect a Chatbot?
    </a>

    <div style="border: 1px solid #eee; border-radius: 8px; padding: 40px;">
        <div style="display: flex; gap: 50px; align-items: flex-start; flex-wrap: wrap;">
            
            <!-- Left side: Logo -->
            <div style="flex: 0 0 160px; text-align: left;">
                <h3 style="color: #25D366; margin: 0 0 5px 0; font-size: 20px;">WhatsApp</h3>
                <div style="display: flex; align-items: center; gap: 8px; color: #888; font-size: 13px; margin-bottom: 30px;">
                    <div style="width: 12px; height: 12px; background: #25D366; border-radius: 50%;"></div>
                    Alternative account connection
                </div>
                <img src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2325D366'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'/></svg>" style="width: 120px; height: 120px; opacity: 0.5; display: block; margin: 0 auto;">
            </div>

            <!-- Right side: Forms -->
            <div style="flex: 1; min-width: 300px;">
                <form method="post" action="{{ path('whatsapp_connect') }}" autocomplete="off">
                    <!-- Prevent browsers from autofilling -->
                    <input style="display:none" type="text" name="fakeusernameremembered"/>
                    <input style="display:none" type="password" name="fakepasswordremembered"/>

                    <h4 style="margin: 0 0 20px 0; font-size: 16px; color: #333;">Business Account ID + Access Token</h4>
                    
                    <div class="form-group" style="margin-bottom: 20px;">
                        <input type="text" id="businessAccountId" name="businessAccountId" class="form-control" 
                               value="{{ connection ? connection.businessAccountId : '' }}" placeholder="WhatsApp Business Account ID" required style="padding: 15px; background: #fff; border: 1px solid #ddd;" autocomplete="new-password">
                    </div>

                    <div class="form-group" style="margin-bottom: 30px;">
                        <input type="password" id="accessToken" name="accessToken" class="form-control" 
                               placeholder="{{ connection ? 'Token is securely stored (enter new to update)' : 'Access Token' }}" 
                               {{ connection ? '' : 'required' }} style="padding: 15px; background: #fff; border: 1px solid #ddd;" autocomplete="new-password">
                    </div>

                    <hr style="border: none; border-top: 1px dashed #ddd; margin: 30px 0;">

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div>
                            <label style="font-size: 11px; text-transform: uppercase; color: #888; font-weight: bold; margin-bottom: 8px; display: block;">Webhook Callback URL</label>
                            <input type="text" class="form-control" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}" readonly style="font-size: 13px; color: #0066cc; background: #f8f9fa; cursor: pointer; padding: 12px;" onclick="copyToClipboard(this.id)" id="copy-webhook">
                        </div>
                        <div>
                            <label style="font-size: 11px; text-transform: uppercase; color: #888; font-weight: bold; margin-bottom: 8px; display: block;">Verify Token</label>
                            <input type="text" class="form-control" value="{{ connection ? connection.verifyToken : fallbackVerifyToken }}" readonly style="font-size: 13px; background: #f8f9fa; cursor: pointer; padding: 12px;" onclick="copyToClipboard(this.id)" id="copy-verify">
                        </div>
                        <div>
                            <label style="font-size: 11px; text-transform: uppercase; color: #888; font-weight: bold; margin-bottom: 8px; display: block;">Privacy Policy URL</label>
                            <input type="text" class="form-control" value="{{ app.request.schemeAndHttpHost }}/policy/privacy" readonly style="font-size: 13px; color: #0066cc; background: #f8f9fa; cursor: pointer; padding: 12px;" onclick="copyToClipboard(this.id)" id="copy-privacy">
                        </div>
                        <div>
                            <label style="font-size: 11px; text-transform: uppercase; color: #888; font-weight: bold; margin-bottom: 8px; display: block;">Terms of Service URL</label>
                            <input type="text" class="form-control" value="{{ app.request.schemeAndHttpHost }}/policy/terms" readonly style="font-size: 13px; color: #0066cc; background: #f8f9fa; cursor: pointer; padding: 12px;" onclick="copyToClipboard(this.id)" id="copy-terms">
                        </div>
                    </div>

                    <div style="margin-top: 35px;">
                        <button type="submit" class="btn btn-primary" style="background: #00d289; color: white; border: none; border-radius: 4px; padding: 12px 25px; font-weight: bold; display: inline-flex; align-items: center; gap: 8px; font-size: 15px; cursor: pointer;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg> Connect
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

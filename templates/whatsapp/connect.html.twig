{% extends 'base.html.twig' %}

{% block title %}WhatsApp Gateway Configuration{% endblock %}

{% block stylesheets %}
<style>
    .config-wizard {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .page-header h1 {
        margin: 0;
        color: #fff;
        font-size: 28px;
        font-weight: 700;
    }
    .page-header p {
        color: var(--text-muted);
        margin-top: 10px;
        font-size: 15px;
    }

    /* ───── Connected Numbers List ───── */
    .connections-section {
        margin-bottom: 40px;
    }
    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .section-title .count-badge {
        background: rgba(6, 182, 212, 0.15);
        color: var(--primary-accent);
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid rgba(6, 182, 212, 0.3);
    }

    .conn-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 16px;
    }

    .conn-card {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 22px;
        transition: all 0.25s;
        position: relative;
    }
    .conn-card:hover {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
        transform: translateY(-2px);
    }

    .conn-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
    }
    .conn-label {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
    }
    .conn-label-fallback {
        color: var(--text-muted);
        font-style: italic;
    }
    .conn-status {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 20px;
        flex-shrink: 0;
    }
    .conn-status.active {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .conn-status.inactive {
        background: rgba(100, 116, 139, 0.15);
        color: #94a3b8;
        border: 1px solid rgba(100, 116, 139, 0.3);
    }

    .conn-details {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 16px;
    }
    .conn-detail {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
    }
    .conn-detail-label {
        color: var(--text-muted);
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        min-width: 110px;
    }
    .conn-detail-value {
        color: var(--primary-accent);
        font-family: monospace;
        font-size: 12px;
        word-break: break-all;
    }
    .conn-phone-display {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .conn-phone-display .phone-icon {
        font-size: 18px;
    }

    .conn-actions {
        display: flex;
        gap: 8px;
        border-top: 1px solid var(--glass-border);
        padding-top: 14px;
    }
    .conn-action-btn {
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.03);
        color: var(--text-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .conn-action-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
    }
    .conn-action-btn.edit-btn:hover {
        border-color: var(--primary-accent);
        color: var(--primary-accent);
    }
    .conn-action-btn.delete-btn:hover {
        border-color: #ef4444;
        color: #ef4444;
    }

    .empty-connections {
        text-align: center;
        padding: 40px;
        color: var(--text-muted);
        background: rgba(15, 23, 42, 0.3);
        border-radius: 12px;
        border: 1px dashed var(--glass-border);
    }
    .empty-connections h3 {
        color: #fff;
        margin: 10px 0 6px;
        font-size: 16px;
    }

    /* ───── Wizard Steps (Add / Edit form) ───── */
    .wizard-step {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        position: relative;
    }
    .step-number {
        position: absolute;
        top: -15px;
        left: 30px;
        background: linear-gradient(135deg, var(--primary-accent), #0284c7);
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 14px;
        box-shadow: 0 4px 10px rgba(6, 182, 212, 0.3);
    }
    .step-title {
        margin-top: 5px;
        margin-bottom: 20px;
        font-size: 18px;
        color: #fff;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .endpoint-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .endpoint-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: background 0.3s;
    }
    .endpoint-item:hover {
        background: rgba(255, 255, 255, 0.06);
    }
    .endpoint-info { flex: 1; }
    .endpoint-label {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: bold;
        margin-bottom: 5px;
        letter-spacing: 0.5px;
    }
    .endpoint-value {
        font-family: monospace;
        color: var(--primary-accent);
        font-size: 13px;
        word-break: break-all;
    }
    .copy-btn {
        background: rgba(6, 182, 212, 0.1);
        color: var(--primary-accent);
        border: 1px solid rgba(6, 182, 212, 0.3);
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-left: 20px;
        white-space: nowrap;
    }
    .copy-btn:hover {
        background: var(--primary-accent);
        color: white;
    }

    .form-divider {
        border: none;
        border-top: 1px solid var(--glass-border);
        margin: 30px 0;
    }

    .edit-banner {
        background: rgba(6, 182, 212, 0.08);
        border: 1px solid rgba(6, 182, 212, 0.2);
        border-radius: 10px;
        padding: 14px 20px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--primary-accent);
        font-size: 14px;
        font-weight: 600;
    }
    .edit-banner a {
        margin-left: auto;
        color: var(--text-muted);
        font-size: 13px;
        text-decoration: none;
    }
    .edit-banner a:hover {
        color: #fff;
    }

    /* ─── Light Mode Theme Style Overrides ─── */
    body[data-theme="light"] .page-header h1,
    body[data-theme="light"] .section-title,
    body[data-theme="light"] .conn-label,
    body[data-theme="light"] .conn-phone-display,
    body[data-theme="light"] .step-title {
        color: #0f172a !important;
    }
    body[data-theme="light"] .conn-card {
        background: #ffffff !important;
        border-color: #cbd5e1 !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03) !important;
    }
    body[data-theme="light"] .conn-card:hover {
        background: #f8fafc !important;
        border-color: #94a3b8 !important;
    }
    body[data-theme="light"] .conn-detail-value {
        color: var(--primary-accent) !important;
    }
    body[data-theme="light"] .conn-detail-value[style*="color: var(--text-muted)"],
    body[data-theme="light"] .conn-detail-value[style*="color:var(--text-muted)"] {
        color: #475569 !important;
    }
    body[data-theme="light"] .conn-action-btn {
        background: #ffffff !important;
        border-color: #cbd5e1 !important;
        color: #475569 !important;
    }
    body[data-theme="light"] .conn-action-btn:hover {
        background: #f1f5f9 !important;
        color: #0f172a !important;
    }
    body[data-theme="light"] .conn-action-btn.edit-btn:hover {
        border-color: var(--primary-accent) !important;
        color: var(--primary-accent) !important;
        background: rgba(6, 182, 212, 0.05) !important;
    }
    body[data-theme="light"] .conn-action-btn.delete-btn:hover {
        border-color: #ef4444 !important;
        color: #ef4444 !important;
        background: rgba(239, 68, 68, 0.05) !important;
    }
    body[data-theme="light"] .wizard-step {
        background: #f8fafc !important;
        border-color: #cbd5e1 !important;
    }
    body[data-theme="light"] .endpoint-item {
        background: #ffffff !important;
        border-color: #cbd5e1 !important;
    }
    body[data-theme="light"] .endpoint-item:hover {
        background: #f8fafc !important;
    }
    body[data-theme="light"] .empty-connections {
        background: #f8fafc !important;
        border-color: #cbd5e1 !important;
    }
    body[data-theme="light"] .empty-connections h3 {
        color: #0f172a !important;
    }
    
    /* ───── Custom Modal ───── */
    .pin-modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .pin-modal-overlay.active {
        display: flex;
    }
    .pin-modal {
        background: #1e293b;
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 30px;
        width: 100%;
        max-width: 400px;
        box-sizing: border-box;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        transform: translateY(20px);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .pin-modal-overlay.active .pin-modal {
        transform: translateY(0);
    }
    body[data-theme="light"] .pin-modal {
        background: #ffffff;
        border-color: #cbd5e1;
    }
    .pin-modal-title {
        color: #fff;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    body[data-theme="light"] .pin-modal-title {
        color: #0f172a;
    }
    .pin-modal-desc {
        color: var(--text-muted);
        font-size: 14px;
        margin-bottom: 20px;
        line-height: 1.5;
    }
    .pin-modal-input {
        width: 100%;
        box-sizing: border-box;
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 20px;
        letter-spacing: 4px;
        text-align: center;
        margin-bottom: 24px;
        font-family: monospace;
        transition: border-color 0.2s;
    }
    .pin-modal-input:focus {
        outline: none;
        border-color: var(--primary-accent);
    }
    body[data-theme="light"] .pin-modal-input {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #0f172a;
    }
    .pin-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }
    .pin-modal-btn {
        padding: 10px 18px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }
    .pin-modal-btn.cancel {
        background: transparent;
        color: var(--text-muted);
    }
    .pin-modal-btn.cancel:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
    }
    body[data-theme="light"] .pin-modal-btn.cancel:hover {
        background: rgba(0, 0, 0, 0.05);
        color: #0f172a;
    }
    .pin-modal-btn.submit {
        background: var(--primary-accent);
        color: #fff;
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
    }
    .pin-modal-btn.submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(6, 182, 212, 0.4);
    }

    /* ───── Phone Number Selection Modal ───── */
    .phone-select-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 24px;
        max-height: 300px;
        overflow-y: auto;
    }
    .phone-select-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 10px;
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid var(--glass-border);
        cursor: pointer;
        transition: all 0.2s;
    }
    .phone-select-item:hover {
        border-color: var(--primary-accent);
        background: rgba(6, 182, 212, 0.08);
    }
    .phone-select-item.selected {
        border-color: var(--primary-accent);
        background: rgba(6, 182, 212, 0.12);
        box-shadow: 0 0 0 1px var(--primary-accent);
    }
    .phone-select-radio {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 2px solid var(--glass-border);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .phone-select-item.selected .phone-select-radio {
        border-color: var(--primary-accent);
    }
    .phone-select-radio-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--primary-accent);
        transform: scale(0);
        transition: transform 0.2s;
    }
    .phone-select-item.selected .phone-select-radio-dot {
        transform: scale(1);
    }
    .phone-select-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .phone-select-name {
        color: #fff;
        font-weight: 600;
        font-size: 14px;
    }
    .phone-select-number {
        color: var(--text-muted);
        font-size: 13px;
    }
    .phone-select-badge {
        margin-left: auto;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 3px 8px;
        border-radius: 12px;
        flex-shrink: 0;
    }
    .phone-select-badge.cloud {
        background: rgba(99, 102, 241, 0.15);
        color: #818cf8;
        border: 1px solid rgba(99, 102, 241, 0.3);
    }
    .phone-select-badge.smb {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }
    body[data-theme="light"] .phone-select-item {
        background: #f8fafc;
        border-color: #e2e8f0;
    }
    body[data-theme="light"] .phone-select-name {
        color: #0f172a;
    }
</style>
{% endblock %}

{% block body %}
<div class="config-wizard">

    <div class="page-header">
        <h1>Infrastructure Gateway</h1>
        <p>Configure your connections to the Meta Cloud Infrastructure</p>
    </div>

    {# ───── Connected Numbers Grid ───── #}
    <div class="connections-section">
        <div class="section-title">
            <span style="display: flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px; height:18px; color:var(--primary-accent);"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                <span>Connected Numbers</span>
            </span>
            <span class="count-badge">{{ connections|length }}</span>
        </div>

        {% if connections is empty %}
            <div class="empty-connections">
                <span style="display: block; margin-bottom: 12px; opacity: 0.4; color: var(--text-muted); text-align: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:48px; height:48px; display: inline-block;"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><circle cx="12" cy="20" r="1"></circle></svg>
                </span>
                <h3>No Connections Yet</h3>
                <p>Add your first WhatsApp number using the form below.</p>
            </div>
        {% else %}
            <div class="conn-grid">
                {% for conn in connections %}
                    <div class="conn-card" id="conn-card-{{ conn.id }}">
                        <div class="conn-card-top">
                            <div>
                                {% if conn.label %}
                                    <div class="conn-label">{{ conn.label }}</div>
                                {% else %}
                                    <div class="conn-label conn-label-fallback">Connection #{{ conn.id }}</div>
                                {% endif %}
                                {% if conn.phoneNumber %}
                                    <div class="conn-phone-display" style="margin-top: 6px;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px; height:14px; stroke: var(--primary-accent);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                        <span>{{ conn.phoneNumber }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <span class="conn-status {{ conn.status }}">{{ conn.status|upper }}</span>
                        </div>

                        <div class="conn-details">
                            <div class="conn-detail">
                                <span class="conn-detail-label">Account ID</span>
                                <span class="conn-detail-value">{{ conn.businessAccountId }}</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">Phone ID</span>
                                <span class="conn-detail-value">{{ conn.phoneNumberId ?? '—' }}</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">Token</span>
                                <span class="conn-detail-value" style="color: var(--text-muted);">●●●●●●●● (encrypted)</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">Connected</span>
                                <span class="conn-detail-value" style="color: var(--text-muted);">{{ conn.createdAt ? conn.createdAt|date('M d, Y') : '—' }}</span>
                            </div>
                        </div>

                        <div class="conn-actions">
                            <a href="{{ path('whatsapp_connect_edit', {id: conn.id}) }}" class="conn-action-btn edit-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                <span>Edit</span>
                            </a>
                            <form method="post" action="{{ path('whatsapp_connect_toggle_status', {id: conn.id}) }}" style="display: flex; margin: 0; padding: 0;">
                                <button type="submit" class="conn-action-btn edit-btn">
                                    {% if conn.status == 'active' %}
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="15"></line><line x1="15" y1="9" x2="9" y2="15"></line></svg>
                                        <span>Disable</span>
                                    {% else %}
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        <span>Enable</span>
                                    {% endif %}
                                </button>
                            </form>
                            {% if not (conn.botSettings.is_smb ?? false) %}
                            <button onclick="registerConnection({{ conn.id }}, '{{ conn.phoneNumber|default(conn.label|default('WhatsApp Connection'))|escape('js') }}')" class="conn-action-btn edit-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                <span>Register</span>
                            </button>
                            {% endif %}
                            <button onclick="deleteConnection({{ conn.id }})" class="conn-action-btn delete-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <hr class="form-divider">

    {# ───── Connect via Embedded Signup ───── #}
    {% set waConfigId = metaSetting is defined and metaSetting ? metaSetting.whatsappConfigId : null %}
    {% set metaAppId = metaSetting is defined and metaSetting ? metaSetting.whatsappAppId : null %}

    <div style="margin-bottom: 30px;">
        <div class="section-title" style="margin-bottom: 16px;">
            <span style="display: flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px; height:18px;">
                    <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
                    <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
                </svg>
                <span>Connect via Embedded Signup</span>
            </span>
        </div>

        {% if waConfigId and metaAppId %}
            <div style="background: rgba(37,211,102,0.06); border: 1px solid rgba(37,211,102,0.2); border-radius: 14px; padding: 28px; text-align: center;">
                <p style="color: #94a3b8; font-size: 14px; margin: 0 0 20px 0; line-height: 1.6;">
                    Connect a WhatsApp Business Account instantly using Meta's Embedded Signup flow.<br>
                    <span style="color: var(--text-muted); font-size: 12px;">This will guide you through Meta's onboarding process to register a phone number.</span>
                </p>
                <button type="button" id="wa-embedded-signup-btn" onclick="launchWhatsAppSignup()"
                        style="background: linear-gradient(135deg, #25d366 0%, #128c7e 100%); color: #fff; border: none; padding: 14px 36px; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 6px 20px rgba(37,211,102,0.3); transition: all 0.25s;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:20px; height:20px;">
                        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
                        <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
                    </svg>
                    Connect WhatsApp Account
                </button>
            </div>
        {% else %}
            <div style="background: rgba(15, 23, 42, 0.3); border: 1px dashed var(--glass-border); border-radius: 14px; padding: 28px; text-align: center;">
                <p style="color: var(--text-muted); font-size: 13px; margin: 0; line-height: 1.6;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; vertical-align: middle; margin-right: 4px; opacity: 0.5;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    Embedded Signup is not configured. Go to <a href="{{ path('app_meta_settings') }}?fb_subtab=wa-api-integration" style="color: var(--primary-accent); text-decoration: underline;">Meta App Settings → WhatsApp API Integration</a> to set up your Configuration ID first.
                </p>
            </div>
        {% endif %}
    </div>

    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 30px;">
        <div style="flex: 1; height: 1px; background: var(--glass-border);"></div>
        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">or connect manually</span>
        <div style="flex: 1; height: 1px; background: var(--glass-border);"></div>
    </div>

    {# ───── Add / Edit Form ───── #}
    {% if editConnection is defined and editConnection %}
        <div class="edit-banner">
            <span style="display: inline-flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px; height:14px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                <span>Editing: {{ editConnection.label ?? ('Connection #' ~ editConnection.id) }}</span>
            </span>
            <a href="{{ path('whatsapp_connect_show') }}">✕ Cancel</a>
        </div>
        <form method="post" action="{{ path('whatsapp_connect_update', {id: editConnection.id}) }}" autocomplete="off" class="glass-panel" style="padding: 40px;">
    {% else %}
        <form method="post" action="{{ path('whatsapp_connect') }}" autocomplete="off" class="glass-panel" style="padding: 40px;">
    {% endif %}

        <!-- Prevent browsers from autofilling -->
        <input style="display:none" type="text" name="fakeusernameremembered"/>
        <input style="display:none" type="password" name="fakepasswordremembered"/>

        <!-- Step 1: Input -->
        <div class="wizard-step">
            <div class="step-number">1</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                {% if editConnection is defined and editConnection %}
                    Update Connection Credentials
                {% else %}
                    Add New WhatsApp Number
                {% endif %}
            </h3>

            <div class="form-row">
                <div class="form-group">
                    <label>Connection Label</label>
                    <input type="text" name="label" class="form-control"
                           value="{{ editConnection.label ?? '' }}" placeholder="e.g. Sales Bot, Support Line..." autocomplete="off">
                </div>
                <div class="form-group">
                    <label>Display Phone Number</label>
                    <input type="text" name="phoneNumber" class="form-control"
                           value="{{ editConnection.phoneNumber ?? '' }}" placeholder="e.g. +1 415 740 0552" autocomplete="off">
                </div>
            </div>

            <div class="form-group">
                <label>System Account ID <span style="color: var(--primary-accent);">*</span></label>
                <input type="text" name="businessAccountId" class="form-control"
                       value="{{ editConnection is defined and editConnection ? editConnection.businessAccountId : '' }}" placeholder="Enter your unique Account ID..." required autocomplete="new-password">
            </div>

            <div class="form-group">
                <label>Phone Number ID <span style="color: var(--primary-accent);">*</span></label>
                <input type="text" name="phoneNumberId" class="form-control"
                       value="{{ editConnection is defined and editConnection ? editConnection.phoneNumberId : '' }}" placeholder="Enter your WhatsApp Phone Number ID..." required autocomplete="new-password">
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label>Secure Access Token <span style="color: var(--primary-accent);">{% if editConnection is not defined or not editConnection %}*{% endif %}</span></label>
                <input type="password" name="accessToken" class="form-control"
                       placeholder="{% if editConnection is defined and editConnection %}Encrypted token stored. Enter a new one to overwrite.{% else %}Enter your persistent access token...{% endif %}"
                       {{ (editConnection is not defined or not editConnection) ? 'required' : '' }} autocomplete="new-password">
            </div>
        </div>

        {% if editConnection is not defined or not editConnection %}
        <!-- Step 2: Webhook endpoints (only for new connections) -->
        <div class="wizard-step">
            <div class="step-number">2</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--secondary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Map Webhook Endpoints
            </h3>
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">
                Copy these system endpoints into your Meta App Dashboard to establish the realtime connection bridge.
            </p>

            <div class="endpoint-list">
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Inbound Webhook Callback</div>
                        <input type="hidden" id="url-webhook" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-webhook')">Copy Webhook</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Verify Token (auto-generated after save)</div>
                        <div class="endpoint-value" style="color: var(--text-muted);">A unique verify token will be generated when you save the connection. Come back to this page to copy it.</div>
                    </div>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Privacy Policy Compliance Route</div>
                        <input type="hidden" id="url-privacy" value="{{ url('app_privacy')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_privacy')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-privacy')">Copy Policy URL</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Terms of Service Compliance Route</div>
                        <input type="hidden" id="url-terms" value="{{ url('app_terms')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_terms')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-terms')">Copy Terms URL</button>
                </div>
            </div>
        </div>
        {% else %}
        <!-- Step 2: Webhook endpoints (for existing connection in edit mode) -->
        <div class="wizard-step">
            <div class="step-number">2</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--secondary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Webhook Configuration
            </h3>
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">
                Copy these system endpoints into your Meta App Dashboard to establish the realtime connection bridge.
            </p>

            <div class="endpoint-list">
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Inbound Webhook Callback</div>
                        <input type="hidden" id="url-webhook" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-webhook')">Copy Webhook</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Cryptographic Verify Token</div>
                        <input type="hidden" id="url-verify" value="{{ editConnection.verifyToken }}">
                        <div class="endpoint-value">{{ editConnection.verifyToken }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-verify')">Copy Token</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Privacy Policy Compliance Route</div>
                        <input type="hidden" id="url-privacy" value="{{ url('app_privacy')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_privacy')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-privacy')">Copy Policy URL</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Terms of Service Compliance Route</div>
                        <input type="hidden" id="url-terms" value="{{ url('app_terms')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_terms')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-terms')">Copy Terms URL</button>
                </div>
            </div>
        </div>
        {% endif %}

        <div style="margin-top: 40px; text-align: center;">
            <button type="submit" class="btn btn-primary" style="padding: 16px 40px; font-size: 16px; border-radius: 30px;">
                {% if editConnection is defined and editConnection %}
                    UPDATE CONNECTION
                {% else %}
                    INITIATE CONNECTION HANDSHAKE
                {% endif %}
            </button>
        </div>
    </form>
</div>

<!-- Phone Number Selection Modal (when multiple numbers discovered) -->
<div class="pin-modal-overlay" id="phoneSelectOverlay">
    <div class="pin-modal" style="max-width: 460px;">
        <div class="pin-modal-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; color: var(--primary-accent);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Select Phone Number
        </div>
        <div class="pin-modal-desc">
            Multiple phone numbers were found on your Meta account. Choose the one you want to connect:
        </div>
        <div class="phone-select-list" id="phoneSelectList"></div>
        <div class="pin-modal-actions">
            <button class="pin-modal-btn cancel" onclick="closePhoneSelectModal()" type="button">Cancel</button>
            <button class="pin-modal-btn submit" id="phoneSelectConfirmBtn" type="button" disabled>Connect Selected</button>
        </div>
    </div>
</div>

<!-- Custom PIN Registration Modal -->
<div class="pin-modal-overlay" id="pinModalOverlay">
    <div class="pin-modal">
        <div class="pin-modal-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; color: var(--primary-accent);"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            Register Phone Number
        </div>
        <div class="pin-modal-desc" id="pinModalDesc">
            Enter a 6-digit PIN to register this phone number on the Meta network (or to re-register). If this is a new number, make up a secure 6-digit PIN.
        </div>
        <input type="text" id="pinModalInput" class="pin-modal-input" placeholder="••••••" maxlength="6" autocomplete="off" inputmode="numeric" pattern="[0-9]*" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        <div class="pin-modal-actions">
            <button class="pin-modal-btn cancel" onclick="closePinModal()" type="button">Cancel</button>
            <button class="pin-modal-btn submit" id="pinModalSubmitBtn" type="button">Register</button>
        </div>
    </div>
</div>

    <!-- Custom Delete Confirmation Modal -->
    <div class="pin-modal-overlay" id="deleteModalOverlay">
        <div class="pin-modal">
            <div class="pin-modal-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 24px; height: 24px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                Delete Connection?
            </div>
            <div class="pin-modal-desc">
                Are you absolutely sure you want to remove this WhatsApp connection? This action cannot be undone and will disconnect your bot.
            </div>
            <div class="pin-modal-actions" style="margin-top: 30px;">
                <button class="pin-modal-btn cancel" onclick="closeDeleteModal()" type="button">Cancel</button>
                <button class="pin-modal-btn submit" style="background: #ef4444;" onclick="confirmDeleteConnection()" type="button">Delete</button>
            </div>
        </div>
    </div>

<script>
{% if metaAppId and waConfigId %}
    // ── Load the Facebook SDK ──
    window.fbAsyncInit = function() {
        FB.init({
            appId      : '{{ metaAppId }}',
            cookie     : true,
            xfbml      : true,
            version    : 'v21.0'
        });
    };

    (function(d, s, id) {
        var js, fjs = d.getElementsByTagName(s)[0];
        if (d.getElementById(id)) return;
        js = d.createElement(s); js.id = id;
        js.src = "https://connect.facebook.net/en_US/sdk.js";
        fjs.parentNode.insertBefore(js, fjs);
    }(document, 'script', 'facebook-jssdk'));

    function launchWhatsAppSignup() {
        console.log("launchWhatsAppSignup: Starting signup flow...");
        const btn = document.getElementById('wa-embedded-signup-btn');
        const originalHtml = btn.innerHTML;
        btn.disabled = true;

        if (!document.getElementById('spin-keyframes')) {
            const style = document.createElement('style');
            style.id = 'spin-keyframes';
            style.innerHTML = '@keyframes spin { 100% { transform: rotate(360deg); } }';
            document.head.appendChild(style);
        }

        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px; height:20px; animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> <span>Waiting for Meta...</span>';

        // Collected data from both channels
        let capturedWabaId = null;
        let capturedPhoneNumberId = null;
        let capturedCode = null;
        let ajaxFlowStarted = false;

        // Helper: once we have enough data, send to backend via AJAX
        function trySendToBackend() {
            console.log("trySendToBackend: evaluating options. capturedWabaId:", capturedWabaId, "capturedPhoneNumberId:", capturedPhoneNumberId, "capturedCode:", capturedCode, "ajaxFlowStarted:", ajaxFlowStarted);
            if (ajaxFlowStarted) return;

            // For Cloud API flow: WA_EMBEDDED_SIGNUP gives waba_id + phone_number_id (no code needed)
            // For Business App flow: we need the code (waba_id/phone_number_id may come from WA_EMBEDDED_SIGNUP or /debug_token)
            // Send whatever we have — the backend handles both scenarios
            if (capturedWabaId && capturedPhoneNumberId && !capturedCode) {
                console.log("trySendToBackend: sending via Cloud API flow");
                ajaxFlowStarted = true;
                sendCloudApiCallback(capturedWabaId, capturedPhoneNumberId);
            } else if (capturedCode) {
                console.log("trySendToBackend: sending via Business App flow");
                ajaxFlowStarted = true;
                sendBusinessAppCallback(capturedCode, capturedWabaId, capturedPhoneNumberId);
            }
        }

        // Cloud API callback (existing endpoint — uses System User Token)
        function sendCloudApiCallback(wabaId, phoneNumberId) {
            console.log("sendCloudApiCallback: wabaId =", wabaId, "phoneNumberId =", phoneNumberId);
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px; height:20px; animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> <span>Saving Connection...</span>';

            const formData = new FormData();
            formData.append('wabaId', wabaId || '');
            formData.append('phoneNumberId', phoneNumberId || '');

            fetch('{{ path('whatsapp_connect_embedded_callback') }}', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(apiData => {
                console.log("sendCloudApiCallback response:", apiData);
                if (apiData.success) {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                    handleConnectionsResponse(apiData);
                } else {
                    if (typeof showToast === 'function') { showToast(apiData.error || 'Failed to save connection.', 'error'); }
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            })
            .catch(err => {
                console.error("sendCloudApiCallback error:", err);
                if (typeof showToast === 'function') { showToast('An error occurred during save.', 'error'); }
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        // Business App callback (NEW endpoint — exchanges code, uses /debug_token)
        function sendBusinessAppCallback(code, wabaId, phoneNumberId) {
            console.log("sendBusinessAppCallback: code =", code, "wabaId =", wabaId, "phoneNumberId =", phoneNumberId);
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px; height:20px; animation: spin 1s linear infinite;"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> <span>Saving Connection...</span>';

            const formData = new FormData();
            formData.append('code', code);
            if (wabaId) formData.append('wabaId', wabaId);
            if (phoneNumberId) formData.append('phoneNumberId', phoneNumberId);

            fetch('{{ path('whatsapp_connect_business_app_callback') }}', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(apiData => {
                console.log("sendBusinessAppCallback response:", apiData);
                if (apiData.success) {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                    handleConnectionsResponse(apiData);
                } else {
                    if (typeof showToast === 'function') { showToast(apiData.error || 'Failed to save connection.', 'error'); }
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            })
            .catch(err => {
                console.error("sendBusinessAppCallback error:", err);
                if (typeof showToast === 'function') { showToast('An error occurred during save.', 'error'); }
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        // ── Channel 1: Listen for WA_EMBEDDED_SIGNUP postMessage ──
        const messageListener = (event) => {
            if (!event.origin.includes("facebook.com") && !event.origin.includes("whatsapp.com")) return;

            let data;
            if (typeof event.data === 'string') {
                try { data = JSON.parse(event.data); } catch (e) { return; }
            } else {
                data = event.data;
            }

            console.log("messageListener received event:", event.origin, data);

            if (data && data.type === 'WA_EMBEDDED_SIGNUP') {
                if (data.event === 'FINISH') {
                    const payload = data.data || data;
                    console.log("WA_EMBEDDED_SIGNUP FINISH matched. Payload:", payload);
                    capturedWabaId = payload.waba_id || payload.wabaID || payload.whatsapp_business_account_id || capturedWabaId;
                    capturedPhoneNumberId = payload.phone_number_id || payload.phoneNumberID || payload.phone_id || capturedPhoneNumberId;
                    window.removeEventListener('message', messageListener);

                    // Try to send — if we already have the code too, send immediately
                    // If no code yet, wait for FB.login callback (it fires shortly after)
                    setTimeout(() => { trySendToBackend(); }, 500);
                } else if (data.event === 'CANCEL') {
                    console.log("WA_EMBEDDED_SIGNUP CANCEL matched.");
                    ajaxFlowStarted = true;
                    if (typeof showToast === 'function') { showToast('Authentication cancelled.', 'error'); }
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    window.removeEventListener('message', messageListener);
                } else if (data.event === 'ERROR') {
                    console.log("WA_EMBEDDED_SIGNUP ERROR matched.");
                    ajaxFlowStarted = true;
                    if (typeof showToast === 'function') { showToast('An error occurred during setup.', 'error'); }
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    window.removeEventListener('message', messageListener);
                }
            }
        };

        window.addEventListener('message', messageListener);

        // ── Channel 2: FB.login() — returns authorization code ──
        console.log("Calling FB.login with config_id:", '{{ waConfigId }}');
        FB.login(function(response) {
            console.log("FB.login response:", response);
            if (!response.authResponse) {
                // User cancelled or popup blocked
                if (!ajaxFlowStarted) {
                    if (typeof showToast === 'function') { showToast('Authentication cancelled or popup blocked.', 'error'); }
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    window.removeEventListener('message', messageListener);
                }
            } else if (response.authResponse.code) {
                capturedCode = response.authResponse.code;
                console.log("FB.login code captured:", capturedCode, ". Waiting for WA_EMBEDDED_SIGNUP to provide IDs (up to 3 seconds)");
                // Wait for WA_EMBEDDED_SIGNUP to provide IDs (up to 3 seconds)
                let attempts = 0;
                const checkInterval = setInterval(() => {
                    if (ajaxFlowStarted) {
                        clearInterval(checkInterval);
                        return;
                    }
                    if (capturedPhoneNumberId) {
                        console.log("capturedPhoneNumberId is set, sending to backend...");
                        clearInterval(checkInterval);
                        trySendToBackend();
                    } else if (attempts >= 6) {
                        console.log("3 seconds passed without capturing phone number ID. Sending whatever we have...");
                        clearInterval(checkInterval);
                        trySendToBackend();
                    }
                    attempts++;
                }, 500);
            }
        }, {
            config_id: '{{ waConfigId }}',
            response_type: 'code',
            override_default_response_type: true,
            extras: {
                featureType: 'whatsapp_business_app_onboarding',
                sessionInfoVersion: 3
            }
        });
    }
{% endif %}
// ── Unified handler for connection responses (both Cloud API and Business App flows) ──
function handleConnectionsResponse(apiData) {
    const conns = apiData.connections || [];
    console.log("handleConnectionsResponse: connections =", conns);

    if (conns.length === 0) {
        if (typeof showToast === 'function') { showToast(apiData.message || 'Connected!', 'success'); }
        refreshConnectionsSection();
        return;
    }

    if (conns.length === 1) {
        // Single number — proceed directly
        if (typeof showToast === 'function') { showToast(apiData.message, 'success'); }
        refreshConnectionsSection(() => {
            const conn = conns[0];
            if (conn.needsRegistration) {
                showRegistrationModal(conn);
            }
        });
        return;
    }

    // Multiple numbers — show selection modal
    showPhoneSelectModal(conns);
}

function refreshConnectionsSection(callback) {
    fetch(window.location.href)
        .then(res => res.text())
        .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newSection = doc.querySelector('.connections-section');
            const oldSection = document.querySelector('.connections-section');
            if (newSection && oldSection) { oldSection.innerHTML = newSection.innerHTML; }
            if (callback) callback();
        });
}

function showRegistrationModal(conn) {
    const desc = document.getElementById('pinModalDesc');
    if (desc) {
        desc.innerHTML = `Enter a 6-digit PIN to register <strong style="color:var(--primary-accent)">${conn.phone || conn.name}</strong> on the Meta network. If this is a new number, make up a secure 6-digit PIN.`;
    }
    isNewConnectionPendingPin = true;
    registerConnection(conn.id);
}

// ── Phone Number Selection Modal ──
let pendingConnections = [];
let selectedConnectionId = null;

function showPhoneSelectModal(connections) {
    pendingConnections = connections;
    selectedConnectionId = null;
    const list = document.getElementById('phoneSelectList');
    const confirmBtn = document.getElementById('phoneSelectConfirmBtn');
    confirmBtn.disabled = true;

    list.innerHTML = connections.map(conn => {
        const badgeClass = conn.isSmb ? 'smb' : 'cloud';
        const badgeLabel = conn.isSmb ? 'Business App' : 'Cloud API';
        return `<div class="phone-select-item" data-conn-id="${conn.id}" onclick="selectPhoneItem(this, '${conn.id}')">
            <div class="phone-select-radio"><div class="phone-select-radio-dot"></div></div>
            <div class="phone-select-info">
                <div class="phone-select-name">${conn.name || 'WhatsApp Connection'}</div>
                <div class="phone-select-number">${conn.phone || 'No number'}</div>
            </div>
            <span class="phone-select-badge ${badgeClass}">${badgeLabel}</span>
        </div>`;
    }).join('');

    document.getElementById('phoneSelectOverlay').classList.add('active');
}

function selectPhoneItem(el, connId) {
    document.querySelectorAll('.phone-select-item').forEach(item => item.classList.remove('selected'));
    el.classList.add('selected');
    selectedConnectionId = connId;
    document.getElementById('phoneSelectConfirmBtn').disabled = false;
}

function closePhoneSelectModal() {
    document.getElementById('phoneSelectOverlay').classList.remove('active');
    // Delete ALL saved connections since user cancelled
    const deletePromises = pendingConnections.map(conn => {
        const deleteUrl = "{{ path('whatsapp_connect_delete', {id: '999999999'}) }}".replace('999999999', conn.id);
        return fetch(deleteUrl, { method: 'POST' }).catch(() => {});
    });
    
    Promise.all(deletePromises).then(() => {
        refreshConnectionsSection();
    });
    
    pendingConnections = [];
    selectedConnectionId = null;
}

document.getElementById('phoneSelectConfirmBtn').addEventListener('click', function() {
    if (!selectedConnectionId) return;
    const overlay = document.getElementById('phoneSelectOverlay');
    overlay.classList.remove('active');

    // Delete unselected connections
    const toDelete = pendingConnections.filter(c => String(c.id) !== String(selectedConnectionId));
    const selected = pendingConnections.find(c => String(c.id) === String(selectedConnectionId));

    const deletePromises = toDelete.map(conn => {
        const deleteUrl = "{{ path('whatsapp_connect_delete', {id: '999999999'}) }}".replace('999999999', conn.id);
        return fetch(deleteUrl, { method: 'POST' }).catch(() => {});
    });

    Promise.all(deletePromises).then(() => {
        if (typeof showToast === 'function') { showToast(`Connected: ${selected.phone || selected.name}`, 'success'); }
        refreshConnectionsSection(() => {
            if (selected && selected.needsRegistration) {
                showRegistrationModal(selected);
            }
        });
    });

    pendingConnections = [];
    selectedConnectionId = null;
});

let connectionToDelete = null;

function deleteConnection(id) {
    connectionToDelete = id;
    document.getElementById('deleteModalOverlay').classList.add('active');
}

function closeDeleteModal() {
    document.getElementById('deleteModalOverlay').classList.remove('active');
    connectionToDelete = null;
}

function confirmDeleteConnection() {
    if (!connectionToDelete) return;
    const id = connectionToDelete;
    closeDeleteModal();

    const deleteUrl = "{{ path('whatsapp_connect_delete', {id: '999999999'}) }}".replace('999999999', id);

    fetch(deleteUrl, { method: 'POST' })
        .then(async r => {
            if (!r.ok) {
                const text = await r.text();
                throw new Error(`HTTP ${r.status}: ` + text.substring(0, 1000));
            }
            return r.json();
        })
        .then(data => {
            if (data.success) {
                const card = document.getElementById('conn-card-' + id);
                if (card) {
                    card.style.transition = 'all 0.3s';
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.95)';
                    setTimeout(() => { card.remove(); }, 300);
                }
                
                // Fetch updated DOM seamlessly to fix badges and empty states
                setTimeout(() => {
                    fetch(window.location.href)
                        .then(res => res.text())
                        .then(html => {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const newSection = doc.querySelector('.connections-section');
                            const oldSection = document.querySelector('.connections-section');
                            if (newSection && oldSection) { oldSection.innerHTML = newSection.innerHTML; }
                        });
                }, 310);
            } else {
                if (typeof showToast === 'function') { showToast(data.error || 'Failed to delete connection.', 'error'); }
            }
        })
        .catch(err => {
            if (typeof showToast === 'function') { showToast('Exception: ' + err.message, 'error'); }
        });
}

let isNewConnectionPendingPin = false;
let currentRegisterId = null;

function closePinModal() {
    document.getElementById('pinModalOverlay').classList.remove('active');
    document.getElementById('pinModalInput').value = '';
    
    if (isNewConnectionPendingPin && currentRegisterId) {
        // Delete the connection from the database because user cancelled the new connection registration
        const deleteUrl = "{{ path('whatsapp_connect_delete', {id: '999999999'}) }}".replace('999999999', currentRegisterId);
        fetch(deleteUrl, { method: 'POST' })
            .then(() => {
                refreshConnectionsSection();
            })
            .catch(() => {});
    }
    
    isNewConnectionPendingPin = false;
    currentRegisterId = null;
}

function registerConnection(id, label) {
    currentRegisterId = id;
    const overlay = document.getElementById('pinModalOverlay');
    const input = document.getElementById('pinModalInput');
    
    if (label) {
        const desc = document.getElementById('pinModalDesc');
        if (desc) {
            desc.innerHTML = `Enter a 6-digit PIN to register <strong style="color:var(--primary-accent)">${label}</strong> on the Meta network (or to re-register). If this is a new number, make up a secure 6-digit PIN.`;
        }
    }
    
    overlay.classList.add('active');
    setTimeout(() => input.focus(), 100);
}

document.getElementById('pinModalSubmitBtn').addEventListener('click', function() {
    if (!currentRegisterId) return;
    
    const pin = document.getElementById('pinModalInput').value;
    
    if (!/^\d{6}$/.test(pin)) {
        if (typeof showToast === 'function') { showToast('PIN must be exactly 6 digits.', 'error'); } else { alert('PIN must be exactly 6 digits.'); }
        return;
    }

    const idToRegister = currentRegisterId;
    isNewConnectionPendingPin = false;
    closePinModal();

    if (typeof showToast === 'function') { showToast('Registering phone number...', 'info'); }

    const formData = new FormData();
    formData.append('pin', pin);

    const registerUrl = "{{ path('whatsapp_connect_register', {id: '999999999'}) }}".replace('999999999', idToRegister);

    fetch(registerUrl, { 
        method: 'POST',
        body: formData
    })
    .then(async r => {
        if (!r.ok) {
            const text = await r.text();
            throw new Error(`HTTP ${r.status}: ` + text.substring(0, 1000));
        }
        return r.json();
    })
    .then(data => {
        if (data.success) {
            if (typeof showToast === 'function') { showToast('Phone number registered successfully!', 'success'); }
            
            // Seamlessly update the connections section without a page reload
            fetch(window.location.href)
                .then(res => res.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    const newSection = doc.querySelector('.connections-section');
                    const oldSection = document.querySelector('.connections-section');
                    if (newSection && oldSection) {
                        oldSection.innerHTML = newSection.innerHTML;
                    }
                });
                
        } else {
            if (typeof showToast === 'function') { showToast(data.error || 'Unknown error', 'error'); }
        }
    })
    .catch(err => {
        if (typeof showToast === 'function') { showToast('Exception: ' + err.message, 'error'); }
    });
});

// Handle Enter key in input
document.getElementById('pinModalInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        document.getElementById('pinModalSubmitBtn').click();
    }
});
</script>

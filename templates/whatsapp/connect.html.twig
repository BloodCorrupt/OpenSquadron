{% extends 'base.html.twig' %}

{% block title %}WhatsApp Gateway Configuration{% endblock %}

{% block stylesheets %}
<style>
    .config-wizard {
        max-width: 800px;
        margin: 0 auto;
    }
    
    .wizard-step {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        position: relative;
    }
    
    .step-number {
        position: absolute;
        top: -15px;
        left: 30px;
        background: linear-gradient(135deg, var(--primary-accent), #0284c7);
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 14px;
        box-shadow: 0 4px 10px rgba(6, 182, 212, 0.3);
    }
    
    .step-title {
        margin-top: 5px;
        margin-bottom: 20px;
        font-size: 18px;
        color: #fff;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .endpoint-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    
    .endpoint-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: background 0.3s;
    }
    
    .endpoint-item:hover {
        background: rgba(255, 255, 255, 0.06);
    }
    
    .endpoint-info {
        flex: 1;
    }
    
    .endpoint-label {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: bold;
        margin-bottom: 5px;
        letter-spacing: 0.5px;
    }
    
    .endpoint-value {
        font-family: monospace;
        color: var(--primary-accent);
        font-size: 13px;
        word-break: break-all;
    }
    
    .copy-btn {
        background: rgba(6, 182, 212, 0.1);
        color: var(--primary-accent);
        border: 1px solid rgba(6, 182, 212, 0.3);
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-left: 20px;
        white-space: nowrap;
    }
    
    .copy-btn:hover {
        background: var(--primary-accent);
        color: white;
    }
</style>
{% endblock %}

{% block body %}
<div class="config-wizard">
    
    <div style="text-align: center; margin-bottom: 40px;">
        <h1 style="margin:0; color: #fff; font-size: 28px; font-weight: 700;">Infrastructure Gateway</h1>
        <p style="color: var(--text-muted); margin-top: 10px; font-size: 15px;">Configure your connection to the Meta Cloud Infrastructure</p>
    </div>

    <form method="post" action="{{ path('whatsapp_connect') }}" autocomplete="off" class="glass-panel" style="padding: 40px;">
        <!-- Prevent browsers from autofilling -->
        <input style="display:none" type="text" name="fakeusernameremembered"/>
        <input style="display:none" type="password" name="fakepasswordremembered"/>

        <!-- Step 1: Input -->
        <div class="wizard-step">
            <div class="step-number">1</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Provide Authentication Credentials
            </h3>
            
            <div class="form-group">
                <label>System Account ID</label>
                <input type="text" id="businessAccountId" name="businessAccountId" class="form-control" 
                       value="{{ connection ? connection.businessAccountId : '' }}" placeholder="Enter your unique Account ID..." required autocomplete="new-password">
            </div>

            <div class="form-group">
                <label>Phone Number ID</label>
                <input type="text" id="phoneNumberId" name="phoneNumberId" class="form-control" 
                       value="{{ connection ? connection.phoneNumberId : '' }}" placeholder="Enter your WhatsApp Phone Number ID..." required autocomplete="new-password">
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label>Secure Access Token</label>
                <input type="password" id="accessToken" name="accessToken" class="form-control" 
                       placeholder="{{ connection ? 'Encrypted token is securely stored. Enter a new token to overwrite.' : 'Enter your persistent access token...' }}" 
                       {{ connection ? '' : 'required' }} autocomplete="new-password">
            </div>
        </div>

        <!-- Step 2: Output -->
        <div class="wizard-step">
            <div class="step-number">2</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--secondary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Map Webhook Endpoints
            </h3>
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">
                Copy these system endpoints into your Meta App Dashboard to establish the realtime connection bridge.
            </p>

            <div class="endpoint-list">
                <!-- Endpoint Item -->
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Inbound Webhook Callback</div>
                        <input type="hidden" id="url-webhook" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('whatsapp_webhook_verify') }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-webhook')">Copy Webhook</button>
                </div>

                <!-- Endpoint Item -->
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Cryptographic Verify Token</div>
                        <input type="hidden" id="url-verify" value="{{ connection ? connection.verifyToken : fallbackVerifyToken }}">
                        <div class="endpoint-value">{{ connection ? connection.verifyToken : fallbackVerifyToken }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-verify')">Copy Token</button>
                </div>

                <!-- Endpoint Item -->
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Privacy Policy Compliance Route</div>
                        <input type="hidden" id="url-privacy" value="{{ app.request.schemeAndHttpHost }}/policy/privacy">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost }}/policy/privacy</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-privacy')">Copy Policy URL</button>
                </div>

                <!-- Endpoint Item -->
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Terms of Service Compliance Route</div>
                        <input type="hidden" id="url-terms" value="{{ app.request.schemeAndHttpHost }}/policy/terms">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost }}/policy/terms</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="copyToClipboard('url-terms')">Copy Terms URL</button>
                </div>
            </div>
        </div>

        <div style="margin-top: 40px; text-align: center;">
            <button type="submit" class="btn btn-primary" style="padding: 16px 40px; font-size: 16px; border-radius: 30px;">
                INITIATE CONNECTION HANDSHAKE
            </button>
        </div>
    </form>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Dashboard - OpenSquadron{% endblock %}

{% block body %}
    <h2 style="margin-top: 0;">Dashboard</h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        <div class="card">
            <h3 class="card-title">Welcome to OpenSquadron!</h3>
            <p>You are logged in as <strong>{{ app.user.userIdentifier }}</strong>.</p>
            <p>Use the sidebar on the left to navigate through your application settings and connected accounts.</p>
        </div>

        <div class="card" style="border-left: 4px solid var(--primary-color);">
            <h3 class="card-title">WhatsApp Cloud API</h3>
            <p>Manage your WhatsApp Cloud API credentials to enable automated messaging and webhooks.</p>
            <a href="{{ path('whatsapp_connect_show') }}" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: var(--primary-color); color: white; text-decoration: none; border-radius: 4px;">Configure WhatsApp</a>
        </div>
    </div>
{% endblock %}

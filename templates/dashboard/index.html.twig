{% extends 'base.html.twig' %}

{% block title %}Dashboard - OpenSquadron{% endblock %}

{% block body %}
    <div class="header">
        <h1>Dashboard</h1>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px;">
        <div class="card glass-panel" style="background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(15, 23, 42, 0.4));">
            <h3 class="card-title">✨ Welcome to OpenSquadron</h3>
            <p style="color: var(--text-muted); font-size: 15px; line-height: 1.6;">
                You are logged in securely as <strong style="color: #fff;">{{ app.user.userIdentifier }}</strong>.
            </p>
            <p style="color: var(--text-muted); font-size: 15px; line-height: 1.6; margin-bottom: 0;">
                Navigate through the command center using the glass panel on the left to manage your infrastructure and live inbox.
            </p>
        </div>

        <div class="card glass-panel" style="border-left: 4px solid var(--secondary-accent);">
            <h3 class="card-title">💬 WhatsApp Cloud API</h3>
            <p style="color: var(--text-muted); font-size: 15px; line-height: 1.6;">
                Manage your Meta Cloud API credentials to establish encrypted channels and realtime webhooks.
            </p>
            <a href="{{ path('whatsapp_connect_show') }}" class="btn btn-primary" style="display: inline-block; margin-top: 15px; text-decoration: none;">Configure Gateway</a>
        </div>
    </div>
{% endblock %}

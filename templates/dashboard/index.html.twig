{% extends 'base.html.twig' %}

{% block title %}Operational Command Center - OpenSquadron{% endblock %}

{% block stylesheets %}
<style>
    /* Premium Futuristic Dark Glassmorphism Styling */
    .dashboard-layout {
        display: flex;
        flex-direction: column;
        gap: 30px;
        margin-top: 10px;
    }

    /* Top Grid: Welcome banner & Quick Action Stats */
    .top-overview-grid {
        display: grid;
        grid-template-columns: 1fr 2.4fr;
        gap: 24px;
    }

    @media (max-width: 1200px) {
        .top-overview-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Immersive Space-Age Welcome Banner */
    .welcome-panel {
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.12), rgba(139, 92, 246, 0.05) 50%, rgba(15, 23, 42, 0.45));
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 30px;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .welcome-panel::before {
        content: '';
        position: absolute;
        top: -40%;
        left: -20%;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, rgba(6, 182, 212, 0) 70%);
        pointer-events: none;
    }

    .welcome-content h1 {
        font-size: 28px;
        font-weight: 800;
        margin: 0 0 8px 0;
        letter-spacing: -0.5px;
        background: linear-gradient(90deg, #fff, #cbd5e1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .welcome-content p {
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.6;
        margin: 0;
    }

    .system-status-indicator {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        padding: 8px 16px;
        border-radius: 30px;
        width: fit-content;
    }

    .system-status-text {
        font-size: 12px;
        font-weight: 600;
        color: #e2e8f0;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Key Metric Widget Columns */
    .metric-columns-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    @media (max-width: 768px) {
        .metric-columns-grid {
            grid-template-columns: 1fr;
        }
    }

    .compact-metric-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 20px 18px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 14px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .compact-metric-card:hover {
        transform: translateY(-3px);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    }

    .compact-metric-card::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: transparent;
        transition: background 0.3s;
    }

    .compact-metric-card.cyan:hover::after { background: var(--primary-accent); }
    .compact-metric-card.emerald:hover::after { background: var(--secondary-accent); }
    .compact-metric-card.purple:hover::after { background: #8b5cf6; }

    .metric-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

    .metric-card-title {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .metric-card-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
    }

    .cyan .metric-card-icon { color: var(--primary-accent); background: rgba(6, 182, 212, 0.08); }
    .emerald .metric-card-icon { color: var(--secondary-accent); background: rgba(16, 185, 129, 0.08); }
    .purple .metric-card-icon { color: #8b5cf6; background: rgba(139, 92, 246, 0.08); }

    .metric-card-body {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
    }

    .metric-card-value {
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .metric-card-spark {
        width: 60px;
        height: 24px;
        opacity: 0.75;
    }

    .metric-card-footer {
        font-size: 11px;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 6px;
        border-top: 1px solid rgba(255, 255, 255, 0.03);
        padding-top: 8px;
    }

    /* Channel Setup Group Setup (Facebook Summary & WhatsApp Summary) */
    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0;
    }

    .channel-summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    @media (max-width: 768px) {
        .channel-summary-grid {
            grid-template-columns: 1fr;
        }
    }

    .channel-summary-card {
        background: rgba(15, 23, 42, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
        position: relative;
        transition: all 0.3s;
    }

    .channel-summary-card:hover {
        background: rgba(15, 23, 42, 0.4);
        border-color: rgba(255, 255, 255, 0.12);
        transform: translateY(-2px);
    }

    .channel-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .channel-logo-box {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        border: 1px solid transparent;
    }

    .whatsapp-style .channel-logo-box {
        background: rgba(16, 185, 129, 0.08);
        color: var(--secondary-accent);
        border-color: rgba(16, 185, 129, 0.15);
    }

    .facebook-style .channel-logo-box {
        background: rgba(59, 130, 246, 0.08);
        color: #3b82f6;
        border-color: rgba(59, 130, 246, 0.15);
    }

    .channel-title-meta {
        display: flex;
        flex-direction: column;
    }

    .channel-name {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
    }

    .channel-subtitle {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .channel-badge {
        margin-left: auto;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 3px 8px;
        border-radius: 6px;
        letter-spacing: 0.5px;
    }

    .channel-badge.connected {
        background: rgba(16, 185, 129, 0.1);
        color: var(--secondary-accent);
        border: 1px solid rgba(16, 185, 129, 0.15);
        box-shadow: 0 0 10px rgba(16, 185, 129, 0.05);
    }

    .channel-badge.disconnected {
        background: rgba(148, 163, 184, 0.05);
        color: var(--text-muted);
        border: 1px solid rgba(148, 163, 184, 0.1);
    }

    /* Multi-metric inner setup values */
    .channel-setup-matrix {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        background: rgba(0, 0, 0, 0.2);
        border-radius: 12px;
        padding: 14px;
        border: 1px solid rgba(255, 255, 255, 0.02);
    }

    @media (max-width: 480px) {
        .channel-setup-matrix {
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
    }

    .matrix-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        text-align: center;
    }

    .matrix-value {
        font-size: 18px;
        font-weight: 800;
        color: #fff;
    }

    .matrix-label {
        font-size: 10px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.3px;
        font-weight: 600;
    }

    .channel-action-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 4px;
    }

    .channel-system-pill {
        display: flex;
        gap: 6px;
    }

    .system-pill-item {
        font-size: 10px;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        color: #94a3b8;
        padding: 2px 6px;
        border-radius: 4px;
        text-transform: uppercase;
    }

    .whatsapp-style .system-pill-item.active {
        color: var(--wa-accent);
        background: rgba(16, 185, 129, 0.05);
        border-color: rgba(16, 185, 129, 0.15);
    }

    .facebook-style .system-pill-item.active {
        color: #60a5fa;
        background: rgba(59, 130, 246, 0.05);
        border-color: rgba(59, 130, 246, 0.15);
    }

    .channel-link-btn {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        color: var(--text-main);
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.25s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .channel-link-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.18);
        color: #fff;
    }

    /* Growth and Breakdown charts */
    .breakdown-grid {
        display: grid;
        grid-template-columns: 1.2fr 2fr;
        gap: 24px;
    }

    @media (max-width: 1024px) {
        .breakdown-grid {
            grid-template-columns: 1fr;
        }
    }

    .analytics-glass-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .card-header-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-heading {
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .card-heading-badge {
        font-size: 11px;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        padding: 4px 10px;
        border-radius: 20px;
    }

    /* Unique Donut Chart rendering */
    .donut-chart-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 10px 0;
    }

    .donut-svg-wrapper {
        position: relative;
        width: 150px;
        height: 150px;
    }

    .donut-svg-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        pointer-events: none;
    }

    .donut-center-val {
        font-size: 26px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .donut-center-lbl {
        font-size: 10px;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-top: 4px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .chart-legends {
        display: flex;
        flex-direction: column;
        gap: 10px;
        width: 100%;
        background: rgba(0, 0, 0, 0.12);
        padding: 12px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.01);
    }

    .legend-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 12px;
    }

    .legend-label-box {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .legend-bullet {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .legend-bullet.wa-bullet { background: var(--secondary-accent); box-shadow: 0 0 6px var(--secondary-accent); }
    .legend-bullet.fb-bullet { background: #3b82f6; box-shadow: 0 0 6px #3b82f6; }

    .legend-name {
        color: var(--text-muted);
        font-weight: 500;
    }

    .legend-counts {
        font-weight: 700;
        color: #fff;
    }

    /* Dynamic curved intake SVG line graph */
    .trend-svg-wrapper {
        position: relative;
        width: 100%;
        height: 190px;
        margin-top: 10px;
    }

    .trend-svg {
        width: 100%;
        height: 100%;
    }

    .trend-labels-x {
        display: flex;
        justify-content: space-between;
        padding: 0 10px;
        font-size: 11px;
        color: var(--text-muted);
        font-weight: 500;
        margin-top: 6px;
    }

    /* Bottom: Broadcast Timeline & Activity logs stream */
    .bottom-pipeline-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    @media (max-width: 768px) {
        .bottom-pipeline-grid {
            grid-template-columns: 1fr;
        }
    }

    .pipeline-section {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* Timeline queues */
    .broadcast-task-queue {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .queue-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 12px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        transition: all 0.2s;
    }

    .queue-card:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.08);
    }

    .queue-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .queue-status-circle {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        position: relative;
    }

    .queue-status-circle.draft { background: var(--text-muted); }
    .queue-status-circle.active-drip { background: var(--primary-accent); box-shadow: 0 0 8px var(--primary-accent); }
    .queue-status-circle.completed { background: var(--secondary-accent); }

    .queue-meta {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .queue-title {
        font-size: 13px;
        font-weight: 700;
        color: #fff;
    }

    .queue-schedule {
        font-size: 11px;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .queue-channel-tag {
        font-size: 9px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 4px;
        text-transform: uppercase;
    }

    .queue-channel-tag.whatsapp { background: rgba(16, 185, 129, 0.1); color: var(--secondary-accent); }
    .queue-channel-tag.facebook { background: rgba(59, 130, 246, 0.1); color: #60a5fa; }

    .queue-right-action {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--primary-accent);
        border: 1px solid rgba(6, 182, 212, 0.2);
        padding: 4px 10px;
        border-radius: 6px;
        background: rgba(6, 182, 212, 0.05);
    }

    /* Scrolling stream feed for users */
    .activity-stream-box {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .activity-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.03);
        transition: all 0.2s;
    }

    .activity-row:hover {
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.06);
    }

    .activity-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-weight: 700;
        font-size: 12px;
        color: #fff;
    }

    .activity-body {
        display: flex;
        flex-direction: column;
        gap: 2px;
        flex-grow: 1;
        min-width: 0;
    }

    .activity-name {
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .activity-meta {
        font-size: 11px;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .activity-platform-icon {
        width: 12px;
        height: 12px;
        display: flex;
        align-items: center;
    }

    .activity-platform-icon svg {
        width: 100%;
        height: 100%;
    }

    .activity-status-label {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 1px 4px;
        border-radius: 3px;
        letter-spacing: 0.2px;
    }

    .activity-status-label.active { background: rgba(16, 185, 129, 0.1); color: var(--secondary-accent); }
    .activity-status-label.unsubscribed { background: rgba(239, 68, 68, 0.1); color: var(--error-color); }

    .activity-time {
        font-size: 10px;
        color: var(--text-muted);
        text-align: right;
        flex-shrink: 0;
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard-layout">

    {# ───────── 1. Welcome & Stats Grid ───────── #}
    <div class="top-overview-grid">
        <!-- Operational Command Center Welcome Card -->
        <div class="welcome-panel">
            <div class="welcome-content">
                <h1>Command Center</h1>
                <p>Welcome back, <strong style="color:var(--primary-accent);">{{ app.user.userIdentifier }}</strong>. System integrity is stable. All automated triggers, AI grounding pipelines, and custom message gateways are online.</p>
            </div>
            <div class="system-status-indicator">
                <div class="pulse-dot"></div>
                <span class="system-status-text">Matrix Gateway: Online</span>
            </div>
        </div>

        <!-- 3 Dynamic Counters mimicking competitor fields with sparklines -->
        <div class="metric-columns-grid">
            <!-- Counter 1: New Subscribers (30 Days) -->
            <div class="compact-metric-card cyan">
                <div class="metric-card-header">
                    <span class="metric-card-title">Audience Intake</span>
                    <div class="metric-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:16px; height:16px;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                </div>
                <div class="metric-card-body">
                    <span class="metric-card-value">{{ sub_total_count }}</span>
                    <!-- Sparkline dynamic intake -->
                    <svg class="metric-card-spark" viewBox="0 0 100 30" fill="none" stroke="var(--primary-accent)" stroke-width="2.5" stroke-linecap="round">
                        <path d="M 0,25 Q 20,10 40,20 T 80,5 L 100,12" />
                    </svg>
                </div>
                <div class="metric-card-footer">
                    <span style="color:var(--secondary-accent); font-weight:700;">{{ sub_active_count }} Active</span>
                    <span>•</span>
                    <span>30 days trend</span>
                </div>
            </div>

            <!-- Counter 2: Bot Flow Dialog Engines -->
            <div class="compact-metric-card emerald">
                <div class="metric-card-header">
                    <span class="metric-card-title">Dialog Engines</span>
                    <div class="metric-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:16px; height:16px;"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line></svg>
                    </div>
                </div>
                <div class="metric-card-body">
                    <span class="metric-card-value">{{ wa_flow_count + fb_flow_count }}</span>
                    <svg class="metric-card-spark" viewBox="0 0 100 30" fill="none" stroke="var(--secondary-accent)" stroke-width="2.5" stroke-linecap="round">
                        <path d="M 0,20 Q 30,5 60,25 T 100,8" />
                    </svg>
                </div>
                <div class="metric-card-footer">
                    <span>{{ wa_flow_count }} WA</span>
                    <span>•</span>
                    <span>{{ fb_flow_count }} FB Flows</span>
                </div>
            </div>

            <!-- Counter 3: Synced Meta Gateways -->
            <div class="compact-metric-card purple">
                <div class="metric-card-header">
                    <span class="metric-card-title">Sync Channels</span>
                    <div class="metric-card-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:16px; height:16px;"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    </div>
                </div>
                <div class="metric-card-body">
                    <span class="metric-card-value">{{ wa_conn_count + fb_conn_count }}</span>

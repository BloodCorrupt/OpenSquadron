{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // High fidelity donut breakdown calculation and animation
        const totalCount = parseInt("{{ sub_total_count }}") || 0;
        const waCount = parseInt("{{ sub_whatsapp_count }}") || 0;
        const fbCount = parseInt("{{ sub_facebook_count }}") || 0;

        const waSlice = document.getElementById("wa-donut-slice");
        const fbSlice = document.getElementById("fb-donut-slice");

        if (totalCount === 0) {
            // Draw clean 50/50 default mock status when database is empty
            if (waSlice) waSlice.setAttribute("stroke-dasharray", "50 100");
            if (fbSlice) {
                fbSlice.setAttribute("stroke-dasharray", "50 100");
                fbSlice.setAttribute("stroke-dashoffset", "75");
            }
        } else {
            // Calculate dynamic percentages
            const waPercentage = Math.round((waCount / totalCount) * 100);
            const fbPercentage = 100 - waPercentage;

            if (waSlice) {
                waSlice.setAttribute("stroke-dasharray", `${waPercentage} 100`);
            }
            if (fbSlice) {
                fbSlice.setAttribute("stroke-dasharray", `${fbPercentage} 100`);
                // Offset by the WhatsApp slice percentage + standard 25 offset
                fbSlice.setAttribute("stroke-dashoffset", `${25 - waPercentage}`);
            }
        }
    });
</script>
{% endblock %}

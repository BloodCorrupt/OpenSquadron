{% extends 'base.html.twig' %}

{% block title %}Team Members - OpenSquadron{% endblock %}

{% block body %}
<div class="content-container" style="padding: 20px;">
    <div class="content-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 20px;">
        <h1 class="content-title" style="margin:0; font-size:24px; color:white;">
            Team Members
        </h1>
        <button onclick="openMemberModal()" style="border:none; padding:10px 20px; border-radius:8px; cursor:pointer; color:white; background:#10b981; font-weight:bold;">
            Add Team Member
        </button>
    </div>

    <div class="table-container" style="background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 20px;">
        <table class="custom-table" style="width: 100%; border-collapse: collapse; color: #fff;">
            <thead>
                <tr>
                    <th style="padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">Name</th>
                    <th style="padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">Email</th>
                    <th style="padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1);">Role</th>
                    <th style="padding: 12px; text-align: right; border-bottom: 1px solid rgba(255,255,255,0.1);">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for member in members %}
                <tr>
                    <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.05);">{{ member.name }}</td>
                    <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.05);">{{ member.email }}</td>
                    <td style="padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        {% if member.teamRole %}
                            <span style="background:rgba(16,185,129,0.2); padding:4px 8px; border-radius:4px; font-size:12px; color:#10b981;">{{ member.teamRole.name }}</span>
                        {% else %}
                            <span style="background:rgba(255,255,255,0.1); padding:4px 8px; border-radius:4px; font-size:12px; color:#aaa;">No Role</span>
                        {% endif %}
                    </td>
                    <td style="padding: 12px; text-align: right; border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <button onclick="editMember({{ member.id }}, '{{ member.name|escape('js') }}', '{{ member.email|escape('js') }}', '{{ member.teamRole ? member.teamRole.id : '' }}')" style="background:transparent; border:1px solid #3b82f6; color:#3b82f6; padding:4px 10px; border-radius:4px; cursor:pointer;">Edit</button>
                        <button onclick="deleteMember({{ member.id }})" style="background:transparent; border:1px solid #ef4444; color:#ef4444; padding:4px 10px; border-radius:4px; cursor:pointer; margin-left:8px;">Delete</button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" style="padding: 20px; text-align: center; color: #aaa;">No team members added yet.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div id="memberModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: #1e293b; padding: 30px; border-radius: 12px; width: 400px; max-width: 90%; color: white; border: 1px solid rgba(255,255,255,0.1);">
        <h2 style="margin-top:0; font-size: 20px;">Team Member</h2>
        
        <input type="hidden" id="memberId">
        
        <div style="margin-bottom: 15px;">
            <label style="display:block; margin-bottom:8px; font-size:14px; color:#cbd5e1;">Name</label>
            <input type="text" id="memberName" style="width:100%; padding:10px; border-radius:6px; border:1px solid rgba(255,255,255,0.2); background:rgba(0,0,0,0.2); color:white; box-sizing:border-box;">
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display:block; margin-bottom:8px; font-size:14px; color:#cbd5e1;">Email</label>
            <input type="email" id="memberEmail" style="width:100%; padding:10px; border-radius:6px; border:1px solid rgba(255,255,255,0.2); background:rgba(0,0,0,0.2); color:white; box-sizing:border-box;">
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display:block; margin-bottom:8px; font-size:14px; color:#cbd5e1;">Password <span style="font-size:12px; color:#aaa;">(Leave blank to keep existing)</span></label>
            <input type="password" id="memberPassword" style="width:100%; padding:10px; border-radius:6px; border:1px solid rgba(255,255,255,0.2); background:rgba(0,0,0,0.2); color:white; box-sizing:border-box;">
        </div>

        <div style="margin-bottom: 20px;">
            <label style="display:block; margin-bottom:8px; font-size:14px; color:#cbd5e1;">Assigned Role</label>
            <select id="memberRole" style="width:100%; padding:10px; border-radius:6px; border:1px solid rgba(255,255,255,0.2); background:rgba(0,0,0,0.2); color:white; box-sizing:border-box;">
                <option value="">-- No Role --</option>
                {% for role in roles %}
                <option value="{{ role.id }}">{{ role.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
            <button onclick="closeMemberModal()" style="padding: 8px 16px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: white; cursor: pointer;">Cancel</button>
            <button onclick="saveMember()" style="padding: 8px 16px; border-radius: 6px; border: none; background: #10b981; color: white; font-weight:bold; cursor: pointer;">Save Member</button>
        </div>
    </div>
</div>

<script>
function openMemberModal() {
    document.getElementById('memberId').value = '';
    document.getElementById('memberName').value = '';
    document.getElementById('memberEmail').value = '';
    document.getElementById('memberPassword').value = '';
    document.getElementById('memberRole').value = '';
    document.getElementById('memberEmail').disabled = false;
    document.getElementById('memberModal').style.display = 'flex';
}

function closeMemberModal() {
    document.getElementById('memberModal').style.display = 'none';
}

function editMember(id, name, email, roleId) {
    document.getElementById('memberId').value = id;
    document.getElementById('memberName').value = name;
    document.getElementById('memberEmail').value = email;
    document.getElementById('memberEmail').disabled = true; // prevent changing email
    document.getElementById('memberPassword').value = '';
    document.getElementById('memberRole').value = roleId;
    
    document.getElementById('memberModal').style.display = 'flex';
}

function saveMember() {
    const id = document.getElementById('memberId').value;
    const name = document.getElementById('memberName').value;
    const email = document.getElementById('memberEmail').value;
    const password = document.getElementById('memberPassword').value;
    const roleId = document.getElementById('memberRole').value;
    
    fetch('{{ path("app_team_members_save") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, name, email, password, roleId })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.error || 'Failed to save member');
        }
    });
}

function deleteMember(id) {
    if (!confirm('Are you sure you want to delete this team member?')) return;
    
    fetch('{{ path("app_team_members_delete") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            window.location.reload();
        } else {
            alert(data.error || 'Failed to delete member');
        }
    });
}
</script>
{% endblock %}

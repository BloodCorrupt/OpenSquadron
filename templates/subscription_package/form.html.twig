{% extends 'base.html.twig' %}

{% block title %}{{ package ? 'Edit' : 'Create New' }} Subscription Package - OpenSquadron{% endblock %}

{% block body %}
<style>
    .form-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 35px;
        max-width: 700px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }
    .form-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 15px;
    }
    .form-title svg {
        width: 24px;
        height: 24px;
        stroke: var(--primary-accent);
    }
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 35px;
        border-top: 1px solid var(--glass-border);
        padding-top: 20px;
    }
    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: var(--text-muted);
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    
    .switch-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(0, 0, 0, 0.15);
        border: 1px solid var(--glass-border);
        padding: 16px;
        border-radius: 8px;
        margin-top: 10px;
    }
    .switch-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .switch-title {
        font-weight: 600;
        color: #fff;
        font-size: 14px;
    }
    .switch-description {
        font-size: 12px;
        color: var(--text-muted);
    }
    .switch-toggle {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }
    .switch-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.1);
        transition: .3s;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
    }
    .slider-round:before {
        position: absolute;
        content: "";
        height: 16px;
        width: 16px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .3s;
        border-radius: 50%;
    }
    .switch-toggle input:checked + .slider-round {
        background-color: var(--primary-accent);
    }
    .switch-toggle input:checked + .slider-round:before {
        transform: translateX(20px);
    }

    .form-row {
        display: flex;
        gap: 20px;
    }
    .form-row .form-group {
        flex: 1;
    }
</style>

<div class="header">
    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
    <h1>{{ package ? 'Edit Package' : 'Create New Package' }}</h1>
</div>

<div class="form-card">
    <div class="form-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
        <span>Package Configuration</span>
    </div>

    <form action="{{ package ? path('app_subscription_packages_edit', {id: package.id}) : path('app_subscription_packages_new') }}" method="POST" autocomplete="off">
        
        <div class="form-group">
            <label for="name">Package Name</label>
            <input type="text" id="name" name="name" class="form-control" value="{{ package ? package.name : '' }}" placeholder="e.g., Pro Plan" required>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="price">Price ($)</label>
                <input type="number" step="0.01" id="price" name="price" class="form-control" value="{{ package ? package.price : '0.00' }}" required>
            </div>
            
            <div class="form-group" id="validity_group">
                <label for="validity_days">Validity (Days)</label>
                <input type="number" id="validity_days" name="validity_days" class="form-control" value="{{ package ? package.validityDays : '30' }}" required>
            </div>
        </div>

        <div class="switch-group" style="margin-top: 20px;">
            <div class="switch-info">
                <span class="switch-title">Lifetime Package</span>
                <span class="switch-description">If enabled, this package never expires (ignores validity days).</span>
            </div>
            <label class="switch-toggle">
                <input type="checkbox" name="is_lifetime" id="is_lifetime" value="1" {% if package and package.isLifetime %}checked{% endif %}>
                <span class="slider-round"></span>
            </label>
        </div>

        <div class="switch-group" style="margin-top: 10px;">
            <div class="switch-info">
                <span class="switch-title">Default Package</span>
                <span class="switch-description">Automatically assign this package to newly created users by default.</span>
            </div>
            <label class="switch-toggle">
                <input type="checkbox" name="is_default" id="is_default" value="1" {% if package and package.isDefault %}checked{% endif %}>
                <span class="slider-round"></span>
            </label>
        </div>

        {% if user.accountType == 'super_admin' %}
            <div class="switch-group" style="margin-top: 20px; border-color: rgba(139, 92, 246, 0.5);">
                <div class="switch-info">
                    <span class="switch-title" style="color: #8b5cf6;">Reseller Package Option</span>
                    <span class="switch-description">If enabled, users assigned this package will automatically be granted Reseller Admin privileges.</span>
                </div>
                <label class="switch-toggle">
                    <input type="checkbox" name="is_reseller_package" id="is_reseller_package" value="1" {% if package and package.isResellerPackage %}checked{% endif %}>
                    <span class="slider-round" style="background-color: {% if package and package.isResellerPackage %}#8b5cf6{% endif %};"></span>
                </label>
            </div>
        {% endif %}

        <h3 style="color: #fff; font-size: 16px; margin-top: 30px; margin-bottom: 15px; border-bottom: 1px solid var(--glass-border); padding-bottom: 8px;">Allowed Modules</h3>
        
        {% set features = package ? package.features : {} %}
        {% set modules = features['modules'] ?? [] %}

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text-main);">
                <input type="checkbox" name="modules[]" value="whatsapp" {% if 'whatsapp' in modules %}checked{% endif %}> WhatsApp Bot Manager
            </label>
            <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text-main);">
                <input type="checkbox" name="modules[]" value="facebook" {% if 'facebook' in modules %}checked{% endif %}> Facebook Bot Manager
            </label>
            <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text-main);">
                <input type="checkbox" name="modules[]" value="instagram" {% if 'instagram' in modules %}checked{% endif %}> Instagram Bot Manager
            </label>
            <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text-main);">
                <input type="checkbox" name="modules[]" value="ai_copilot" {% if 'ai_copilot' in modules %}checked{% endif %}> Intelligent AI Copilot
            </label>
            <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--text-main);">
                <input type="checkbox" name="modules[]" value="ecommerce" {% if 'ecommerce' in modules %}checked{% endif %}> eCommerce Automations
            </label>
        </div>

        <h3 style="color: #fff; font-size: 16px; margin-top: 30px; margin-bottom: 15px; border-bottom: 1px solid var(--glass-border); padding-bottom: 8px;">Storage Policy</h3>
        {% set storage_mode = features['media_storage_mode'] ?? 'parent' %}
        <div class="form-group">
            <label for="media_storage_mode">Media Storage Mode</label>
            <select id="media_storage_mode" name="media_storage_mode" class="form-control" style="background: rgba(0, 0, 0, 0.2); border: 1px solid var(--glass-border); color: #fff; border-radius: 8px; padding: 10px;">
                <option value="parent" {% if storage_mode == 'parent' %}selected{% endif %}>Use Shared Storage (Inherit from Reseller/Super Admin)</option>
                <option value="user" {% if storage_mode == 'user' %}selected{% endif %}>Enforce Custom R2 Storage (User must supply their own credentials)</option>
                <option value="choice" {% if storage_mode == 'choice' %}selected{% endif %}>Allow Choice (User chooses between Shared and Custom R2)</option>
            </select>
            <small style="color: var(--text-muted); display: block; margin-top: 6px;">
                Define how media and attachments are stored for subscribers of this package.
            </small>
        </div>

        <h3 style="color: #fff; font-size: 16px; margin-top: 30px; margin-bottom: 15px; border-bottom: 1px solid var(--glass-border); padding-bottom: 8px;">Usage Limits</h3>
        
        {% set limits = features['limits'] ?? {} %}

        <div class="form-row">
            <div class="form-group">
                <label for="limit_bots">Bot Connections (0 = unlimited)</label>
                <input type="number" id="limit_bots" name="limit_bots" class="form-control" value="{{ limits['bots'] ?? 0 }}">
            </div>
            
            <div class="form-group">
                <label for="limit_team">Team Members (0 = unlimited)</label>
                <input type="number" id="limit_team" name="limit_team" class="form-control" value="{{ limits['team'] ?? 0 }}">
            </div>
            
            <div class="form-group">
                <label for="limit_messages">Monthly Messages (0 = unlimited)</label>
                <input type="number" id="limit_messages" name="limit_messages" class="form-control" value="{{ limits['messages'] ?? 0 }}">
            </div>
        </div>

        <div class="form-actions">
            <a href="{{ path('app_subscription_packages_index') }}" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">{{ package ? 'Save Changes' : 'Create Package' }}</button>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const lifetimeToggle = document.getElementById('is_lifetime');
        const validityGroup = document.getElementById('validity_group');
        const validityInput = document.getElementById('validity_days');
        
        function updateValidityVisibility() {
            if (lifetimeToggle.checked) {
                validityGroup.style.display = 'none';
                validityInput.removeAttribute('required');
            } else {
                validityGroup.style.display = 'block';
                validityInput.setAttribute('required', 'required');
            }
        }
        
        lifetimeToggle.addEventListener('change', updateValidityVisibility);
        updateValidityVisibility();
    });
</script>
{% endblock %}

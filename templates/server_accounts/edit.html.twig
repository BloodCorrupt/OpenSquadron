{% extends 'base.html.twig' %}

{% block title %}Edit Account - OpenSquadron{% endblock %}

{% block body %}
<style>
    .form-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 35px;
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }
    .form-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 15px;
    }
    .form-title svg {
        width: 24px;
        height: 24px;
        stroke: var(--primary-accent);
    }
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 35px;
        border-top: 1px solid var(--glass-border);
        padding-top: 20px;
    }
    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: var(--text-muted);
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    
    /* Toggle switch component styling */
    .switch-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(0, 0, 0, 0.15);
        border: 1px solid var(--glass-border);
        padding: 16px;
        border-radius: 8px;
        margin-top: 10px;
    }
    .switch-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .switch-title {
        font-weight: 600;
        color: #fff;
        font-size: 14px;
    }
    .switch-description {
        font-size: 12px;
        color: var(--text-muted);
    }
    .switch-toggle {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }
    .switch-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.1);
        transition: .3s;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
    }
    .slider-round:before {
        position: absolute;
        content: "";
        height: 16px;
        width: 16px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .3s;
        border-radius: 50%;
    }
    .switch-toggle input:checked + .slider-round {
        background-color: var(--primary-accent);
    }
    .switch-toggle input:checked + .slider-round:before {
        transform: translateX(20px);
    }
    
    /* Field animation helper */
    .conditional-field {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        margin-bottom: 0;
    }
    .conditional-field.visible {
        max-height: 200px;
        opacity: 1;
        margin-bottom: 24px;
    }
    
    .role-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .role-badge.admin {
        background: rgba(6, 182, 212, 0.1);
        color: var(--primary-accent);
        border-color: rgba(6, 182, 212, 0.2);
    }
    .role-badge.user {
        background: rgba(16, 185, 129, 0.1);
        color: var(--secondary-accent);
        border-color: rgba(16, 185, 129, 0.2);
    }
    .role-badge.team {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
        border-color: rgba(245, 158, 11, 0.2);
    }
    .role-badge.super-admin {
        background: rgba(139, 92, 246, 0.1);
        color: #8b5cf6;
        border-color: rgba(139, 92, 246, 0.2);
    }
</style>

<div class="header">
    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
    <h1>Edit Account Settings</h1>
</div>

<div class="form-card">
    <div class="form-title">
        <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                <span>Edit Profile</span>
            </div>
            <div>
                {% if account.accountType == 'super_admin' %}
                    <span class="role-badge super-admin">Super Admin</span>
                {% elseif account.accountType == 'admin' %}
                    <span class="role-badge admin">Reseller Admin</span>
                {% elseif account.accountType == 'user' %}
                    <span class="role-badge user">User</span>
                {% else %}
                    <span class="role-badge team">Team</span>
                {% endif %}
            </div>
        </div>
    </div>

    <form action="{% if account.id == currentUser.id %}{{ path('app_accounts_edit_self') }}{% else %}{{ path('app_server_accounts_edit', {id: account.id}) }}{% endif %}" method="POST" autocomplete="off" enctype="multipart/form-data">
        {# Full Name Field #}
        <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" class="form-control" value="{{ account.name }}" placeholder="e.g. John Doe" autocomplete="off">
        </div>

        {# Email Field #}
        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" class="form-control" value="{{ account.email }}" required autocomplete="off">
        </div>

        {# Profile Avatar Field #}
        <div class="form-group" style="margin-bottom: 24px;">
            <label>Profile Avatar</label>
            <div style="display: flex; align-items: center; gap: 20px; margin-top: 10px; margin-bottom: 20px; background: rgba(0,0,0,0.15); border: 1px solid var(--glass-border); padding: 15px; border-radius: 12px;">
                <div style="flex-shrink: 0; width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); overflow: hidden;" id="avatar_preview_container">
                    {% if account.avatar %}
                        {% if 'preset:' in account.avatar %}
                            {% set presetName = account.avatar|replace({'preset:': ''}) %}
                            <div class="avatar-inner avatar-preset-{{ presetName }}" style="width: 100%; height: 100%; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px;">
                                {{ (account.name ?: account.email)|slice(0, 1)|upper }}
                            </div>
                        {% else %}
                            <img src="{{ '/' ~ account.avatar }}" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">
                        {% endif %}
                    {% else %}
                        <div class="avatar-inner" style="width: 100%; height: 100%; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px;">
                            {{ (account.name ?: account.email)|slice(0, 1)|upper }}
                        </div>
                    {% endif %}
                </div>
                <div>
                    <h4 style="margin: 0 0 5px 0; color: #fff; font-size: 14px;">Avatar Preview</h4>
                    <p style="margin: 0; color: var(--text-muted); font-size: 12px;">Choose a beautiful gradient preset or upload a custom image below.</p>
                </div>
            </div>

            <!-- Upload Custom File -->
            <div style="margin-bottom: 20px;">
                <label for="avatar_file" style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px; display: block;">Upload Image File (.png, .jpg, .jpeg)</label>
                <input type="file" id="avatar_file" name="avatar_file" class="form-control" accept="image/*" style="padding: 10px;">
            </div>

            <!-- Preset Colors -->
            <div>
                <label style="font-size: 13px; color: var(--text-muted); margin-bottom: 8px; display: block;">Or Select Gradient Preset</label>
                <input type="hidden" name="avatar_preset" id="avatar_preset" value="">
                <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;" id="preset_selector_group">
                    <button type="button" class="preset-btn {% if account.avatar == 'preset:purple' %}active{% endif %}" data-preset="purple" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all 0.2s; padding: 0; background: none;" onclick="selectPreset('purple')">
                        <div class="avatar-preset-purple" style="width: 100%; height: 100%; border-radius: 50%;"></div>
                    </button>
                    <button type="button" class="preset-btn {% if account.avatar == 'preset:emerald' %}active{% endif %}" data-preset="emerald" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all 0.2s; padding: 0; background: none;" onclick="selectPreset('emerald')">
                        <div class="avatar-preset-emerald" style="width: 100%; height: 100%; border-radius: 50%;"></div>
                    </button>
                    <button type="button" class="preset-btn {% if account.avatar == 'preset:cyan' %}active{% endif %}" data-preset="cyan" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all 0.2s; padding: 0; background: none;" onclick="selectPreset('cyan')">
                        <div class="avatar-preset-cyan" style="width: 100%; height: 100%; border-radius: 50%;"></div>
                    </button>
                    <button type="button" class="preset-btn {% if account.avatar == 'preset:gold' %}active{% endif %}" data-preset="gold" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all 0.2s; padding: 0; background: none;" onclick="selectPreset('gold')">
                        <div class="avatar-preset-gold" style="width: 100%; height: 100%; border-radius: 50%;"></div>
                    </button>
                    <button type="button" class="preset-btn {% if account.avatar == 'preset:rose' %}active{% endif %}" data-preset="rose" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all 0.2s; padding: 0; background: none;" onclick="selectPreset('rose')">
                        <div class="avatar-preset-rose" style="width: 100%; height: 100%; border-radius: 50%;"></div>
                    </button>
                    <button type="button" class="btn" style="padding: 6px 12px; font-size: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--error-color); border-radius: 6px; cursor: pointer; font-weight: 600;" onclick="selectPreset('clear')">Clear Avatar</button>
                </div>
            </div>
        </div>

        {# Password Field #}
        <div class="form-group">
            <label for="password">Security Password <span style="font-size: 12px; color: var(--text-muted); font-weight: normal;">(leave blank to keep current)</span></label>
            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" autocomplete="new-password">
        </div>

        {# Only Admins editing other accounts can modify roles/types #}
        {% if currentUser.accountType in ['super_admin', 'admin'] and account.id != currentUser.id %}
            <div class="form-group">
                <label for="account_type">Account Type</label>
                <select id="account_type" name="account_type" class="form-control" style="background-color: #0c111d; color: #fff; cursor: pointer;">
                    {% if currentUser.accountType == 'super_admin' %}
                        <option value="super_admin" {% if account.accountType == 'super_admin' %}selected{% endif %}>Super Admin (Server Root)</option>
                        <option value="admin" {% if account.accountType == 'admin' %}selected{% endif %}>Reseller Admin (Standalone Workspace)</option>
                    {% endif %}
                    <option value="user" {% if account.accountType == 'user' %}selected{% endif %}>User Account (Standalone Workspace)</option>
                    <option value="team" {% if account.accountType == 'team' %}selected{% endif %}>Team Account (Sub-account of Owner)</option>
                </select>
            </div>

            {# Team Enabled Switch (Only applicable if 'User' is selected) #}
            <div id="team_support_field" class="conditional-field">
                <div class="switch-group">
                    <div class="switch-info">
                        <span class="switch-title">Team Support Features</span>
                        <span class="switch-description">Allows this user to create and delegate access to sub-accounts.</span>
                    </div>
                    <label class="switch-toggle">
                        <input type="checkbox" name="team_enabled" id="team_enabled" value="1" {% if account.teamEnabled %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
            </div>

            {# Parent Selection Field (Only applicable if 'Team' is selected) #}
            <div id="parent_owner_field" class="form-group conditional-field">
                <label for="parent_id">Assign to Workspace</label>
                <select id="parent_id" name="parent_id" class="form-control" style="background-color: #0c111d; color: #fff; cursor: pointer;">
                    {% for owner in owners %}
                        <option value="{{ owner.id }}" {% if account.parent and account.parent.id == owner.id %}selected{% endif %}>
                            {{ owner.email }} ({% if owner.accountType == 'super_admin' %}Super Admin{% elseif owner.accountType == 'admin' %}Reseller Admin{% else %}User{% endif %})
                        </option>
                    {% else %}
                        <option value="">No parent owners available</option>
                    {% endfor %}
                </select>
            </div>
        {% else %}
            {# Retain standard properties if edit does not allow modifying type #}
            <input type="hidden" name="account_type" value="{{ account.accountType }}">
            {% if account.parent %}
                <input type="hidden" name="parent_id" value="{{ account.parent.id }}">
            {% endif %}
            {% if account.accountType == 'user' and account.id == currentUser.id %}
                {# Users can toggle their own team support switch if admin allowed it #}
                <div class="switch-group" style="margin-bottom: 24px;">
                    <div class="switch-info">
                        <span class="switch-title">Team Support Features</span>
                        <span class="switch-description">Control whether your workspace supports sub-accounts.</span>
                    </div>
                    <label class="switch-toggle">
                        <input type="checkbox" name="team_enabled" id="team_enabled" value="1" {% if account.teamEnabled %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
            {% endif %}
        {% endif %}

        {# Action Buttons #}
        <div class="form-actions">
            {% if app.user.parent is not null %}
                <a href="{{ path('app_dashboard') }}" class="btn-secondary">Cancel</a>
            {% else %}
                <a href="{{ path('app_server_accounts_index') }}" class="btn-secondary">Cancel</a>
            {% endif %}
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
    </form>
</div>

{% block javascripts %}
<style>
    .preset-btn.active {
        border-color: var(--primary-accent) !important;
        box-shadow: 0 0 10px var(--primary-accent);
        transform: scale(1.1);
    }
</style>
<script>
    function selectPreset(preset) {
        document.getElementById('avatar_preset').value = preset;
        
        // Remove active class from all buttons
        document.querySelectorAll('.preset-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        
        // Add active to the clicked one
        if (preset !== 'clear') {
            const activeBtn = document.querySelector(`.preset-btn[data-preset="${preset}"]`);
            if (activeBtn) activeBtn.classList.add('active');
        }
        
        // Update Preview
        const preview = document.getElementById('avatar_preview_container');
        const nameVal = document.getElementById('name').value || document.getElementById('email').value;
        const initial = nameVal ? nameVal.charAt(0).toUpperCase() : 'A';
        
        if (preset === 'clear') {
            preview.innerHTML = `<div class="avatar-inner" style="width: 100%; height: 100%; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px;">${initial}</div>`;
        } else {
            preview.innerHTML = `<div class="avatar-inner avatar-preset-${preset}" style="width: 100%; height: 100%; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px;">${initial}</div>`;
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const accountTypeSelect = document.getElementById('account_type');
        const teamSupportField = document.getElementById('team_support_field');
        const parentOwnerField = document.getElementById('parent_owner_field');

        if (accountTypeSelect) {
            function updateFieldsVisibility() {
                const selectedType = accountTypeSelect.value;
                
                // Reset visibilities
                if (teamSupportField) teamSupportField.classList.remove('visible');
                if (parentOwnerField) parentOwnerField.classList.remove('visible');

                if (selectedType === 'user' && teamSupportField) {
                    teamSupportField.classList.add('visible');
                } else if (selectedType === 'team' && parentOwnerField) {
                    parentOwnerField.classList.add('visible');
                }
            }

            updateFieldsVisibility();
            accountTypeSelect.addEventListener('change', updateFieldsVisibility);
        }
        
        // Dynamic file upload preview helper
        const fileInput = document.getElementById('avatar_file');
        if (fileInput) {
            fileInput.addEventListener('change', function(e) {
                if (e.target.files && e.target.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(evt) {
                        const preview = document.getElementById('avatar_preview_container');
                        preview.innerHTML = `<img src="${evt.target.result}" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">`;
                        
                        // Clear active preset buttons
                        document.querySelectorAll('.preset-btn').forEach(btn => {
                            btn.classList.remove('active');
                        });
                        document.getElementById('avatar_preset').value = '';
                    };
                    reader.readAsDataURL(e.target.files[0]);
                }
            });
        }
    });
</script>
{% endblock %}
{% endblock %}

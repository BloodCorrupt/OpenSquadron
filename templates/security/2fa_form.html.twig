{% extends 'base.html.twig' %}

{% block title %}Two-Factor Authentication{% endblock %}

{% block body %}
<div class="auth-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh;">
    <div class="card" style="width: 100%; max-width: 400px; padding: 30px; text-align: center;">
        <svg viewBox="0 0 24 24" style="width: 50px; height: 50px; fill: none; stroke: var(--primary-accent); stroke-width: 2; margin-bottom: 20px;">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line>
        </svg>
        
        <h2>Authentication Required</h2>
        <p style="color: var(--text-muted); margin-bottom: 25px;">Please enter the 6-digit code from your authenticator app.</p>

        {% if authenticationError %}
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #ef4444; padding: 10px; border-radius: 8px; margin-bottom: 20px;">
                {{ authenticationError }}
            </div>
        {% endif %}

        <form action="{{ checkPathUrl ? checkPathUrl : path('2fa_login_check') }}" method="post">
            <div class="form-group" style="text-align: left;">
                <input id="_auth_code" type="text" name="_auth_code" class="form-control" autocomplete="one-time-code" autofocus style="letter-spacing: 5px; font-size: 20px; text-align: center;" placeholder="123456">
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Verify Code</button>
        </form>
        
        <p style="margin-top: 20px;">
            <a href="{{ path('app_logout') }}" style="color: var(--text-muted); text-decoration: none;">Cancel and log out</a>
        </p>
    </div>
</div>
{% endblock %}

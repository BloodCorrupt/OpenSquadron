{% extends 'base.html.twig' %}

{% block title %}SMTP Settings - OpenSquadron{% endblock %}

{% block body %}
<style>
    .form-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 35px;
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }
    .form-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 15px;
    }
    .form-title svg {
        width: 24px;
        height: 24px;
        stroke: var(--primary-accent);
    }
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 35px;
        border-top: 1px solid var(--glass-border);
        padding-top: 20px;
    }
    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: var(--text-muted);
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    .info-box {
        background: rgba(6, 182, 212, 0.1);
        border: 1px solid rgba(6, 182, 212, 0.2);
        color: #e0f2fe;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        font-size: 14px;
        line-height: 1.5;
    }
</style>

<div class="header">
    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
    <h1>SMTP Email Settings</h1>
</div>

<div class="form-card">
    <div class="form-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 9.36l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 9.36-7.94l-3.77 3.77z"></path></svg>
        Configure Mail Server
    </div>

    <div class="info-box">
        Configure your SMTP settings below. These settings will be used to send welcome emails and verification codes to users you create in your workspace. 
        <strong>Note:</strong> Unverified users cannot log in.
    </div>

    <form action="{{ path('app_smtp_settings') }}" method="POST" autocomplete="off">
        
        <div class="form-group">
            <label for="host">SMTP Host</label>
            <input type="text" id="host" name="host" class="form-control" value="{{ smtpSettings.host }}" placeholder="e.g. smtp.gmail.com" required>
        </div>

        <div class="form-group">
            <label for="port">SMTP Port</label>
            <input type="number" id="port" name="port" class="form-control" value="{{ smtpSettings.port }}" placeholder="e.g. 587" required>
        </div>

        <div class="form-group">
            <label for="encryption">Encryption</label>
            <select id="encryption" name="encryption" class="form-control" style="background-color: #0c111d; color: #fff; cursor: pointer;">
                <option value="" {% if not smtpSettings.encryption %}selected{% endif %}>None</option>
                <option value="tls" {% if smtpSettings.encryption == 'tls' %}selected{% endif %}>TLS</option>
                <option value="ssl" {% if smtpSettings.encryption == 'ssl' %}selected{% endif %}>SSL</option>
            </select>
        </div>

        <div class="form-group">
            <label for="username">SMTP Username</label>
            <input type="text" id="username" name="username" class="form-control" value="{{ smtpSettings.username }}" placeholder="e.g. you@gmail.com">
        </div>

        <div class="form-group">
            <label for="password">SMTP Password {% if smtpSettings.password %}<span style="font-size: 12px; color: var(--text-muted); font-weight: normal;">(leave blank to keep current)</span>{% endif %}</label>
            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" autocomplete="new-password" {% if not smtpSettings.password %}required{% endif %}>
        </div>

        <div class="form-group">
            <label for="fromEmail">From Email Address</label>
            <input type="email" id="fromEmail" name="fromEmail" class="form-control" value="{{ smtpSettings.fromEmail }}" placeholder="e.g. noreply@yourdomain.com" required>
        </div>

        <div class="form-group">
            <label for="fromName">From Name</label>
            <input type="text" id="fromName" name="fromName" class="form-control" value="{{ smtpSettings.fromName }}" placeholder="e.g. Support Team" required>
        </div>

        <div class="form-group" style="margin-top: 30px; padding: 20px; background: rgba(0,0,0,0.2); border-radius: 8px; border: 1px solid var(--glass-border);">
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <label for="registrationEnabled" style="margin-bottom: 5px; display: block; font-size: 15px; font-weight: 600; color: #fff;">Enable Public Registration</label>
                    <div style="font-size: 13px; color: var(--text-muted);">
                        Allow users to sign up for an account under your workspace via the public registration page.
                    </div>
                </div>
                <label class="switch" style="position: relative; display: inline-block; width: 50px; height: 26px;">
                    <input type="checkbox" id="registrationEnabled" name="registrationEnabled" value="1" {% if user.registrationEnabled %}checked{% endif %} style="opacity: 0; width: 0; height: 0;">
                    <span class="slider" style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.1); transition: .4s; border-radius: 34px;">
                        <span style="position: absolute; content: ''; height: 18px; width: 18px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%;"></span>
                    </span>
                </label>
            </div>
            
            <div style="margin-top: 15px; font-size: 13px; color: var(--text-muted); background: rgba(0,0,0,0.1); padding: 10px; border-radius: 6px;">
                <strong>Your Registration Link:</strong><br>
                <code style="color: var(--primary-accent); user-select: all; display: block; margin-top: 5px;">{{ url('app_register', {ref: user.id}) }}</code>
            </div>
        </div>

        <style>
            .switch input:checked + .slider {
                background-color: var(--primary-accent);
            }
            .switch input:focus + .slider {
                box-shadow: 0 0 1px var(--primary-accent);
            }
            .switch input:checked + .slider span {
                transform: translateX(24px);
            }
        </style>

        <div class="form-actions">
            <a href="{{ path('app_dashboard') }}" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Save Settings</button>
        </div>
    </form>
</div>

<div class="form-card" style="margin-top: 30px;">
    <div class="form-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"></path><path d="M22 2L15 22L11 13L2 9L22 2Z"></path></svg>
        Test Configuration
    </div>
    
    <div style="font-size: 14px; color: var(--text-muted); margin-bottom: 20px;">
        Make sure you save your SMTP settings above before sending a test email.
    </div>

    <form action="{{ path('app_smtp_settings_test') }}" method="POST" autocomplete="off">
        <div class="form-group">
            <label for="testEmail">Recipient Email Address</label>
            <div style="display: flex; gap: 10px;">
                <input type="email" id="testEmail" name="testEmail" class="form-control" placeholder="e.g. you@example.com" required style="flex-grow: 1;">
                <button type="submit" class="btn btn-secondary" style="white-space: nowrap;">Send Test Email</button>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}HTTP API Integrations - OpenSquadron{% endblock %}

{% block body %}
<style>
    /* Styling extension matching open squadron glassmorphism */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }
    .page-title {
        font-size: 24px;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #fff, var(--primary-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .action-group {
        display: flex;
        gap: 12px;
    }
    .btn-glass {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .btn-glass:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-1px);
    }
    .btn-primary-accent {
        background: rgba(6, 182, 212, 0.15);
        border: 1px solid var(--primary-accent);
        color: var(--primary-accent);
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.1);
    }
    .btn-primary-accent:hover {
        background: rgba(6, 182, 212, 0.25);
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.2);
    }
    .btn-success {
        border-color: var(--secondary-accent);
        color: var(--secondary-accent);
        background: rgba(16, 185, 129, 0.08);
    }
    .btn-success:hover {
        background: rgba(16, 185, 129, 0.18);
    }
    .btn-danger {
        border-color: var(--error-color);
        color: var(--error-color);
        background: rgba(239, 68, 68, 0.08);
    }
    .btn-danger:hover {
        background: rgba(239, 68, 68, 0.18);
    }
    
    /* Table Filter styling */
    .filter-panel {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
        padding: 18px 25px;
        margin-bottom: 25px;
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .filter-group label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        font-weight: 600;
    }
    .glass-input {
        box-sizing: border-box;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 9px 14px;
        border-radius: 8px;
        font-size: 13px;
        outline: none;
        transition: all 0.3s;
        min-width: 150px;
    }
    .glass-input:focus {
        border-color: var(--primary-accent);
        box-shadow: 0 0 10px rgba(6, 182, 212, 0.15);
    }

    /* Grid cards layout */
    .grid-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
    }
    @media (min-width: 1200px) {
        .grid-container.has-form {
            grid-template-columns: 1.2fr 0.8fr;
        }
    }
    
    .panel-card {
        padding: 25px;
        margin-bottom: 30px;
    }
    .panel-card-title {
        font-size: 18px;
        font-weight: 600;
        margin-top: 0;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 12px;
    }

    /* Table styling */
    .glass-table-wrapper {
        overflow-x: auto;
        border-radius: 12px;
    }
    .glass-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 13.5px;
    }
    .glass-table th, .glass-table td {
        padding: 14px 18px;
        border-bottom: 1px solid var(--glass-border);
    }
    .glass-table th {
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-muted);
        font-weight: 600;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .glass-table tr:hover td {
        background: rgba(255, 255, 255, 0.01);
    }
    
    .badge {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
    }
    .badge-success { background: rgba(16, 185, 129, 0.15); color: var(--secondary-accent); border: 1px solid rgba(16, 185, 129, 0.3); }
    .badge-warning { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .badge-danger { background: rgba(239, 68, 68, 0.15); color: var(--error-color); border: 1px solid rgba(239, 68, 68, 0.3); }
    .badge-info { background: rgba(6, 182, 212, 0.15); color: var(--primary-accent); border: 1px solid rgba(6, 182, 212, 0.3); }
    
    /* Connection builder details */
    .form-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    @media (min-width: 768px) {
        .form-row.two-cols { grid-template-columns: 1fr 1fr; }
        .form-row.three-cols { grid-template-columns: 1.2fr 0.8fr 1fr; }
    }
    
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .form-group label {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--text-main);
    }
    
    /* Sub grids (Headers/Cookies) dynamic row container */
    .dynamic-grid-box {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
    }
    .dynamic-grid-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }
    .dynamic-grid-title {
        font-size: 13.5px;
        font-weight: 600;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .dynamic-row {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 12px;
        margin-bottom: 10px;
        align-items: center;
    }
    
    /* Radio Selector */
    .radio-pill-group {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        background: rgba(15, 23, 42, 0.5);
        padding: 5px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        width: fit-content;
    }
    .radio-pill {
        display: none;
    }
    .radio-pill-label {
        padding: 6px 14px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s;
    }
    .radio-pill:checked + .radio-pill-label {
        background: var(--primary-accent);
        color: #fff;
        box-shadow: 0 0 10px rgba(6, 182, 212, 0.3);
    }
    
    /* Sandbox response drawer */
    .sandbox-panel {
        margin-top: 25px;
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(6, 182, 212, 0.3);
        border-radius: 12px;
        padding: 20px;
        display: none;
    }
    .sandbox-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--primary-accent);
        margin-top: 0;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .sandbox-log-box {
        font-family: monospace;
        font-size: 12.5px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 15px;
        color: #e2e8f0;
        max-height: 250px;
        overflow-y: auto;
        white-space: pre-wrap;
    }
    
    /* Beautiful Modal style */
    .glass-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .glass-modal-content {
        width: 100%;
        max-width: 900px;
        max-height: 85vh;
        overflow-y: auto;
        padding: 30px;
        position: relative;
    }
    .glass-modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 24px;
        transition: all 0.2s;
    }
    .glass-modal-close:hover {
        color: #fff;
    }
    
    /* Helper list details */
    .instruction-alert {
        background: rgba(245, 158, 11, 0.05);
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #f59e0b;
        padding: 15px 20px;
        border-radius: 12px;
        font-size: 13px;
        margin-bottom: 25px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }
    
    .call-stats {
        display: flex;
        gap: 12px;
        font-size: 12px;
    }
    .stat-circle {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    
    @media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }
        .action-group {
            flex-direction: column;
            width: 100%;
        }
        .action-group .btn-glass {
            width: 100%;
            justify-content: center;
        }
        .filter-panel {
            flex-direction: column;
            align-items: stretch;
            padding: 15px;
            gap: 12px;
        }
        .filter-group {
            width: 100%;
        }
        .filter-group .glass-input {
            min-width: 0;
            width: 100%;
        }
        .panel-card {
            padding: 15px;
            margin-bottom: 20px;
            min-width: 0;
            overflow: hidden;
        }
        .panel-card-title {
            font-size: 16px;
            margin-bottom: 15px;
        }
        .glass-table th, .glass-table td {
            padding: 10px 12px;
        }
        .dynamic-row {
            grid-template-columns: 1fr;
            gap: 8px;
            background: rgba(255, 255, 255, 0.02);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid var(--glass-border);
        }
        .dynamic-row .btn-danger {
            justify-content: center;
            width: 100%;
        }
        .dynamic-row .glass-input {
            min-width: 0;
            width: 100%;
        }
        .radio-pill-group {
            width: 100%;
            justify-content: center;
        }
        .glass-modal-content {
            padding: 20px 15px;
            margin: 10px;
        }
        .glass-modal-close {
            top: 15px;
            right: 15px;
        }
        .sandbox-log-box {
            padding: 10px;
            font-size: 11.5px;
        }
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Global HTTP API Manager</h1>
        <p style="color: var(--text-muted); margin: 5px 0 0 0; font-size: 14px;">Connect, configure, and dynamically call third-party HTTP integrations globally.</p>
    </div>
    <div class="action-group">
        <button class="btn-glass btn-primary-accent" onclick="showFormCard()">
            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Create API
        </button>
        <button class="btn-glass" onclick="openImportModal()">
            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><polyline points="9 15 12 12 15 15"></polyline></svg>
            Import payload
        </button>
        <button class="btn-glass btn-success" onclick="openLogsModal()">
            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            HTTP API Report
        </button>
    </div>
</div>

<div class="grid-container" id="mainGrid">
    <!-- List panel -->
    <div class="panel-card glass-panel" id="listColumn">
        <div class="panel-card-title">
            <span>Connected HTTP APIs</span>
        </div>
        
        <!-- Filter bar -->
        <form class="filter-panel glass-panel" method="GET" action="{{ path('app_http_api_index') }}">
            <div class="filter-group">
                <label>Status</label>
                <select name="status" class="glass-input" onchange="this.form.submit()">
                    <option value="all" {% if status == 'all' %}selected{% endif %}>Any Status</option>
                    <option value="active" {% if status == 'active' %}selected{% endif %}>Active</option>
                    <option value="inactive" {% if status == 'inactive' %}selected{% endif %}>Inactive</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Verification</label>
                <select name="verified" class="glass-input" onchange="this.form.submit()">
                    <option value="all" {% if verified == 'all' %}selected{% endif %}>Any Verification</option>
                    <option value="verified" {% if verified == 'verified' %}selected{% endif %}>Verified</option>
                    <option value="unverified" {% if verified == 'unverified' %}selected{% endif %}>Unverified</option>
                </select>
            </div>
            <div class="filter-group" style="flex-grow: 1;">
                <label>Search</label>
                <div style="position: relative; width: 100%; box-sizing: border-box;">
                    <input type="text" name="search" class="glass-input" placeholder="Search & Enter..." value="{{ search }}" style="width: 100%;">
                    {% if search %}
                        <a href="{{ path('app_http_api_index', {status: status, verified: verified}) }}" style="position: absolute; right: 12px; top: 10px; color: var(--text-muted); font-size: 14px; text-decoration: none;">×</a>
                    {% endif %}
                </div>
            </div>
        </form>
        
        <div class="glass-table-wrapper">
            <table class="glass-table">
                <thead>
                    <tr>
                        <th style="width: 40px;">#</th>
                        <th>API Name</th>
                        <th>Endpoint URL</th>
                        <th>Channel</th>
                        <th>Status</th>
                        <th>Verified</th>
                        <th>Call Counters</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for api in httpApis %}
                        <tr id="api-row-{{ api.id }}">
                            <td style="color: var(--text-muted);">{{ loop.index }}</td>
                            <td style="font-weight: 600;">{{ api.name }}</td>
                            <td style="font-family: monospace; font-size: 12px; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                {{ api.endpointUrl }}
                            </td>
                            <td>
                                <span class="badge badge-info">{{ api.channel|upper }}</span>
                            </td>
                            <td>
                                {% if api.status == 'active' %}
                                    <span class="badge badge-success">Active</span>
                                {% else %}
                                    <span class="badge badge-warning">Inactive</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if api.isVerified %}
                                    <span class="badge badge-success">Verified</span>
                                {% else %}
                                    <span class="badge badge-danger">Unverified</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="call-stats">
                                    <span class="stat-circle" title="Total calls">
                                        <span style="color: var(--text-muted);">📞</span> {{ api.totalCall }}
                                    </span>
                                    <span class="stat-circle" style="color: var(--secondary-accent);" title="Successful calls">
                                        ✔ {{ api.totalSuccess }}
                                    </span>
                                    <span class="stat-circle" style="color: var(--error-color);" title="Error calls">
                                        ✖ {{ api.totalError }}
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <button class="btn-glass" style="padding: 5px 10px; font-size: 12px;" onclick="editConnection({{ api|json_encode|e('html_attr') }})">
                                        Edit
                                    </button>
                                    <button class="btn-glass btn-danger" style="padding: 5px 10px; font-size: 12px;" onclick="deleteConnection({{ api.id }})">
                                        Delete
                                    </button>
                                    <button class="btn-glass" style="padding: 5px 10px; font-size: 12px; border-color: rgba(255,255,255,0.15);" onclick="exportConnection({{ api.id }})">
                                        Export
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" style="text-align: center; color: var(--text-muted); padding: 40px 0;">
                                No HTTP API connections found. Click "Create API" to connect your first endpoint!
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Connection details panel (Hidden by default, shown on create/edit) -->
    <div class="panel-card glass-panel" id="formColumn" style="display: none;">
        <div class="panel-card-title">
            <span id="formTitle">API Connection Details</span>
            <span style="cursor: pointer; font-size: 18px; color: var(--text-muted);" onclick="hideFormCard()">×</span>
        </div>
        
        <div class="instruction-alert">
            <span>💡</span>
            <div>
                <strong>Placeholder Support:</strong> You can parse subscriber variables in URLs, Headers, Queries, and Body Data using:
                <div style="font-family: monospace; font-size: 11.5px; margin-top: 5px; color: #f59e0b;">
                    &#123;&#123;subscriber.name&#125;&#125;, &#123;&#123;subscriber.phone_number&#125;&#125;, &#123;&#123;subscriber.psid&#125;&#125;, &#123;&#123;subscriber.custom_attributes.YOUR_KEY&#125;&#125;
                </div>
            </div>
        </div>
        
        <form id="connectionForm" onsubmit="event.preventDefault();">
            <input type="hidden" name="id" id="apiId">
            
            <div class="form-row three-cols">
                <div class="form-group">
                    <label>API Name *</label>
                    <input type="text" name="name" id="apiName" class="glass-input" required placeholder="e.g. Stripe Webhook, Log Engine">
                </div>
                <div class="form-group">
                    <label>Method *</label>
                    <select name="method" id="apiMethod" class="glass-input">
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="PATCH">PATCH</option>
                        <option value="DELETE">DELETE</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Channel *</label>
                    <select name="channel" id="apiChannel" class="glass-input">
                        <option value="global">Global (All)</option>
                        <option value="whatsapp">WhatsApp</option>
                        <option value="facebook">Facebook</option>
                    </select>
                </div>
            </div>
            
            <div class="form-row two-cols">
                <div class="form-group" style="grid-column: span 1;">
                    <label>Endpoint URL *</label>
                    <input type="url" name="endpointUrl" id="apiEndpointUrl" class="glass-input" required placeholder="https://api.yourdomain.com/v1/trigger">
                </div>
                <div class="form-group">
                    <label>Test Subscriber ID (For verifying placeholders)</label>
                    <input type="text" name="testSubscriberId" id="apiTestSubscriberId" class="glass-input" placeholder="Subscriber ID or Phone or PSID">
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Status</label>
                    <select name="status" id="apiStatus" class="glass-input">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
            </div>
            
            <!-- Dynamic Headers box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title">🌐 Header Data</span>
                    <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('headers')">+ Add</button>
                </div>
                <div id="headersGridContainer"></div>
            </div>
            
            <!-- Dynamic Queries box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title">🔍 Option Data (Query Parameters)</span>
                    <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('options')">+ Add</button>
                </div>
                <div id="optionsGridContainer"></div>
            </div>

            <!-- Dynamic Cookies box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title">🍪 Cookie Data</span>
                    <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('cookies')">+ Add</button>
                </div>
                <div id="cookiesGridContainer"></div>
            </div>
            
            <!-- Body Selector box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title">📦 Body Data</span>
                    <div class="radio-pill-group">
                        <input type="radio" name="bodyType" id="bodyDefault" value="DEFAULT" class="radio-pill" checked onchange="toggleBodySection()">
                        <label for="bodyDefault" class="radio-pill-label">DEFAULT</label>

                        <input type="radio" name="bodyType" id="bodyFormData" value="FORM-DATA" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyFormData" class="radio-pill-label">FORM-DATA</label>

                        <input type="radio" name="bodyType" id="bodyUrlEncoded" value="X-WWW-FORM-URLENCODED" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyUrlEncoded" class="radio-pill-label">X-WWW-FORM-URLENCODED</label>

                        <input type="radio" name="bodyType" id="bodyJson" value="JSON" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyJson" class="radio-pill-label">JSON</label>

                        <input type="radio" name="bodyType" id="bodyBinary" value="BINARY" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyBinary" class="radio-pill-label">BINARY</label>
                    </div>
                </div>
                
                <div id="bodyDataGridContainer" style="display: none; margin-top: 15px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <span style="font-size: 12.5px; color: var(--text-muted);">Form parameters</span>
                        <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('bodyData')">+ Add Row</button>
                    </div>
                    <div id="bodyParamsRows"></div>
                </div>
                
                <div id="bodyDataTextContainer" style="display: none; margin-top: 15px;">
                    <textarea id="bodyRawText" class="glass-input" style="width: 100%; min-height: 120px; font-family: monospace;" placeholder="Enter raw request body content..."></textarea>
                </div>
            </div>
            
            <div class="sandbox-panel" id="sandboxPanel">
                <h4 class="sandbox-title">
                    <span>📡 Connection Sandbox Log</span>
                    <span id="sandboxStatusBadge" class="badge">PENDING</span>
                </h4>
                <div class="sandbox-log-box" id="sandboxLogBox">Firing connection test...</div>
            </div>
            
            <div style="display: flex; justify-content: space-between; margin-top: 30px;">
                <button type="button" class="btn-glass btn-primary-accent" style="border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.08);" onclick="verifyConnection()">
                    ⚡ Verify Connection
                </button>
                <button type="button" class="btn-glass btn-success" onclick="saveConnection()">
                    💾 Save Connection
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Logs/Report Modal -->
<div class="glass-modal" id="logsModal">
    <div class="glass-modal-content glass-panel">
        <span class="glass-modal-close" onclick="closeLogsModal()">×</span>
        <h2 style="margin-top: 0; margin-bottom: 20px; font-size: 20px; border-bottom: 1px solid var(--glass-border); padding-bottom: 12px; color: var(--primary-accent);">Outbound HTTP API Call Logs</h2>
        
        <div class="glass-table-wrapper" style="max-height: 50vh; overflow-y: auto;">
            <table class="glass-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>API Name</th>
                        <th>Subscriber</th>
                        <th>Status</th>
                        <th>Method</th>
                        <th>Endpoint URL</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="logsTableBody">
                    <!-- Logs list generated dynamically -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Dynamic Log Details Expansion Box -->
<div class="glass-modal" id="logDetailsModal" style="z-index: 10000;">
    <div class="glass-modal-content glass-panel" style="max-width: 700px;">
        <span class="glass-modal-close" onclick="closeLogDetailsModal()">×</span>
        <h3 id="logDetailsTitle" style="margin-top: 0; color: var(--primary-accent);">Call Details</h3>
        
        <div style="margin-bottom: 15px;">
            <strong>Target URL:</strong> <span id="logDetailsUrl" style="font-family: monospace; word-break: break-all;"></span>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 20px;">
            <div>
                <strong style="display: block; margin-bottom: 5px;">📤 Request Payload:</strong>
                <pre class="sandbox-log-box" id="logDetailsRequest" style="max-height: 180px;"></pre>
            </div>
            <div>
                <strong style="display: block; margin-bottom: 5px;">📥 Response Payload:</strong>
                <pre class="sandbox-log-box" id="logDetailsResponse" style="max-height: 180px;"></pre>
            </div>
        </div>
    </div>
</div>

<!-- Import Configuration Modal -->
<div class="glass-modal" id="importModal">
    <div class="glass-modal-content glass-panel" style="max-width: 550px;">
        <span class="glass-modal-close" onclick="closeImportModal()">×</span>
        <h2 style="margin-top: 0; margin-bottom: 20px; font-size: 20px; color: var(--primary-accent); border-bottom: 1px solid var(--glass-border); padding-bottom: 12px;">Import API Settings Payload</h2>
        
        <div style="margin-bottom: 15px; font-size: 13px; color: var(--text-muted);">
            Paste the JSON configuration template payload exported from another OpenSquadron tenant workspace to restore integration details dynamically.
        </div>
        
        <div class="form-group">
            <label>JSON Configuration Code *</label>
            <textarea id="importJsonTextarea" class="glass-input" style="width: 100%; min-height: 180px; font-family: monospace;" placeholder='{ "name": "API", "endpointUrl": ... }'></textarea>
        </div>
        
        <div style="margin-top: 25px; text-align: right;">
            <button class="btn-glass btn-success" onclick="submitImport()">Restore Configuration</button>
        </div>
    </div>
</div>

<script>
    // Grid management utility mapping
    const grids = {
        headers: [],
        options: [],
        cookies: [],
        bodyData: []
    };

    function showFormCard() {
        document.getElementById('formTitle').innerText = 'API Connection Details';
        document.getElementById('connectionForm').reset();
        document.getElementById('apiId').value = '';
        
        // Reset dynamic grids
        grids.headers = [];
        grids.options = [];
        grids.cookies = [];
        grids.bodyData = [];
        renderAllGrids();
        
        toggleBodySection();
        document.getElementById('sandboxPanel').style.display = 'none';

        // Toggle layout
        const mainGrid = document.getElementById('mainGrid');
        mainGrid.classList.add('has-form');
        document.getElementById('formColumn').style.display = 'block';
    }

    function hideFormCard() {
        const mainGrid = document.getElementById('mainGrid');
        mainGrid.classList.remove('has-form');
        document.getElementById('formColumn').style.display = 'none';
    }

    function addGridRow(gridType, key = '', value = '') {
        grids[gridType].push({ key, value });
        renderGrid(gridType);
    }

    function removeGridRow(gridType, index) {
        grids[gridType].splice(index, 1);
        renderGrid(gridType);
    }

    function updateGridField(gridType, index, field, val) {
        grids[gridType][index][field] = val;
    }

    function renderGrid(gridType) {
        let container;
        if (gridType === 'bodyData') {
            container = document.getElementById('bodyParamsRows');
        } else {
            container = document.getElementById(gridType + 'GridContainer');
        }
        
        container.innerHTML = '';
        
        grids[gridType].forEach((row, i) => {
            const div = document.createElement('div');
            div.className = 'dynamic-row';
            div.innerHTML = `
                <input type="text" class="glass-input" placeholder="Key Name" value="${escapeHtml(row.key)}" oninput="updateGridField('${gridType}', ${i}, 'key', this.value)">
                <input type="text" class="glass-input" placeholder="Value / {{ '{{ placeholder }}' }}" value="${escapeHtml(row.value)}" oninput="updateGridField('${gridType}', ${i}, 'value', this.value)">
                <button type="button" class="btn-glass btn-danger" style="padding: 8px 12px;" onclick="removeGridRow('${gridType}', ${i})">×</button>
            `;
            container.appendChild(div);
        });
    }

    function renderAllGrids() {
        renderGrid('headers');
        renderGrid('options');
        renderGrid('cookies');
        renderGrid('bodyData');
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function toggleBodySection() {
        const checkedVal = document.querySelector('input[name="bodyType"]:checked').value;
        const gridBox = document.getElementById('bodyDataGridContainer');
        const textBox = document.getElementById('bodyDataTextContainer');
        
        if (checkedVal === 'DEFAULT') {
            gridBox.style.display = 'none';
            textBox.style.display = 'none';
        } else if (checkedVal === 'FORM-DATA' || checkedVal === 'X-WWW-FORM-URLENCODED') {
            gridBox.style.display = 'block';
            textBox.style.display = 'none';
        } else {
            gridBox.style.display = 'none';
            textBox.style.display = 'block';
        }
    }

    // Load connection detail for editing
    function editConnection(api) {
        showFormCard();
        document.getElementById('formTitle').innerText = 'Edit API Connection';
        document.getElementById('apiId').value = api.id;
        document.getElementById('apiName').value = api.name;
        document.getElementById('apiMethod').value = api.method;
        document.getElementById('apiChannel').value = api.channel;
        document.getElementById('apiEndpointUrl').value = api.endpointUrl;
        document.getElementById('apiTestSubscriberId').value = api.testSubscriberId || '';
        document.getElementById('apiStatus').value = api.status;

        // body config
        const bodyType = api.bodyType || 'DEFAULT';
        document.getElementById('body' + capitalizeFirst(bodyType.replace('-',''))).checked = true;
        
        // Populate dynamic lists
        grids.headers = api.headers || [];
        grids.options = api.options || [];
        grids.cookies = api.cookies || [];
        
        if (bodyType === 'FORM-DATA' || bodyType === 'X-WWW-FORM-URLENCODED') {
            try {
                grids.bodyData = JSON.parse(api.bodyData) || [];
            } catch(e) {
                grids.bodyData = [];
            }
            document.getElementById('bodyRawText').value = '';
        } else {
            grids.bodyData = [];
            document.getElementById('bodyRawText').value = api.bodyData || '';
        }

        renderAllGrids();
        toggleBodySection();
    }

    function capitalizeFirst(str) {
        if (str === 'XWWWFORMURLENCODED') return 'UrlEncoded';
        return str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();
    }

    // Delete configuration
    function deleteConnection(id) {
        if (!confirm('Are you sure you want to delete this HTTP API integration and its call history?')) return;
        
        const fd = new FormData();
        fetch(`/settings/http-api/delete/${id}`, {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert('Error: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('Failed to execute delete operation.');
        });
    }

    // Build payload to send
    function buildFormDataPayload() {
        const fd = new FormData();
        fd.append('id', document.getElementById('apiId').value);
        fd.append('name', document.getElementById('apiName').value);
        fd.append('method', document.getElementById('apiMethod').value);
        fd.append('channel', document.getElementById('apiChannel').value);
        fd.append('endpointUrl', document.getElementById('apiEndpointUrl').value);
        fd.append('testSubscriberId', document.getElementById('apiTestSubscriberId').value);
        fd.append('status', document.getElementById('apiStatus').value);
        
        const bodyType = document.querySelector('input[name="bodyType"]:checked').value;
        fd.append('bodyType', bodyType);

        if (bodyType === 'FORM-DATA' || bodyType === 'X-WWW-FORM-URLENCODED') {
            fd.append('bodyData', JSON.stringify(grids.bodyData));
        } else {
            fd.append('bodyData', document.getElementById('bodyRawText').value);
        }

        fd.append('headers', JSON.stringify(grids.headers));
        fd.append('options', JSON.stringify(grids.options));
        fd.append('cookies', JSON.stringify(grids.cookies));
        
        return fd;
    }

    // Save Connection Details
    function saveConnection() {
        const name = document.getElementById('apiName').value.trim();
        const url = document.getElementById('apiEndpointUrl').value.trim();
        
        if (!name || !url) {
            alert('Please specify the API Name and Endpoint URL.');
            return;
        }

        const fd = buildFormDataPayload();
        fetch('/settings/http-api/save', {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert('Error: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('An error occurred while saving the configuration.');
        });
    }

    // Verify Sandbox connection
    function verifyConnection() {
        const url = document.getElementById('apiEndpointUrl').value.trim();
        if (!url) {
            alert('Please specify the Endpoint URL before verification.');
            return;
        }

        const panel = document.getElementById('sandboxPanel');
        const badge = document.getElementById('sandboxStatusBadge');
        const logBox = document.getElementById('sandboxLogBox');

        panel.style.display = 'block';
        badge.className = 'badge badge-warning';
        badge.innerText = 'PENDING';
        logBox.innerText = 'Initializing Outbound request execution...\nResolving placeholder configurations...';

        const fd = buildFormDataPayload();
        fetch('/settings/http-api/verify', {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                badge.className = 'badge badge-success';
                badge.innerText = 'SUCCESS (' + data.statusCode + ')';
                
                let headersStr = '';
                for (const [k, v] of Object.entries(data.responseHeaders)) {
                    headersStr += `${k}: ${v.join(', ')}\n`;
                }

                logBox.innerText = `[SUCCESS] Request Executed Successfully!\n` +
                                   `Target URL: ${data.interpolatedUrl}\n` +
                                   `Status Code: ${data.statusCode}\n\n` +
                                   `--- RESPONSE HEADERS ---\n${headersStr}\n` +
                                   `--- RESPONSE BODY ---\n${data.responseBody}`;
            } else {
                badge.className = 'badge badge-danger';
                badge.innerText = 'ERROR';
                logBox.innerText = `[FAILURE] Connection Test Failed!\nTarget URL: ${data.interpolatedUrl || url}\nError details:\n${data.error}`;
            }
        })
        .catch(e => {
            badge.className = 'badge badge-danger';
            badge.innerText = 'EXCEPTION';
            logBox.innerText = `[EXCEPTION] Client Error:\n${e.message}`;
        });
    }

    // Export payload file
    function exportConnection(id) {
        fetch(`/settings/http-api/export/${id}`)
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(data.config, null, 4));
                const dlAnchorElem = document.createElement('a');
                dlAnchorElem.setAttribute("href", dataStr);
                dlAnchorElem.setAttribute("download", `http_api_config_${id}.json`);
                dlAnchorElem.click();
            } else {
                alert('Export failed: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('An error occurred during export.');
        });
    }

    // Import Modals Control
    function openImportModal() {
        document.getElementById('importJsonTextarea').value = '';
        document.getElementById('importModal').style.display = 'flex';
    }
    function closeImportModal() {
        document.getElementById('importModal').style.display = 'none';
    }

    function submitImport() {
        const json = document.getElementById('importJsonTextarea').value.trim();
        if (!json) {
            alert('Pasting JSON payload is required.');
            return;
        }

        const fd = new FormData();
        fd.append('configJson', json);

        fetch('/settings/http-api/import', {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert('Import failed: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('Failed to import JSON payload.');
        });
    }

    // Reports/Logs Modal Control
    function openLogsModal() {
        const tableBody = document.getElementById('logsTableBody');
        tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-muted);">Fetching latest audit trails...</td></tr>';
        
        document.getElementById('logsModal').style.display = 'flex';

        fetch('/settings/http-api/logs')
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                tableBody.innerHTML = '';
                if (data.logs.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-muted);">No call logs recorded yet.</td></tr>';
                    return;
                }

                data.logs.forEach(log => {
                    const tr = document.createElement('tr');
                    const statusClass = (log.status >= 200 && log.status < 300) ? 'badge-success' : 'badge-danger';
                    
                    tr.innerHTML = `
                        <td style="font-size:12px; color:var(--text-muted);">${log.createdAt}</td>
                        <td style="font-weight:600;">${escapeHtml(log.apiName)}</td>
                        <td>${escapeHtml(log.subscriber)}</td>
                        <td>
                            <span class="badge ${statusClass}">
                                ${log.status || 'ERROR'}
                            </span>
                        </td>
                        <td style="font-weight:700; font-size:11px;">${log.method}</td>
                        <td style="font-family:monospace; font-size:11.5px; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${log.url}">
                            ${log.url}
                        </td>
                        <td>
                            <button class="btn-glass" style="padding: 4px 8px; font-size: 11px;" onclick='showLogDetails(${JSON.stringify(log)})'>
                                View Logs
                            </button>
                        </td>
                    `;
                    tableBody.appendChild(tr);
                });
            } else {
                tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--error-color);">Failed to load logs.</td></tr>';
            }
        })
        .catch(e => {
            tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--error-color);">Connection error loading logs.</td></tr>';
        });
    }

    function closeLogsModal() {
        document.getElementById('logsModal').style.display = 'none';
    }

    function showLogDetails(log) {
        document.getElementById('logDetailsTitle').innerText = `${log.apiName} Audit Log (${log.method})`;
        document.getElementById('logDetailsUrl').innerText = log.url;
        
        let requestStr = JSON.stringify(log.payload, null, 4);
        document.getElementById('logDetailsRequest').innerText = requestStr;

        let responseStr = '';
        if (log.error) {
            responseStr = `[CLIENT EXCEPTION/TIMEOUT]\n${log.error}`;
        } else {
            responseStr = `Status: ${log.status}\n\n--- HEADERS ---\n${JSON.stringify(log.responseHeaders, null, 4)}\n\n--- BODY ---\n${log.responseBody}`;
        }
        document.getElementById('logDetailsResponse').innerText = responseStr;

        document.getElementById('logDetailsModal').style.display = 'flex';
    }

    function closeLogDetailsModal() {
        document.getElementById('logDetailsModal').style.display = 'none';
    }
</script>
{% endblock %}

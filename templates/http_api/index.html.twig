<!-- Import Configuration Modal -->
<div class="glass-modal" id="importModal">
    <div class="glass-modal-content glass-panel" style="max-width: 550px;">
        <span class="glass-modal-close" onclick="closeImportModal()"><svg viewBox="0 0 24 24" style="width: 20px; height: 20px;" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></span>
        <h2 style="margin-top: 0; margin-bottom: 20px; font-size: 20px; color: var(--primary-accent); border-bottom: 1px solid var(--glass-border); padding-bottom: 12px;">Import API Settings Payload</h2>
        
        <div style="margin-bottom: 15px; font-size: 13px; color: var(--text-muted);">
            Paste the JSON configuration template payload exported from another OpenSquadron tenant workspace to restore integration details dynamically.
        </div>
        
        <div class="form-group">
            <label>JSON Configuration Code *</label>
            <textarea id="importJsonTextarea" class="glass-input" style="width: 100%; min-height: 180px; font-family: monospace;" placeholder='{ "name": "API", "endpointUrl": ... }'></textarea>
        </div>
        
        <div style="margin-top: 25px; text-align: right;">
            <button class="btn-glass btn-success" onclick="submitImport()">Restore Configuration</button>
        </div>
    </div>
</div>

<script>
    // Grid management utility mapping
    const grids = {
        headers: [],
        options: [],
        cookies: [],
        bodyData: []
    };

    function showFormCard() {
        document.getElementById('formTitle').innerText = 'API Connection Details';
        document.getElementById('connectionForm').reset();
        document.getElementById('apiId').value = '';
        
        // Reset dynamic grids
        grids.headers = [];
        grids.options = [];
        grids.cookies = [];
        grids.bodyData = [];
        renderAllGrids();
        
        toggleBodySection();
        document.getElementById('sandboxPanel').style.display = 'none';

        // Open modal
        document.getElementById('apiFormModal').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function hideFormCard() {
        document.getElementById('apiFormModal').style.display = 'none';
        document.body.style.overflow = '';
    }

    function addGridRow(gridType, key = '', value = '') {
        grids[gridType].push({ key, value });
        renderGrid(gridType);
    }

    function removeGridRow(gridType, index) {
        grids[gridType].splice(index, 1);
        renderGrid(gridType);
    }

    function updateGridField(gridType, index, field, val) {
        grids[gridType][index][field] = val;
    }

    function renderGrid(gridType) {
        let container;
        if (gridType === 'bodyData') {
            container = document.getElementById('bodyParamsRows');
        } else {
            container = document.getElementById(gridType + 'GridContainer');
        }
        
        container.innerHTML = '';
        
        grids[gridType].forEach((row, i) => {
            const div = document.createElement('div');
            div.className = 'dynamic-row';
            div.innerHTML = `
                <input type="text" class="glass-input" placeholder="Key Name" value="${escapeHtml(row.key)}" oninput="updateGridField('${gridType}', ${i}, 'key', this.value)">
                <input type="text" class="glass-input" placeholder="Value / {{ '{{ placeholder }}' }}" value="${escapeHtml(row.value)}" oninput="updateGridField('${gridType}', ${i}, 'value', this.value)">
                <button type="button" class="btn-glass btn-danger" style="padding: 8px 12px; display: inline-flex; align-items: center; justify-content: center;" onclick="removeGridRow('${gridType}', ${i})"><svg viewBox="0 0 24 24" style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            `;
            container.appendChild(div);
        });
    }

    function renderAllGrids() {
        renderGrid('headers');
        renderGrid('options');
        renderGrid('cookies');
        renderGrid('bodyData');
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function toggleBodySection() {
        const checkedVal = document.querySelector('input[name="bodyType"]:checked').value;
        const gridBox = document.getElementById('bodyDataGridContainer');
        const textBox = document.getElementById('bodyDataTextContainer');
        const binaryBox = document.getElementById('bodyBinaryContainer');
        
        if (checkedVal === 'DEFAULT') {
            gridBox.style.display = 'none';
            textBox.style.display = 'none';
            binaryBox.style.display = 'none';
        } else if (checkedVal === 'FORM-DATA' || checkedVal === 'X-WWW-FORM-URLENCODED') {
            gridBox.style.display = 'block';
            textBox.style.display = 'none';
            binaryBox.style.display = 'none';
        } else if (checkedVal === 'BINARY') {
            gridBox.style.display = 'none';
            textBox.style.display = 'none';
            binaryBox.style.display = 'block';
        } else {
            gridBox.style.display = 'none';
            textBox.style.display = 'block';
            binaryBox.style.display = 'none';
        }
    }

    // Load connection detail for editing
    function editConnection(api) {
        showFormCard();
        document.getElementById('formTitle').innerText = 'Edit API Connection';
        document.getElementById('apiId').value = api.id;
        document.getElementById('apiName').value = api.name;
        document.getElementById('apiMethod').value = api.method;
        document.getElementById('apiChannel').value = api.channel;
        document.getElementById('apiEndpointUrl').value = api.endpointUrl;
        document.getElementById('apiTestSubscriberId').value = api.testSubscriberId || '';
        document.getElementById('apiStatus').value = api.status;

        // body config
        const bodyType = api.bodyType || 'DEFAULT';
        document.getElementById('body' + capitalizeFirst(bodyType.replace('-',''))).checked = true;
        
        // Populate dynamic lists
        grids.headers = api.headers || [];
        grids.options = api.options || [];
        grids.cookies = api.cookies || [];
        
        if (bodyType === 'FORM-DATA' || bodyType === 'X-WWW-FORM-URLENCODED') {
            try {
                grids.bodyData = JSON.parse(api.bodyData) || [];
            } catch(e) {
                grids.bodyData = [];
            }
            document.getElementById('bodyRawText').value = '';
        } else if (bodyType === 'BINARY') {
            grids.bodyData = [];
            document.getElementById('bodyRawText').value = '';
            try {
                const binData = JSON.parse(api.bodyData);
                if (binData && typeof binData === 'object' && binData.key !== undefined) {
                    document.getElementById('binaryKey').value = binData.key || '';
                    document.getElementById('binaryType').value = binData.type || 'File Upload';
                    document.getElementById('binaryValue').value = binData.value || '';
                } else {
                    document.getElementById('binaryKey').value = '';
                    document.getElementById('binaryType').value = 'File Upload';
                    document.getElementById('binaryValue').value = api.bodyData || '';
                }
            } catch(e) {
                document.getElementById('binaryKey').value = '';
                document.getElementById('binaryType').value = 'File Upload';
                document.getElementById('binaryValue').value = api.bodyData || '';
            }
        } else {
            grids.bodyData = [];
            document.getElementById('bodyRawText').value = api.bodyData || '';
        }

        renderAllGrids();
        toggleBodySection();
    }

    function capitalizeFirst(str) {
        if (str === 'XWWWFORMURLENCODED') return 'UrlEncoded';
        return str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();
    }

    // Delete configuration
    function deleteConnection(id) {
        if (!confirm('Are you sure you want to delete this HTTP API integration and its call history?')) return;
        
        const fd = new FormData();
        fetch(`/settings/http-api/delete/${id}`, {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert('Error: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('Failed to execute delete operation.');
        });
    }

    // Build payload to send
    function buildFormDataPayload() {
        const fd = new FormData();
        fd.append('id', document.getElementById('apiId').value);
        fd.append('name', document.getElementById('apiName').value);
        fd.append('method', document.getElementById('apiMethod').value);
        fd.append('channel', document.getElementById('apiChannel').value);
        fd.append('endpointUrl', document.getElementById('apiEndpointUrl').value);
        fd.append('testSubscriberId', document.getElementById('apiTestSubscriberId').value);
        fd.append('status', document.getElementById('apiStatus').value);
        
        const bodyType = document.querySelector('input[name="bodyType"]:checked').value;
        fd.append('bodyType', bodyType);

        if (bodyType === 'FORM-DATA' || bodyType === 'X-WWW-FORM-URLENCODED') {
            fd.append('bodyData', JSON.stringify(grids.bodyData));
        } else if (bodyType === 'BINARY') {
            fd.append('bodyData', JSON.stringify({
                key: document.getElementById('binaryKey').value,
                type: document.getElementById('binaryType').value,
                value: document.getElementById('binaryValue').value
            }));
        } else {
            fd.append('bodyData', document.getElementById('bodyRawText').value);
        }

        fd.append('headers', JSON.stringify(grids.headers));
        fd.append('options', JSON.stringify(grids.options));
        fd.append('cookies', JSON.stringify(grids.cookies));
        
        return fd;
    }

    // Save Connection Details
    function saveConnection() {
        const name = document.getElementById('apiName').value.trim();
        const url = document.getElementById('apiEndpointUrl').value.trim();
        
        if (!name || !url) {
            alert('Please specify the API Name and Endpoint URL.');
            return;
        }

        const fd = buildFormDataPayload();
        fetch('/settings/http-api/save', {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert('Error: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('An error occurred while saving the configuration.');
        });
    }

    // Verify Sandbox connection
    function verifyConnection() {
        const url = document.getElementById('apiEndpointUrl').value.trim();
        if (!url) {
            alert('Please specify the Endpoint URL before verification.');
            return;
        }

        const panel = document.getElementById('sandboxPanel');
        const badge = document.getElementById('sandboxStatusBadge');
        const logBox = document.getElementById('sandboxLogBox');

        panel.style.display = 'block';
        badge.className = 'badge badge-warning';
        badge.innerText = 'PENDING';
        logBox.innerText = 'Initializing Outbound request execution...\nResolving placeholder configurations...';

        const fd = buildFormDataPayload();
        fetch('/settings/http-api/verify', {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                badge.className = 'badge badge-success';
                badge.innerText = 'SUCCESS (' + data.statusCode + ')';
                
                let headersStr = '';
                for (const [k, v] of Object.entries(data.responseHeaders)) {
                    headersStr += `${k}: ${v.join(', ')}\n`;
                }

                logBox.innerText = `[SUCCESS] Request Executed Successfully!\n` +
                                   `Target URL: ${data.interpolatedUrl}\n` +
                                   `Status Code: ${data.statusCode}\n\n` +
                                   `--- RESPONSE HEADERS ---\n${headersStr}\n` +
                                   `--- RESPONSE BODY ---\n${data.responseBody}`;
            } else {
                badge.className = 'badge badge-danger';
                badge.innerText = 'ERROR';
                logBox.innerText = `[FAILURE] Connection Test Failed!\nTarget URL: ${data.interpolatedUrl || url}\nError details:\n${data.error}`;
            }
        })
        .catch(e => {
            badge.className = 'badge badge-danger';
            badge.innerText = 'EXCEPTION';
            logBox.innerText = `[EXCEPTION] Client Error:\n${e.message}`;
        });
    }

    // Export payload file
    function exportConnection(id) {
        fetch(`/settings/http-api/export/${id}`)
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(data.config, null, 4));
                const dlAnchorElem = document.createElement('a');
                dlAnchorElem.setAttribute("href", dataStr);
                dlAnchorElem.setAttribute("download", `http_api_config_${id}.json`);
                dlAnchorElem.click();
            } else {
                alert('Export failed: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('An error occurred during export.');
        });
    }

    // Import Modals Control
    function openImportModal() {
        document.getElementById('importJsonTextarea').value = '';
        document.getElementById('importModal').style.display = 'flex';
    }
    function closeImportModal() {
        document.getElementById('importModal').style.display = 'none';
    }

    function submitImport() {
        const json = document.getElementById('importJsonTextarea').value.trim();
        if (!json) {
            alert('Pasting JSON payload is required.');
            return;
        }

        const fd = new FormData();
        fd.append('configJson', json);

        fetch('/settings/http-api/import', {
            method: 'POST',
            body: fd
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                window.location.reload();
            } else {
                alert('Import failed: ' + data.error);
            }
        })
        .catch(e => {
            console.error(e);
            alert('Failed to import JSON payload.');
        });
    }

    // Reports/Logs Modal Control
    function openLogsModal() {
        const tableBody = document.getElementById('logsTableBody');
        tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-muted);">Fetching latest audit trails...</td></tr>';
        
        document.getElementById('logsModal').style.display = 'flex';

        fetch('/settings/http-api/logs')
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                tableBody.innerHTML = '';
                if (data.logs.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-muted);">No call logs recorded yet.</td></tr>';
                    return;
                }

                data.logs.forEach(log => {
                    const tr = document.createElement('tr');
                    const statusClass = (log.status >= 200 && log.status < 300) ? 'badge-success' : 'badge-danger';
                    
                    tr.innerHTML = `
                        <td style="font-size:12px; color:var(--text-muted);">${log.createdAt}</td>
                        <td style="font-weight:600;">${escapeHtml(log.apiName)}</td>
                        <td>${escapeHtml(log.subscriber)}</td>
                        <td>
                            <span class="badge ${statusClass}">
                                ${log.status || 'ERROR'}
                            </span>
                        </td>
                        <td style="font-weight:700; font-size:11px;">${log.method}</td>
                        <td style="font-family:monospace; font-size:11.5px; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${log.url}">
                            ${log.url}
                        </td>
                        <td>
                            <button class="btn-glass" style="padding: 4px 8px; font-size: 11px;" onclick='showLogDetails(${JSON.stringify(log)})'>
                                View Logs
                            </button>
                        </td>
                    `;
                    tableBody.appendChild(tr);
                });
            } else {
                tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--error-color);">Failed to load logs.</td></tr>';
            }
        })
        .catch(e => {
            tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--error-color);">Connection error loading logs.</td></tr>';
        });
    }

    function closeLogsModal() {
        document.getElementById('logsModal').style.display = 'none';
    }

    function showLogDetails(log) {
        document.getElementById('logDetailsTitle').innerText = `${log.apiName} Audit Log (${log.method})`;
        document.getElementById('logDetailsUrl').innerText = log.url;
        
        let requestStr = JSON.stringify(log.payload, null, 4);
        document.getElementById('logDetailsRequest').innerText = requestStr;

        let responseStr = '';
        if (log.error) {
            responseStr = `[CLIENT EXCEPTION/TIMEOUT]\n${log.error}`;
        } else {
            responseStr = `Status: ${log.status}\n\n--- HEADERS ---\n${JSON.stringify(log.responseHeaders, null, 4)}\n\n--- BODY ---\n${log.responseBody}`;
        }
        document.getElementById('logDetailsResponse').innerText = responseStr;

        document.getElementById('logDetailsModal').style.display = 'flex';
    }

    function closeLogDetailsModal() {
        document.getElementById('logDetailsModal').style.display = 'none';
    }

    function insertVariable(text) {
        const textarea = document.getElementById('bodyRawText');
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const value = textarea.value;
        
        textarea.value = value.substring(0, start) + text + value.substring(end);
        
        // Put cursor right after the inserted text
        textarea.selectionStart = textarea.selectionEnd = start + text.length;
        textarea.focus();
    }

    function filterVariables() {
        const search = document.getElementById('variableSearch').value.toLowerCase();
        const btns = document.querySelectorAll('.variable-btn');
        btns.forEach(btn => {
            if (btn.innerText.toLowerCase().includes(search)) {
                btn.style.display = 'flex';
            } else {
                btn.style.display = 'none';
            }
        });
    }
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}HTTP API Integrations - OpenSquadron{% endblock %}

{% block body %}
<style>
    /* Styling extension matching open squadron glassmorphism */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }
    .page-title {
        font-size: 24px;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #fff, var(--primary-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .action-group {
        display: flex;
        gap: 12px;
    }
    .btn-glass {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .btn-glass:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-1px);
    }
    .btn-primary-accent {
        background: rgba(6, 182, 212, 0.15);
        border: 1px solid var(--primary-accent);
        color: var(--primary-accent);
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.1);
    }
    .btn-primary-accent:hover {
        background: rgba(6, 182, 212, 0.25);
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.2);
    }
    /* Light mode: all ghost btn-glass elements must use dark text */
    body[data-theme="light"] .btn-glass {
        color: var(--text-main) !important;
        background: rgba(15, 23, 42, 0.05) !important;
        border-color: rgba(15, 23, 42, 0.18) !important;
    }
    body[data-theme="light"] .btn-glass:hover {
        background: rgba(15, 23, 42, 0.1) !important;
        border-color: rgba(15, 23, 42, 0.28) !important;
    }
    body[data-theme="light"] .btn-glass.btn-primary-accent {
        color: var(--primary-accent) !important;
        background: rgba(8, 145, 178, 0.1) !important;
        border-color: var(--primary-accent) !important;
    }
    body[data-theme="light"] .btn-glass.btn-success {
        color: #fff !important;
        background: #059669 !important;
        border-color: #059669 !important;
    }
    body[data-theme="light"] .btn-glass.btn-success:hover {
        background: #047857 !important;
        border-color: #047857 !important;
    }
    body[data-theme="light"] .btn-glass.btn-danger {
        color: #b91c1c !important;
        background: #fef2f2 !important;
        border-color: #fca5a5 !important;
    }
    .btn-success {
        border-color: #059669;
        color: #fff;
        background: #059669;
        box-shadow: 0 2px 8px rgba(5, 150, 105, 0.25);
    }
    .btn-success:hover {
        background: #047857;
        border-color: #047857;
        box-shadow: 0 4px 14px rgba(5, 150, 105, 0.35);
    }
    .btn-danger {
        border-color: var(--error-color);
        color: var(--error-color);
        background: rgba(239, 68, 68, 0.08);
    }
    .btn-danger:hover {
        background: rgba(239, 68, 68, 0.18);
    }
    
    /* Table Filter styling */
    .filter-panel {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
        padding: 18px 25px;
        margin-bottom: 25px;
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .filter-group label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        font-weight: 600;
    }
    .glass-input {
        box-sizing: border-box;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 9px 14px;
        border-radius: 8px;
        font-size: 13px;
        outline: none;
        transition: all 0.3s;
        min-width: 150px;
    }
    .glass-input:focus {
        border-color: var(--primary-accent);
        box-shadow: 0 0 10px rgba(6, 182, 212, 0.15);
    }
    /* Light mode input override */
    body[data-theme="light"] .glass-input {
        background: #fff !important;
        border: 1px solid rgba(15, 23, 42, 0.2) !important;
        color: var(--text-main) !important;
    }
    body[data-theme="light"] .glass-input::placeholder {
        color: #94a3b8 !important;
    }

    /* Grid cards layout */
    .grid-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
    }
    @media (min-width: 1200px) {
        .grid-container.has-form {
            grid-template-columns: 1.2fr 0.8fr;
        }
    }
    
    .panel-card {
        padding: 25px;
        margin-bottom: 30px;
    }
    .panel-card-title {
        font-size: 18px;
        font-weight: 600;
        margin-top: 0;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 12px;
    }

    /* Table styling */
    .glass-table-wrapper {
        overflow-x: auto;
        border-radius: 12px;
    }
    .glass-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 13.5px;
    }
    .glass-table th, .glass-table td {
        padding: 14px 18px;
        border-bottom: 1px solid var(--glass-border);
    }
    .glass-table th {
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-muted);
        font-weight: 600;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .glass-table tr:hover td {
        background: rgba(255, 255, 255, 0.01);
    }
    
    .badge {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
    }
    .badge-success { background: rgba(16, 185, 129, 0.15); color: var(--secondary-accent); border: 1px solid rgba(16, 185, 129, 0.3); }
    .badge-warning { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .badge-danger { background: rgba(239, 68, 68, 0.15); color: var(--error-color); border: 1px solid rgba(239, 68, 68, 0.3); }
    .badge-info { background: rgba(6, 182, 212, 0.15); color: var(--primary-accent); border: 1px solid rgba(6, 182, 212, 0.3); }
    
    /* Connection builder details */
    .form-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    @media (min-width: 768px) {
        .form-row.two-cols { grid-template-columns: 1fr 1fr; }
        .form-row.three-cols { grid-template-columns: 1.2fr 0.8fr 1fr; }
    }
    
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .form-group label {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--text-main);
    }
    
    /* Sub grids (Headers/Cookies) dynamic row container */
    .dynamic-grid-box {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
    }
    .dynamic-grid-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }
    .dynamic-grid-title {
        font-size: 13.5px;
        font-weight: 600;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .dynamic-row {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 12px;
        margin-bottom: 10px;
        align-items: center;
    }
    
    /* Radio Selector */
    .radio-pill-group {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        background: rgba(15, 23, 42, 0.5);
        padding: 5px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        width: fit-content;
    }
    .radio-pill {
        display: none;
    }
    .radio-pill-label {
        padding: 6px 14px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s;
    }
    .radio-pill:checked + .radio-pill-label {
        background: var(--primary-accent);
        color: #fff;
        box-shadow: 0 0 10px rgba(6, 182, 212, 0.3);
    }
    
    /* Sandbox response drawer */
    .sandbox-panel {
        margin-top: 25px;
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(6, 182, 212, 0.3);
        border-radius: 12px;
        padding: 20px;
        display: none;
    }
    .sandbox-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--primary-accent);
        margin-top: 0;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .sandbox-log-box {
        font-family: monospace;
        font-size: 12.5px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 15px;
        color: #e2e8f0;
        max-height: 250px;
        overflow-y: auto;
        white-space: pre-wrap;
    }
    
    /* Beautiful Modal style */
    .glass-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .glass-modal-content {
        width: 100%;
        max-width: 900px;
        max-height: 85vh;
        overflow-y: auto;
        padding: 30px;
        position: relative;
    }
    .glass-modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 24px;
        transition: all 0.2s;
    }
    .glass-modal-close:hover {
        color: #fff;
    }
    
    /* Helper list details */
    .instruction-alert {
        background: rgba(245, 158, 11, 0.05);
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #f59e0b;
        padding: 15px 20px;
        border-radius: 12px;
        font-size: 13px;
        margin-bottom: 25px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }
    
    .call-stats {
        display: flex;
        gap: 12px;
        font-size: 12px;
    }
    .stat-circle {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    
    @media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }
        .action-group {
            flex-direction: column;
            width: 100%;
        }
        .action-group .btn-glass {
            width: 100%;
            justify-content: center;
        }
        .filter-panel {
            flex-direction: column;
            align-items: stretch;
            padding: 15px;
            gap: 12px;
        }
        .filter-group {
            width: 100%;
        }
        .filter-group .glass-input {
            min-width: 0;
            width: 100%;
        }
        .panel-card {
            padding: 15px;
            margin-bottom: 20px;
            min-width: 0;
            overflow: hidden;
        }
        .panel-card-title {
            font-size: 16px;
            margin-bottom: 15px;
        }
        .glass-table th, .glass-table td {
            padding: 10px 12px;
        }
        .dynamic-row {
            grid-template-columns: 1fr;
            gap: 8px;
            background: rgba(255, 255, 255, 0.02);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid var(--glass-border);
        }
        .dynamic-row .btn-danger {
            justify-content: center;
            width: 100%;
        }
        .dynamic-row .glass-input {
            min-width: 0;
            width: 100%;
        }
        .radio-pill-group {
            width: 100%;
            justify-content: center;
        }
        .glass-modal-content {
            padding: 20px 15px;
            margin: 10px;
        }
        .glass-modal-close {
            top: 15px;
            right: 15px;
        }
        .sandbox-log-box {
            padding: 10px;
            font-size: 11.5px;
        }
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Global HTTP API Manager</h1>
        <p style="color: var(--text-muted); margin: 5px 0 0 0; font-size: 14px;">Connect, configure, and dynamically call third-party HTTP integrations globally.</p>
    </div>
    <div class="action-group">
        <button class="btn-glass btn-primary-accent" onclick="showFormCard()">
            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Create API
        </button>
        <button class="btn-glass" onclick="openImportModal()">
            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><polyline points="9 15 12 12 15 15"></polyline></svg>
            Import payload
        </button>
        <button class="btn-glass btn-success" onclick="openLogsModal()">
            <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            HTTP API Report
        </button>
    </div>
</div>

<div class="grid-container" id="mainGrid">
    <!-- List panel -->
    <div class="panel-card glass-panel" id="listColumn">
        <div class="panel-card-title">
            <span>Connected HTTP APIs</span>
        </div>
        
        <!-- Filter bar -->
        <form class="filter-panel glass-panel" method="GET" action="{{ path('app_http_api_index') }}">
            <div class="filter-group">
                <label>Status</label>
                <select name="status" class="glass-input" onchange="this.form.submit()">
                    <option value="all" {% if status == 'all' %}selected{% endif %}>Any Status</option>
                    <option value="active" {% if status == 'active' %}selected{% endif %}>Active</option>
                    <option value="inactive" {% if status == 'inactive' %}selected{% endif %}>Inactive</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Verification</label>
                <select name="verified" class="glass-input" onchange="this.form.submit()">
                    <option value="all" {% if verified == 'all' %}selected{% endif %}>Any Verification</option>
                    <option value="verified" {% if verified == 'verified' %}selected{% endif %}>Verified</option>
                    <option value="unverified" {% if verified == 'unverified' %}selected{% endif %}>Unverified</option>
                </select>
            </div>
            <div class="filter-group" style="flex-grow: 1;">
                <label>Search</label>
                <div style="position: relative; width: 100%; box-sizing: border-box;">
                    <input type="text" name="search" class="glass-input" placeholder="Search & Enter..." value="{{ search }}" style="width: 100%;">
                    {% if search %}
                        <a href="{{ path('app_http_api_index', {status: status, verified: verified}) }}" style="position: absolute; right: 12px; top: 10px; color: var(--text-muted); font-size: 14px; text-decoration: none;"><svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></a>
                    {% endif %}
                </div>
            </div>
        </form>
        
        <div class="glass-table-wrapper">
            <table class="glass-table">
                <thead>
                    <tr>
                        <th style="width: 40px;">#</th>
                        <th>API Name</th>
                        <th>Endpoint URL</th>
                        <th>Status</th>
                        <th>Verified</th>
                        <th>Call Counters</th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for api in httpApis %}
                        <tr id="api-row-{{ api.id }}">
                            <td style="color: var(--text-muted);">{{ loop.index }}</td>
                            <td style="font-weight: 600;">{{ api.name }}</td>
                            <td style="font-family: monospace; font-size: 12px; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                {{ api.endpointUrl }}
                            </td>
                            <td>
                                {% if api.status == 'active' %}
                                    <span class="badge badge-success">Active</span>
                                {% else %}
                                    <span class="badge badge-warning">Inactive</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if api.isVerified %}
                                    <span class="badge badge-success">Verified</span>
                                {% else %}
                                    <span class="badge badge-danger">Unverified</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="call-stats">
                                    <span class="stat-circle" title="Total calls">
                                        <svg viewBox="0 0 24 24" style="width: 14px; height: 14px; color: var(--text-muted);" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg> {{ api.totalCall }}
                                    </span>
                                    <span class="stat-circle" style="color: var(--secondary-accent);" title="Successful calls">
                                        <svg viewBox="0 0 24 24" style="width: 14px; height: 14px; margin-right: 2px;" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg> {{ api.totalSuccess }}
                                    </span>
                                    <span class="stat-circle" style="color: var(--error-color);" title="Error calls">
                                        <svg viewBox="0 0 24 24" style="width: 14px; height: 14px; margin-right: 2px;" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg> {{ api.totalError }}
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <button class="btn-glass" style="padding: 5px 10px; font-size: 12px;" onclick="editConnection({{ api|json_encode|e('html_attr') }})">
                                        Edit
                                    </button>
                                    <button class="btn-glass btn-danger" style="padding: 5px 10px; font-size: 12px;" onclick="deleteConnection({{ api.id }})">
                                        Delete
                                    </button>
                                    <button class="btn-glass" style="padding: 5px 10px; font-size: 12px; border-color: rgba(255,255,255,0.15);" onclick="exportConnection({{ api.id }})">
                                        Export
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" style="text-align: center; color: var(--text-muted); padding: 40px 0;">
                                No HTTP API connections found. Click "Create API" to connect your first endpoint!
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    </div>
</div>

<!-- API Connection Form Modal -->
<div class="glass-modal" id="apiFormModal" style="align-items: flex-start; padding: 40px 20px;" onclick="if(event.target===this)hideFormCard()">
    <div class="glass-modal-content glass-panel" style="max-width: 900px; width: 100%; max-height: 90vh; display: flex; flex-direction: column; position: relative; padding: 0; overflow: hidden;">
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 20px 25px 15px; border-bottom: 1px solid var(--glass-border); flex-shrink: 0;">
            <h2 id="formTitle" style="margin: 0; font-size: 20px; color: var(--primary-accent); font-weight: 700;">API Connection Details</h2>
            <span class="glass-modal-close" onclick="hideFormCard()" style="position: relative; top: auto; right: auto;"><svg viewBox="0 0 24 24" style="width: 20px; height: 20px;" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></span>
        </div>

        <div style="flex: 1; overflow-y: auto; padding: 20px 25px;">

        <div class="instruction-alert" style="margin-bottom: 20px;">
            <span><svg viewBox="0 0 24 24" style="width: 18px; height: 18px;" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6"></path><path d="M10 22h4"></path><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A6 6 0 1 0 7.5 11.5c.76.76 1.23 1.52 1.41 2.5"></path></svg></span>
            <div>
                <strong>Placeholder Support:</strong> You can parse subscriber variables in URLs, Headers, Queries, and Body Data using:
                <div style="font-family: monospace; font-size: 11.5px; margin-top: 5px; color: #f59e0b;">
                    &#123;&#123;subscriber.name&#125;&#125;, &#123;&#123;subscriber.phone_number&#125;&#125;, &#123;&#123;subscriber.psid&#125;&#125;, &#123;&#123;subscriber.custom_attributes.YOUR_KEY&#125;&#125;
                </div>
            </div>
        </div>

        <form id="connectionForm" onsubmit="event.preventDefault();">
            <input type="hidden" name="id" id="apiId">
            <input type="hidden" name="channel" id="apiChannel" value="global">

            <div class="form-row two-cols">
                <div class="form-group">
                    <label>API Name *</label>
                    <input type="text" name="name" id="apiName" class="glass-input" required placeholder="e.g. Stripe Webhook, Log Engine">
                </div>
                <div class="form-group">
                    <label>Method *</label>
                    <select name="method" id="apiMethod" class="glass-input">
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="PATCH">PATCH</option>
                        <option value="DELETE">DELETE</option>
                    </select>
                </div>
            </div>

            <div class="form-row two-cols">
                <div class="form-group">
                    <label>Endpoint URL *</label>
                    <input type="url" name="endpointUrl" id="apiEndpointUrl" class="glass-input" required placeholder="https://api.yourdomain.com/v1/trigger">
                </div>
                <div class="form-group">
                    <label>Test Subscriber ID (For verifying placeholders)</label>
                    <input type="text" name="testSubscriberId" id="apiTestSubscriberId" class="glass-input" placeholder="Subscriber ID or Phone or PSID">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Status</label>
                    <select name="status" id="apiStatus" class="glass-input">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <!-- Dynamic Headers box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title"><svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg> Header Data</span>
                    <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('headers')">+ Add</button>
                </div>
                <div id="headersGridContainer"></div>
            </div>

            <!-- Dynamic Queries box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title"><svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg> Option Data (Query Parameters)</span>
                    <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('options')">+ Add</button>
                </div>
                <div id="optionsGridContainer"></div>
            </div>

            <!-- Dynamic Cookies box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title"><svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="8"></line><line x1="16" y1="12" x2="16" y2="12"></line><line x1="9" y1="13" x2="9" y2="13"></line></svg> Cookie Data</span>
                    <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('cookies')">+ Add</button>
                </div>
                <div id="cookiesGridContainer"></div>
            </div>

            <!-- Body Selector box -->
            <div class="dynamic-grid-box">
                <div class="dynamic-grid-header">
                    <span class="dynamic-grid-title"><svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg> Body Data</span>
                    <div class="radio-pill-group">
                        <input type="radio" name="bodyType" id="bodyDefault" value="DEFAULT" class="radio-pill" checked onchange="toggleBodySection()">
                        <label for="bodyDefault" class="radio-pill-label">DEFAULT</label>

                        <input type="radio" name="bodyType" id="bodyFormData" value="FORM-DATA" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyFormData" class="radio-pill-label">FORM-DATA</label>

                        <input type="radio" name="bodyType" id="bodyUrlEncoded" value="X-WWW-FORM-URLENCODED" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyUrlEncoded" class="radio-pill-label">X-WWW-FORM-URLENCODED</label>

                        <input type="radio" name="bodyType" id="bodyJson" value="JSON" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyJson" class="radio-pill-label">JSON</label>

                        <input type="radio" name="bodyType" id="bodyBinary" value="BINARY" class="radio-pill" onchange="toggleBodySection()">
                        <label for="bodyBinary" class="radio-pill-label">BINARY</label>
                    </div>
                </div>

                <div id="bodyDataGridContainer" style="display: none; margin-top: 15px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <span style="font-size: 12.5px; color: var(--text-muted);">Form parameters</span>
                        <button type="button" class="btn-glass" style="padding: 4px 10px; font-size: 12px;" onclick="addGridRow('bodyData')">+ Add Row</button>
                    </div>
                    <div id="bodyParamsRows"></div>
                </div>

                <div id="bodyDataTextContainer" style="display: none; margin-top: 15px;">
                    <div style="display: flex; flex-wrap: wrap; gap: 15px;">
                        <div style="flex: 1 1 300px; min-width: 0;">
                            <textarea id="bodyRawText" class="glass-input" style="width: 100%; min-height: 220px; height: 100%; font-family: monospace; resize: vertical;" placeholder="Enter raw request body content..."></textarea>
                        </div>
                        <div class="glass-panel" style="flex: 0 0 250px; padding: 12px; max-height: 220px; overflow-y: auto; background: rgba(0,0,0,0.15); border: 1px solid var(--glass-border); border-radius: 8px;">
                            <div style="font-size: 11px; font-weight: bold; margin-bottom: 10px; color: var(--primary-accent); display: flex; align-items: center; gap: 4px;">
                                <svg viewBox="0 0 24 24" style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                                AVAILABLE VARIABLES
                            </div>
                            <div style="margin-bottom: 8px;">
                                <input type="text" id="variableSearch" class="glass-input" style="width: 100%; font-size: 11px; padding: 6px 10px;" placeholder="Search variables..." onkeyup="filterVariables()">
                            </div>
                            <div class="variable-list" style="display: flex; flex-direction: column; gap: 5px;">
                                <button type="button" class="btn-glass variable-btn" onclick="insertVariable('{{ '{{subscriber.name}}' }}')" style="padding: 6px; font-size: 11px; font-family: monospace; text-align: left; justify-content: flex-start;">{{ '{{subscriber.name}}' }}</button>
                                <button type="button" class="btn-glass variable-btn" onclick="insertVariable('{{ '{{subscriber.phone_number}}' }}')" style="padding: 6px; font-size: 11px; font-family: monospace; text-align: left; justify-content: flex-start;">{{ '{{subscriber.phone_number}}' }}</button>
                                <button type="button" class="btn-glass variable-btn" onclick="insertVariable('{{ '{{subscriber.psid}}' }}')" style="padding: 6px; font-size: 11px; font-family: monospace; text-align: left; justify-content: flex-start;">{{ '{{subscriber.psid}}' }}</button>
                                <button type="button" class="btn-glass variable-btn" onclick="insertVariable('{{ '{{subscriber.custom_attributes.KEY}}' }}')" style="padding: 6px; font-size: 11px; font-family: monospace; text-align: left; justify-content: flex-start; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="Replace KEY with your custom attribute name">{{ '{{subscriber.custom_attributes.KEY}}' }}</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="bodyBinaryContainer" style="display: none; margin-top: 15px;">
                    <div class="form-row three-cols" style="background: rgba(0,0,0,0.15); border: 1px solid var(--glass-border); border-radius: 8px; padding: 15px;">
                        <div class="form-group">
                            <label style="color: var(--primary-accent); font-size: 11px;">BODY : KEY *</label>
                            <input type="text" id="binaryKey" class="glass-input" placeholder="Key">
                        </div>
                        <div class="form-group">
                            <label style="color: var(--primary-accent); font-size: 11px;">BODY : TYPE *</label>
                            <select id="binaryType" class="glass-input">
                                <option value="File Upload">File Upload</option>
                                <option value="Raw Data">Raw Data</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label style="color: var(--primary-accent); font-size: 11px;">BODY : VALUE *</label>
                            <input type="text" id="binaryValue" class="glass-input" placeholder="File URL or raw value">
                        </div>
                    </div>
                </div>
            </div>

            <div class="sandbox-panel" id="sandboxPanel">
                <h4 class="sandbox-title">
                    <span style="display: flex; align-items: center; gap: 6px;"><svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16"></path><path d="M12 2v20"></path><path d="M8 18h8"></path><path d="M17 11.95V12a1 1 0 0 1-1 1h-2"></path><path d="M12 6a4 4 0 0 1 4 4v1"></path><path d="M8 12v-1a4 4 0 0 1 4-4"></path></svg> Connection Sandbox Log</span>
                    <span id="sandboxStatusBadge" class="badge">PENDING</span>
                </h4>
                <div class="sandbox-log-box" id="sandboxLogBox">Firing connection test...</div>
            </div>

        </form>

        </div><!-- end scrollable body -->

        <!-- Sticky footer -->
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 25px; border-top: 1px solid var(--glass-border); flex-shrink: 0; background: rgba(0,0,0,0.2);">
            <button type="button" class="btn-glass btn-primary-accent" style="border-color: #f59e0b; color: #f59e0b; background: rgba(245, 158, 11, 0.08); display: inline-flex; align-items: center; gap: 6px;" onclick="verifyConnection()">
                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg> Verify Connection
            </button>
            <button type="button" class="btn-glass btn-success" style="display: inline-flex; align-items: center; gap: 6px;" onclick="saveConnection()">
                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg> Save Connection
            </button>
        </div>
    </div>
</div>

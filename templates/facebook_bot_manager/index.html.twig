{% extends 'base.html.twig' %}

{% block title %}Facebook Bot Console - OpenSquadron{% endblock %}

{% block stylesheets %}
<style>
    /* Premium Two-column layout */
    .manager-shell {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 30px;
        margin-top: 20px;
        min-height: calc(100vh - 180px);
    }

    /* Grouped Left Nav Sidebar Panel */
    .manager-nav {
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 20px 15px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        height: fit-content;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    }
    .manager-nav .nav-header {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 1px;
        margin-top: 14px;
        margin-bottom: 6px;
        padding-left: 12px;
        opacity: 0.8;
    }
    .manager-nav .nav-header:first-of-type {
        margin-top: 0;
    }
    .manager-nav .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 10px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
        cursor: pointer;
        user-select: none;
    }
    .manager-nav .nav-item:hover {
        color: var(--text-main);
        background: rgba(255, 255, 255, 0.04);
        transform: translateX(2px);
    }
    .manager-nav .nav-item.is-active {
        color: var(--text-main);
        background: rgba(6, 182, 212, 0.12);
        border-color: rgba(6, 182, 212, 0.25);
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.08);
    }
    .manager-nav .nav-item-icon {
        font-size: 16px;
        display: flex;
        align-items: center;
    }
    .manager-nav .nav-item-icon svg {
        width: 16px;
        height: 16px;
    }
    .manager-nav .nav-item-status {
        margin-left: auto;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.05);
        letter-spacing: 0.2px;
    }
    .manager-nav .nav-item.is-active .nav-item-status {
        background: rgba(6, 182, 212, 0.25);
        color: var(--primary-accent);
    }

    /* Right Content Panels */
    .manager-content-pane {
        display: none;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 30px;
        flex-direction: column;
        gap: 24px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .manager-content-pane.is-active {
        display: flex;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed var(--glass-border);
        padding-bottom: 18px;
    }
    .content-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .content-title svg {
        width: 24px;
        height: 24px;
        color: var(--primary-accent);
    }
    .content-subtitle {
        font-size: 15px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* Glass Console Grid Hub */
    .console-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-top: 10px;
    }
    .console-card {
        background: rgba(30, 41, 59, 0.3);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .console-card:hover {
        background: rgba(30, 41, 59, 0.55);
        border-color: rgba(6, 182, 212, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(6, 182, 212, 0.08);
    }
    .console-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.6), transparent);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .console-card:hover::before {
        opacity: 1;
    }
    .console-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .console-icon-wrapper {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        background: rgba(6, 182, 212, 0.1);
        border: 1px solid rgba(6, 182, 212, 0.2);
        color: var(--primary-accent);
        transition: all 0.2s;
    }
    .console-card:hover .console-icon-wrapper {
        background: var(--primary-accent);
        color: #0f172a;
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
    }
    .console-icon-wrapper svg {
        width: 20px;
        height: 20px;
    }
    .console-card-title {
        font-size: 16px;
        font-weight: 700;
        color: #f8fafc;
    }
    .console-card-status {
        margin-left: auto;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-muted);
    }
    .console-card:hover .console-card-status {
        background: rgba(6, 182, 212, 0.2);
        color: var(--primary-accent);
    }
    .console-card-desc {
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.5;
        flex: 1;
    }
    .console-card-action {
        font-size: 14px;
        font-weight: 600;
        color: var(--primary-accent);
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 5px;
    }
    .console-card-action svg {
        width: 14px;
        height: 14px;
        transition: transform 0.2s;
    }
    .console-card:hover .console-card-action svg {
        transform: translateX(3px);
    }

    /* Premium forms and inputs */
    .glass-form-card {
        background: rgba(15, 23, 42, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .form-label {
        font-size: 15px;
        font-weight: 600;
        color: #cbd5e1;
    }
    .form-helper {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.4;
    }
    .glass-input, .glass-textarea {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 10px 14px;
        color: #fff;
        font-size: 15px;
        outline: none;
        transition: all 0.2s;
    }
    .glass-input:focus, .glass-textarea:focus {
        border-color: var(--primary-accent);
        box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
    }
    .glass-textarea {
        resize: vertical;
        min-height: 100px;
    }

    /* Mobile Chat Preview Layout (Highly Premium) */
    .preview-container {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
    }
    .form-side {
        flex: 1;
        min-width: 320px;
    }
    .preview-side {
        width: 300px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
    .iphone-shell {
        width: 270px;
        height: 480px;
        border: 8px solid #334155;
        border-radius: 36px;
        background: #0f172a;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .iphone-header {
        height: 44px;
        background: #1e293b;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
    }
    .iphone-body {
        flex: 1;
        padding: 15px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: radial-gradient(circle at top, #1e293b, #0f172a);
    }
    .iphone-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-top: 40px;
        gap: 15px;
    }
    .iphone-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--primary-accent);
        display: grid;
        place-items: center;
        color: #0f172a;
        font-weight: 800;
        font-size: 24px;
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.3);
    }
    .iphone-page-name {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
    }
    .iphone-page-desc {
        font-size: 11px;
        color: var(--text-muted);
    }
    .iphone-welcome-bubble {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 12px;
        font-size: 12px;
        color: #e2e8f0;
        line-height: 1.5;
        text-align: left;
        width: 100%;
        max-height: 180px;
        overflow-y: auto;
    }
    .iphone-footer {
        display: flex;
        flex-direction: column;
        gap: 10px;
        width: 100%;
        margin-bottom: 5px;
    }
    .iphone-btn-started {
        background: var(--primary-accent);
        color: #0f172a;
        font-size: 12px;
        font-weight: 700;
        padding: 10px;
        border-radius: 8px;
        text-align: center;
        width: 100%;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(6, 182, 212, 0.25);
    }

    /* Table, list and checklist components */
    .table-container {
        overflow-x: auto;
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.15);
    }
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 15px;
    }
    .custom-table th {
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid var(--glass-border);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 13px;
        color: var(--text-muted);
        letter-spacing: 0.5px;
    }
    .custom-table td {
        padding: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-main);
        vertical-align: middle;
    }
    .custom-table tr:last-child td {
        border-bottom: none;
    }
    .custom-table tr:hover td {
        background: rgba(255, 255, 255, 0.01);
    }

    /* Toolbar search and filter Row */
    .toolbar-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }
    .toolbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        max-width: 600px;
    }
    .toolbar-search {
        position: relative;
        flex: 1;
    }
    .toolbar-search input {
        width: 100%;
        padding: 10px 14px 10px 36px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        font-size: 15px;
        color: #fff;
        outline: none;
        transition: all 0.2s;
    }
    .toolbar-search input:focus {
        border-color: var(--primary-accent);
        box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
    }
    .toolbar-search .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 14px;
        height: 14px;
        stroke: #fff;
        opacity: 0.5;
        pointer-events: none;
        fill: none;
        stroke-width: 2.2;
    }
    .toolbar-select {
        padding: 10px 14px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        font-size: 15px;
        color: #fff;
        outline: none;
        cursor: pointer;
        min-width: 140px;
    }

    .btn-action {
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent;
        color: #fff;
        text-decoration: none;
        user-select: none;
    }
    .btn-create {
        background: var(--primary-accent);
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.2);
    }
    .btn-create:hover {
        background: #0891b2;
        transform: translateY(-1px);
    }
    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    /* Switch toggle */
    .switch-toggle {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 22px;
        vertical-align: middle;
    }
    .switch-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        transition: .3s;
        border-radius: 34px;
    }
    .slider-round:before {
        position: absolute;
        content: "";
        height: 14px;
        width: 14px;
        left: 3px;
        bottom: 3px;
        background-color: #64748b;
        transition: .3s;
        border-radius: 50%;
    }
    .switch-toggle input:checked + .slider-round {
        background-color: rgba(6, 182, 212, 0.2);
        border-color: rgba(6, 182, 212, 0.4);
    }
    .switch-toggle input:checked + .slider-round:before {
        transform: translateX(22px);
        background-color: var(--primary-accent);
    }

    .keyword-tag {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 6px;
        background: rgba(6, 182, 212, 0.1);
        border: 1px solid rgba(6, 182, 212, 0.2);
        color: var(--primary-accent);
        font-size: 13px;
        font-weight: 600;
        margin-right: 4px;
        margin-bottom: 4px;
    }
    .match-mode-badge {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.05);
        padding: 2px 6px;
        border-radius: 4px;
        display: inline-block;
        margin-top: 4px;
    }

    .row-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .btn-row-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        cursor: pointer;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-muted);
        transition: all 0.15s;
        text-decoration: none;
    }
    .btn-row-action:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.15);
    }
    .btn-row-action.edit-action:hover {
        border-color: var(--primary-accent);
        color: var(--primary-accent);
        background: rgba(6, 182, 212, 0.05);
    }
    .btn-row-action.delete-action:hover {
        border-color: #ef4444;
        color: #ef4444;
        background: rgba(239, 68, 68, 0.05);
    }
    .btn-row-action.clone-action:hover {
        border-color: #f59e0b;
        color: #f59e0b;
        background: rgba(245, 158, 11, 0.05);
    }
    .btn-row-action.export-action:hover {
        border-color: #10b981;
        color: #10b981;
        background: rgba(16, 185, 129, 0.05);
    }

    .no-data-row {
        text-align: center;
        color: var(--text-muted);
        padding: 40px !important;
        font-style: italic;
    }

    .fb-toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #0f172a;
        color: #ffffff;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s, transform 0.25s;
        z-index: 10000;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        border: 1px solid var(--glass-border);
    }
    .fb-toast.is-shown { opacity: 1; transform: translateX(-50%) translateY(0); }
    .fb-toast.is-success { border-left: 4px solid #10b981; }
    .fb-toast.is-error { border-left: 4px solid #ef4444; }

    select.form-control option, select.toolbar-select option, select option {
        background-color: #0f172a !important;
        color: #f8fafc !important;
    }

    .sidebar-mobile-toggle {
        display: none;
    }

    @media (max-width: 768px) {
        .sidebar-mobile-toggle {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            padding: 10px 14px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            border: 1px solid var(--glass-border);
        }
        
        .manager-nav:not(.is-open) > :not(.sidebar-mobile-toggle) {
            display: none !important;
        }
        
        .manager-nav.is-open .sidebar-mobile-toggle svg:last-of-type {
            transform: rotate(180deg);
        }
        
        .manager-shell {
            grid-template-columns: 1fr;
            gap: 20px;
            margin-top: 15px;
        }
        
        .manager-nav {
            padding: 15px;
            gap: 8px;
        }
        
        .manager-content-pane {
            padding: 12px 10px !important;
            min-width: 0;
            overflow: hidden;
            gap: 16px;
        }
        
        .content-header {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
            padding-bottom: 12px;
        }
        
        .content-header .row-actions, .content-header div:last-child {
            width: 100%;
        }
        
        .content-header .btn-action {
            width: 100%;
            justify-content: center;
        }
        
        .console-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .toolbar-row {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }
        
        .toolbar-left {
            flex-direction: column;
            align-items: stretch;
            width: 100%;
            max-width: none;
            gap: 10px;
        }
        
        .toolbar-search {
            width: 100%;
        }
        
        .toolbar-select {
            width: 100%;
        }
        
        .btn-create, .btn-action {
            width: 100%;
            justify-content: center;
        }
        
        .preview-container {
            flex-direction: column-reverse;
            align-items: center;
            gap: 25px;
        }
        
        .form-side {
            width: 100%;
            min-width: 0;
        }
        
        .preview-side {
            width: 100%;
            align-items: center;
        }
        
        .custom-table th, .custom-table td {
            padding: 10px 12px;
            font-size: 13.5px;
        }
        
        .templates-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .form-row {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .glass-form-card {
            padding: 12px !important;
            gap: 15px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="manager-shell">
    {# ───────── Left Sidebar Navigation (Logical Groups) ───────── #}
    <div class="manager-nav">
        <div class="sidebar-mobile-toggle">
            <span>
                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke-width: 2.5;"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                Menu Options
            </span>
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="nav-header">Facebook Page</div>
        <div style="margin-bottom: 10px; padding: 0 10px;">
            <select id="facebook-conn-selector" class="form-control" style="background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); color: #fff; padding: 8px 12px; border-radius: 8px; font-size: 15px; width: 100%; height: 38px;" onchange="changeConnection(this.value)">
                {% if connections is empty %}
                    <option value="">No Pages Connected</option>
                {% else %}
                    {% for conn in connections %}
                        <option value="{{ conn.id }}" {% if connection and connection.id == conn.id %}selected{% endif %}>
                            {{ conn.label ?: conn.pageName ?: 'Unnamed Page (' ~ conn.id ~ ')' }}
                        </option>
                    {% endfor %}
                {% endif %}
            </select>
        </div>

        <!-- 1. General Panel -->
        <div class="nav-header">Main Console</div>
        <div class="nav-item is-active" data-tab-target="console">
            <span class="nav-item-icon">

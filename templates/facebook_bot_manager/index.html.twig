                    <label class="form-label" for="welcome-payload">Get Started Trigger Payload</label>
                    <div class="form-helper" style="margin-bottom: 4px;">The postback identifier triggered when a user selects the "Get Started" prompt button.</div>
                    <input type="text" id="welcome-payload" class="glass-input" style="font-family:monospace;" value="{{ settings['welcome-screen'].getStartedPayload }}">

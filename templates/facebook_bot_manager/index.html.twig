        {% endif %}
    </div>

</div>

<div id="toast" class="fb-toast">Message</div>

<script>
    const activeConnectionId = '{{ connection ? connection.id : "" }}';

    function showToast(msg, type = 'success') {
        const el = document.getElementById('toast');
        el.textContent = msg;
        el.className = 'fb-toast is-shown ' + (type === 'success' ? 'is-success' : 'is-error');
        setTimeout(() => el.classList.remove('is-shown'), 3000);
    }

    // Save Unified Settings AJAX Helper
    function postSettingsSave(type, dataStructure) {
        if (!activeConnectionId) {
            showToast('Please connect a Facebook page first.', 'error');
            return;
        }

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);
        formData.append('type', type);
        formData.append('data', JSON.stringify(dataStructure));

        fetch('{{ path('app_facebook_bot_save_settings') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Settings saved successfully!', 'success');
            } else {
                showToast('Failed to save settings: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Save error: ' + err.message, 'error'));
    }

    // 4. Postbacks Saver
    function addPostbackRow() {
        const tr = document.createElement('tr');
        tr.className = 'postback-row';
        tr.innerHTML = `
            <td><input type="text" class="glass-input postback-name" style="width:100%"></td>
            <td><input type="text" class="glass-input postback-payload" style="width:100%; font-family:monospace;"></td>
            <td><input type="text" class="glass-input postback-action" style="width:100%"></td>
            <td>
                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </td>
        `;
        document.querySelector('#postbacks-table tbody').appendChild(tr);
    }

    function savePostbacks() {
        const rows = [];
        document.querySelectorAll('.postback-row').forEach(tr => {
            const name = tr.querySelector('.postback-name').value.trim();
            const payload = tr.querySelector('.postback-payload').value.trim();
            const action = tr.querySelector('.postback-action').value.trim();
            if (name !== '' && payload !== '') {
                rows.push({ name, payload, action });
            }
        });
        postSettingsSave('postbacks', rows);
    }

    // 5. Growth Widget Previewer & Saver
    function updateWidgetPreview() {
        const type = document.getElementById('widget-type').value;
        const color = document.getElementById('widget-color').value;
        const size = document.getElementById('widget-size').value;

        const mockInline = document.getElementById('mock-inline-widget');
        const mockFloating = document.getElementById('mock-floating-widget');
        const mockCheckbox = document.getElementById('mock-checkbox-accent');

        if (type === 'checkbox') {
            mockInline.style.display = 'flex';
            mockFloating.style.display = 'none';
            if (mockCheckbox) mockCheckbox.style.accentColor = color;
        } else {
            mockInline.style.display = 'none';
            mockFloating.style.display = 'grid';
            mockFloating.style.backgroundColor = color;
            mockFloating.style.transform = size === 'large' ? 'scale(1.15)' : 'scale(1.0)';
        }

        const embedCode = `<!-- OpenSquadron Messenger Growth Widget Embed -->\n<div class="opensquadron-messenger-widget"\n  data-page-id="${activeConnectionId}"\n  data-widget-type="${type}"\n  data-color="${color}"\n  data-size="${size}">\n</div>\n<script src="https://opensquadron.io/js/widget.js" async defer><\/script>`;
        const textarea = document.getElementById('widget-embed-code');
        if (textarea) textarea.value = embedCode;
    }

    function saveGrowthWidgets() {
        const type = document.getElementById('widget-type').value;
        const color = document.getElementById('widget-color').value;
        const size = document.getElementById('widget-size').value;
        const domains = document.getElementById('widget-domains').value.trim();
        postSettingsSave('growth-widgets', { widgetType: type, color, size, domains });
    }

    // 6. Drip Sequences Saver
    function addSequenceRow() {
        const tr = document.createElement('tr');
        tr.className = 'sequence-row';
        tr.innerHTML = `
            <td><input type="text" class="glass-input seq-name" style="width:100%"></td>
            <td>
                <select class="glass-input seq-delay" style="width:100%">
                    <option value="1 hour">1 Hour Delay</option>
                    <option value="4 hours">4 Hours Delay</option>
                    <option value="24 hours" selected>24 Hours (Next Day)</option>
                    <option value="72 hours">72 Hours Delay</option>
                </select>
            </td>
            <td style="text-align: center;">
                <label class="switch-toggle">
                    <input type="checkbox" class="seq-active" checked>
                    <span class="slider-round"></span>
                </label>
            </td>
            <td>

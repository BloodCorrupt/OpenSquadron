        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="postbacks-table">
                    <thead>
                        <tr>
                            <th>Postback Action Label</th>
                            <th>Custom Payload Reference</th>
                            <th>Trigger Action Description</th>
                            <th style="width: 80px;">Action</th>
                        </tr>

                    </div>
                    <div class="iphone-body">
                        <div class="iphone-content" id="preview-greeting-container">
                            <div class="iphone-avatar">
                                {{ connection ? connection.pageName|default('F')|slice(0,1)|upper : 'F' }}
                            </div>
                            <div class="iphone-page-name">{{ connection ? connection.pageName ?: 'Facebook Page' : 'Facebook Page' }}</div>
                            <div class="iphone-page-desc">Authorized OpenSquadron Integration</div>
                            
                            <div class="iphone-welcome-bubble" id="preview-greeting-bubble">
                                Welcome to OpenSquadron! Tap Get Started to explore our automated integrations.
                            </div>
                        </div>
                        
                        <div class="iphone-footer">
                            <div class="iphone-btn-started">Get Started</div>
                            <div style="font-size:8px; color:var(--text-muted); text-align:center; line-height:1.3; width:100%;">Clicking Get Started triggers the welcome webhook callback.</div>

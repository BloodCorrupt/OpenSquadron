    function toggleMenuValInput(select) {
        const row = select.closest('tr');
        const valInput = row.querySelector('.menu-val');
        if (select.value === 'web_url') {
            valInput.placeholder = 'e.g. https://yoursite.com';
            valInput.type = 'url';
        } else {
            valInput.placeholder = 'e.g. PAYLOAD_KEY';
            valInput.type = 'text';
        }
    }

    function savePersistentMenu() {
        const rows = [];
        document.querySelectorAll('.menu-row').forEach(tr => {
            const title = tr.querySelector('.menu-title').value.trim();
            const type = tr.querySelector('.menu-type').value;
            const val = tr.querySelector('.menu-val').value.trim();
            if (title !== '' && val !== '') {
                if (type === 'postback') {
                    rows.push({ title, type, payload: val });
                } else {
                    rows.push({ title, type, url: val });
                }
            }
        });
        postSettingsSave('persistent-menu', rows);
    }


<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}OpenSquadron{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-gradient-start: #0f172a;
            --bg-gradient-end: #1e293b;
            --topbar-bg: rgba(15, 23, 42, 0.7);
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --primary-accent: #06b6d4; /* Cyan */
            --secondary-accent: #10b981; /* Emerald */
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --menu-hover-bg: rgba(255, 255, 255, 0.05);
            --menu-active-color: var(--primary-accent);
            --error-color: #ef4444;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="is-embedded" style="background: transparent; margin: 0; padding: 0; overflow: hidden; height: 100vh;">
    {% block body %}{% endblock %}
    {% block javascripts %}{% endblock %}
</body>
</html>

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}OpenSquadron{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-gradient-start: #0f172a;
            --bg-gradient-end: #1e293b;
            --topbar-bg: rgba(15, 23, 42, 0.7);
            --glass-bg: rgba(15, 23, 42, 0.45);
            --glass-border: rgba(255, 255, 255, 0.04);
            --primary-accent: #06b6d4; /* Cyan */
            --secondary-accent: #10b981; /* Emerald */
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --text-header: #ffffff;
            --menu-hover-bg: rgba(255, 255, 255, 0.05);
            --menu-active-color: var(--primary-accent);
            --error-color: #ef4444;

            --dropdown-bg: rgba(15, 23, 42, 0.95);
            --select-bg: rgba(15, 23, 42, 0.6);
            --select-options-bg: rgba(11, 19, 41, 0.95);
            --select-text: #ffffff;
            --select-option-hover: rgba(56, 189, 248, 0.12);
            --select-option-selected: rgba(56, 189, 248, 0.2);
        }
        body[data-theme="light"] {
            --bg-gradient-start: #f8fafc;
            --bg-gradient-end: #e2e8f0;
            --topbar-bg: rgba(255, 255, 255, 0.75);
            --glass-bg: rgba(255, 255, 255, 0.65);
            --glass-border: rgba(15, 23, 42, 0.08);
            --primary-accent: #0891b2;
            --secondary-accent: #059669;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --text-header: #0f172a;
            --menu-hover-bg: rgba(15, 23, 42, 0.05);
            --menu-active-color: var(--primary-accent);
            --error-color: #ef4444;

            --dropdown-bg: rgba(255, 255, 255, 0.98);
            --select-bg: rgba(255, 255, 255, 0.8);
            --select-options-bg: rgba(255, 255, 255, 0.98);
            --select-text: #1e293b;
            --select-option-hover: rgba(8, 145, 178, 0.08);
            --select-option-selected: rgba(8, 145, 178, 0.15);
        }
        /* ─── Visually Hidden Native Select ─── */
        .hidden-native-select {
            position: absolute !important;
            width: 1px !important;
            height: 1px !important;
            padding: 0 !important;
            margin: -1px !important;
            overflow: hidden !important;
            clip: rect(0, 0, 0, 0) !important;
            white-space: nowrap !important;
            border: 0 !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }

        /* ─── Custom Glass Select Replacement ─── */
        .custom-glass-select-wrapper {
            position: relative;
            display: block;
            width: 100%;
            font-family: 'Inter', sans-serif;
            box-sizing: border-box;
            vertical-align: middle;
        }
        .custom-glass-select-trigger {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            min-height: 42px;
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid var(--glass-border);
            background-color: var(--select-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            color: var(--select-text);
            font-size: 14px;
            cursor: pointer;
            box-sizing: border-box;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
            user-select: none;
        }
        .custom-glass-select-trigger:hover {
            background-color: var(--select-bg);
            border-color: var(--primary-accent);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.15), inset 0 2px 4px rgba(0, 0, 0, 0.2);
        }
        .custom-glass-select-trigger:focus,
        .custom-glass-select-wrapper.is-active .custom-glass-select-trigger {
            border-color: var(--primary-accent);
            box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.25), inset 0 2px 4px rgba(0, 0, 0, 0.2);
            outline: none;
        }
        .custom-glass-select-label {
            flex: 1 !important;
            white-space: nowrap !important;
            overflow: hidden !important;
            text-overflow: ellipsis !important;
            text-align: left !important;
        }
        .custom-glass-select-chevron {
            flex-shrink: 0 !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            transition: transform 0.25s ease;
            color: var(--primary-accent);
            margin-left: 10px;
        }
        .custom-glass-select-wrapper.is-active .custom-glass-select-chevron {
            transform: rotate(180deg);
        }
        .custom-glass-select-options {
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            width: 100%;
            max-height: 260px;
            overflow-y: auto;
            background: var(--select-options-bg) !important;
            backdrop-filter: blur(24px) !important;
            -webkit-backdrop-filter: blur(24px) !important;
            border: 1px solid var(--glass-border) !important;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 20px rgba(6, 182, 212, 0.15) !important;
            z-index: 999999 !important;
            box-sizing: border-box;
            opacity: 0;
            transform: translateY(-10px);
            pointer-events: none;
            transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .custom-glass-select-wrapper.is-active .custom-glass-select-options {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }
        .custom-glass-select-option {
            padding: 11px 16px;
            font-size: 14px;
            color: var(--select-text);
            opacity: 0.8;
            cursor: pointer;
            transition: all 0.15s ease;
            border-left: 3px solid transparent;
            user-select: none;
            text-align: left;
        }
        .custom-glass-select-option:hover {
            background: var(--select-option-hover) !important;
            color: var(--select-text) !important;
            opacity: 1 !important;
            border-left-color: var(--primary-accent) !important;
            padding-left: 19px;
        }
        .custom-glass-select-option.is-selected {
            background: var(--select-option-selected) !important;
            color: var(--primary-accent) !important;
            opacity: 1 !important;
            font-weight: 600;
            border-left-color: var(--primary-accent) !important;
        }
        .custom-glass-select-group-label {
            padding: 8px 12px 4px 12px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(56, 189, 248, 0.6);
            font-weight: 700;
            user-select: none;
            pointer-events: none;
            text-align: left;
        }
        .custom-glass-select-options::-webkit-scrollbar {
            width: 6px;
        }
        .custom-glass-select-options::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }
        .custom-glass-select-options::-webkit-scrollbar-thumb {
            background: rgba(56, 189, 248, 0.3);
            border-radius: 10px;
        }
        .custom-glass-select-options::-webkit-scrollbar-thumb:hover {
            background: rgba(56, 189, 248, 0.5);
        }

        /* ─── Light Mode Global Overrides ─── */
        body[data-theme="light"] h1,
        body[data-theme="light"] h2,
        body[data-theme="light"] h3,
        body[data-theme="light"] h4,
        body[data-theme="light"] h5,
        body[data-theme="light"] h6,
        body[data-theme="light"] .content-title,
        body[data-theme="light"] .card-title,
        body[data-theme="light"] .section-title,
        body[data-theme="light"] .welcome-content h1,
        body[data-theme="light"] .metric-card-value,
        body[data-theme="light"] .stat-value,
        body[data-theme="light"] .switch-title,
        body[data-theme="light"] .form-title,
        body[data-theme="light"] .dialog-card h3,
        body[data-theme="light"] .indicator-label,
        body[data-theme="light"] .form-label,
        body[data-theme="light"] .console-card-title,
        body[data-theme="light"] .form-group label,
        body[data-theme="light"] .card-heading,
        body[data-theme="light"] .chart-heading,
        body[data-theme="light"] .channel-name,
        body[data-theme="light"] .matrix-value,
        body[data-theme="light"] .donut-center-val,
        body[data-theme="light"] .legend-counts,
        body[data-theme="light"] .queue-title,
        body[data-theme="light"] .activity-name,
        body[data-theme="light"] .activity-avatar,
        body[data-theme="light"] .welcome-panel h1,
        body[data-theme="light"] .welcome-panel p {
            color: var(--text-header) !important;
            background: none !important;
            -webkit-text-fill-color: var(--text-header) !important;
        }

        body[data-theme="light"] .welcome-content p {
            color: var(--text-muted) !important;
        }

        body[data-theme="light"] .card,
        body[data-theme="light"] .form-card,
        body[data-theme="light"] .manager-nav,
        body[data-theme="light"] .manager-content-pane,
        body[data-theme="light"] .stats-card,
        body[data-theme="light"] .channel-summary-card,
        body[data-theme="light"] .welcome-panel,
        body[data-theme="light"] .compact-metric-card,
        body[data-theme="light"] .console-card,
        body[data-theme="light"] .glass-form-card,
        body[data-theme="light"] .modal-content,
        body[data-theme="light"] .table-container {
            background: var(--glass-bg) !important;
            border-color: var(--glass-border) !important;
            color: var(--text-main) !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03) !important;
        }

        body[data-theme="light"] .channel-summary-card:hover,
        body[data-theme="light"] .compact-metric-card:hover,
        body[data-theme="light"] .console-card:hover,
        body[data-theme="light"] .queue-card:hover {
            background: rgba(255, 255, 255, 0.95) !important;
            border-color: var(--primary-accent) !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06) !important;
        }

        body[data-theme="light"] .channel-setup-matrix,
        body[data-theme="light"] .chart-legends,
        body[data-theme="light"] .activity-row {
            background: rgba(0, 0, 0, 0.02) !important;
            border-color: var(--glass-border) !important;
        }

        body[data-theme="light"] .activity-row:hover {
            background: rgba(0, 0, 0, 0.04) !important;
            border-color: var(--glass-border) !important;
        }

        body[data-theme="light"] .form-control,
        body[data-theme="light"] .glass-input,
        body[data-theme="light"] .glass-textarea,
        body[data-theme="light"] .toolbar-select,
        body[data-theme="light"] select,
        body[data-theme="light"] input,
        body[data-theme="light"] textarea {
            background: #ffffff !important;
            border: 1px solid rgba(0, 0, 0, 0.12) !important;
            color: var(--text-main) !important;
        }

        body[data-theme="light"] .form-control:focus,
        body[data-theme="light"] .glass-input:focus,
        body[data-theme="light"] .glass-textarea:focus,
        body[data-theme="light"] input:focus,
        body[data-theme="light"] textarea:focus {
            border-color: var(--primary-accent) !important;
            box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.15) !important;
        }

        body[data-theme="light"] .form-control::placeholder,
        body[data-theme="light"] .glass-input::placeholder,
        body[data-theme="light"] .glass-textarea::placeholder,
        body[data-theme="light"] input::placeholder,
        body[data-theme="light"] textarea::placeholder {
            color: var(--text-muted) !important;
            opacity: 0.8 !important;
        }

        body[data-theme="light"] select option,
        body[data-theme="light"] .toolbar-select option {
            background-color: #ffffff !important;
            color: var(--text-main) !important;
        }

        body[data-theme="light"] .custom-glass-select-trigger {
            background-color: #ffffff !important;
            color: var(--text-main) !important;
            border-color: rgba(0, 0, 0, 0.12) !important;
            box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.05) !important;
        }

        body[data-theme="light"] .custom-glass-select-options {
            background: #ffffff !important;
            border-color: rgba(0, 0, 0, 0.08) !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08) !important;
        }

        body[data-theme="light"] .custom-glass-select-option {
            color: var(--text-main) !important;
        }

        body[data-theme="light"] .custom-glass-select-option:hover {
            background: rgba(0, 0, 0, 0.03) !important;
        }

        body[data-theme="light"] .custom-glass-select-option.is-selected {
            background: rgba(8, 145, 178, 0.08) !important;
            color: var(--primary-accent) !important;
        }

        body[data-theme="light"] .custom-table th {
            background: rgba(0, 0, 0, 0.02) !important;
            color: var(--text-muted) !important;
            border-bottom: 1px solid rgba(0, 0, 0, 0.06) !important;
        }

        body[data-theme="light"] .custom-table td {
            border-bottom: 1px solid rgba(0, 0, 0, 0.04) !important;
            color: var(--text-main) !important;
        }

        body[data-theme="light"] .custom-table tr:hover td {
            background: rgba(0, 0, 0, 0.01) !important;
        }

        body[data-theme="light"] .toolbar-search .search-icon {
            stroke: var(--text-muted) !important;
        }

        body[data-theme="light"] .toolbar-search input {
            background: #ffffff !important;
            color: var(--text-main) !important;
            border-color: rgba(0, 0, 0, 0.12) !important;
        }

        body[data-theme="light"] .apexcharts-text,
        body[data-theme="light"] .apexcharts-legend-text,
        body[data-theme="light"] .apexcharts-title-text {
            fill: var(--text-main) !important;
            color: var(--text-main) !important;
        }

        body[data-theme="light"] .system-status-indicator,
        body[data-theme="light"] .metric-card-icon {
            background: rgba(0, 0, 0, 0.03) !important;
            border-color: var(--glass-border) !important;
        }

        body[data-theme="light"] .system-status-text {
            color: var(--text-main) !important;
        }

        body[data-theme="light"] .slider-round {
            background-color: rgba(0, 0, 0, 0.05) !important;
        }

        body[data-theme="light"] .manager-nav .nav-item:hover {
            background: rgba(0, 0, 0, 0.03) !important;
        }

        body[data-theme="light"] .manager-nav .nav-item-status {
            background: rgba(0, 0, 0, 0.05) !important;
            color: var(--text-muted) !important;
        }

        body[data-theme="light"] .manager-nav .nav-item.is-active .nav-item-status {
            background: rgba(16, 185, 129, 0.15) !important;
            color: var(--wa-primary) !important;
        }

        body[data-theme="light"] .system-pill-item {
            background: rgba(0, 0, 0, 0.03) !important;
            color: var(--text-muted) !important;
        }
        
        body[data-theme="light"] .activity-time,
        body[data-theme="light"] .queue-schedule,
        body[data-theme="light"] .stat-label,
        body[data-theme="light"] .channel-subtitle,
        body[data-theme="light"] .matrix-label {
            color: var(--text-muted) !important;
        }

        body[data-theme="light"] ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.02) !important;
        }
        body[data-theme="light"] ::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1) !important;
            border-color: rgba(0, 0, 0, 0.02) !important;
        }
        body[data-theme="light"] ::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.18) !important;
        }

        /* Extra overrides for inline styles & info boxes */
        body[data-theme="light"] .info-box {
            color: #0369a1 !important;
            background: rgba(6, 182, 212, 0.08) !important;
            border-color: rgba(6, 182, 212, 0.2) !important;
        }

        body[data-theme="light"] [style*="color:#fff"],
        body[data-theme="light"] [style*="color: #fff"],
        body[data-theme="light"] [style*="color:#ffffff"],
        body[data-theme="light"] [style*="color: #ffffff"] {
            color: var(--text-header) !important;
        }
    </style>
    {% block stylesheets %}{% endblock %}
    {% set custom_css = get_custom_css() %}
    {% if custom_css %}
        <style>
            {{ custom_css|raw }}
        </style>
    {% endif %}
</head>
<body class="is-embedded" style="background: transparent; margin: 0; padding: 0; overflow: hidden; height: 100vh;" {% if app.user and app.user.theme == 'light' %}data-theme="light"{% endif %}>
    {% block body %}{% endblock %}
    
    <script>
        // Custom select outside click handler
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.custom-glass-select-wrapper')) {
                document.querySelectorAll('.custom-glass-select-wrapper').forEach(w => {
                    w.classList.remove('is-active');
                });
            }
        });

        // ─── Custom Glass Select Replacement Script ───
        function initCustomSelect(select) {
            if (select.getAttribute('data-custom-select') === 'true') return;
            select.setAttribute('data-custom-select', 'true');

            let selectedOption = select.options[select.selectedIndex] || select.options[0];
            let triggerText = selectedOption ? selectedOption.textContent : '';

            const wrapper = document.createElement('div');
            wrapper.className = 'custom-glass-select-wrapper';
            
            const originalClasses = select.className.split(' ');
            originalClasses.forEach(cls => {
                if (cls && 
                    cls !== 'form-control' && 
                    cls !== 'hidden-native-select' && 
                    cls !== 'glass-input' && 
                    cls !== 'glass-select' &&
                    cls !== 'sidebar-select' &&
                    cls !== 'toolbar-select' &&
                    cls !== 'sidebar-filter-select' &&
                    !cls.startsWith('menu-') &&
                    !cls.startsWith('btn-') &&
                    !cls.startsWith('ui-') &&
                    !cls.startsWith('df-') &&
                    !cls.startsWith('bc-') &&
                    !cls.startsWith('seq-') &&
                    !cls.startsWith('rcn-') &&
                    !cls.startsWith('conn-') &&
                    !cls.endsWith('-type') &&
                    !cls.endsWith('-freq') &&
                    !cls.endsWith('-delay') &&
                    !cls.endsWith('-template') &&
                    !cls.endsWith('-status') &&
                    !cls.endsWith('-method') &&
                    !cls.endsWith('-trigger')
                ) {
                    wrapper.classList.add(cls);
                }
            });

            const trigger = document.createElement('div');
            trigger.className = 'custom-glass-select-trigger';
            trigger.setAttribute('tabindex', '0');
            
            const triggerLabel = document.createElement('span');
            triggerLabel.className = 'custom-glass-select-label';
            triggerLabel.textContent = triggerText;
            
            const triggerChevron = document.createElement('span');
            triggerChevron.className = 'custom-glass-select-chevron';
            triggerChevron.innerHTML = `<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'></polyline></svg>`;
            
            trigger.appendChild(triggerLabel);
            trigger.appendChild(triggerChevron);
            wrapper.appendChild(trigger);

            const optionsContainer = document.createElement('div');
            optionsContainer.className = 'custom-glass-select-options';
            wrapper.appendChild(optionsContainer);

            function buildOptions() {
                optionsContainer.innerHTML = '';
                const children = select.children;

                for (let i = 0; i < children.length; i++) {
                    const child = children[i];
                    if (child.tagName === 'OPTGROUP') {
                        const groupLabel = document.createElement('div');
                        groupLabel.className = 'custom-glass-select-group-label';
                        groupLabel.textContent = child.label;
                        optionsContainer.appendChild(groupLabel);

                        const groupOptions = child.querySelectorAll('option');
                        groupOptions.forEach(opt => {
                            createOptionItem(opt);
                        });
                    } else if (child.tagName === 'OPTION') {
                        createOptionItem(child);
                    }
                }
            }

            function createOptionItem(opt) {
                const optItem = document.createElement('div');
                optItem.className = 'custom-glass-select-option';
                optItem.textContent = opt.textContent;
                optItem.setAttribute('data-value', opt.value);
                
                if (opt.selected) {
                    optItem.classList.add('is-selected');
                }

                optItem.addEventListener('click', (e) => {
                    e.stopPropagation();
                    
                    select.value = opt.value;
                    select.dispatchEvent(new Event('change', { bubbles: true }));
                    select.dispatchEvent(new Event('input', { bubbles: true }));
                    
                    triggerLabel.textContent = opt.textContent;
                    optionsContainer.querySelectorAll('.custom-glass-select-option').forEach(item => {
                        item.classList.remove('is-selected');
                    });
                    optItem.classList.add('is-selected');
                    wrapper.classList.remove('is-active');
                });

                optionsContainer.appendChild(optItem);
            }

            buildOptions();

            trigger.addEventListener('click', (e) => {
                e.stopPropagation();
                const isActive = wrapper.classList.contains('is-active');
                
                document.querySelectorAll('.custom-glass-select-wrapper').forEach(w => {
                    w.classList.remove('is-active');
                });

                if (!isActive) {
                    buildOptions();
                    wrapper.classList.add('is-active');
                    
                    setTimeout(() => {
                        const rect = optionsContainer.getBoundingClientRect();
                        if (rect.bottom > window.innerHeight && rect.top > rect.height) {
                            optionsContainer.style.top = 'auto';
                            optionsContainer.style.bottom = 'calc(100% + 6px)';
                        } else {
                            optionsContainer.style.top = 'calc(100% + 6px)';
                            optionsContainer.style.bottom = 'auto';
                        }
                    }, 0);
                }
            });

            trigger.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    trigger.click();
                } else if (e.key === 'Escape') {
                    wrapper.classList.remove('is-active');
                }
            });

            select.addEventListener('change', () => {
                const activeOpt = select.options[select.selectedIndex];
                if (activeOpt) {
                    triggerLabel.textContent = activeOpt.textContent;
                    optionsContainer.querySelectorAll('.custom-glass-select-option').forEach(item => {
                        if (item.getAttribute('data-value') === activeOpt.value) {
                            item.classList.add('is-selected');
                        } else {
                            item.classList.remove('is-selected');
                        }
                    });
                }
            });

            select.parentNode.insertBefore(wrapper, select);
            select.classList.add('hidden-native-select');
            wrapper.appendChild(select);
        }

        function initAllCustomSelects() {
            document.querySelectorAll('select:not(.hidden-native-select)').forEach(select => {
                initCustomSelect(select);
            });
        }

        function setupCustomSelectMutationObserver() {
            const observer = new MutationObserver((mutations) => {
                let shouldInit = false;
                mutations.forEach(mutation => {
                    if (mutation.addedNodes.length) {
                        mutation.addedNodes.forEach(node => {
                            if (node.nodeType === Node.ELEMENT_NODE) {
                                if (node.tagName === 'SELECT' && !node.classList.contains('hidden-native-select')) {
                                    shouldInit = true;
                                } else if (node.querySelectorAll) {
                                    const found = node.querySelectorAll('select:not(.hidden-native-select)');
                                    if (found.length) {
                                        shouldInit = true;
                                    }
                                }
                            }
                        });
                    }
                });
                if (shouldInit) {
                    initAllCustomSelects();
                }
            });
            observer.observe(document.body, { childList: true, subtree: true });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                initAllCustomSelects();
                setupCustomSelectMutationObserver();
            });
        } else {
            initAllCustomSelects();
            setupCustomSelectMutationObserver();
        }
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>

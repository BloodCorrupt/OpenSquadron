{% extends 'base.html.twig' %}

{% block title %}Add New Account - OpenSquadron{% endblock %}

{% block body %}
<style>
    .form-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 35px;
        max-width: 600px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }
    .form-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 15px;
    }
    .form-title svg {
        width: 24px;
        height: 24px;
        stroke: var(--primary-accent);
    }
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 35px;
        border-top: 1px solid var(--glass-border);
        padding-top: 20px;
    }
    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: var(--text-muted);
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    
    /* Toggle switch component styling */
    .switch-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(0, 0, 0, 0.15);
        border: 1px solid var(--glass-border);
        padding: 16px;
        border-radius: 8px;
        margin-top: 10px;
    }
    .switch-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .switch-title {
        font-weight: 600;
        color: #fff;
        font-size: 14px;
    }
    .switch-description {
        font-size: 12px;
        color: var(--text-muted);
    }
    .switch-toggle {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }
    .switch-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.1);
        transition: .3s;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
    }
    .slider-round:before {
        position: absolute;
        content: "";
        height: 16px;
        width: 16px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .3s;
        border-radius: 50%;
    }
    .switch-toggle input:checked + .slider-round {
        background-color: var(--primary-accent);
    }
    .switch-toggle input:checked + .slider-round:before {
        transform: translateX(20px);
    }
    
    /* Field animation helper */
    .conditional-field {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        margin-bottom: 0;
    }
    .conditional-field.visible {
        max-height: 200px;
        opacity: 1;
        margin-bottom: 24px;
    }
</style>

<div class="header">
    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
    <h1>Create New Account</h1>
</div>

<div class="form-card">
    <div class="form-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        <span>Account Provisioning Portal</span>
    </div>

    <form action="{{ path('app_reseller_clients_new') }}" method="POST" autocomplete="off">
        {# Email Field #}
        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" class="form-control" placeholder="user@opensquadron.local" required autocomplete="off">
        </div>

        {# Password Field #}
        <div class="form-group">
            <label for="password">Security Password</label>
            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="new-password">
        </div>

        {# Account Type & Extra configurations (Only for System Admins) #}
        {% if currentUser.accountType in ['super_admin', 'admin'] %}
            <div class="form-group">
                <label for="account_type">Account Type</label>
                <select id="account_type" name="account_type" class="form-control" style="background-color: #0c111d; color: #fff; cursor: pointer;">
                    {% if currentUser.accountType == 'super_admin' %}
                        <option value="super_admin">Super Admin (Server Root)</option>
                        <option value="admin">Reseller Admin (Standalone Workspace)</option>
                    {% endif %}
                    <option value="user">User Account (Standalone Workspace)</option>
                    <option value="team" selected>Team Account (Sub-account of Owner)</option>
                </select>
            </div>

            {# Team Enabled Switch (Only applicable if 'User' is selected) #}
            <div id="team_support_field" class="conditional-field">
                <div class="switch-group">
                    <div class="switch-info">
                        <span class="switch-title">Team Support Features</span>
                        <span class="switch-description">Allows this user to create and delegate access to sub-accounts.</span>
                    </div>
                    <label class="switch-toggle">
                        <input type="checkbox" name="team_enabled" id="team_enabled" value="1">
                        <span class="slider-round"></span>
                    </label>
                </div>
            </div>

            {# Parent Selection Field (Only applicable if 'Team' is selected) #}
            <div id="parent_owner_field" class="form-group conditional-field visible">
                <label for="parent_id">Assign to Workspace</label>
                <select id="parent_id" name="parent_id" class="form-control" style="background-color: #0c111d; color: #fff; cursor: pointer;">
                    {% for owner in owners %}
                        <option value="{{ owner.id }}" {% if owner.id == currentUser.id %}selected{% endif %}>
                            {{ owner.email }} ({% if owner.accountType == 'super_admin' %}Super Admin{% elseif owner.accountType == 'admin' %}Reseller Admin{% else %}User{% endif %})
                        </option>
                    {% else %}
                        <option value="">No parent owners available - defaulting to yourself</option>
                    {% endfor %}
                </select>
            </div>
        {% else %}
            {# If the creator is a non-admin User with team support enabled #}
            <input type="hidden" name="account_type" value="team">
            <input type="hidden" name="parent_id" value="{{ currentUser.id }}">
        {% endif %}

        {# Action Buttons #}
        <div class="form-actions">
            <a href="{{ path('app_reseller_clients_index') }}" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Create Account</button>
        </div>
    </form>
</div>

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const accountTypeSelect = document.getElementById('account_type');
        const teamSupportField = document.getElementById('team_support_field');
        const parentOwnerField = document.getElementById('parent_owner_field');

        if (accountTypeSelect) {
            function updateFieldsVisibility() {
                const selectedType = accountTypeSelect.value;
                
                // Reset visibilities
                teamSupportField.classList.remove('visible');
                parentOwnerField.classList.remove('visible');

                if (selectedType === 'user') {
                    teamSupportField.classList.add('visible');
                } else if (selectedType === 'team') {
                    parentOwnerField.classList.add('visible');
                }
            }

            // Trigger initially on load
            updateFieldsVisibility();

            // Setup change listener
            accountTypeSelect.addEventListener('change', updateFieldsVisibility);
        }
    });
</script>
{% endblock %}
{% endblock %}

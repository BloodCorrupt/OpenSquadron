{% extends 'base.html.twig' %}

{% block title %}Account Management - OpenSquadron{% endblock %}

{% block body %}
<style>
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    .stat-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: transform 0.3s, border-color 0.3s;
    }
    .stat-card:hover {
        transform: translateY(-2px);
        border-color: var(--primary-accent);
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(6, 182, 212, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-accent);
    }
    .stat-icon.emerald {
        background: rgba(16, 185, 129, 0.1);
        color: var(--secondary-accent);
    }
    .stat-icon svg {
        width: 24px;
        height: 24px;
        stroke-width: 2.2;
    }
    .stat-info {
        display: flex;
        flex-direction: column;
    }
    .stat-number {
        font-size: 24px;
        font-weight: 700;
        color: #fff;
    }
    .stat-label {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 500;
        margin-top: 2px;
    }

    /* Table/List Styles */
    .accounts-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 30px;
    }
    .card-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }
    .account-table {
        width: 100%;
        border-collapse: collapse;
    }
    .account-table th {
        text-align: left;
        padding: 16px 20px;
        font-size: 13px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        border-bottom: 1px solid var(--glass-border);
    }
    .account-table td {
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-main);
        font-size: 15px;
        vertical-align: middle;
    }
    .account-table tr:last-child td {
        border-bottom: none;
    }
    .account-table tr:hover td {
        background-color: rgba(255, 255, 255, 0.01);
    }
    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
    }
    .role-badge.super-admin {
        background: rgba(139, 92, 246, 0.1);
        color: #8b5cf6;
        border: 1px solid rgba(139, 92, 246, 0.2);
    }
    .role-badge.admin {
        background: rgba(6, 182, 212, 0.1);
        color: var(--primary-accent);
        border: 1px solid rgba(6, 182, 212, 0.2);
    }
    .role-badge.user {
        background: rgba(16, 185, 129, 0.1);
        color: var(--secondary-accent);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .role-badge.team {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }
    
    .db-info {
        font-family: monospace;
        font-size: 13px;
        color: var(--text-muted);
        background: rgba(0, 0, 0, 0.15);
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid var(--glass-border);
    }
    
    .actions-cell {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }
    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }
    .btn-action:hover {
        background: rgba(6, 182, 212, 0.1);
        color: var(--primary-accent);
        border-color: var(--primary-accent);
        transform: scale(1.05);
    }
    .btn-action.delete:hover {
        background: rgba(239, 68, 68, 0.1);
        color: var(--error-color);
        border-color: var(--error-color);
    }
    
    @media (max-width: 768px) {
        .stats-row {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        .stat-card {
            padding: 16px;
        }
        .accounts-card {
            padding: 15px;
            min-width: 0;
            overflow: hidden;
        }
        .card-header-row {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }
        .card-header-row a.btn-primary {
            width: 100%;
            justify-content: center;
        }
        .account-table th, .account-table td {
            padding: 12px 10px;
            font-size: 13.5px;
        }
        .actions-cell {
            justify-content: flex-start;
        }
    }
</style>

<div class="header">
    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
    <h1>Client Management</h1>
</div>

{# Quick Metrics Summary Row #}
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
        </div>
        <div class="stat-info">
            <span class="stat-number">{{ accounts|length }}</span>
            <span class="stat-label">Total Accounts</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon emerald">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
        </div>
        <div class="stat-info">
            {% set workspace_count = 0 %}
            {% for acc in accounts %}
                {% if acc.parent is null %}
                    {% set workspace_count = workspace_count + 1 %}
                {% endif %}
            {% endfor %}
            <span class="stat-number">{{ workspace_count }}</span>
            <span class="stat-label">Isolated Workspaces</span>
        </div>
    </div>
</div>

<div class="accounts-card">
    <div class="card-header-row">
        <div style="font-size: 18px; font-weight: 600;">Registered Directory</div>
        <a href="{{ path('app_reseller_clients_new') }}" class="btn btn-primary" style="padding: 10px 20px; font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width: 16px; height: 16px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add New Account
        </a>
    </div>

    <div style="overflow-x: auto;">
        <table class="account-table">
            <thead>
                <tr>
                    <th>Email Address</th>
                    <th>Account Type</th>
                    <th>Team Support</th>
                    <th>Parent Owner</th>
                    {% if user.accountType == 'super_admin' %}
                        <th>Created By</th>
                    {% endif %}
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for acc in accounts %}
                    <tr>
                        <td style="font-weight: 600; color: #fff;">{{ acc.email }}</td>
                        <td>
                            {% if acc.accountType == 'super_admin' %}
                                <span class="role-badge super-admin">Super Admin</span>
                            {% elseif acc.accountType == 'admin' %}
                                <span class="role-badge admin">Reseller Admin</span>
                            {% elseif acc.accountType == 'user' %}
                                <span class="role-badge user">User</span>
                            {% else %}
                                <span class="role-badge team">Team</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if acc.accountType == 'team' %}
                                <span style="opacity: 0.3;">—</span>
                            {% else %}
                                <span style="color: {% if acc.teamEnabled %}var(--secondary-accent){% else %}var(--text-muted){% endif %}; font-weight: 600;">
                                    {% if acc.teamEnabled %}Enabled{% else %}Disabled{% endif %}
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if acc.parent %}
                                <span style="color: var(--text-muted); font-size: 14px;">{{ acc.parent.email }}</span>
                            {% else %}
                                <span style="opacity: 0.3;">—</span>
                            {% endif %}
                        </td>
                        {% if user.accountType == 'super_admin' %}
                        <td>
                            {% if acc.createdBy %}
                                <span style="color: var(--text-muted); font-size: 14px;">{{ acc.createdBy.email }}</span>
                            {% else %}
                                <span style="opacity: 0.3;">—</span>
                            {% endif %}
                        </td>
                        {% endif %}
                        <td class="actions-cell">
                            {% if acc.id == user.id %}
                                <span style="font-size: 12px; color: var(--primary-accent); font-weight: 600; padding: 8px 12px; background: rgba(6, 182, 212, 0.05); border-radius: 6px; border: 1px solid rgba(6, 182, 212, 0.1); margin-right: 8px; align-self: center;">You (Active)</span>
                            {% endif %}
                            
                            <a href="{% if acc.id == user.id %}{{ path('app_accounts_edit_self') }}{% else %}{{ path('app_reseller_clients_edit', {id: acc.id}) }}{% endif %}" class="btn-action" title="Edit Account">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                            </a>
                            
                            {% if acc.id != user.id %}
                                <form action="{{ path('app_reseller_clients_delete', {id: acc.id}) }}" method="POST" style="display: inline;" onsubmit="return confirm('Are you absolutely sure you want to delete this account? Warning: Deleting an owner will permanently destroy all their connected channels and bot flows!');">
                                    <button type="submit" class="btn-action delete" title="Delete Account" style="outline: none;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1-2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    </button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 40px 0;">No accounts found. Click "Add New Account" to populate this workspace.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

    function uploadMpcFile(file, statusElId, successCallback) {
        const statusEl = document.getElementById(statusElId);
        if (statusEl) {
            statusEl.style.display = 'block';
            statusEl.style.color = 'var(--text-muted)';
            statusEl.textContent = 'Preparing upload...';
        }

        fetch('{{ path('app_media_presign') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                filename: file.name,
                contentType: file.type,
                prefix: 'posts'
            })
        })
        .then(res => {
            if (!res.ok) {
                return res.json().then(errData => {
                    if (errData.code === 'R2_NOT_CONFIGURED') {
                        throw new Error('R2_NOT_CONFIGURED');
                    }
                    throw new Error(errData.error || 'Failed to get presigned upload URL.');
                });
            }
            return res.json();
        })
        .then(data => {
            if (statusEl) {
                statusEl.textContent = 'Uploading to Cloudflare R2...';
            }
            return fetch(data.uploadUrl, {
                method: 'PUT',
                headers: {
                    'Content-Type': file.type
                },
                body: file
            }).then(putRes => {
                if (!putRes.ok) {
                    throw new Error('Failed to upload file to storage bucket.');
                }
                return data.publicUrl;
            });
        })
        .then(publicUrl => {
            if (statusEl) {
                statusEl.style.color = '#10b981';
                statusEl.textContent = 'Upload successful!';
            }
            successCallback(publicUrl);
        })
        .catch(err => {
            if (err.message === 'R2_NOT_CONFIGURED') {
                if (statusEl) {
                    statusEl.textContent = 'Cloudflare R2 not configured. Uploading to local server...';
                }
                const formData = new FormData();
                formData.append('file', file);
                formData.append('prefix', 'posts');

                fetch('{{ path('app_media_upload_local') }}', {
                    method: 'POST',
                    body: formData
                })
                .then(res => {
                    if (!res.ok) {
                        return res.json().then(errData => {
                            throw new Error(errData.error || 'Failed to upload locally.');
                        });
                    }
                    return res.json();
                })
                .then(data => {
                    if (statusEl) {
                        statusEl.style.color = '#10b981';
                        statusEl.textContent = 'Upload successful (Local fallback)!';
                    }
                    successCallback(data.publicUrl);
                })
                .catch(localErr => {
                    if (statusEl) {
                        statusEl.style.color = '#f43f5e';
                        statusEl.textContent = 'Upload failed: ' + localErr.message;
                    }
                });
            } else {
                if (statusEl) {
                    statusEl.style.color = '#f43f5e';
                    statusEl.textContent = 'Upload failed: ' + err.message;
                }
            }
        });
    }

    function handleMpcImageUpload(input) {
        if (!input.files || input.files.length === 0) return;
        const file = input.files[0];
        if (mpcCarouselImages.length >= 10) {
            showToast('Maximum 10 images allowed.', 'error');
            return;
        }
        uploadMpcFile(file, 'mpc-image-upload-status', function(url) {
            mpcCarouselImages.push(url);
            renderCarouselList();
            updateMpcPreview();
        });
    }

    function handleMpcVideoUpload(input) {

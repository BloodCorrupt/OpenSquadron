    function saveMMEntry() {
        const index = parseInt(document.getElementById('mm-modal-index').value);
        const title = document.getElementById('mm-modal-title-input').value.trim();
        const payload = document.getElementById('mm-modal-payload').value.trim();
        
        if (!title || !payload) {
            showToast('Campaign Title and Payload are required', 'error');
            return;
        }
        
        const entry = {
            id: document.getElementById('mm-modal-id').value,
            title: title,
            frequency: document.getElementById('mm-modal-frequency').value,
            payload: payload,
            budgetCents: parseInt(document.getElementById('mm-modal-budget').value) || 0,
            imageUrl: document.getElementById('mm-modal-image').value.trim(),
            typingIndicator: document.getElementById('mm-modal-typing').checked,
            delayMinutes: parseInt(document.getElementById('mm-modal-delay-min').value) || 0,
            delaySeconds: parseInt(document.getElementById('mm-modal-delay-sec').value) || 0,
            linkedPostbackId: document.getElementById('mm-modal-linked-pb').value || '',
            status: 'draft',
            updatedAt: new Date().toISOString().slice(0, 19).replace('T', ' ')
        };
        
        if (index >= 0) {
            entry.stats = marketingMessages[index].stats;
            marketingMessages[index] = entry;
        } else {
            entry.stats = {subscribers: 0, sent: 0, delivered: 0, errors: 0};
            marketingMessages.push(entry);
        }
        
        postSettingsSave('marketing-messages', marketingMessages);
        closeMMModal();
        renderMMCards();
    }


    function removeFilterRule(btn) {
        const card = btn.closest('.filter-rule-card');
        if (card) {
            card.remove();
        }
    }

    function insertRulePlaceholder(btn, token) {
        const card = btn.closest('.filter-rule-card');
        if (!card) return;
        const textarea = card.querySelector('.rule-comment-reply-text');
        if (!textarea) return;
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;
        textarea.value = text.substring(0, start) + token + text.substring(end);
        textarea.focus();
        textarea.selectionStart = textarea.selectionEnd = start + token.length;
    }

    function populateModalSettings(s) {
        if (!s) s = {};
        document.getElementById('modal-offensive-hide').checked = s.hideOrDelete === 'hide';
        document.getElementById('modal-offensive-delete').checked = s.hideOrDelete === 'delete';
        document.getElementById('modal-offensive-keywords').value = s.offensiveKeywords || '';
        document.getElementById('modal-offensive-private-reply-flow-id').value = s.offensivePrivateReplyFlowId || '';
        document.getElementById('modal-send-multiple-times').checked = !!s.sendReplyMultipleTimes;
        document.getElementById('modal-enable-comment-reply').checked = s.enableCommentReply !== false;
        document.getElementById('modal-hide-comment-after-reply').checked = !!s.hideCommentAfterReply;
        document.getElementById('modal-campaign-name').value = s.campaignName || '';

        const mode = s.automationMode || 'generic';
        switchAutomationMode(mode);

        document.getElementById('modal-ai-context-id').value = s.aiContextId || '';
        document.getElementById('modal-ai-private-reply-flow-id').value = s.privateReplyFlowId || '';
        document.getElementById('modal-comment-reply-text').value = s.commentReplyText || '';
        document.getElementById('modal-generic-private-reply-flow-id').value = s.privateReplyFlowId || '';

        // Clear and rebuild filter rules
        const rulesContainer = document.getElementById('filter-rules-container');
        if (rulesContainer) {
            rulesContainer.innerHTML = '';
        }
        filterRuleCounter = 0;

        if (s.filterRules && Array.isArray(s.filterRules) && s.filterRules.length > 0) {
            s.filterRules.forEach(rule => {
                addFilterRuleRow(rule);
            });
        } else {
            // Check for legacy single-rule filter configuration
            if (s.filterWords) {
                addFilterRuleRow({
                    filterWords: s.filterWords,
                    filterMatchType: s.filterMatchType || 'exact',
                    commentReplyText: s.commentReplyText || '',
                    privateReplyFlowId: s.privateReplyFlowId || ''
                });
            } else {
                // If completely empty, add one row by default
                addFilterRuleRow();
            }
        }

        // Populate fallback settings
        const fallback = s.fallbackSettings || {};
        document.getElementById('modal-fallback-comment-reply-text').value = fallback.commentReplyText || '';
        document.getElementById('modal-fallback-private-reply-flow-id').value = fallback.privateReplyFlowId || '';
    }

    function switchAutomationMode(mode) {
        ['ai', 'generic', 'filter'].forEach(m => {
            const btn = document.getElementById('mode-btn-' + m);
            const panel = document.getElementById('panel-mode-' + m);
            if (btn) {
                if (m === mode) {
                    btn.classList.add('is-active');
                } else {
                    btn.classList.remove('is-active');
                }
            }
            if (panel) {
                panel.style.display = m === mode ? 'block' : 'none';
            }
        });
    }

    function insertPlaceholder(elemId, token) {
        const el = document.getElementById(elemId);
        if (!el) return;
        const start = el.selectionStart;
        const end = el.selectionEnd;
        const text = el.value;
        el.value = text.substring(0, start) + token + text.substring(end);
        el.focus();
        el.selectionStart = el.selectionEnd = start + token.length;
    }


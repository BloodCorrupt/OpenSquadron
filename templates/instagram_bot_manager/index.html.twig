    function publishMpcPost(tab) {
        const pageIds = getSelectedPageIds();
        if (pageIds.length === 0) {
            showToast('Please select at least one Instagram Page.', 'error');
            return;
        }

        const btn = document.getElementById('mpc-btn-submit-' + tab);
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span>Publishing...</span>';

        // Gather fields based on tab
        let message = '';
        let link = '';
        let mediaType = 'none';
        let mediaUrl = '';
        let type = 'multimedia';
        let slides = '[]';
        let postNow = true;

        if (tab === 'text') {
            message = document.getElementById('mpc-text-message')?.value?.trim() || '';
            postNow = document.getElementById('mpc-post-now-text')?.checked ?? true;
        } else if (tab === 'link') {
            message = document.getElementById('mpc-link-message')?.value?.trim() || '';
            link = document.getElementById('mpc-link-url')?.value?.trim() || '';
            postNow = document.getElementById('mpc-post-now-link')?.checked ?? true;
        } else if (tab === 'image') {
            message = document.getElementById('mpc-image-message')?.value?.trim() || '';
            const singleUrl = document.getElementById('mpc-image-url')?.value?.trim() || '';
            postNow = document.getElementById('mpc-post-now-image')?.checked ?? true;
            if (mpcCarouselImages.length > 1) {
                type = 'carousel';
                slides = JSON.stringify(mpcCarouselImages.map(url => ({ imageUrl: url, title: '' })));
            } else if (mpcCarouselImages.length === 1) {
                mediaType = 'image';
                mediaUrl = mpcCarouselImages[0];
            } else if (singleUrl) {
                mediaType = 'image';
                mediaUrl = singleUrl;
            }
        } else if (tab === 'video') {
            message = document.getElementById('mpc-video-message')?.value?.trim() || '';
            mediaUrl = document.getElementById('mpc-video-url')?.value?.trim() || '';
            mediaType = mediaUrl ? 'video' : 'none';
            postNow = document.getElementById('mpc-post-now-video')?.checked ?? true;
        }

        if (message === '' && mediaUrl === '' && link === '' && mpcCarouselImages.length === 0) {
            showToast('Please provide content for your post.', 'error');
            btn.disabled = false;
            btn.innerHTML = origHtml;
            return;
        }

        let scheduledTime = '';
        let timezone = 'UTC';
        if (!postNow) {
            scheduledTime = document.getElementById('mpc-schedule-time-' + tab)?.value || '';
            timezone = document.getElementById('mpc-timezone-' + tab)?.value || 'UTC';
            if (!scheduledTime) {
                showToast('Please select a schedule time or toggle Post Now.', 'error');
                btn.disabled = false;
                btn.innerHTML = origHtml;
                return;
            }
        }

        // Publish to each selected page
        const promises = pageIds.map(connId => {
            const formData = new FormData();
            formData.append('connectionId', connId);
            formData.append('type', type);
            formData.append('message', message);
            formData.append('link', link);
            formData.append('mediaType', mediaType);
            formData.append('mediaUrl', mediaUrl);
            formData.append('slides', slides);
            formData.append('publishNow', postNow ? 'true' : 'false');
            formData.append('scheduledTime', scheduledTime);
            formData.append('timezone', timezone);

            return fetch('{{ path('app_instagram_bot_posts_save') }}', {
                method: 'POST',
                body: formData
            }).then(res => res.json());
        });

        Promise.all(promises)
            .then(results => {
                const allSuccess = results.every(r => r.success);
                const anyFailed = results.some(r => r.post && r.post.status === 'failed');
                if (allSuccess && !anyFailed) {
                    showToast(`Post published to ${pageIds.length} page(s) successfully!`, 'success');
                    // Reset form
                    const textareaIds = ['mpc-text-message', 'mpc-link-message', 'mpc-image-message', 'mpc-video-message'];
                    textareaIds.forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
                    const inputIds = ['mpc-link-url', 'mpc-image-url', 'mpc-video-url'];
                    inputIds.forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
                    mpcCarouselImages.length = 0;
                    renderCarouselList();
                    updateMpcPreview();
                    loadRecentPosts(false);
                } else if (anyFailed) {
                    const failedMsg = results.filter(r => r.post?.status === 'failed').map(r => r.post.errorMessage).join('; ');
                    showToast('Some posts failed: ' + (failedMsg || 'Unknown API error'), 'error');
                    loadRecentPosts(false);
                } else {
                    showToast('Post saved.', 'success');
                    loadRecentPosts(false);
                }
            })
            .catch(err => showToast('Publish error: ' + err.message, 'error'))
            .finally(() => {
                btn.disabled = false;
                btn.innerHTML = origHtml;
            });
    }


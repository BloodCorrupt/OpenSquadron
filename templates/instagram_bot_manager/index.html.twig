        const container = document.getElementById('comment-posts-container');
        if (!container) return;
        if (filteredCommentPosts.length === 0) {
            container.innerHTML = `<div style="color: var(--text-muted); font-size: 13px; text-align: center; padding: 30px 0;">No posts found.</div>`;
            return;
        }
        let html = '';

                        {% if connections is not empty %}
                            {% for conn in connections %}
                            <div class="mpc-page-item {% if connection and connection.id == conn.id %}is-active{% endif %}" onclick="selectCommentAutomationConnection('{{ conn.id }}')" style="cursor: pointer; padding: 10px; border-radius: 8px; display: flex; align-items: center; gap: 10px; transition: all 0.2s; margin-bottom: 4px;" data-page-name="{{ conn.pageName|default('Page')|lower }}">
                                <div class="mpc-page-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary-accent); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px;">
                                    {{ conn.pageName|default('P')|slice(0,1)|upper }}
                                </div>
                                <div style="display: flex; flex-direction: column; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    <span class="mpc-page-name" style="font-weight: 600; font-size: 13px; color: var(--text-main);">{{ conn.pageName ?: conn.label ?: 'Page #' ~ conn.id }}</span>
                                    <span style="font-size: 10px; color: var(--text-muted);">{{ conn.pageId }}</span>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div style="color: var(--text-muted); font-size: 13px; text-align: center; padding: 20px 0;">No pages found</div>
                        {% endif %}
                    </div>
                </div>

                {# Middle Column: Full Page Settings & Metrics #}
                <div class="comment-middle-col" style="padding: 24px; display: flex; flex-direction: column; gap: 20px; overflow-y: auto; min-width: 0;">
                    {% if connection %}
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 22px; height: 22px; color: var(--primary-accent);"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                        <h2 id="comment-active-page-name" style="font-size: 18px; font-weight: 700; color: var(--text-main); margin: 0;">{{ connection.pageName }}</h2>
                    </div>

                    <!-- Metrics Counters -->
                    <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
                        <div class="glass-card" style="padding: 16px; display: flex; align-items: center; gap: 16px; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 12px;">
                            <div style="background: rgba(6,182,212,0.1); width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--primary-accent);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                            </div>
                            <div>
                                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted);">Auto Reply Enabled Posts</div>
                                <div style="font-size: 14px; font-weight: 700; color: var(--text-main); margin-top: 4px;">
                                    Active Campaigns: <span id="metric-reply-enabled-count" style="color:var(--primary-accent);">0</span>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card" style="padding: 16px; display: flex; align-items: center; gap: 16px; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 12px;">
                            <div style="background: rgba(59,130,246,0.1); width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #3b82f6;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                            </div>
                            <div>
                                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted);">Auto Comment Enabled Posts</div>
                                <div style="font-size: 14px; font-weight: 700; color: var(--text-main); margin-top: 4px;">
                                    Configured: <span id="metric-comment-enabled-count" style="color:#3b82f6;">0</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Full Page Campaign Card -->
                    <div class="glass-card" style="padding: 24px; text-align: center; border: 1px solid var(--glass-border); border-radius: 14px; background: rgba(15,23,42,0.4); display: flex; flex-direction: column; align-items: center; gap: 16px; margin-top: 10px;">
                        <div style="display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 15px; font-weight: 700; color: var(--text-main);">
                            <span>Full Page Campaigns</span>
                            <span id="full-page-status-badge" class="status-badge status-draft">Inactive</span>
                        </div>
                        
                        <div style="background: rgba(6,182,212,0.1); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary-accent); margin: 10px 0;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width: 40px; height: 40px;"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                        </div>

                        <!-- Switch Container -->
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                            <span style="font-size: 13px; font-weight: 600; color: var(--text-muted);">Enable Full Page Reply</span>
                            <label class="toggle-switch toggle-switch-blue">
                                <input type="checkbox" id="full-page-reply-switch" onchange="toggleFullPageReply(this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        
                        <button class="btn-action" style="background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); color: #fff; padding: 10px 20px; border-radius: 8px; border: none; font-weight: 600; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 8px; width: 100%; justify-content: center;" onclick="openFullPageSettingsModal()">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                            <span>Configure Reply</span>
                        </button>
                    </div>
                    
                    <div style="margin-top: auto; display: flex; justify-content: center;">
                        <div style="position: relative; display: inline-block;">
                            <button class="btn-action btn-secondary" style="font-size: 12px; padding: 8px 16px; display: flex; align-items: center; gap: 6px;" onclick="toggleCampaignReportDropdown(event)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                <span>See Campaign Reports</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:10px; height:10px;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </button>
                            <div id="comment-reports-dropdown" class="glass-card" style="display: none; position: absolute; bottom: 42px; left: 0; min-width: 180px; z-index: 100; padding: 8px; border: 1px solid var(--glass-border); background: rgba(30, 41, 59, 0.95); border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.5);">
                                <div style="padding: 6px 10px; font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 4px;">Reports</div>
                                <a href="#" onclick="alert('Auto reply reports functionality is active and tracked in system webhooks.')" style="display: block; padding: 6px 10px; font-size: 12px; color: var(--text-main); text-decoration: none; border-radius: 4px; transition: background 0.2s;">Auto Reply Report</a>
                                <a href="#" onclick="alert('Auto comment reports functionality is active and tracked in system webhooks.')" style="display: block; padding: 6px 10px; font-size: 12px; color: var(--text-main); text-decoration: none; border-radius: 4px; transition: background 0.2s;">Auto Comment Report</a>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div style="color: var(--text-muted); font-size: 14px; text-align: center; padding: 40px 0;">Please connect a page to get started.</div>
                    {% endif %}
                </div>

                {# Right Column: Latest Posts #}
                <div class="comment-right-col" style="padding: 20px; display: flex; flex-direction: column; gap: 16px; overflow-y: auto; min-width: 0;">
                    <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 4px;">
                        <div style="display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 14px; color: var(--text-main);">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px; color: var(--primary-accent);"><path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
                            <span>Latest Posts</span>
                        </div>
                        <button class="btn-action" style="font-size: 12px; padding: 6px 12px; display: flex; align-items: center; gap: 4px; border: 1px solid rgba(6,182,212,0.3); background: rgba(6,182,212,0.05); color: var(--primary-accent); border-radius: 6px;" onclick="openCampaignByIdModal()">
                            Set Campaign by ID
                        </button>
                    </div>

                    <!-- Post Search -->
                    <input type="text" class="modal-input" placeholder="Search..." id="comment-post-search" oninput="filterCommentPosts()" style="margin-bottom: 4px; font-size: 12px; height: 34px;">

                    <!-- Posts List Container -->
                    <div id="comment-posts-container" style="display: flex; flex-direction: column; gap: 10px;">
                        <!-- Dynamically rendered -->
                        <div style="color: var(--text-muted); font-size: 13px; text-align: center; padding: 30px 0;">Loading posts...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

{# â•â•â•â•â•â•â•â•â•â•â• Dialog Modals for Comment Automation â•â•â•â•â•â•â•â•â•â•â• #}

<!-- Manual Comment Modal -->
<div id="manual-comment-modal" class="modal-overlay">
    <div class="modal-card" style="max-width: 500px;">
        <div class="modal-header">
            <div class="modal-title">Send Manual Comment</div>
            <button class="modal-close-btn" onclick="closeManualCommentModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="manual-comment-graph-id" />
            <div style="margin-bottom: 16px;">
                <label class="switch-label" style="display: block; margin-bottom: 6px;">Your Comment *</label>
                <textarea id="manual-comment-text" class="modal-textarea" placeholder="Type your comment here..." style="min-height: 120px;"></textarea>
            </div>
        </div>
        <div class="modal-footer" style="display: flex; justify-content: flex-end; gap: 12px; padding-top: 16px; border-top: 1px solid var(--glass-border);">
            <button class="btn-action btn-secondary" onclick="closeManualCommentModal()">Cancel</button>
            <button class="btn-action btn-create" id="btn-send-manual-comment" onclick="submitManualComment()">Send Comment</button>
        </div>
    </div>
</div>

<!-- 1. Configuration Modal -->
<div id="comment-automation-modal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-header">
            <div class="modal-title" id="comment-modal-title">Configure Page-Level Comment Auto-Responder</div>
            <button class="modal-close-btn" onclick="closeCommentAutomationModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        <div class="modal-body">
            
            <!-- Offensive Comments Controls -->
            <div class="form-group-card">
                <div style="display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 13px; color: var(--text-main); margin-bottom: 12px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px; color: #ef4444;"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                    <span>Abusive Comment Moderation Filter</span>
                </div>
                
                <div class="form-group-grid" style="margin-bottom: 14px;">
                    <div class="switch-row">
                        <span class="switch-label">Automatically hide abusive comments</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="modal-offensive-hide" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="switch-row">
                        <span class="switch-label">Automatically delete abusive comments</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="modal-offensive-delete">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <div style="margin-bottom: 14px;">
                    <label class="switch-label" style="display: block; margin-bottom: 6px;">
                        Comma-separated blocked/abusive keywords
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:12px; height:12px; color:var(--primary-accent); cursor:help;" title="e.g. spam, scam, fake"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                    </label>
                    <textarea id="modal-offensive-keywords" class="modal-textarea" placeholder="Type keywords here in comma separated (keyword1,keyword2)...Keep it blank for no actions"></textarea>
                </div>

                <div>
                    <label class="switch-label" style="display: block; margin-bottom: 6px;">Private direct message to send after deleting/hiding</label>
                    <div style="display: flex; gap: 8px; align-items: center;">
                        <select id="modal-offensive-private-reply-flow-id" class="modal-input" style="flex: 1;">
                            <option value="">Choose a DM sequence</option>
                            {% for flow in flows %}
                                <option value="{{ flow.id }}">{{ flow.name }}</option>
                            {% endfor %}
                        </select>
                        <a href="{{ path('app_instagram_bot_flows') }}" target="_blank" style="font-size:11px; color:var(--primary-accent); text-decoration:none; font-weight:700;">+ Add Template</a>
                        <span style="font-size:11px; color:var(--text-muted); cursor:pointer; font-weight:700;" onclick="refreshFlowsList()">ðŸ”„ Refresh List</span>
                    </div>
                </div>
            </div>

            <!-- General Settings Toggles -->
            <div class="form-group-card">
                <div style="display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 13px; color: var(--text-main); margin-bottom: 12px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px; color: var(--primary-accent);"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    <span>General Settings</span>
                </div>
                <div class="form-group-grid">
                    <div class="switch-row">
                        <span class="switch-label">Allow repeat auto-replies to the same user?</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="modal-send-multiple-times">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="switch-row">
                        <span class="switch-label">Enable automated comment replies</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="modal-enable-comment-reply" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
                <div class="switch-row" style="margin-top: 14px;">
                    <span class="switch-label">Hide user's comment immediately after replying?</span>
                    <label class="toggle-switch">
                        <input type="checkbox" id="modal-hide-comment-after-reply">
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- Automation Modes Selector -->
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <span class="switch-label" style="font-weight: 700;">Select Auto-Responder Mode</span>
                
                <div class="mode-options-bar">
                    <div class="mode-option-btn" id="mode-btn-ai" onclick="switchAutomationMode('ai')">
                        <div class="mode-option-radio"></div>
                        <span class="mode-option-text">AI-Powered Response</span>
                    </div>
                    <div class="mode-option-btn" id="mode-btn-generic" onclick="switchAutomationMode('generic')">
                        <div class="mode-option-radio"></div>
                        <span class="mode-option-text">Static Universal Reply</span>
                    </div>
                    <div class="mode-option-btn" id="mode-btn-filter" onclick="switchAutomationMode('filter')">
                        <div class="mode-option-radio"></div>
                        <span class="mode-option-text">Keyword/Phrase Triggered Reply</span>
                    </div>
                </div>
            </div>

            <!-- Dynamic Input Panels based on Mode -->
            
            <!-- Panel 1: AI reply -->
            <div id="panel-mode-ai" class="form-group-card" style="display: none;">
                <div style="font-weight: 700; font-size: 13px; color: var(--text-main); margin-bottom: 12px;">AI Assistant Rules</div>
                
                <div style="margin-bottom: 14px;">
                    <label class="switch-label" style="display: block; margin-bottom: 6px;">AI Persona & Context Data *</label>
                    <select id="modal-ai-context-id" class="modal-input">
                        <option value="">Select AI Persona</option>
                        {% for ctx in contexts %}
                            <option value="{{ ctx.id }}">{{ ctx.name }}</option>
                        {% endfor %}
                    </select>
                    <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">The AI will generate smart, context-aware comments and responses based on this context.</div>
                </div>

                <div>
                    <label class="switch-label" style="display: block; margin-bottom: 6px;">Private direct message template to send to the commenter</label>
                    <select id="modal-ai-private-reply-flow-id" class="modal-input">
                        <option value="">Choose a DM sequence</option>
                        {% for flow in flows %}
                            <option value="{{ flow.id }}">{{ flow.name }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <!-- Panel 2: Generic reply -->
            <div id="panel-mode-generic" class="form-group-card" style="display: none;">
                <div style="font-weight: 700; font-size: 13px; color: var(--text-main); margin-bottom: 12px;">Universal Reply Config</div>
                
                <div style="margin-bottom: 14px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                        <label class="switch-label">Public comment reply text *</label>
                        <div style="display: flex; gap: 6px;">
                            <button type="button" class="btn-action" style="font-size: 10px; padding: 4px 8px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff;" onclick="insertPlaceholder('modal-comment-reply-text', '{first_name}')">First name</button>
                            <button type="button" class="btn-action" style="font-size: 10px; padding: 4px 8px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff;" onclick="insertPlaceholder('modal-comment-reply-text', '{last_name}')">Last name</button>
                        </div>
                    </div>
                    <textarea id="modal-comment-reply-text" class="modal-textarea" placeholder="Type your message here..."></textarea>
                </div>


                <div>
                    <label class="switch-label" style="display: block; margin-bottom: 6px;">Private direct message template to send to the commenter</label>
                    <select id="modal-generic-private-reply-flow-id" class="modal-input">
                        <option value="">Choose a DM sequence</option>
                        {% for flow in flows %}
                            <option value="{{ flow.id }}">{{ flow.name }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <!-- Panel 3: Filter reply -->
            <div id="panel-mode-filter" class="form-group-card" style="display: none; gap: 16px;">
                <div style="font-weight: 700; font-size: 13px; color: var(--text-main); margin-bottom: 4px;">Word/Sentence Filter Settings</div>
                
                <div id="filter-rules-container" style="display: flex; flex-direction: column; gap: 16px;">
                    <!-- Filter rule blocks will be appended here -->
                </div>

                <div style="display: flex; justify-content: flex-end; margin-bottom: 10px;">
                    <button type="button" class="btn-action" style="font-size: 13px; padding: 8px 14px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff;" onclick="addFilterRuleRow()">
                        + Add more filtering
                    </button>
                </div>

                <div class="form-group-card" style="border: 1px dashed rgba(255, 255, 255, 0.15); background: rgba(255, 255, 255, 0.01); padding: 18px; border-radius: 10px;">
                    <div style="font-weight: 700; font-size: 13px; color: var(--text-main); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 6px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px; color: var(--primary-accent);"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        <span>Fallback Configuration</span>
                    </div>
                    
                    <div style="margin-bottom: 14px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                            <label class="switch-label">Fallback Public Reply (If no keywords match)</label>
                            <div style="display: flex; gap: 6px;">
                                <button type="button" class="btn-action" style="font-size: 10px; padding: 4px 8px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff;" onclick="insertPlaceholder('modal-fallback-comment-reply-text', '{first_name}')">First name</button>
                                <button type="button" class="btn-action" style="font-size: 10px; padding: 4px 8px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff;" onclick="insertPlaceholder('modal-fallback-comment-reply-text', '{last_name}')">Last name</button>
                            </div>
                        </div>
                        <textarea id="modal-fallback-comment-reply-text" class="modal-textarea" placeholder="Type your message here..."></textarea>
                    </div>


                    <div>
                        <label class="switch-label" style="display: block; margin-bottom: 6px;">Fallback Private DM Template (If no keywords match)</label>
                        <select id="modal-fallback-private-reply-flow-id" class="modal-input">
                            <option value="">Choose a DM sequence</option>
                            {% for flow in flows %}
                                <option value="{{ flow.id }}">{{ flow.name }}</option>
                            {% endfor %}

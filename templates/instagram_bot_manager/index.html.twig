    function refreshFlowsList() {
        fetch(window.location.href)
        .then(res => res.text())
        .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newSelect = doc.getElementById('modal-offensive-private-reply-flow-id');
            if (newSelect && newSelect.options.length > 0) {
                const dropdowns = [
                    'modal-offensive-private-reply-flow-id',
                    'modal-ai-private-reply-flow-id',
                    'modal-generic-private-reply-flow-id',
                    'modal-fallback-private-reply-flow-id',
                    'flow-dropdown-options-template'
                ];
                dropdowns.forEach(id => {
                    const el = document.getElementById(id);
                    if (el) {
                        const currentVal = el.value;
                        el.innerHTML = newSelect.innerHTML;
                        el.value = currentVal;
                    }
                });
                
                // Refresh all dynamic select lists inside rule cards
                document.querySelectorAll('#filter-rules-container .rule-private-reply-flow-id').forEach(select => {
                    const currentVal = select.value;
                    select.innerHTML = newSelect.innerHTML;
                    select.value = currentVal;
                });
                
                showToast('Flow templates list refreshed successfully!', 'success');
            } else {
                showToast('Failed to refresh flows: list empty.', 'error');
            }
        })
        .catch(err => showToast('Refresh error: ' + err.message, 'error'));
    }


    function toggleFullPageReply(isChecked) {
        if (!activeConnectionId) {
            showToast('Please connect a Instagram page first.', 'error');
            const sw = document.getElementById('full-page-reply-switch');
            if (sw) sw.checked = !isChecked;
            return;
        }

        if (!pageCommentSettings) {
            pageCommentSettings = {
                hideOrDelete: 'hide',
                offensiveKeywords: '',
                offensivePrivateReplyFlowId: '',
                sendReplyMultipleTimes: false,
                enableCommentReply: true,
                hideCommentAfterReply: false,
                automationMode: 'generic',
                campaignName: 'Full Page Campaign',
                aiContextId: '',
                privateReplyFlowId: '',
                commentReplyText: '',
                filterMatchType: 'exact',
                filterWords: '',
                filterRules: [],
                fallbackSettings: {}
            };
        }

        pageCommentSettings.enableCommentReply = isChecked;
        updateFullPageCampaignUI();

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);
        formData.append('type', 'comment-automation');
        formData.append('data', JSON.stringify(pageCommentSettings));

        fetch('{{ path('app_instagram_bot_save_settings') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast(`Full Page Reply ${isChecked ? 'enabled' : 'disabled'}!`, 'success');
            } else {
                pageCommentSettings.enableCommentReply = !isChecked;
                updateFullPageCampaignUI();
                showToast('Failed to save settings: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => {

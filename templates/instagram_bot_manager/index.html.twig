    function updateMpcPreview() {
        const previewText = document.getElementById('mpc-preview-text');
        const previewMedia = document.getElementById('mpc-preview-media');
        const previewImg = document.getElementById('mpc-preview-img');
        const previewPlaceholder = document.getElementById('mpc-preview-placeholder');
        const previewLinkCard = document.getElementById('mpc-preview-link-card');
        const previewVideo = document.getElementById('mpc-preview-video');

        // Reset all preview sections
        if (previewMedia) previewMedia.style.display = 'none';
        if (previewLinkCard) previewLinkCard.style.display = 'none';
        if (previewVideo) previewVideo.style.display = 'none';

        if (mpcActiveTab === 'text') {
            const msg = document.getElementById('mpc-text-message')?.value || '';
            if (previewText) previewText.textContent = msg || 'Text goes here';
        } else if (mpcActiveTab === 'link') {
            const msg = document.getElementById('mpc-link-message')?.value || '';
            const linkUrl = document.getElementById('mpc-link-url')?.value?.trim() || '';
            if (previewText) previewText.textContent = msg || 'Text goes here';
            if (previewLinkCard) {
                previewLinkCard.style.display = 'block';
                const titleEl = document.getElementById('mpc-preview-link-title');
                const descEl = document.getElementById('mpc-preview-link-desc');
                if (linkUrl) {
                    try {
                        const parsed = new URL(linkUrl);
                        if (titleEl) titleEl.textContent = parsed.hostname;
                    } catch(e) {
                        if (titleEl) titleEl.textContent = 'Title goes here...';
                    }
                } else {
                    if (titleEl) titleEl.textContent = 'Title goes here...';
                }
                if (descEl) descEl.textContent = 'Description goes here..';
            }
        } else if (mpcActiveTab === 'image') {
            const msg = document.getElementById('mpc-image-message')?.value || '';
            const imgUrl = document.getElementById('mpc-image-url')?.value?.trim() || '';
            if (previewText) previewText.textContent = msg || 'Text goes here';
            if (previewMedia) {
                previewMedia.style.display = 'block';
                if (mpcCarouselImages.length > 0 || imgUrl) {
                    const showUrl = mpcCarouselImages[0] || imgUrl;
                    if (previewImg) { previewImg.src = showUrl; previewImg.style.display = 'block'; }
                    if (previewPlaceholder) previewPlaceholder.style.display = 'none';
                } else {
                    if (previewImg) previewImg.style.display = 'none';
                    if (previewPlaceholder) previewPlaceholder.style.display = 'flex';
                }
            }
        } else if (mpcActiveTab === 'video') {
            const msg = document.getElementById('mpc-video-message')?.value || '';
            if (previewText) previewText.textContent = msg || 'Text goes here';
            if (previewVideo) previewVideo.style.display = 'block';
        }
    }


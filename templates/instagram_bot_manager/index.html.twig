<script>
    window.openSquadronActiveFlows = [
        {% for flow in flows %}
            {% if flow.isActive %}
                { id: {{ flow.id }}, name: "{{ flow.name|escape('js') }}" },
            {% endif %}
        {% endfor %}
    ];
    let activeConnectionId = '{{ connection ? connection.id : "" }}';
    let pageCommentSettings = {{ settings['comment-automation']|default(null)|json_encode|raw }};
    let postbacks = {{ settings['postbacks']|default([])|json_encode|raw }};
    let marketingMessages = {{ settings['marketing-messages']|default([])|json_encode|raw }};
    let globalApiConnectors = {{ settings['api-connectors']|default([])|json_encode|raw }};
    let sequencesList = {{ sequences|json_encode|raw }};
    
    // Webhooks backward compatibility conversion
    let rawWebhooks = {{ settings['outbound-webhooks']|default([])|json_encode|raw }};
    let globalOutboundWebhooks = [];
    if (rawWebhooks) {
        if (Array.isArray(rawWebhooks)) {
            globalOutboundWebhooks = rawWebhooks;
        } else if (typeof rawWebhooks === 'object' && rawWebhooks.url) {
            globalOutboundWebhooks = [{
                name: 'Default Webhook',
                url: rawWebhooks.url,
                triggers: rawWebhooks.events || [],
                sendData: ['SUBSCRIBER_ID', 'SUBSCRIBER_NAME']
            }];
        }
    }
    let commentPosts = [];
    let filteredCommentPosts = [];
    let currentEditingPostId = null;

    function selectCommentAutomationConnection(connId) {
        // Sync comment automation page list active class
        document.querySelectorAll('#comment-bot-list .mpc-page-item').forEach(el => {
            el.classList.remove('is-active');
        });
        document.querySelectorAll('#comment-bot-list .mpc-page-item').forEach(el => {
            if (el.getAttribute('onclick') && el.getAttribute('onclick').includes(connId)) {
                el.classList.add('is-active');
            }
        });

        // Sync post manager page list active class
        document.querySelectorAll('#post-manager-page-list .mpc-page-item').forEach(el => {
            el.classList.remove('is-active');
        });
        document.querySelectorAll('#post-manager-page-list .mpc-page-item').forEach(el => {
            if (el.getAttribute('onclick') && el.getAttribute('onclick').includes(connId)) {
                el.classList.add('is-active');
            }
        });

        // Set active connection ID
        activeConnectionId = connId;

        // Update main page connection selector dropdown to match
        const mainSelector = document.getElementById('Instagram-conn-selector');
        if (mainSelector) {
            mainSelector.value = connId;
        }

        // Sync the checkboxes in Posting Panel sidebar: check the active one, uncheck others
        const checkboxes = document.querySelectorAll('input[name="mpc_pages[]"]');
        checkboxes.forEach(cb => {
            cb.checked = (cb.value == connId);
        });

        // Clear cached posts so we don't display posts from the previous page
        managerPosts = [];
        filteredPosts = [];
        commentPosts = [];
        filteredCommentPosts = [];

        // Update the browser URL without reload
        const url = new URL(window.location);
        url.searchParams.set('connectionId', connId);
        window.history.replaceState({}, '', url);

        // Fetch connection details via AJAX
        fetch(`/Instagram-bot-manager/get-connection-details?connectionId=${connId}`)
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Update the connection title
                const nameHeader = document.getElementById('comment-active-page-name');
                if (nameHeader) {
                    nameHeader.textContent = data.connection.pageName;
                }

                // Update flows dropdown options inside the modal
                rebuildFlowDropdowns(data.flows);

                // Update settings
                pageCommentSettings = data.commentSettings;

                // Update Full Page Campaign UI
                updateFullPageCampaignUI();

                // Load posts and metrics
                loadCommentAutomationTab(true);
            } else {
                showToast(data.error || 'Failed to switch page.', 'error');
            }
        })
        .catch(err => {
            console.error('Error switching page connection:', err);
            showToast('Error switching page connection: ' + err.message, 'error');
        });
    }

    function rebuildFlowDropdowns(flows) {
        const dropdownIds = [
            'modal-offensive-private-reply-flow-id',
            'modal-ai-private-reply-flow-id',
            'modal-generic-private-reply-flow-id',
            'modal-fallback-private-reply-flow-id',
            'flow-dropdown-options-template'
        ];
        dropdownIds.forEach(id => {
            const select = document.getElementById(id);
            if (!select) return;
            const defaultVal = select.value;
            // Keep the default / first option
            const firstOpt = select.options[0];
            select.innerHTML = '';
            if (firstOpt) select.appendChild(firstOpt);
            flows.forEach(flow => {
                const opt = document.createElement('option');
                opt.value = flow.id;
                opt.textContent = flow.name;
                select.appendChild(opt);
            });
            // Re-select original value if it exists in the new list, otherwise select empty
            select.value = [...select.options].some(o => o.value === defaultVal) ? defaultVal : "";
        });
    }

    function timeAgo(dateString) {
        if (!dateString) return '';
        try {
            const parts = dateString.split(/[- :]/);
            let utcDate;
            if (parts.length >= 5) {
                utcDate = new Date(Date.UTC(parts[0], parts[1]-1, parts[2], parts[3], parts[4], parts[5] || 0));
            } else {
                utcDate = new Date(dateString);
            }
            const diffMs = new Date() - utcDate;
            const diffSec = Math.floor(diffMs / 1000);
            if (diffSec < 60) return 'Just now';
            const diffMin = Math.floor(diffSec / 60);
            if (diffMin < 60) return `${diffMin} min${diffMin > 1 ? 's' : ''} ago`;
            const diffHr = Math.floor(diffMin / 60);
            if (diffHr < 24) return `${diffHr} hour${diffHr > 1 ? 's' : ''} ago`;
            const diffDays = Math.floor(diffHr / 24);
            if (diffDays < 30) return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
            const diffMonths = Math.floor(diffDays / 30);
            if (diffMonths < 12) return `${diffMonths} month${diffMonths > 1 ? 's' : ''} ago`;
            const diffYears = Math.floor(diffMonths / 12);
            return `${diffYears} year${diffYears > 1 ? 's' : ''} ago`;
        } catch (e) {
            return '';
        }
    }

    function loadCommentAutomationTab(forceRefresh = false) {
        if (!activeConnectionId) return;
        const container = document.getElementById('comment-posts-container');
        if (container) {
            container.innerHTML = `<div style="color: var(--text-muted); font-size: 13px; text-align: center; padding: 30px 0;">
                <svg class="spin-icon" style="width:16px;height:16px;margin-right:6px;vertical-align:middle;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
                Loading posts...
            </div>`;
        }
        fetch(`/Instagram-bot-manager/posts/list?connectionId=${activeConnectionId}&refresh=${forceRefresh}`)
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                commentPosts = data.posts || [];
                filterCommentPosts();
                updateCommentMetrics();
            } else {
                if (container) {
                    container.innerHTML = `<div style="color: #ef4444; font-size: 13px; text-align: center; padding: 30px 0;">Failed to load posts: ${data.error || 'Unknown error'}</div>`;
                }
            }
        })
        .catch(err => {
            if (container) {
                container.innerHTML = `<div style="color: #ef4444; font-size: 13px; text-align: center; padding: 30px 0;">Error loading posts: ${err.message}</div>`;
            }
        });
    }

    function updateCommentMetrics() {
        let activeCampaigns = 0;
        let configuredPosts = 0;
        commentPosts.forEach(post => {
            if (post.commentAutomationSettings) {
                configuredPosts++;
                if (post.commentAutomationSettings.enableCommentReply) {
                    activeCampaigns++;
                }
            }
        });
        const replyEl = document.getElementById('metric-reply-enabled-count');
        const commentEl = document.getElementById('metric-comment-enabled-count');
        if (replyEl) replyEl.textContent = activeCampaigns;
        if (commentEl) commentEl.textContent = configuredPosts;
    }

    function filterCommentBots() {
        const query = document.getElementById('comment-bot-search').value.toLowerCase().trim();
        document.querySelectorAll('#comment-bot-list .mpc-page-item').forEach(el => {
            const name = el.getAttribute('data-page-name') || '';
            if (name.includes(query)) {
                el.style.display = 'flex';
            } else {
                el.style.display = 'none';
            }
        });
    }

    // Filter posts inside comment automation tab
    function filterCommentPosts() {
        const query = document.getElementById('comment-post-search').value.toLowerCase().trim();
        filteredCommentPosts = commentPosts.filter(post => {
            const msg = (post.message || '').toLowerCase();
            const id = (post.fbPostId || '').toLowerCase();
            return msg.includes(query) || id.includes(query);
        });
        renderCommentPostsList();
    }


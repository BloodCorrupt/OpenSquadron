                <!-- 12. Outbound Webhooks -->
                <div class="console-card" onclick="switchTab('outbound-webhooks')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(20, 184, 166, 0.1); color: #14b8a6;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><circle cx="12" cy="19" r="2"></circle></svg>
                        </div>
                        <span class="console-card-title">Out-bound Webhook</span>
                    </div>
                    <p class="console-card-desc">Publish unified real-time conversation message payloads securely to your target external CRMs.</p>
                    <div class="console-card-action">
                        <span>Webhook Setup</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 13. Action Buttons -->
                <div class="console-card" onclick="switchTab('action-buttons')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        </div>
                        <span class="console-card-title">Action Buttons</span>
                    </div>
                    <p class="console-card-desc">Configure call buttons, template redirections, and instant reply action presets.</p>
                    <div class="console-card-action">
                        <span>Edit Button Presets</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 14. Welcome Screen -->
                <div class="console-card" onclick="switchTab('welcome-screen')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(234, 179, 8, 0.1); color: #eab308;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 8 12 12 16 14"></polyline><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        </div>
                        <span class="console-card-title">Welcome greeting</span>
                    </div>
                    <p class="console-card-desc">Draft welcome greetings and payloads that present to users before they send their first message.</p>
                    <div class="console-card-action">
                        <span>Edit Welcome Message</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 15. Instagram Social Posting -->
                <div class="console-card" onclick="switchTab('Instagram-poster')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
                        </div>
                        <span class="console-card-title">Social Posting</span>
                    </div>
                    <p class="console-card-desc">Instantly draft and publish visual media, rich text, and link posts directly to your connected page feed.</p>
                    <div class="console-card-action">
                        <span>Create & Post Now</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 16. Bot Configuration -->
                <div class="console-card" onclick="switchTab('bot-settings')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(255, 255, 255, 0.1); color: #fff; border-color: rgba(255, 255, 255, 0.2);">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                        </div>
                        <span class="console-card-title">Bot Configuration</span>
                    </div>
                    <p class="console-card-desc">Configure business hours, whitelist modes, and global operating settings for this bot connection.</p>
                    <div class="console-card-action" style="color: #fff;">
                        <span>Open Configuration</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    {# 1. Bot Reply Settings Content Pane #}
    <div class="manager-content-pane" id="pane-bot-reply">
        {% if connections is not empty %}
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M6 11V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"></path></svg>
                    <span>Trigger-Based Autoreplies</span>
                </h1>
                <div class="content-subtitle">Manage keyword triggers and interactive conversations builder flows.</div>
            </div>
            
            <a href="{{ path('app_instagram_bot_flows', {id: 'new', connectionId: connection ? connection.id : ''}) }}" class="btn-action btn-create">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                <span>Create Flow</span>
            </a>
        </div>

        {# Toolbar filters #}
        <div class="toolbar-row">
            <div class="toolbar-left">
                <select class="toolbar-select">
                    <option value="all">All Folders</option>
                </select>
                <div class="toolbar-search">
                    <svg class="search-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="text" id="flow-search" placeholder="Search flows...">
                </div>
            </div>
        </div>

        <div class="table-container">
            <table class="custom-table" id="flows-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Unique ID</th>
                        <th>Reference Name</th>
                        <th>Keywords</th>
                        <th style="width: 100px; text-align: center;">Status</th>
                        <th style="width: 160px; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if flows is empty %}
                    <tr>
                        <td colspan="6" class="no-data-row">
                            No flows available. Click "Create Flow" to get started.
                        </td>
                    </tr>
                    {% else %}
                        {% for flow in flows %}
                            <tr class="flow-row" data-flow-id="{{ flow.id }}">
                                <td>{{ loop.index }}</td>
                                <td style="font-family: monospace; color: var(--primary-accent);">
                                    #{{ flow.id|default('0') }}
                                </td>
                                <td style="font-weight: 600;">
                                    {{ flow.name }}
                                </td>
                                <td>
                                    {% if flow.triggerKeyword %}
                                        {% for kw in flow.triggerKeyword|split(',') %}
                                            <span class="keyword-tag">{{ kw|trim }}</span>
                                        {% endfor %}
                                    {% else %}
                                        <span style="color:var(--text-muted); font-style:italic;">None</span>
                                    {% endif %}
                                    {% if flow.matchMode %}
                                        <br><span class="match-mode-badge">{{ flow.matchMode }}</span>
                                    {% endif %}
                                </td>
                                <td style="text-align: center;">
                                    <label class="switch-toggle">
                                        <input type="checkbox" {% if flow.isActive %}checked{% endif %} onchange="toggleFlow({{ flow.id }}, this.checked)">
                                        <span class="slider-round"></span>
                                    </label>
                                </td>
                                <td>
                                    <div class="row-actions" style="justify-content: flex-end;">
                                        <a href="{{ path('app_instagram_bot_flows', {id: flow.id, connectionId: connection ? connection.id : ''}) }}" class="btn-row-action edit-action" title="Edit Flow">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                                        </a>
                                        <a href="{{ path('app_instagram_bot_flows_export', {id: flow.id}) }}" class="btn-row-action export-action" title="Export JSON" download>
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                        </a>
                                        <button class="btn-row-action clone-action" title="Clone Flow" onclick="cloneFlow({{ flow.id }})">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                        </button>
                                        <button class="btn-row-action delete-action" title="Delete Flow" onclick="deleteFlow({{ flow.id }})">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>

    {# 2. AI Agent Configuration Content Pane #}
    <div class="manager-content-pane" id="pane-ai-agent">
        {% if connections is not empty %}
        {% set copilotSettings = settings['copilot-settings'] ?? {} %}
        {% set enableIntentRouting = copilotSettings.enableIntentRouting ?? false %}
        {% set intentCampaign = copilotSettings.intentCampaign ?? '' %}
        {% set routingProtocol = copilotSettings.routingProtocol ?? 'omnipresent' %}
        {% set deepContext = copilotSettings.deepContext ?? false %}
        {% set suspendOffHours = copilotSettings.suspendOffHours ?? false %}
        {% set humanEscalation = copilotSettings.humanEscalation ?? false %}
        {% set typingIndicator = copilotSettings.typingIndicator ?? false %}
        {% set replyBuffer = copilotSettings.replyBuffer ?? 0 %}
        {% set reasoningDepth = copilotSettings.reasoningDepth ?? 'standard' %}

        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    <span>Intelligent AI Copilot Console</span>
                </h1>
                <div class="content-subtitle">Deploy a context-grounded, multi-agent response coordinator with cognitive routing and transmission logic.</div>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 960px; gap: 28px;">
            <!-- Row 1: Autonomous Response Activation Toggle -->
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; border-bottom: 1px solid var(--glass-border); padding-bottom: 20px;">
                <div>
                    <div style="font-weight: 700; color: #fff; font-size: 16px; display: flex; align-items: center; gap: 8px;">
                        <span style="display: inline-block; width: 8px; height: 8px; background: var(--wa-primary); border-radius: 50%; box-shadow: 0 0 8px var(--wa-primary);"></span>
                        <span>Activate Autonomous Response Engine</span>
                    </div>
                    <div class="form-helper" style="margin-top: 4px;">Directly handle incoming customer messages with context-grounded LLM completions.</div>
                </div>
                <label class="switch-toggle" style="margin: 0; scale: 1.1;">
                    <input type="checkbox" id="ai-agent-active" {% if connection and connection.isAiActive() %}checked{% endif %}>
                    <span class="slider-round"></span>
                </label>
            </div>

            <!-- Row 2: Two columns - Context Selector & Intent Detection Toggle -->
            <div class="form-row">
                <!-- Column 2.1: Grounding Knowledge Context Selector -->
                <div class="form-group">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <label class="form-label" for="ai-agent-context-select">Grounding Knowledge Context</label>
                        <a href="{{ path('app_ai_settings') }}" style="font-size: 13px; text-decoration: none; color: var(--wa-accent); font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
                            <span>+ Configure Context Profiles</span>
                        </a>
                    </div>
                    <div class="form-helper" style="margin-bottom: 4px;">Select the knowledge-base profile, system instructions, and boundaries constraint.</div>
                    <select id="ai-agent-context-select" class="glass-input" style="width: 100%; height: 42px;">
                        <option value="">-- No Context Profile (Use Connection Default) --</option>
                        {% for ctx in contexts %}
                            <option value="{{ ctx.id }}" {% if connection and connection.getActiveContext() and connection.getActiveContext().getId() == ctx.id %}selected{% endif %}>
                                {{ ctx.name }} {% if ctx.getAgentRole() %}({{ ctx.getAgentRole() }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>


                </div>

                <!-- Column 2.2: Cognitive Intent Routing Toggle -->
                <div class="form-group" style="justify-content: space-between; border-left: 1px dashed var(--glass-border); padding-left: 20px;">
                    <div>
                        <label class="form-label" style="display: flex; justify-content: space-between; align-items: center;">
                            <span>Cognitive Intent Routing</span>
                            <label class="switch-toggle" style="margin: 0; scale: 0.95;">
                                <input type="checkbox" id="ai-enable-intent-routing" {% if enableIntentRouting %}checked{% endif %}>
                                <span class="slider-round"></span>
                            </label>
                        </label>
                        <div class="form-helper" style="margin-top: 6px;">Evaluate incoming requests to identify explicit customer intents, routing queries dynamically.</div>
                    </div>

                    <!-- Hidden sub-field: Intent Campaign ID Input -->
                    <div class="form-group" id="intent-campaign-group" style="display: none; margin-top: 10px;">
                        <label class="form-label" for="ai-intent-campaign" style="font-size: 13px; color: #94a3b8;">Primary Intent Campaign Mapping</label>
                        <input type="text" id="ai-intent-campaign" class="glass-input" placeholder="e.g. general_inquiries_v2" value="{{ intentCampaign }}" style="height: 38px; font-size: 13px;">
                    </div>
                </div>
            </div>

            <!-- Row 3: Engine Routing Protocol Select (Omnipresent vs Fallback) -->
            <div class="form-group" style="border-top: 1px dashed var(--glass-border); padding-top: 20px;">
                <label class="form-label">Engine Routing Protocol</label>
                <div class="form-helper" style="margin-bottom: 12px;">Configure how the AI responder coordinates and intervenes with pre-defined automation flow triggers.</div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px;">
                    <!-- Card 1: Omnipresent Mode -->
                    <label class="console-card" style="cursor: pointer; padding: 15px; margin: 0; display: flex; flex-direction: row; gap: 12px; align-items: flex-start; transition: all 0.25s; border-color: {% if routingProtocol == 'omnipresent' %}var(--wa-primary){% else %}var(--glass-border){% endif %}; background: {% if routingProtocol == 'omnipresent' %}rgba(16, 185, 129, 0.08){% else %}rgba(30, 41, 59, 0.3){% endif %};" id="label-protocol-omni">
                        <input type="radio" name="ai-routing-protocol" value="omnipresent" style="margin-top: 4px;" {% if routingProtocol == 'omnipresent' %}checked{% endif %} onclick="selectRoutingProtocol('omnipresent')">
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-weight: 700; color: #fff; font-size: 14px;">Omnipresent Responder Mode</span>
                            <span style="font-size: 12px; color: var(--text-muted); line-height: 1.4;">AI engine intercepts and handles all inbound user queries, bypassing standard flows.</span>
                        </div>
                    </label>
                    <!-- Card 2: Fallback Co-Pilot Mode -->
                    <label class="console-card" style="cursor: pointer; padding: 15px; margin: 0; display: flex; flex-direction: row; gap: 12px; align-items: flex-start; transition: all 0.25s; border-color: {% if routingProtocol == 'fallback' %}var(--wa-primary){% else %}var(--glass-border){% endif %}; background: {% if routingProtocol == 'fallback' %}rgba(16, 185, 129, 0.08){% else %}rgba(30, 41, 59, 0.3){% endif %};" id="label-protocol-fallback">
                        <input type="radio" name="ai-routing-protocol" value="fallback" style="margin-top: 4px;" {% if routingProtocol == 'fallback' %}checked{% endif %} onclick="selectRoutingProtocol('fallback')">
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-weight: 700; color: #fff; font-size: 14px;">Fallback Co-Pilot Mode</span>
                            <span style="font-size: 12px; color: var(--text-muted); line-height: 1.4;">Only trigger the AI engine when no keyword or dynamic flow trigger-match is found.</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Row 4: 2x2 Toggle Cards Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; border-top: 1px dashed var(--glass-border); padding-top: 20px;">
                <!-- Card 1: Enable Deep Conversational Context -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Deep Conversational Context</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Maintains cohesive multi-turn dialogue memory across long customer threads.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-deep-context" {% if deepContext %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <!-- Card 2: Suspend Responses Outside Operating Hours -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Suspend Responses in Off-Hours</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Silences autonomous replies outside set business operating hours.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-suspend-off-hours" {% if suspendOffHours %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <!-- Card 3: Automated Handoff & Human Escalation -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Automated Handoff Escalation</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Instantly assigns chats to standard departments/agents upon manual handoff flags.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-human-escalation" {% if humanEscalation %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <!-- Card 4: Simulate Typing Indicator State -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Simulate Typing Indicator State</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Shows native chat 'typing...' status to customer before transmitting responses.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-typing-indicator" {% if typingIndicator %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
            </div>

            <!-- Row 5: Buffers & Depth dropdowns -->
            <div class="form-row" style="border-top: 1px dashed var(--glass-border); padding-top: 20px;">
                <!-- Delay/Buffer -->
                <div class="form-group">
                    <label class="form-label" for="ai-reply-buffer">Response Transmission Buffer (Seconds)</label>
                    <div class="form-helper" style="margin-bottom: 4px;">Configures realistic typing intervals before response is dispatched. Max 60s.</div>
                    <div style="position: relative; display: block; width: 100%; box-sizing: border-box;">
                        <input type="number" id="ai-reply-buffer" class="glass-input" min="0" max="60" value="{{ replyBuffer }}" style="box-sizing: border-box !important; width: 100%; padding-right: 42px; height: 42px;">
                        <span style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); font-size: 13px; color: var(--text-muted); font-weight: 600;">sec</span>
                    </div>
                </div>

                <!-- Cognitive Level / Reasoning Engine Depth -->
                <div class="form-group">
                    <label class="form-label" for="ai-reasoning-depth">Cognitive Reasoning Engine Depth</label>
                    <div class="form-helper" style="margin-bottom: 4px;">Sets conversational thinking complexity depth for response formulation.</div>
                    <select id="ai-reasoning-depth" class="glass-input" style="width: 100%; height: 42px;">
                        <option value="standard" {% if reasoningDepth == 'standard' %}selected{% endif %}>Standard (Lowest Latency)</option>
                        <option value="enhanced" {% if reasoningDepth == 'enhanced' %}selected{% endif %}>Enhanced (Balanced Precision)</option>
                        <option value="deep" {% if reasoningDepth == 'deep' %}selected{% endif %}>Deep Reasoning (Complex Workflows)</option>
                    </select>
                </div>
            </div>

            <!-- Row 6: Form actions -->
            <div style="display: flex; justify-content: flex-end; border-top: 1px solid var(--glass-border); padding-top: 20px; margin-top: 5px;">
                <button type="button" class="btn-action btn-create" id="btn-save-ai-agent-settings" onclick="saveAiAgentSettings()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    <span>Save AI Agent Settings</span>
                </button>
            </div>
        </div>
        {% endif %}
    </div>

    {# 3. Meta Template Campaigns Content Pane #}
    <div class="manager-content-pane" id="pane-broadcast-template">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
                    <span>Meta Template Campaigns</span>
                </h1>
                <div class="content-subtitle">Coordinate and review marketing and transaction notification templates approved by Meta.</div>
            </div>
            <button class="btn-action btn-create" onclick="alert('Feature requires connecting to a live Meta Developer App account with WhatsApp Business API access.')">
                <span>Submit New Template</span>
            </button>
        </div>

        <div class="table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Template Name</th>
                        <th>Category</th>
                        <th>Language</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in settings['broadcast-template'] %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td style="font-family: monospace; color: var(--primary-accent);">{{ item.name }}</td>
                        <td><span class="match-mode-badge">{{ item.category }}</span></td>
                        <td>{{ item.language }}</td>
                        <td>
                            <span class="keyword-tag" style="background: {% if item.status == 'APPROVED' %}rgba(16,185,129,0.1){% else %}rgba(245,158,11,0.1){% endif %}; border-color: {% if item.status == 'APPROVED' %}rgba(16,185,129,0.2){% else %}rgba(245,158,11,0.2){% endif %}; color: {% if item.status == 'APPROVED' %}#10b981{% else %}#f59e0b{% endif %};">
                                {{ item.status }}
                            </span>
                        </td>
                        <td>
                            <button class="btn-action btn-secondary" style="padding: 6px 12px; font-size:11px;" onclick="showToast('Loading preview details...', 'success')">Preview</button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# 4. Interactive Postbacks Content Pane #}
    <div class="manager-content-pane" id="pane-post-back">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"></polyline><path d="M3 11V9a4 4 0 0 1 4-4h14"></path><polyline points="7 23 3 19 7 15"></polyline><path d="M21 13v2a4 4 0 0 1-4 4H3"></path></svg>
                    <span>Postback Registry</span>
                </h1>
                <div class="content-subtitle">Manage interactive payload identifiers used for quick replies, persistent menus, and buttons.</div>
            </div>
            <button class="btn-action btn-create" onclick="openPostbackModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                <span>Register New Postback</span>
            </button>
        </div>

        <div class="toolbar-row">
            <div class="toolbar-left">
                <div class="search-input-wrapper">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="text" class="glass-input" id="search-postbacks" placeholder="Search by label or ID..." onkeyup="filterPostbacks()" style="padding-left:36px; min-width:280px;">
                </div>
            </div>
            <div class="toolbar-right">
                <button class="btn-action btn-secondary" onclick="renderPostbackTable()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                </button>
            </div>
        </div>

        <div class="glass-form-card" style="padding: 0;">
            <div class="table-container" style="margin-bottom: 0;">
                <table class="custom-table" id="postbacks-table">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>Postback Label</th>
                            <th>Postback ID (Reference)</th>
                            <th>Linked Flow</th>
                            <th>Last Updated</th>
                            <th style="width: 80px; text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="postbacks-tbody">
                        <!-- Rendered via JS -->
                    </tbody>
                </table>
            </div>
            <!-- Pagination -->
            <div class="pagination-footer" style="padding: 12px 20px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 12px; color: #94a3b8;" id="postbacks-count-display">Showing 0 entries</span>
                <div style="display: flex; gap: 8px;">
                    <button class="btn-action btn-secondary" style="padding: 4px 10px; font-size:12px;" disabled>Previous</button>
                    <button class="btn-action btn-secondary" style="padding: 4px 10px; font-size:12px;" disabled>Next</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Postback Slide-in Modal -->
    <div class="slide-panel-overlay" id="postback-modal-overlay" onclick="closePostbackModal()"></div>
    <div class="slide-panel" id="postback-modal">
        <div class="slide-panel-header">
            <h2 class="slide-panel-title" id="postback-modal-title">Register Postback</h2>
            <button class="slide-panel-close" onclick="closePostbackModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        <div class="slide-panel-content">
            <input type="hidden" id="pb-modal-index" value="-1">
            
            <div class="form-group">
                <label class="form-label">Postback Label <span style="color:#ef4444">*</span></label>
                <div class="form-helper" style="margin-bottom:8px;">Internal name to identify this postback action.</div>
                <input type="text" id="pb-modal-name" class="glass-input" style="width:100%" placeholder="e.g. Main Menu Trigger">
            </div>

            <div class="form-group">
                <label class="form-label">Postback ID</label>
                <div class="form-helper" style="margin-bottom:8px;">Auto-generated unique identifier used by the webhook.</div>
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="pb-modal-id" class="glass-input" style="width:100%; font-family:monospace; color:#34d399; background:rgba(52,211,153,0.05);" readonly>
                    <button class="btn-action btn-secondary copy-btn" onclick="copyToClipboard(document.getElementById('pb-modal-id').value, this)" title="Copy ID">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                </div>
                <div style="margin-top: 8px; font-size:12px;">
                    <label style="display:flex; align-items:center; gap:6px; cursor:pointer; color:#94a3b8;">
                        <input type="checkbox" id="pb-modal-override-id" onchange="document.getElementById('pb-modal-id').readOnly = !this.checked;"> Allow custom override (Advanced)
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Trigger Action Payload</label>
                <div class="form-helper" style="margin-bottom:8px;">The exact string sent to the webhook (often same as Postback ID).</div>
                <input type="text" id="pb-modal-payload" class="glass-input" style="width:100%; font-family:monospace;" placeholder="e.g. MAIN_MENU_TRIGGER">
            </div>

            <div class="form-group">
                <label class="form-label">Action Description</label>
                <input type="text" id="pb-modal-action" class="glass-input" style="width:100%" placeholder="e.g. Opens the main menu">
            </div>

            <div class="form-group">
                <label class="form-label">Linked Bot Flow</label>
                <div class="form-helper" style="margin-bottom:8px;">Automatically trigger a specific visual flow when this postback is received.</div>
                <select id="pb-modal-flow" class="glass-input" style="width:100%">
                    <option value="">-- No linked flow (Webhook only) --</option>
                    {% for flow in flows %}
                        <option value="{{ flow.id }}">{{ flow.name ?: 'Untitled Flow #' ~ flow.id }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="slide-panel-footer">
            <button class="btn-action btn-secondary" onclick="closePostbackModal()">Cancel</button>
            <button class="btn-action btn-create" onclick="savePostbackEntry()">Save Postback</button>
        </div>
    </div>


    {# 5. Growth & Chat Widgets Content Pane #}
    <div class="manager-content-pane" id="pane-growth-widgets">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                    <span>Growth & Chat Widgets</span>
                </h1>
                <div class="content-subtitle">Deploy responsive website chat bubbles and opt-in checkbox components.</div>
            </div>
        </div>

        <div class="preview-container">
            <div class="form-side glass-form-card">
                <div class="form-group">
                    <label class="form-label">Opt-in Widget Type</label>
                    <select id="widget-type" class="glass-input" onchange="updateWidgetPreview()">
                        <option value="checkbox" {% if settings['growth-widgets'].widgetType == 'checkbox' %}selected{% endif %}>Checkbox Plugin (Inline Form)</option>
                        <option value="chat_bubble" {% if settings['growth-widgets'].widgetType == 'chat_bubble' %}selected{% endif %}>Messenger Chat Bubble (Floating)</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Theme Accent Color</label>
                        <input type="color" id="widget-color" class="glass-input" style="height:42px; padding:4px;" value="{{ settings['growth-widgets'].color }}" oninput="updateWidgetPreview()">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Button Size</label>
                        <select id="widget-size" class="glass-input" onchange="updateWidgetPreview()">
                            <option value="medium" {% if settings['growth-widgets'].size == 'medium' %}selected{% endif %}>Medium Accent</option>
                            <option value="large" {% if settings['growth-widgets'].size == 'large' %}selected{% endif %}>Large Accent</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Domain Integration</label>
                    <div class="form-helper">The external hostname where this widget is authorized to render.</div>
                    <input type="text" id="widget-domains" class="glass-input" placeholder="e.g. opensquadron.io" value="{{ settings['growth-widgets'].domains }}">
                </div>

                <div class="form-group">
                    <label class="form-label">Generated Integration Embed Script</label>
                    <textarea class="glass-textarea" style="font-family:monospace; font-size:11px;" readonly id="widget-embed-code"></textarea>
                </div>

                <div style="display:flex; justify-content:flex-end;">
                    <button class="btn-action btn-create" onclick="saveGrowthWidgets()">Save Widget Config</button>
                </div>
            </div>

            <!-- Custom Website Live Mock Preview -->
            <div class="preview-side">
                <div class="form-label">Interactive website mockup</div>
                <div style="width: 270px; height: 380px; border-radius: 12px; border:1px solid var(--glass-border); background: #0f172a; display:flex; flex-direction:column; justify-content:space-between; position:relative; overflow:hidden; padding:15px; box-shadow: 0 10px 25px rgba(0,0,0,0.3);">
                    <!-- Header -->
                    <div style="display:flex; align-items:center; gap:8px; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:10px;">
                        <div style="width:10px; height:10px; border-radius:50%; background:#ef4444;"></div>
                        <div style="width:10px; height:10px; border-radius:50%; background:#f59e0b;"></div>
                        <div style="width:10px; height:10px; border-radius:50%; background:#10b981;"></div>
                        <span style="font-size:10px; color:var(--text-muted); margin-left:10px; font-family:monospace;">yoursite.com</span>
                    </div>
                    <!-- Body -->
                    <div style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; padding:10px;">
                        <h4 style="color:#fff; font-size:13px; margin-bottom:8px;">Checkout Form Page</h4>
                        <p style="color:var(--text-muted); font-size:10px; line-height:1.4;">Fill checkout details and tick checkbox to get order confirmations on Messenger.</p>
                        
                        <!-- Dynamic inline mock widget -->
                        <div id="mock-inline-widget" style="margin-top:15px; padding:10px; border:1px dashed #334155; border-radius:8px; display:flex; align-items:center; gap:8px; background:rgba(0,0,0,0.2);">
                            <input type="checkbox" checked style="accent-color: var(--primary-accent);" id="mock-checkbox-accent">
                            <span style="font-size:9px; color:#fff; font-weight:600;">Keep me updated on Messenger</span>
                        </div>
                    </div>
                    
                    <!-- Dynamic floating mock widget -->
                    <div id="mock-floating-widget" style="position:absolute; bottom:15px; right:15px; width:38px; height:38px; border-radius:50%; display:grid; place-items:center; color:#fff; cursor:pointer; box-shadow:0 4px 10px rgba(0,0,0,0.4); background:var(--primary-accent);">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px; height:18px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# 6. Drip Sequences Content Pane #}
    <div class="manager-content-pane" id="pane-sequences">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    <span>Drip Sequences & Delays</span>
                </h1>
                <div class="content-subtitle">Queue automated, delayed messages scheduled to run after custom user trigger dates.</div>
            </div>
            <button class="btn-action btn-create" onclick="addSequenceRow()">Add Delayed Drip</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="sequences-table">
                    <thead>
                        <tr>
                            <th>Sequence Campaign Name</th>
                            <th style="width: 140px;">Steps Count</th>
                            <th style="width: 100px; text-align: center;">Active Status</th>
                            <th style="width: 110px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in sequences %}
                        {% set seqId = item.id %}
                        <tr class="sequence-row" data-seq-id="{{ seqId }}">
                            <td>
                                <input type="hidden" class="seq-id" value="{{ seqId }}">
                                <input type="text" class="glass-input seq-name" style="width:100%" value="{{ item.name }}">
                            </td>
                            <td style="font-family: monospace; color: var(--primary-accent); font-weight: 600; vertical-align: middle;">
                                {{ item.stepsCount|default(0) }} steps
                            </td>
                            <td style="text-align: center; vertical-align: middle;">
                                <label class="switch-toggle">
                                    <input type="checkbox" class="seq-active" {% if item.isActive %}checked{% endif %}>
                                    <span class="slider-round"></span>
                                </label>
                            </td>
                            <td>
                                <div class="row-actions" style="justify-content: flex-end;">
                                    <a href="{{ path('app_instagram_bot_sequence_builder') }}?id={{ seqId }}&connectionId={{ connection ? connection.id : '' }}" class="btn-row-action edit-action" title="Build Sequence Flow" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: var(--primary-accent); background: rgba(255,255,255,0.02); transition: all 0.2s;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                    </a>
                                    <button class="btn-row-action delete-action" onclick="deleteSequenceById('{{ seqId }}', this.closest('tr'))" title="Delete Sequence" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: #f87171; background: rgba(255,255,255,0.02); transition: all 0.2s;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveSequences()">Save Sequences</button>
            </div>
        </div>
    </div>

    {# 7. Captured Forms & Inputs Content Pane #}
    <div class="manager-content-pane" id="pane-user-inputs">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    <span>Captured Forms & Inputs</span>
                </h1>
                <div class="content-subtitle">Define custom fields and variables that are gathered from users and mapped to CRM attributes.</div>
            </div>
            <button class="btn-action btn-create" onclick="addUserInputRow()">Add Field</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="user-inputs-table">
                    <thead>
                        <tr>
                            <th>Variable Field Name</th>
                            <th>Validation Type</th>
                            <th>Prompt Question Text</th>
                            <th style="width: 80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in settings['user-inputs'] %}
                        <tr class="user-input-row">
                            <td><input type="text" class="glass-input ui-name" style="width:100%; font-family:monospace;" value="{{ item.fieldName }}"></td>
                            <td>
                                <select class="glass-input ui-type" style="width:100%">
                                    <option value="TEXT" {% if item.dataType == 'TEXT' %}selected{% endif %}>Free-form Text</option>
                                    <option value="EMAIL" {% if item.dataType == 'EMAIL' %}selected{% endif %}>Email Address</option>
                                    <option value="PHONE" {% if item.dataType == 'PHONE' %}selected{% endif %}>Phone Number</option>
                                    <option value="NUMBER" {% if item.dataType == 'NUMBER' %}selected{% endif %}>Numeric Value</option>
                                </select>
                            </td>
                            <td><input type="text" class="glass-input ui-prompt" style="width:100%" value="{{ item.prompt }}"></td>
                            <td>
                                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveUserInputs()">Save Input Fields</button>
            </div>
        </div>
    </div>

    {# 8. Persistent Menu Content Pane #}
    <div class="manager-content-pane" id="pane-persistent-menu">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                    <span>Persistent Chat Menu</span>
                </h1>
                <div class="content-subtitle">Structure the persistent navigation bar visible to users at the bottom of their Messenger screen.</div>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn-action btn-secondary" onclick="syncPersistentMenu()">Sync from Instagram</button>
                <button class="btn-action btn-create" onclick="addMenuRow()">Add Menu Item</button>
            </div>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="menu-table">
                    <thead>
                        <tr>
                            <th>Menu Button Label</th>
                            <th>Action Type</th>
                            <th>Action Value (Payload or Web URL)</th>
                            <th style="width: 80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in settings['persistent-menu'] %}
                        <tr class="menu-row">
                            <td><input type="text" class="glass-input menu-title" style="width:100%" value="{{ item.title }}"></td>
                            <td>
                                <select class="glass-input menu-type" style="width:100%" onchange="toggleMenuValInput(this)">
                                    <option value="postback" {% if item.type == 'postback' %}selected{% endif %}>Trigger Postback Payload</option>
                                    <option value="web_url" {% if item.type == 'web_url' %}selected{% endif %}>Redirect to Web URL</option>
                                </select>
                            </td>
                            <td>
                                <input type="url" class="glass-input menu-val-input" style="width:100%; {% if item.type == 'postback' %}display:none;{% endif %}" placeholder="e.g. https://yoursite.com" value="{{ item.type == 'web_url' ? item.url : '' }}">
                                <select class="glass-input menu-val-select" style="width:100%; {% if item.type != 'postback' %}display:none;{% endif %}">
                                    <option value="">-- Select Postback --</option>
                                    {% for pb in settings['postbacks']|default([]) %}
                                        <option value="{{ pb.payload }}" {% if item.type == 'postback' and item.payload == pb.payload %}selected{% endif %}>{{ pb.name }} ({{ pb.payload }})</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="savePersistentMenu()">Save Persistent Menu</button>
            </div>
        </div>
    </div>

    {# 9. Marketing Messages Content Pane (Replaces RCN) #}
    <div class="manager-content-pane" id="pane-marketing-messages">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    <span>Marketing Messages Campaigns</span>
                </h1>
                <div class="content-subtitle">Send paid marketing updates outside the standard 24h window. Replaces deprecated RCN (Feb 2026).</div>
            </div>
            <div style="display:flex; gap:12px;">
                <button class="btn-action btn-secondary" onclick="fetchMarketingTokens()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px; margin-right:6px;"><path d="M21 2v6h-6"></path><path d="M3 12a9 9 0 1 0 2.13-5.83L2 11"></path></svg>
                    Sync Tokens
                </button>
                <button class="btn-action btn-create" onclick="openMMModal()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    Create Campaign
                </button>
            </div>
        </div>

        <!-- Campaign Cards Grid -->
        <div class="mm-campaign-grid" id="mm-campaigns-container">
            <!-- Rendered via JS -->
        </div>
    </div>

    <!-- Marketing Messages Slide-in Modal -->
    <div class="slide-panel-overlay" id="mm-modal-overlay" onclick="closeMMModal()"></div>
    <div class="slide-panel" id="mm-modal" style="width: 550px;">
        <div class="slide-panel-header">
            <h2 class="slide-panel-title" id="mm-modal-title">Configure Campaign</h2>
            <button class="slide-panel-close" onclick="closeMMModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        <div class="slide-panel-content">
            <input type="hidden" id="mm-modal-index" value="-1">
            <input type="hidden" id="mm-modal-id" value="">
            
            <div class="form-group">
                <label class="form-label">Campaign Title <span style="color:#ef4444">*</span></label>
                <input type="text" id="mm-modal-title-input" class="glass-input" style="width:100%" placeholder="e.g. Weekly Product Updates">
            </div>

            <div class="form-group">
                <label class="form-label">Notification Frequency</label>
                <div class="form-helper" style="margin-bottom:8px;">Determines the cooldown period between messages.</div>
                <select id="mm-modal-frequency" class="glass-input" style="width:100%">
                    <option value="DAILY">Daily (1 message/day limit)</option>
                    <option value="WEEKLY">Weekly (1 message/week limit)</option>
                    <option value="MONTHLY">Monthly (1 message/month limit)</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Opt-in Postback Reference</label>
                <div class="form-helper" style="margin-bottom:8px;">The trigger payload users tap to subscribe to this campaign.</div>
                <div style="display:flex; gap:8px;">
                    <input type="text" id="mm-modal-payload" class="glass-input" style="width:100%; font-family:monospace;" placeholder="e.g. WEEKLY_UPDATE_MM">
                    <button class="btn-action btn-secondary copy-btn" onclick="copyToClipboard(document.getElementById('mm-modal-payload').value, this)" title="Copy Payload">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Campaign Budget (Cents)</label>
                <div class="form-helper" style="margin-bottom:8px;">Marketing Messages are paid. Set lifetime budget in cents (e.g., 5000 = $50.00).</div>
                <input type="number" id="mm-modal-budget" class="glass-input" style="width:100%" min="0" value="0">
            </div>

            <div class="form-group">
                <label class="form-label">Opt-in Card Image (Optional)</label>
                <div class="form-helper" style="margin-bottom:8px;">Absolute URL for the image shown on the opt-in request card.</div>
                <input type="url" id="mm-modal-image" class="glass-input" style="width:100%" placeholder="https://example.com/image.jpg">
            </div>

            <div class="form-group" style="margin-top:24px;">
                <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                    <input type="checkbox" id="mm-modal-typing" style="width:18px; height:18px;">
                    <span style="font-weight:600;">Enable Smart Typing Indicator</span>
                </label>
                <div class="form-helper" style="margin-left:28px;">Show "bot is typing..." before sending the opt-in request.</div>
            </div>

            <div class="form-group">
                <label class="form-label">Smart Reply Delay</label>
                <div style="display:flex; gap:16px;">
                    <div style="flex:1;">
                        <label style="font-size:12px; color:#94a3b8;">Minutes</label>
                        <input type="number" id="mm-modal-delay-min" class="glass-input" style="width:100%" min="0" max="60" value="0">
                    </div>
                    <div style="flex:1;">
                        <label style="font-size:12px; color:#94a3b8;">Seconds</label>
                        <input type="number" id="mm-modal-delay-sec" class="glass-input" style="width:100%" min="0" max="59" value="0">
                    </div>
                </div>
            </div>
            
            <div class="form-group" style="padding:16px; background:rgba(255,255,255,0.02); border-radius:8px; border:1px solid rgba(255,255,255,0.05); margin-top:24px;">
                <label class="form-label">Linked Postback Identifier</label>
                <div class="form-helper" style="margin-bottom:8px;">Optionally link an existing Postback Registry ID to this campaign for tracking.</div>
                <select id="mm-modal-linked-pb" class="glass-input" style="width:100%">
                    <option value="">-- No linked postback --</option>
                    <!-- Populated by JS from postbacks array -->
                </select>
            </div>
        </div>
        <div class="slide-panel-footer">
            <button class="btn-action btn-secondary" onclick="closeMMModal()">Cancel</button>
            <button class="btn-action btn-create" onclick="saveMMEntry()">Save Campaign</button>
        </div>
    </div>

    {# 9b. Recurring Notifications (RCN) Content Pane #}
    <div class="manager-content-pane" id="pane-rcn-notifications">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    <span>Recurring Notifications (RCN)</span>
                </h1>
                <div class="content-subtitle">Draft opt-in sequences permitting daily, weekly, or monthly notifications outside standard window rules.</div>
            </div>
        </div>

        <!-- Premium Meta Deprecation Advisory Glass Box -->
        <div class="glass-notice-box" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); padding: 20px; border-radius: 14px; margin-bottom: 24px; display:flex; flex-direction:column; gap:12px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.25);">
            <div style="display:flex; align-items:center; gap:10px; color:#f87171; font-weight:700; font-size:15px; text-transform:uppercase; letter-spacing:0.5px;">
                <svg style="width:20px; height:20px; color:#f87171;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                Meta Deprecation Advisory (Feb 2026)
            </div>
            <p style="font-size:13.5px; line-height:1.6; color:#cbd5e1; margin:0;">
                Recurring Notifications (RCN) has been **officially deprecated by Meta as of February 2026**. Modern applications should migrate to the **Marketing Messages (MM)** API to ensure long-term compatibility and advanced promotional reach.
            </p>
            <div style="display:flex; margin-top:4px;">
                <button class="btn-action btn-secondary" onclick="switchTab('marketing-messages')" style="display:inline-flex; align-items:center; gap:6px; background:rgba(6, 182, 212, 0.15); border:1px solid rgba(6, 182, 212, 0.3); color:#22d3ee; padding: 8px 16px; border-radius: 8px; font-weight: 700; cursor:pointer; transition: all 0.2s;" onmouseover="this.style.background='rgba(6, 182, 212, 0.25)'" onmouseout="this.style.background='rgba(6, 182, 212, 0.15)'">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width:14px; height:14px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    Go to Marketing Messages (MM)
                </button>
            </div>
        </div>

        <!-- Legacy Config Form Card -->
        <div class="glass-form-card" style="width:100%;">
            <h3 style="margin-top:0; font-size:16px; font-weight:700; color:#fff; display:flex; align-items:center; gap:8px;">
                <svg style="width:18px; height:18px; color:var(--primary-accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                Legacy RCN Setup (Developer Access)
            </h3>
            <div class="form-helper" style="margin-bottom:20px; color:#94a3b8;">This table retains legacy configurations. Row payloads can be bound to conversational quick replies and triggers.</div>
            
            <div class="table-container" style="border: 1px solid var(--glass-border); border-radius: 10px; overflow: hidden; background: rgba(15, 23, 42, 0.25);">
                <table class="custom-table" id="rcn-table" style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--glass-border);">
                            <th style="padding:14px 12px; text-align:left; font-weight:700; color:#94a3b8;">Notification Title</th>
                            <th style="width: 250px; padding:14px 12px; text-align:left; font-weight:700; color:#94a3b8;">Frequency</th>
                            <th style="width: 280px; padding:14px 12px; text-align:left; font-weight:700; color:#94a3b8;">Opt-In Payload Reference</th>
                            <th style="width: 80px; text-align:center; padding:14px 12px; font-weight:700; color:#94a3b8;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in settings['rcn-notifications']|default([]) %}
                        <tr class="rcn-row" style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                            <td style="padding:10px 12px;"><input type="text" class="glass-input rcn-title" style="width:100%" value="{{ row.title }}"></td>
                            <td style="padding:10px 12px;">
                                <select class="glass-input rcn-freq" style="width:100%">
                                    <option value="DAILY" {% if row.frequency == 'DAILY' %}selected{% endif %}>Daily notifications</option>
                                    <option value="WEEKLY" {% if row.frequency == 'WEEKLY' or row.frequency == '' %}selected{% endif %}>Weekly notifications</option>
                                    <option value="MONTHLY" {% if row.frequency == 'MONTHLY' %}selected{% endif %}>Monthly notifications</option>
                                </select>
                            </td>
                            <td style="padding:10px 12px;"><input type="text" class="glass-input rcn-payload" style="width:100%; font-family:monospace;" value="{{ row.payload }}"></td>
                            <td style="text-align:center; padding:10px 12px;">
                                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:space-between; margin-top:20px; gap:12px;">
                <button class="btn-action btn-secondary" onclick="addRcnRow()">+ Add Campaign Row</button>
                <button class="btn-action btn-create" onclick="saveRcn()">Save RCN Setup</button>
            </div>
        </div>
    </div>

    {# 10. Whitelisted Domains Content Pane #}
    <div class="manager-content-pane" id="pane-whitelisted-domains">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    <span>Whitelisted Domains</span>
                </h1>
                <div class="content-subtitle">Declare domains securely permitted to render within internal Messenger Webview extension panes.</div>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 680px;">
            <div class="form-group">
                <label class="form-label">Authorized Whitelist URLs</label>
                <div class="form-helper" style="margin-bottom: 8px;">Enter one absolute secure domain URL (HTTPS) per line. Meta strictly rejects unsecured (HTTP) domain integrations.</div>
                <textarea id="whitelisted-domains-input" class="glass-textarea" style="font-family:monospace; min-height:150px;">{{ settings['whitelisted-domains'].domains }}</textarea>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveWhitelistedDomains()">Save Domains Whitelist</button>
            </div>
        </div>
    </div>

    {# 11. API Connectors Content Pane #}
    <div class="manager-content-pane" id="pane-api-connectors">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 0 1-.3 12.03l-5.69-5.69-1.07 1.07 5.69 5.69a9 9 0 0 1-12.03-.3l3.87-3.87a3 3 0 0 0 4.24 0l1.41-1.41a3 3 0 0 0 0-4.24l-3.87-3.87zM9 2H5v4M19 18v4h-4"></path></svg>
                    <span>JSON API Connector</span>
                </h1>
                <div class="content-subtitle">Define webhook endpoint URLs, trigger events, and customized payload delivery maps.</div>
            </div>
            <button class="btn-action btn-create" onclick="openApiConnectorModal()">Create Connector</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="connectors-table">
                    <thead>
                        <tr>
                            <th>Connector Label</th>
                            <th>Webhook URL</th>
                            <th>Triggers</th>
                            <th style="width: 100px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Rendered dynamically by renderApiConnectorsTable() -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# 12. Outbound Webhooks Content Pane #}
    <div class="manager-content-pane" id="pane-outbound-webhooks">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><circle cx="12" cy="19" r="2"></circle></svg>
                    <span>Out-bound Webhook</span>
                </h1>
                <div class="content-subtitle">Publish unified real-time conversation message payloads securely to your target external webhooks.</div>
            </div>
            <button class="btn-action btn-create" onclick="openOutboundWebhookModal()">Create Webhook</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="outbound-webhooks-table">
                    <thead>
                        <tr>
                            <th>Webhook Name</th>
                            <th>Out-bound Webhook URL</th>
                            <th>Triggers</th>
                            <th style="width: 100px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Rendered dynamically by renderOutboundWebhooksTable() -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# 13. Action Buttons Content Pane #}
    <div class="manager-content-pane" id="pane-action-buttons">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                    <span>Action Button Settings</span>
                </h1>
                <div class="content-subtitle">Configure automated quick-action templates and system-level event responders.</div>
            </div>
            
            <div class="dropdown-options-container" style="position: relative; display: inline-block;">
                <button class="btn-action btn-secondary" onclick="toggleOptionsDropdown(event)" style="display:flex; align-items:center; gap:8px;">
                    <span>Options</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div id="options-dropdown-menu" style="display:none; position: absolute; right:0; top:42px; background: rgba(15, 23, 42, 0.95); border: 1px solid var(--glass-border); border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.5); z-index:100; min-width: 180px; padding: 6px 0;">
                    <a href="javascript:void(0)" onclick="bulkTogglePresets(true)" style="display:block; padding: 10px 16px; color:#fff; font-size:13px; text-decoration:none; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.background='transparent'">Enable All Presets</a>
                    <a href="javascript:void(0)" onclick="bulkTogglePresets(false)" style="display:block; padding: 10px 16px; color:#fff; font-size:13px; text-decoration:none; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.background='transparent'">Disable All Presets</a>
                </div>
            </div>
        </div>

        <div class="presets-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; width: 100%;">
            {% for item in actionButtons %}
            <div class="preset-card {% if item.isEnabled %}is-active{% endif %}" data-key="{{ item.buttonKey }}" onclick="openPresetConfig('{{ item.buttonKey }}')" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 22px 20px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; transition: all 0.25s ease; position: relative;">
                <div style="display: flex; align-items: center; gap: 16px;">
                    <div class="preset-icon-wrapper" style="width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s;
                        {% if item.isEnabled %}
                            background: rgba(6, 182, 212, 0.15); color: #06b6d4; border: 1px solid rgba(6, 182, 212, 0.25);
                        {% else %}
                            background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.05);
                        {% endif %}">
                        {% if item.buttonKey == 'get-started' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width: 18px; height: 18px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        {% elseif item.buttonKey == 'no-match' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><path d="M18.85 15.08a9 9 0 0 0-2.28-7.57M13.73 21a2 2 0 0 1-3.46 0M3 3l18 18M9 9v0a6 6 0 0 0 6 6v0M4.27 4.27a6 6 0 0 0 0 7.46"></path></svg>
                        {% elseif item.buttonKey == 'location-reply' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        {% elseif item.buttonKey == 'unsubscribe' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                        {% elseif item.buttonKey == 'resubscribe' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                        {% elseif item.buttonKey == 'chat-with-human' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
                        {% elseif item.buttonKey == 'chat-with-bot' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M9 2v3M15 2v3"></path></svg>
                        {% endif %}
                    </div>
                    <div>
                        <div class="preset-label" style="font-weight: 600; color: #fff; font-size: 14px; margin-bottom: 2px;">{{ item.buttonLabel }}</div>
                        <div style="font-size: 11px; color: var(--text-muted);">
                            {% if item.replyType == 'flow' %}
                                Triggers Chat Flow
                            {% elseif item.replyType == 'text' %}
                                Sends Text Reply
                            {% else %}
                                No action configured
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <label class="switch-toggle" onclick="event.stopPropagation();" style="margin: 0;">
                    <input type="checkbox" class="preset-toggle" data-key="{{ item.buttonKey }}" {% if item.isEnabled %}checked{% endif %} onchange="togglePresetActive('{{ item.buttonKey }}', this.checked)">
                    <span class="slider-round"></span>
                </label>
            </div>
            {% endfor %}
        </div>
    </div>

    <!-- Preset Configuration Modal -->
    <div class="glass-modal-backdrop" id="preset-config-modal-backdrop" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(10px); z-index: 1050; align-items: center; justify-content: center;">
        <div class="glass-form-card" style="width: 500px; padding: 25px; border-radius: 16px; border: 1px solid var(--glass-border); box-shadow: 0 15px 35px rgba(0,0,0,0.6); position: relative;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--glass-border); padding-bottom: 12px; margin-bottom: 20px;">
                <h3 style="font-size: 15px; font-weight: 700; color: #fff; margin: 0;" id="preset-modal-title">Configure Preset Button</h3>
                <button class="btn-row-action delete-action" onclick="closePresetConfigModal()" style="border:none; background:none; cursor:pointer; color:var(--text-muted);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </div>
            
            <input type="hidden" id="preset-edit-key">
            
            <div class="form-group" style="margin-bottom:15px;">
                <label class="form-label">Button Status</label>
                <div style="display:flex; align-items:center; gap:10px;">
                    <label class="switch-toggle" style="margin: 0;">
                        <input type="checkbox" id="preset-edit-enabled">
                        <span class="slider-round"></span>
                    </label>
                    <span style="font-size:12px; color:var(--text-muted);">Enable action handler for this trigger event</span>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:15px;">
                <label class="form-label" for="preset-edit-label">Custom Button Label</label>
                <input type="text" id="preset-edit-label" class="glass-input" style="width:100%;">
            </div>

            <div class="form-group" style="margin-bottom:15px;">
                <label class="form-label" for="preset-edit-reply-type">Action Handler Type</label>
                <select id="preset-edit-reply-type" class="glass-input" style="width:100%;" onchange="togglePresetReplyFields()">
                    <option value="none">None (Disabled)</option>
                    <option value="flow">Trigger Bot Flow</option>
                    <option value="text">Send Reply Message</option>
                </select>
            </div>

            <div class="form-group" id="preset-flow-field-container" style="display:none; margin-bottom:15px;">
                <label class="form-label" for="preset-edit-flow">Target Chat Bot Flow</label>
                <select id="preset-edit-flow" class="glass-input" style="width:100%;">
                    <option value="">-- Select Flow --</option>
                    {% for flow in flows %}
                        {% if flow.isActive %}
                            <option value="{{ flow.id }}">{{ flow.name }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>

            <div class="form-group" id="preset-text-field-container" style="display:none; margin-bottom:15px;">
                <label class="form-label" for="preset-edit-text">Reply Text Message</label>
                <textarea id="preset-edit-text" class="glass-textarea" style="width:100%; height:80px;"></textarea>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px; border-top: 1px solid var(--glass-border); padding-top:15px;">
                <button class="btn-action btn-secondary" onclick="closePresetConfigModal()">Cancel</button>
                <button class="btn-action btn-create" onclick="savePresetConfig()">Save Configuration</button>
            </div>
        </div>
    </div>

    {# 13b. Bot Configuration Settings Pane #}
    <div class="manager-content-pane" id="pane-bot-settings">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    <span>Bot Configuration</span>
                </h1>
                <div class="content-subtitle">Manage Business Hours and Whitelist mode for this bot connection.</div>
            </div>
            <div>
                <button class="btn-action btn-create" onclick="saveBotSettings()">
                    <svg viewBox="0 0 24 24" style="width: 16px; height: 16px;" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    Save Config
                </button>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 800px;">
            <div style="font-size: 18px; font-weight: 600; color: #fff; margin-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">Business Hours</div>
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <div class="form-label">Enable Business Hours</div>
                        <div class="form-helper">When enabled, the bot will automatically pause responses during off-hours.</div>
                    </div>
                    <label class="switch-toggle">
                        <input type="checkbox" id="bh-enabled" {% if settings['business-hours']['enabled'] %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Operating Mode</label>
                        <select class="form-control" id="bh-mode">
                            <option value="bot" {% if (settings['business-hours']['mode'] ?? 'bot') == 'bot' %}selected{% endif %}>Bot handles during Business Hours</option>
                            <option value="human" {% if (settings['business-hours']['mode'] ?? 'bot') == 'human' %}selected{% endif %}>Human handles during Business Hours</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Start Time</label>
                        <input type="time" class="glass-input" id="bh-start-time" value="{{ settings['business-hours']['startTime'] ?? '09:00' }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">End Time</label>
                        <input type="time" class="glass-input" id="bh-end-time" value="{{ settings['business-hours']['endTime'] ?? '17:00' }}">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Active Days</label>
                    <div class="form-helper" style="margin-bottom: 10px;">Select the days your business is open.</div>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;" id="bh-days-container">
                        {% set activeDays = settings['business-hours']['days'] ?? ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'] %}
                        {% for day in ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'] %}
                        <label style="display: flex; align-items: center; justify-content: center; padding: 8px 16px; border-radius: 8px; cursor: pointer; transition: all 0.2s; user-select: none; {% if day in activeDays %}background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);{% else %}background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);{% endif %}">
                            <input type="checkbox" value="{{ day }}" class="bh-day-cb" style="display: none;" {% if day in activeDays %}checked{% endif %} onchange="this.parentElement.style.background = this.checked ? 'rgba(255,255,255,0.15)' : 'rgba(255,255,255,0.03)'; this.parentElement.style.borderColor = this.checked ? 'rgba(255,255,255,0.3)' : 'rgba(255,255,255,0.08)';">
                            <span style="font-size: 14px; color: #fff; font-weight: 500;">{{ day }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        
        <div class="glass-form-card" style="max-width: 800px; margin-top: 20px;">
            <div style="font-size: 18px; font-weight: 600; color: #fff; margin-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">Whitelist Mode</div>
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <div class="form-label">Enable Whitelist Mode</div>
                        <div class="form-helper">When enabled, the bot will ONLY reply to the numbers/IDs listed below.</div>
                    </div>
                    <label class="switch-toggle">
                        <input type="checkbox" id="wl-enabled" {% if settings['whitelist-mode']['enabled'] ?? false %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
                
                <div class="form-group" id="wl-numbers-container">
                    <label class="form-label">Whitelisted PSIDs (Manual Input)</label>
                    <div class="form-helper" style="margin-bottom: 8px;">Enter PSIDs separated by commas or new lines. The bot will only respond to these PSIDs.</div>
                    <textarea class="glass-textarea" id="wl-numbers" style="width: 100%; height: 100px; resize: vertical;" placeholder="e.g. 1234567890, 0987654321">{{ settings['whitelist-mode']['whitelistedNumbers'] ?? '' }}</textarea>
                </div>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 800px; margin-top: 20px;">
            <div style="font-size: 18px; font-weight: 600; color: #fff; margin-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">Blacklist Mode</div>
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <div class="form-label">Enable Blacklist Mode</div>
                        <div class="form-helper">When enabled, the bot will completely IGNORE and pause interactions from the PSIDs listed below.</div>
                    </div>
                    <label class="switch-toggle">
                        <input type="checkbox" id="bl-enabled" {% if settings['blacklist-mode']['enabled'] ?? false %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
                
                <div class="form-group" id="bl-numbers-container">
                    <label class="form-label">Blacklisted PSIDs (Manual Input)</label>
                    <div class="form-helper" style="margin-bottom: 8px;">Enter PSIDs separated by commas or new lines.</div>
                    <textarea class="glass-textarea" id="bl-numbers" style="width: 100%; height: 100px; resize: vertical;" placeholder="e.g. 1234567890, 0987654321">{{ settings['blacklist-mode']['blacklistedNumbers'] ?? '' }}</textarea>
                </div>
            </div>
        </div>
    </div>

    {# 14. Welcome Screen Content Pane #}
    <div class="manager-content-pane" id="pane-welcome-screen">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 8 12 12 16 14"></polyline><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    <span>Welcome & Get Started Setup</span>
                </h1>
                <div class="content-subtitle">Draft welcome greetings and payloads that present to users before they send their first message.</div>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn-action btn-secondary" onclick="syncWelcomeScreen()">Sync from Instagram</button>
            </div>
        </div>

        {% if connections is not empty %}
        <div class="preview-container">
            <div class="form-side" style="display:flex; flex-direction:column; gap:20px; width:60%;">
                
                <!-- Welcome Greeting Panel Card -->
                <div class="glass-form-card" style="padding:20px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--glass-border); padding-bottom: 15px; margin-bottom:15px;">
                        <div>
                            <div style="font-weight: 700; color: #fff; font-size: 14px;">Show Welcome Page Greeting</div>
                            <div class="form-helper">Toggle whether users are greeted with customized greeting panels.</div>
                        </div>
                        <label class="switch-toggle" style="margin: 0;">
                            <input type="checkbox" id="welcome-show" {% if settings['welcome-screen'].showGreeting %}checked{% endif %} onchange="updateGreetingPreview()">
                            <span class="slider-round"></span>
                        </label>
                    </div>

                    <div class="form-group">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                            <label class="form-label" for="welcome-greeting-text" style="margin:0;">Custom Welcome Greeting Text</label>
                            <div style="display:flex; gap:8px;">
                                <button type="button" class="btn-action btn-secondary" style="font-size:11px; padding:3px 8px; height:auto;" onclick="insertGreetingVariable('{{ '{{user_first_name}}' }}')">Insert First Name</button>
                                <button type="button" class="btn-action btn-secondary" style="font-size:11px; padding:3px 8px; height:auto;" onclick="insertGreetingVariable('{{ '{{user_last_name}}' }}')">Insert Last Name</button>
                            </div>
                        </div>
                        <textarea id="welcome-greeting-text" class="glass-textarea" oninput="updateGreetingPreview()">{{ settings['welcome-screen'].greetingText }}</textarea>
                        <div class="form-helper">Maximum 160 characters. Highlight details of what the bot performs. You can use First and Last Name tags.</div>
                    </div>
                </div>

                <!-- Get Started Configuration Card -->
                <div class="glass-form-card" style="padding:20px;">
                    <h3 style="font-size:14px; font-weight:700; color:#fff; border-bottom: 1px solid var(--glass-border); padding-bottom:10px; margin-bottom:15px;">Get Started Button Settings</h3>
                    
                    <div class="form-group">
                        <label class="form-label" for="get-started-status">Get Started Status</label>
                        <select id="get-started-status" class="glass-input" onchange="toggleGetStartedStatus()">
                            <option value="enabled" {% if settings['welcome-screen'].getStartedStatus == 'enabled' %}selected{% endif %}>Enabled</option>
                            <option value="disabled" {% if settings['welcome-screen'].getStartedStatus == 'disabled' %}selected{% endif %}>Disabled</option>
                        </select>
                        <div class="form-helper">Toggle the initial "Get Started" prompt button.</div>
                    </div>

                    <div class="form-group" id="get-started-payload-container" style="{% if settings['welcome-screen'].getStartedStatus == 'disabled' %}display:none;{% endif %}">
                        <label class="form-label" for="get-started-flow-selector">Trigger Flow / Payload Mapping</label>
                        <div style="display:flex; gap:10px; margin-bottom:8px;">
                            <select id="get-started-flow-selector" class="glass-input" style="flex:1;" onchange="updateGetStartedPayloadFromSelector()">
                                <option value="WELCOME_GET_STARTED_TRIGGER" {% if settings['welcome-screen'].getStartedPayload == 'WELCOME_GET_STARTED_TRIGGER' or settings['welcome-screen'].getStartedPayload == '' %}selected{% endif %}>Default Custom Payload (WELCOME_GET_STARTED_TRIGGER)</option>
                                {% for flow in flows %}
                                    {% if flow.isActive %}
                                    <option value="FLOW_ID_{{ flow.id }}" {% if settings['welcome-screen'].getStartedPayload == 'FLOW_ID_' ~ flow.id %}selected{% endif %}>Trigger Flow: {{ flow.name }}</option>
                                    {% endif %}
                                {% endfor %}
                                <option value="custom" {% if settings['welcome-screen'].getStartedPayload != 'WELCOME_GET_STARTED_TRIGGER' and not settings['welcome-screen'].getStartedPayload starts with 'FLOW_ID_' and settings['welcome-screen'].getStartedPayload != '' %}selected{% endif %}>Custom Text Payload...</option>
                            </select>
                        </div>
                        <input type="text" id="welcome-payload" class="glass-input" style="font-family:monospace; {% if settings['welcome-screen'].getStartedPayload == 'WELCOME_GET_STARTED_TRIGGER' or settings['welcome-screen'].getStartedPayload starts with 'FLOW_ID_' or settings['welcome-screen'].getStartedPayload == '' %}display:none;{% endif %}" value="{{ settings['welcome-screen'].getStartedPayload }}">
                        <div class="form-helper" id="get-started-payload-helper">The trigger payload dispatched back when the user taps "Get Started".</div>
                    </div>
                </div>

                <!-- Conversation Initiator FAQs (Ice Breakers) Card -->
                <div class="glass-form-card" style="padding:20px;">
                    <h3 style="font-size:14px; font-weight:700; color:#fff; border-bottom: 1px solid var(--glass-border); padding-bottom:10px; margin-bottom:15px;">Conversation Initiators & FAQs (Ice Breakers)</h3>
                    
                    <div class="form-group">
                        <label class="form-label" for="ice-breakers-status">FAQs / Ice Breakers Status</label>
                        <select id="ice-breakers-status" class="glass-input" onchange="toggleIceBreakersStatus()">
                            <option value="enabled" {% if settings['welcome-screen'].iceBreakersStatus == 'enabled' %}selected{% endif %}>Enabled</option>
                            <option value="disabled" {% if settings['welcome-screen'].iceBreakersStatus == 'disabled' or settings['welcome-screen'].iceBreakersStatus == '' %}selected{% endif %}>Disabled</option>
                        </select>
                        <div class="form-helper">Ice Breakers allow users to click standard FAQ questions before they send their first message.</div>
                    </div>

                    <div id="ice-breakers-container" style="{% if settings['welcome-screen'].iceBreakersStatus != 'enabled' %}display:none;{% endif %} margin-top: 15px;">
                        <div id="ice-breaker-rows" style="display:flex; flex-direction:column; gap:12px; margin-bottom:15px;">
                            <!-- FAQ questions will be rendered here dynamically -->
                        </div>
                        <button type="button" id="btn-add-ice-breaker" class="btn-action btn-secondary" onclick="addNewIceBreakerRow()" style="font-size:12px; width:100%; border: 1px dashed var(--glass-border);">+ Add FAQ Question</button>
                    </div>
                </div>

                <div style="display:flex; justify-content:flex-end; margin-top:10px;">
                    <button class="btn-action btn-create" onclick="saveWelcomeScreen()">Save Welcome Greeting</button>
                </div>
            </div>

            <!-- iOS Live Messenger Preview -->
            <div class="preview-side">
                <div class="form-label">iOS Messenger live preview</div>
                <div class="iphone-shell">
                    <div class="iphone-header">
                        <span>{{ connection ? connection.pageName ?: 'Instagram Page' : 'Instagram Page' }}</span>
                    </div>
                    <div class="iphone-body">
                        <div class="iphone-content" id="preview-greeting-container">
                            <div class="iphone-avatar">
                                {{ connection ? connection.pageName|default('F')|slice(0,1)|upper : 'F' }}
                            </div>
                            <div class="iphone-page-name">{{ connection ? connection.pageName ?: 'Instagram Page' : 'Instagram Page' }}</div>
                            <div class="iphone-page-desc">Authorized OpenSquadron Integration</div>
                            
                            <div class="iphone-welcome-bubble" id="preview-greeting-bubble">
                                Welcome to OpenSquadron! Tap Get Started to explore our automated integrations.
                            </div>
                        </div>

                        <!-- FAQ Questions Preview -->
                        <div id="preview-ice-breakers-container" style="display:flex; flex-direction:column; gap:6px; padding: 10px; border-top: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.15);">
                            <!-- Dynamic preview questions -->
                        </div>
                        
                        <div class="iphone-footer" id="preview-get-started-container">
                            <div class="iphone-btn-started">Get Started</div>
                            <div style="font-size:8px; color:var(--text-muted); text-align:center; line-height:1.3; width:100%;">Clicking Get Started triggers the welcome webhook callback.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    {# 15. Instagram Social Posting Content Pane #}
    <div class="manager-content-pane" id="pane-Instagram-poster">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
                    <span>Instagram Social Posting</span>
                </h1>
                <div class="content-subtitle">Automatically post text, links, images and videos to Instagram and Instagram.</div>
            </div>
        </div>

        <!-- Poster Sub-Tabs -->
        <div class="poster-tabs">
            <button class="poster-tab-btn is-active" id="poster-tab-btn-create" onclick="switchPosterTab('create')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                Posting Panel
            </button>
            <button class="poster-tab-btn" id="poster-tab-btn-manage" onclick="switchPosterTab('manage')">

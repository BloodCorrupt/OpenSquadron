    function saveWelcomeScreen() {
        const showGreeting = document.getElementById('welcome-show').checked;
        const greetingText = document.getElementById('welcome-greeting-text').value.trim();
        const getStartedStatus = document.getElementById('get-started-status').value;
        const getStartedPayload = document.getElementById('welcome-payload').value.trim();
        const iceBreakersStatus = document.getElementById('ice-breakers-status').value;
        
        const iceBreakers = [];
        document.querySelectorAll('#ice-breaker-rows .ice-breaker-row').forEach(row => {
            const question = row.querySelector('.ice-breaker-question').value.trim();
            const payload = row.querySelector('.ice-breaker-payload').value.trim();
            if (question !== '' && payload !== '') {
                iceBreakers.push({ question, payload });
            }
        });

        if (showGreeting && getStartedStatus !== 'enabled') {
            showToast('Instagram requires the Get Started button to be enabled when using a Welcome Greeting.', 'error');
            return;
        }
        if (showGreeting && greetingText === '') {
            showToast('Please enter a Welcome Greeting text.', 'error');
            return;
        }
        if (showGreeting && greetingText.replace(new RegExp('\\{\\{.*?\\}\\}', 'g'), '').trim() === '') {
            showToast('Instagram requires the Welcome Greeting to contain at least some normal text, not just variables.', 'error');
            return;
        }
        if (getStartedStatus === 'enabled' && getStartedPayload === '') {
            showToast('Please specify a payload or select a chat flow for the Get Started button.', 'error');
            return;
        }
        if (getStartedStatus === 'enabled' && iceBreakersStatus === 'enabled') {
            showToast('Instagram does not allow both Get Started and FAQ (Ice Breakers) to be enabled at the same time.', 'error');
            return;
        }

        postSettingsSave('welcome-screen', { 
            showGreeting, 
            greetingText, 
            getStartedStatus, 
            getStartedPayload, 
            iceBreakersStatus, 
            iceBreakers 
        });
    }

    function syncWelcomeScreen() {
        if (!activeConnectionId) {
            showToast('Please connect a Instagram page first.', 'error');
            return;
        }

        showToast('Syncing welcome screen from Instagram...', 'info');

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);

        fetch('{{ path('app_instagram_bot_sync_welcome_screen') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Welcome screen synced successfully!', 'success');
                if (data.data) {
                    document.getElementById('welcome-show').checked = data.data.showGreeting;
                    document.getElementById('welcome-greeting-text').value = data.data.greetingText || '';
                    
                    const getStartedStatus = document.getElementById('get-started-status');
                    if (getStartedStatus) {
                        getStartedStatus.value = data.data.getStartedStatus || 'enabled';
                        toggleGetStartedStatus();
                    }

                    const welcomePayload = document.getElementById('welcome-payload');
                    if (welcomePayload) {
                        welcomePayload.value = data.data.getStartedPayload || '';
                    }

                    // Update Selector
                    const getStartedSelector = document.getElementById('get-started-flow-selector');
                    if (getStartedSelector) {
                        const payloadVal = data.data.getStartedPayload || '';
                        if (payloadVal === 'WELCOME_GET_STARTED_TRIGGER' || payloadVal === '') {
                            getStartedSelector.value = 'WELCOME_GET_STARTED_TRIGGER';
                            welcomePayload.style.display = 'none';
                        } else if (payloadVal.startsWith('FLOW_ID_')) {
                            getStartedSelector.value = payloadVal;
                            welcomePayload.style.display = 'none';
                        } else {
                            getStartedSelector.value = 'custom';
                            welcomePayload.style.display = 'block';
                        }
                    }

                    const iceBreakersStatus = document.getElementById('ice-breakers-status');
                    if (iceBreakersStatus) {
                        iceBreakersStatus.value = data.data.iceBreakersStatus || 'disabled';
                        toggleIceBreakersStatus();
                    }

                    // Rebuild Ice Breakers list
                    const container = document.getElementById('ice-breaker-rows');
                    if (container) {
                        container.innerHTML = '';
                        if (data.data.iceBreakers && data.data.iceBreakers.length > 0) {
                            data.data.iceBreakers.forEach(item => {
                                addNewIceBreakerRow(item.question, item.payload);
                            });
                        }
                    }
                    updateIceBreakerUi();
                }
            } else {
                showToast('Failed to sync welcome screen: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => {
            console.error(err);
            showToast('An error occurred while syncing welcome screen: ' + err.message, 'error');
        });
    }


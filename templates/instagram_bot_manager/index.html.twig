    function loadRecentPosts(refresh = false) {
        if (!activeConnectionId) return;

        const tbody = document.getElementById('posts-manager-tbody');
        if (managerPosts.length === 0 && tbody) {
            tbody.innerHTML = `<tr><td colspan="6" class="no-data-row"><div style="display:flex;align-items:center;justify-content:center;gap:10px;"><svg class="spin-icon" style="width:16px;height:16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg> Loading posts...</div></td></tr>`;
        }

        const refreshBtn = document.getElementById('btn-refresh-posts');
        const refreshText = document.getElementById('refresh-btn-text');
        const refreshIcon = document.getElementById('refresh-icon-svg');
        
        if (refresh && !isRefreshingPosts) {
            isRefreshingPosts = true;
            if (refreshBtn) refreshBtn.disabled = true;
            if (refreshText) refreshText.textContent = 'Syncing...';
            if (refreshIcon) refreshIcon.classList.add('spin-icon');
        }

        const url = '{{ path('app_instagram_bot_posts_list') }}?connectionId=' + activeConnectionId + '&refresh=false';
        
        fetch(url)
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    managerPosts = data.posts || [];
                    filterManagerPosts();
                }

                if (refresh) {
                    const syncUrl = '{{ path('app_instagram_bot_posts_list') }}?connectionId=' + activeConnectionId + '&refresh=true';
                    return fetch(syncUrl)
                        .then(res => res.json())
                        .then(syncData => {
                            if (syncData.success) {
                                managerPosts = syncData.posts || [];
                                filterManagerPosts();
                                if (syncData.syncError) {
                                    showToast('Sync warning: ' + syncData.syncError, 'error');
                                } else {
                                    showToast('Posts synchronized with Instagram!', 'success');
                                }
                            } else {
                                showToast('Failed to sync with Instagram: ' + (syncData.error || 'Unknown error'), 'error');
                            }
                        });
                }
            })
            .catch(err => {
                console.error('Error loading posts:', err);
                showToast('Error loading posts: ' + err.message, 'error');
                if (tbody && managerPosts.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="6" class="no-data-row" style="color:#ef4444;">Error loading posts list.</td></tr>`;
                }
            })
            .finally(() => {
                if (refresh) {
                    isRefreshingPosts = false;
                    if (refreshBtn) refreshBtn.disabled = false;
                    if (refreshText) refreshText.textContent = 'Refresh Posts';
                    if (refreshIcon) refreshIcon.classList.remove('spin-icon');
                }
            });
    }

    function filterManagerPosts() {
        const q = (document.getElementById('post-manager-search')?.value || '').toLowerCase().trim();
        if (!q) {
            filteredPosts = [...managerPosts];
        } else {
            filteredPosts = managerPosts.filter(p => {
                const msg = (p.message || '').toLowerCase();
                const id = (p.fbPostId || p.id || '').toLowerCase();
                return msg.includes(q) || id.includes(q);
            });
        }
        
        postsCurrentPage = 1;
        renderPostsTable();
    }

    function renderPostsTable() {
        const tbody = document.getElementById('posts-manager-tbody');
        if (!tbody) return;

        if (filteredPosts.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="no-data-row">No posts found.</td></tr>`;
            const paginationRow = document.getElementById('posts-pagination-row');
            if (paginationRow) paginationRow.style.display = 'none';
            return;
        }

        const totalPosts = filteredPosts.length;
        const totalPages = Math.ceil(totalPosts / postsPerPage);
        
        if (postsCurrentPage < 1) postsCurrentPage = 1;
        if (postsCurrentPage > totalPages) postsCurrentPage = totalPages;

        const startIdx = (postsCurrentPage - 1) * postsPerPage;
        const endIdx = Math.min(startIdx + postsPerPage, totalPosts);
        const pagePosts = filteredPosts.slice(startIdx, endIdx);

        let html = '';
        pagePosts.forEach(post => {
            let contentHtml = '<div class="post-content-cell">';
            if (post.mediaUrl) {
                contentHtml += `<img class="post-media-thumb" src="${post.mediaUrl}" onerror="this.style.display='none';">`;
            }
            contentHtml += '<div style="display:flex; flex-direction:column; min-width:0; flex:1;">';
            
            let textContent = post.message || '';
            if (textContent.length > 120) {
                textContent = textContent.substring(0, 117) + '...';
            }
            contentHtml += `<div class="post-text-wrap" title="${post.message ? post.message.replace(/"/g, '&quot;') : ''}">${textContent || '<span style="font-style:italic; color:var(--text-muted);">No text message</span>'}</div>`;
            
            if (post.link && !post.link.includes('Instagram.com') && !post.link.includes('graph.Instagram.com')) {
                contentHtml += `<a href="${post.link}" target="_blank" class="post-link-indicator">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    <span>${post.link.length > 35 ? post.link.substring(0, 32) + '...' : post.link}</span>
                </a>`;
            }
            contentHtml += '</div></div>';

            let typeText = 'Text';
            if (post.type === 'carousel') {
                typeText = 'Carousel';
            } else if (post.mediaType === 'image') {
                typeText = 'Image';
            } else if (post.mediaType === 'video') {
                typeText = 'Video';
            } else if (post.link && !post.link.includes('Instagram.com') && !post.link.includes('graph.Instagram.com')) {
                typeText = 'Link';
            }
            let typeHtml = `<span class="platform-badge platform-Instagram">${typeText}</span>`;

            let engagementHtml = '';
            if (post.status === 'published') {
                const likes = post.likes || 0;
                const comments = post.comments || 0;
                const shares = post.shares || 0;
                
                engagementHtml = `
                    <div class="engagement-metrics">
                        <div class="metric-item" title="${likes} Likes">
                            <svg viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
                            <span>${likes}</span>
                        </div>
                        <div class="metric-item" title="${comments} Comments">
                            <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                            <span>${comments}</span>
                        </div>
                        <div class="metric-item" title="${shares} Shares">
                            <svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                            <span>${shares}</span>
                        </div>
                    </div>
                `;
            } else {
                engagementHtml = '<span style="color:var(--text-muted); font-size: 13px;">â€”</span>';
            }

            let dateStr = post.createdAt || '';
            if (dateStr) {
                try {
                    const parts = dateStr.split(/[- :]/);
                    if (parts.length >= 5) {
                        const utcDate = new Date(Date.UTC(parts[0], parts[1]-1, parts[2], parts[3], parts[4], parts[5] || 0));
                        dateStr = utcDate.toLocaleString(undefined, {month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'});
                    }
                } catch(e) {}
            }

            let statusClass = 'status-draft';
            let statusText = 'Draft';
            let statusTitle = 'Draft Post';
            if (post.status === 'published') {
                statusClass = 'status-published';
                statusText = 'Published';
                statusTitle = 'Published to Instagram';
            } else if (post.status === 'failed') {
                statusClass = 'status-failed';
                statusText = 'Failed';
                statusTitle = post.errorMessage || 'Publishing failed';
            }
            let statusHtml = `<span class="status-badge ${statusClass}" title="${statusTitle.replace(/"/g, '&quot;')}">${statusText}</span>`;

            let actionsHtml = '<div style="display:flex; gap:6px; align-items:center;">';
            if (post.status === 'draft' || post.status === 'failed') {
                actionsHtml += `
                    <button class="btn-row-action" title="Publish Now" onclick="publishDraftPost('${post.id}', this)" style="color:var(--primary-accent); background:rgba(6,182,212,0.1); border:1px solid rgba(6,182,212,0.2);">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
                    </button>
                `;
            } else if (post.status === 'published' && (post.fbPostId || post.link)) {
                let fbLink = post.link || '';
                if (post.fbPostId && (!fbLink || !fbLink.includes('Instagram.com'))) {
                    fbLink = `https://Instagram.com/${post.fbPostId}`;
                }
                if (fbLink) {
                    actionsHtml += `
                        <a href="${fbLink}" target="_blank" class="btn-row-action" title="View on Instagram" style="color:#60a5fa; background:rgba(59,130,246,0.1); border:1px solid rgba(59,130,246,0.2); display:flex; align-items:center; justify-content:center; text-decoration:none; width:28px; height:28px; border-radius:6px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"></path></svg>
                        </a>
                    `;
                }
            }
            actionsHtml += `
                <button class="btn-row-action delete-action" title="Delete Log Entry" onclick="deleteManagerPost('${post.id}', this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            `;
            actionsHtml += '</div>';

            html += `
                <tr>
                    <td>${contentHtml}</td>
                    <td>${typeHtml}</td>
                    <td>${engagementHtml}</td>
                    <td style="font-size:13px; font-weight:600; color:var(--text-muted);">${dateStr}</td>
                    <td>${statusHtml}</td>
                    <td>${actionsHtml}</td>
                </tr>
            `;
        });

        tbody.innerHTML = html;

        const paginationRow = document.getElementById('posts-pagination-row');
        if (paginationRow) {
            paginationRow.style.display = totalPosts > 0 ? 'flex' : 'none';
            
            const infoEl = document.getElementById('posts-pagination-info');
            if (infoEl) {
                infoEl.textContent = `Showing ${startIdx + 1}-${endIdx} of ${totalPosts} posts`;
            }

            const pageNumEl = document.getElementById('posts-page-num');
            if (pageNumEl) {
                pageNumEl.textContent = `Page ${postsCurrentPage} of ${totalPages}`;
            }

            const prevBtn = document.getElementById('posts-btn-prev');
            if (prevBtn) {
                prevBtn.disabled = postsCurrentPage === 1;
            }

            const nextBtn = document.getElementById('posts-btn-next');
            if (nextBtn) {
                nextBtn.disabled = postsCurrentPage === totalPages;
            }
        }
    }

    function changePostsPage(dir) {
        postsCurrentPage += dir;
        renderPostsTable();
    }

    function publishDraftPost(postId, btn) {
        if (!activeConnectionId) return;
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = `<svg class="spin-icon" style="width:12px;height:12px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>`;

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);

        const publishUrl = '{{ path('app_instagram_bot_posts_publish', {id: 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', postId);

        fetch(publishUrl, {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Post published to Instagram successfully!', 'success');
                loadRecentPosts(false);
            } else {
                showToast('Failed to publish: ' + (data.error || 'Unknown error'), 'error');
                btn.disabled = false;
                btn.innerHTML = origHtml;
                loadRecentPosts(false);
            }
        })
        .catch(err => {
            showToast('Publish error: ' + err.message, 'error');
            btn.disabled = false;
            btn.innerHTML = origHtml;
        });
    }

    function deleteManagerPost(postId, btn) {
        if (!confirm('Are you sure you want to delete this post record? This only removes it from this local manager panel log, it does not delete it from Instagram.')) return;
        if (!activeConnectionId) return;

        const row = btn.closest('tr');
        const origOpacity = row.style.opacity;
        row.style.opacity = '0.5';

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);

        const deleteUrl = '{{ path('app_instagram_bot_posts_delete', {id: 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', postId);

        fetch(deleteUrl, {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Post record deleted.', 'success');
                managerPosts = managerPosts.filter(p => p.id !== postId);
                filterManagerPosts();
            } else {
                showToast('Failed to delete: ' + (data.error || 'Unknown error'), 'error');
                row.style.opacity = origOpacity;
            }
        })
        .catch(err => {
            showToast('Delete error: ' + err.message, 'error');
            row.style.opacity = origOpacity;
        });
    }

    // Dynamic Tab Switcher Logic
    function switchTab(tabId) {
        if (tabId === 'comment-automation') {
            switchTab('Instagram-poster');
            switchPosterTab('comment-automation');
            return;
        }

        // Toggle Nav item states
        document.querySelectorAll('.manager-nav .nav-item[data-tab-target]').forEach(el => {
            if (el.getAttribute('data-tab-target') === tabId) {
                el.classList.add('is-active');
            } else {
                el.classList.remove('is-active');
            }
        });

        // Toggle Content Pane states
        document.querySelectorAll('.manager-content-pane').forEach(el => {
            if (el.id === 'pane-' + tabId) {
                el.classList.add('is-active');
                el.style.display = 'flex';
            } else {
                el.classList.remove('is-active');
                el.style.display = 'none';
            }
        });

        // Trigger previews when tab is opened
        if (tabId === 'growth-widgets') {
            updateWidgetPreview();
        } else if (tabId === 'welcome-screen') {
            updateGreetingPreview();
        } else if (tabId === 'Instagram-poster') {
            updateMpcPreview();
            const params = new URLSearchParams(window.location.search);
            const subtab = params.get('subtab') || 'create';
            switchPosterTab(subtab);
        }

        // Save selected tab state to URL
        const url = new URL(window.location);
        url.searchParams.set('tab', tabId);
        window.history.replaceState({}, '', url);
    }

    // Wire-up DOM actions on load
    document.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const tab = params.get('tab') || 'console';
        switchTab(tab);
        
        renderPostbackTable();
        renderMMCards();
        renderApiConnectorsTable();
        renderOutboundWebhooksTable();

        // Mobile Sidebar Toggling Logic
        const navToggle = document.querySelector('.sidebar-mobile-toggle');
        const managerNav = document.querySelector('.manager-nav');
        if (navToggle && managerNav) {
            navToggle.addEventListener('click', () => {
                managerNav.classList.toggle('is-open');
            });
            // Also close it when a menu option (nav-item) is clicked
            document.querySelectorAll('.manager-nav .nav-item').forEach(item => {
                item.addEventListener('click', () => {
                    managerNav.classList.remove('is-open');
                });
            });
            // Initialize Ice Breakers (FAQs)
            const initialIceBreakers = {{ settings['welcome-screen'].iceBreakers|default([])|json_encode|raw }};
            if (initialIceBreakers && initialIceBreakers.length > 0) {
                initialIceBreakers.forEach(item => {
                    addNewIceBreakerRow(item.question, item.payload);
                });
            }
            updateIceBreakerUi();
        }
    });

    document.querySelectorAll('.manager-nav .nav-item[data-tab-target]').forEach(el => {
        el.addEventListener('click', () => {
            if (el.classList.contains('is-disabled')) return;
            switchTab(el.getAttribute('data-tab-target'));
        });
    });

    function saveBotSettings() {
        if (!activeConnectionId) {
            return showToast('Please select a connection first.', 'error');
        }
        
        const mode = document.getElementById('bh-mode').value;

        const start = document.getElementById('bh-start-time').value;
        const end = document.getElementById('bh-end-time').value;
        const enabled = document.getElementById('bh-enabled').checked;
        
        const days = Array.from(document.querySelectorAll('.bh-day-cb:checked')).map(cb => cb.value);
        
        const bhSettings = {
            enabled,
            mode,
            timezone: tz,
            startTime: start,
            endTime: end,
            days,
            awayMessage: ''
        };
        
        fetch('/instagram-bot-manager/save-settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({
                connectionId: activeConnectionId,
                type: 'business-hours',
                data: JSON.stringify(bhSettings)
            })
        }).then(r => r.json()).then(res => {
            if (res.success) {
                const wlEnabled = document.getElementById('wl-enabled').checked;
                const wlNumbers = document.getElementById('wl-numbers').value;
                fetch('/instagram-bot-manager/save-settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        connectionId: activeConnectionId,
                        type: 'whitelist-mode',
                        data: JSON.stringify({ enabled: wlEnabled, whitelistedNumbers: wlNumbers })
                    })
                }).then(r2 => r2.json()).then(res2 => {
                    if (res2.success) {
                        const blEnabled = document.getElementById('bl-enabled').checked;
                        const blNumbers = document.getElementById('bl-numbers').value;
                        fetch('/instagram-bot-manager/save-settings', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({
                                connectionId: activeConnectionId,
                                type: 'blacklist-mode',
                                data: JSON.stringify({ enabled: blEnabled, blacklistedNumbers: blNumbers })
                            })
                        }).then(r3 => r3.json()).then(res3 => {
                            if (res3.success) {
                                showToast('Bot Settings saved successfully!', 'success');
                            } else {
                                showToast(res3.error, 'error');
                            }
                        });
                    } else {
                        showToast(res2.error, 'error');
                    }
                });
            } else {
                showToast(res.error, 'error');
            }
        });
    }
</script>
{% endblock %}




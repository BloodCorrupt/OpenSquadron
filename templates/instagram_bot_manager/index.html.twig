    // 4. Postback Registry CRUD
    function generateId(prefix = '') {
        return prefix + '_' + Math.random().toString(36).substring(2, 10);
    }

    function renderPostbackTable() {
        const tbody = document.getElementById('postbacks-tbody');
        if (!tbody) return;
        const query = document.getElementById('search-postbacks')?.value.toLowerCase() || '';
        tbody.innerHTML = '';
        
        let filtered = postbacks;
        if (query) {
            filtered = postbacks.filter(p => p.name.toLowerCase().includes(query) || (p.id && p.id.toLowerCase().includes(query)) || (p.payload && p.payload.toLowerCase().includes(query)));
        }
        
        const countDisplay = document.getElementById('postbacks-count-display');
        if (countDisplay) countDisplay.textContent = `Showing ${filtered.length} entries`;
        
        filtered.forEach((item) => {
            const tr = document.createElement('tr');
            const actualIndex = postbacks.indexOf(item);
            
            let linkedFlowName = 'None';
            if (item.linkedFlowId) {
                const flow = window.openSquadronActiveFlows.find(f => f.id == item.linkedFlowId);
                if (flow) linkedFlowName = flow.name;
            }
            
            tr.innerHTML = `
                <td>${actualIndex + 1}</td>
                <td style="font-weight: 600;">${escapeHtml(item.name)}</td>
                <td style="font-family: monospace; color: #34d399;">${escapeHtml(item.id || item.payload)}</td>
                <td><span class="keyword-tag" style="background: rgba(255,255,255,0.05); border:none;">${escapeHtml(linkedFlowName)}</span></td>
                <td style="font-size: 11px; color: #94a3b8;">${escapeHtml(item.updatedAt || 'N/A')}</td>
                <td>
                    <div class="row-actions" style="justify-content: flex-end;">
                        <button class="btn-row-action edit-action" onclick="openPostbackModal(${actualIndex})" title="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg></button>
                        <button class="btn-row-action delete-action" onclick="deletePostbackEntry(${actualIndex})" title="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                    </div>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    function filterPostbacks() { renderPostbackTable(); }

    function openPostbackModal(index = -1) {
        document.getElementById('pb-modal-index').value = index;
        const idInput = document.getElementById('pb-modal-id');
        const overrideCheckbox = document.getElementById('pb-modal-override-id');
        
        if (index >= 0) {
            const item = postbacks[index];
            document.getElementById('postback-modal-title').textContent = 'Edit Postback';
            document.getElementById('pb-modal-name').value = item.name || '';
            document.getElementById('pb-modal-payload').value = item.payload || '';
            document.getElementById('pb-modal-action').value = item.action || '';
            document.getElementById('pb-modal-flow').value = item.linkedFlowId || '';
            
            idInput.value = item.id || item.payload || generateId('pb');
            idInput.readOnly = true;
            overrideCheckbox.checked = false;
        } else {
            document.getElementById('postback-modal-title').textContent = 'Register Postback';
            document.getElementById('pb-modal-name').value = '';
            document.getElementById('pb-modal-payload').value = '';
            document.getElementById('pb-modal-action').value = '';
            document.getElementById('pb-modal-flow').value = '';
            
            idInput.value = generateId('pb');
            idInput.readOnly = true;
            overrideCheckbox.checked = false;
        }
        
        document.getElementById('postback-modal').classList.add('is-open');
        document.getElementById('postback-modal-overlay').classList.add('is-open');
    }

    function closePostbackModal() {
        document.getElementById('postback-modal').classList.remove('is-open');
        document.getElementById('postback-modal-overlay').classList.remove('is-open');
    }

    function copyToClipboard(text, btn) {
        navigator.clipboard.writeText(text).then(() => {
            const oldHtml = btn.innerHTML;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" style="width:16px; height:16px;"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            setTimeout(() => btn.innerHTML = oldHtml, 2000);
        });
    }

    function savePostbackEntry() {
        const index = parseInt(document.getElementById('pb-modal-index').value);
        const name = document.getElementById('pb-modal-name').value.trim();
        const id = document.getElementById('pb-modal-id').value.trim();
        const payload = document.getElementById('pb-modal-payload').value.trim();
        const action = document.getElementById('pb-modal-action').value.trim();
        const linkedFlowId = document.getElementById('pb-modal-flow').value || null;
        
        if (!name || !payload || !id) {
            showToast('Label, ID, and Payload are required', 'error');
            return;
        }
        
        const now = new Date().toISOString().slice(0, 19).replace('T', ' ');
        const entry = { id, name, payload, action, linkedFlowId, updatedAt: now };
        
        if (index >= 0) { postbacks[index] = entry; } else { postbacks.push(entry); }
        
        postSettingsSave('postbacks', postbacks);
        closePostbackModal();
        renderPostbackTable();
    }

    function deletePostbackEntry(index) {
        if (confirm('Are you sure you want to delete this postback?')) {
            postbacks.splice(index, 1);
            postSettingsSave('postbacks', postbacks);
            renderPostbackTable();
        }
    }


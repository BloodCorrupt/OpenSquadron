                    <label class="switch-label" style="display: block; margin-bottom: 6px;">Keyword Matching Strategy</label>
                    <div style="display: flex; gap: 12px; align-items: center; height: 38px;">
                        <label style="display: flex; align-items: center; gap: 6px; cursor: pointer; color: var(--text-main); font-size: 13px;">
                            <input type="radio" name="match-type-${ruleId}" value="exact" ${(!data.filterMatchType || data.filterMatchType === 'exact') ? 'checked' : ''} class="rule-match-exact">
                            <span>Strict Match (Exact)</span>
                        </label>
                        <label style="display: flex; align-items: center; gap: 6px; cursor: pointer; color: var(--text-main); font-size: 13px;">
                            <input type="radio" name="match-type-${ruleId}" value="partial" ${(data.filterMatchType === 'partial') ? 'checked' : ''} class="rule-match-partial">

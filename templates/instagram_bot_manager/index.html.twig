    function toggleMenuValInput(select) {
        const row = select.closest('tr');
        const input = row.querySelector('.menu-val-input');
        const sel = row.querySelector('.menu-val-select');
        let targetSel = sel;
        if (sel && sel.parentNode && sel.parentNode.classList.contains('custom-glass-select-wrapper')) {
            targetSel = sel.parentNode;
        }
        
        if (select.value === 'web_url') {
            input.style.display = 'block';
            targetSel.style.display = 'none';
        } else {
            input.style.display = 'none';
            targetSel.style.display = 'block';
        }
    }

    function savePersistentMenu() {
        const rows = [];
        let hasError = false;
        document.querySelectorAll('.menu-row').forEach(tr => {
            const title = tr.querySelector('.menu-title').value.trim();
            const type = tr.querySelector('.menu-type').value;
            let payloadUrl = '';
            if (type === 'postback') {
                payloadUrl = tr.querySelector('.menu-val-select').value;
            } else {
                payloadUrl = tr.querySelector('.menu-val-input').value.trim();
            }
            if (title === '') {
                showToast('All Persistent Menu items must have a title.', 'error');
                hasError = true;
                return;
            }
            if (payloadUrl === '') {
                showToast('All Persistent Menu items must have a valid payload or URL.', 'error');
                hasError = true;
                return;
            }
            
            const item = { title, type };
            if (type === 'postback') {
                item.payload = payloadUrl;
            } else {
                item.url = payloadUrl;
            }
            rows.push(item);
        });

        if (hasError) return;
        postSettingsSave('persistent-menu', rows);
    }

    function syncPersistentMenu() {
        if (!activeConnectionId) {
            showToast('Please connect a Instagram page first.', 'error');
            return;
        }

        showToast('Syncing persistent menu from Instagram...', 'info');

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);

        fetch('{{ path('app_instagram_bot_sync_persistent_menu') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Persistent menu synced successfully!', 'success');
                const tbody = document.querySelector('#menu-table tbody');
                tbody.innerHTML = '';
                if (data.data && data.data.length > 0) {
                    data.data.forEach(item => {
                        const tr = document.createElement('tr');
                        tr.className = 'menu-row';
                        const typeVal = item.type === 'postback' ? item.payload : item.url;
                        tr.innerHTML = `
                            <td><input type="text" class="glass-input menu-title" style="width:100%" value="${escapeHtml(item.title)}"></td>
                            <td>
                                <select class="glass-input menu-type" style="width:100%" onchange="toggleMenuValInput(this)">
                                    <option value="postback" ${item.type === 'postback' ? 'selected' : ''}>Trigger Postback Payload</option>
                                    <option value="web_url" ${item.type === 'web_url' ? 'selected' : ''}>Redirect to Web URL</option>
                                </select>
                            </td>
                            <td>
                                <input type="text" class="glass-input menu-val" style="width:100%" value="${escapeHtml(typeVal)}">
                            </td>
                            <td>
                                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                } else {
                    showToast('No persistent menu found on Instagram page.', 'info');
                }
            } else {
                showToast('Sync failed: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Sync error: ' + err.message, 'error'));
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }


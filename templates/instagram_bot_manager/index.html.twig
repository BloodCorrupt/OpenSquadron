    function updateFullPageCampaignUI() {
        const isEnabled = pageCommentSettings && pageCommentSettings.enableCommentReply !== false;
        
        const badge = document.getElementById('full-page-status-badge');
        if (badge) {
            if (isEnabled) {
                badge.textContent = 'Active';
                badge.className = 'status-badge status-published';
            } else {
                badge.textContent = 'Inactive';
                badge.className = 'status-badge status-draft';
            }
        }

        const sw = document.getElementById('full-page-reply-switch');
        if (sw) {
            sw.checked = isEnabled;
        }

    function saveCommentAutomationSettings() {
        if (!activeConnectionId) {
            showToast('Please connect a Instagram page first.', 'error');
            return;
        }
        
        const hideOrDelete = document.getElementById('modal-offensive-delete').checked ? 'delete' : 'hide';
        const offensiveKeywords = document.getElementById('modal-offensive-keywords').value.trim();
        const offensivePrivateReplyFlowId = document.getElementById('modal-offensive-private-reply-flow-id').value;
        
        const sendReplyMultipleTimes = document.getElementById('modal-send-multiple-times').checked;
        const enableCommentReply = document.getElementById('modal-enable-comment-reply').checked;
        const hideCommentAfterReply = document.getElementById('modal-hide-comment-after-reply').checked;
        
        const campaignName = document.getElementById('modal-campaign-name').value.trim();
        
        let automationMode = 'generic';
        if (document.getElementById('mode-btn-ai').classList.contains('is-active')) {
            automationMode = 'ai';
        } else if (document.getElementById('mode-btn-filter').classList.contains('is-active')) {
            automationMode = 'filter';
        }
        
        let aiContextId = '';
        let privateReplyFlowId = '';
        let commentReplyText = '';
        let filterMatchType = 'exact';
        let filterWords = '';
        let filterRules = [];
        let fallbackSettings = {};
        
        if (automationMode === 'ai') {
            aiContextId = document.getElementById('modal-ai-context-id').value;
            privateReplyFlowId = document.getElementById('modal-ai-private-reply-flow-id').value;
        } else if (automationMode === 'generic') {
            commentReplyText = document.getElementById('modal-comment-reply-text').value;
            privateReplyFlowId = document.getElementById('modal-generic-private-reply-flow-id').value;
        } else if (automationMode === 'filter') {
            const ruleCards = document.querySelectorAll('#filter-rules-container .filter-rule-card');
            
            if (enableCommentReply && ruleCards.length === 0) {
                showToast('Please add at least one filter rule.', 'error');
                return;
            }

            for (let i = 0; i < ruleCards.length; i++) {
                const card = ruleCards[i];
                const words = card.querySelector('.rule-filter-words').value.trim();
                const matchType = card.querySelector('.rule-match-exact').checked ? 'exact' : 'partial';
                const commentText = card.querySelector('.rule-comment-reply-text').value;
                const privateReplyFlow = card.querySelector('.rule-private-reply-flow-id').value;

                if (enableCommentReply) {
                    if (!words) {
                        showToast(`Please enter filter words for Rule #${i + 1}.`, 'error');
                        return;
                    }
                    if (!commentText && !privateReplyFlow) {
                        showToast(`Please enter a comment reply or select a message template for Rule #${i + 1}.`, 'error');
                        return;
                    }
                }

                filterRules.push({
                    filterWords: words,
                    filterMatchType: matchType,
                    commentReplyText: commentText,
                    privateReplyFlowId: privateReplyFlow
                });
            }

            // Gather fallback settings
            const fallbackCommentText = document.getElementById('modal-fallback-comment-reply-text').value;
            const fallbackPrivateReplyFlow = document.getElementById('modal-fallback-private-reply-flow-id').value;

            fallbackSettings = {
                commentReplyText: fallbackCommentText,
                privateReplyFlowId: fallbackPrivateReplyFlow
            };

            // Backwards compatibility: populate legacy fields with the first rule values
            if (filterRules.length > 0) {
                filterWords = filterRules[0].filterWords;
                filterMatchType = filterRules[0].filterMatchType;
                commentReplyText = filterRules[0].commentReplyText;
                privateReplyFlowId = filterRules[0].privateReplyFlowId;
            }
        }
        
        if (enableCommentReply) {
            if (automationMode === 'ai' && !aiContextId) {
                showToast('Please select an AI Context.', 'error');
                return;
            }
            if (automationMode === 'generic' && !commentReplyText) {
                showToast('Please enter a comment reply message.', 'error');
                return;
            }
        }
        
        if (!campaignName) {
            showToast('Please enter a campaign name.', 'error');
            return;
        }
        
        const settingsStructure = {
            hideOrDelete,
            offensiveKeywords,
            offensivePrivateReplyFlowId,
            sendReplyMultipleTimes,
            enableCommentReply,
            hideCommentAfterReply,
            automationMode,
            campaignName,
            aiContextId,
            privateReplyFlowId,
            commentReplyText,
            filterMatchType,
            filterWords,
            filterRules,
            fallbackSettings
        };
        
        const saveBtn = document.getElementById('btn-save-comment-automation');
        const origBtnText = saveBtn.innerHTML;
        saveBtn.disabled = true;
        saveBtn.innerHTML = `<svg class="spin-icon" style="width:14px;height:14px;margin-right:6px;vertical-align:middle;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg> Saving...`;
        
        if (currentEditingPostId === null) {
            const formData = new FormData();
            formData.append('connectionId', activeConnectionId);
            formData.append('type', 'comment-automation');
            formData.append('data', JSON.stringify(settingsStructure));
            
            fetch('{{ path('app_instagram_bot_save_settings') }}', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                saveBtn.disabled = false;
                saveBtn.innerHTML = origBtnText;
                if (data.success) {
                    pageCommentSettings = settingsStructure;
                    showToast('Full Page Comment Automation settings saved!', 'success');
                    closeCommentAutomationModal();
                    updateCommentMetrics();
                    updateFullPageCampaignUI();
                } else {
                    showToast('Failed to save settings: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(err => {
                saveBtn.disabled = false;
                saveBtn.innerHTML = origBtnText;
                showToast('Save error: ' + err.message, 'error');
            });
        } else {
            const formData = new FormData();
            formData.append('connectionId', activeConnectionId);
            formData.append('postId', currentEditingPostId);
            formData.append('settings', JSON.stringify(settingsStructure));
            
            fetch('/Instagram-bot-manager/posts/save-comment-settings', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                saveBtn.disabled = false;
                saveBtn.innerHTML = origBtnText;
                if (data.success) {
                    showToast('Post comment automation settings saved!', 'success');
                    closeCommentAutomationModal();
                    loadCommentAutomationTab(false);
                } else {
                    showToast('Failed to save: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(err => {
                saveBtn.disabled = false;
                saveBtn.innerHTML = origBtnText;
                showToast('Save error: ' + err.message, 'error');
            });
        }
    }


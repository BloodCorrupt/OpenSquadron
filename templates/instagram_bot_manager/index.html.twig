    function submitManualComment() {
        const graphId = document.getElementById('manual-comment-graph-id').value;
        const message = document.getElementById('manual-comment-text').value.trim();
        const btn = document.getElementById('btn-send-manual-comment');
        
        if (!message) {
            showToast('Please enter a comment.', 'error');
            return;
        }
        
        btn.disabled = true;
        btn.textContent = 'Sending...';
        
        fetch('{{ path('app_instagram_bot_posts_comment_manual') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                postId: graphId,
                message: message,
                connectionId: activeConnectionId
            })
        })
        .then(res => res.json())
        .then(data => {
            btn.disabled = false;
            btn.textContent = 'Send Comment';
            if (data.success) {
                showToast('Comment sent successfully!', 'success');
                closeManualCommentModal();
            } else {
                showToast('Failed to send comment: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => {
            btn.disabled = false;
            btn.textContent = 'Send Comment';
            showToast('Network error: ' + err.message, 'error');
        });
    }


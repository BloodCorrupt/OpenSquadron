    body[data-theme="light"] .modal-input:focus,
    body[data-theme="light"] .modal-textarea:focus {
        border-color: var(--primary-accent) !important;
        box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.12) !important;
    }
    body[data-theme="light"] .mode-option-btn {
        background: #ffffff !important;
        border-color: #cbd5e1 !important;
        color: #475569 !important;
    }
    body[data-theme="light"] .mode-option-btn:hover {
        background: #f8fafc !important;
        color: #0f172a !important;
    }
    body[data-theme="light"] .mode-option-btn.is-active {
        background: rgba(8, 145, 178, 0.08) !important;
        border-color: rgba(8, 145, 178, 0.3) !important;
        color: var(--primary-accent) !important;
    }
    body[data-theme="light"] .toggle-slider {
        background-color: #cbd5e1 !important;
        border-color: #cbd5e1 !important;
    }
    body[data-theme="light"] .toggle-switch input:checked + .toggle-slider {
        background-color: rgba(16, 185, 129, 0.2) !important;
        border-color: rgba(16, 185, 129, 0.4) !important;
    }
    body[data-theme="light"] .toggle-switch-blue input:checked + .toggle-slider {
        background-color: rgba(6, 182, 212, 0.2) !important;
        border-color: rgba(6, 182, 212, 0.4) !important;
    }
    body[data-theme="light"] #outbound-webhook-modal div[style*="background: rgba(0,0,0,0.15)"],
    body[data-theme="light"] #outbound-webhook-modal div[style*="background:rgba(0,0,0,0.15)"] {

                        <button type="button" class="btn-action" style="font-size: 10px; padding: 4px 8px; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff;" onclick="insertRulePlaceholder(this, '{last_name}')">Last name</button>
                    </div>
                </div>

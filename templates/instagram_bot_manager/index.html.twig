{% block body %}
<div class="manager-shell">
    {# â”€â”€â”€â”€â”€â”€â”€â”€â”€ Left Sidebar Navigation (Logical Groups) â”€â”€â”€â”€â”€â”€â”€â”€â”€ #}
    {% if connections is not empty %}
    <div class="manager-nav">
        <div class="sidebar-mobile-toggle">
            <span>
                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke-width: 2.5;"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                Menu Options
            </span>
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="nav-header">Instagram Page</div>
        <div style="margin-bottom: 10px; padding: 0 10px;">
            <select id="Instagram-conn-selector" class="form-control" style="background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); color: #fff; padding: 8px 12px; border-radius: 8px; font-size: 15px; width: 100%; height: 38px;" onchange="changeConnection(this.value)">
                {% if connections is empty %}
                    <option value="">No Pages Connected</option>
                {% else %}
                    {% for conn in connections %}
                        <option value="{{ conn.id }}" {% if connection and connection.id == conn.id %}selected{% endif %}>
                            {{ conn.label ?: conn.pageName ?: 'Unnamed Page (' ~ conn.id ~ ')' }}
                        </option>
                    {% endfor %}
                {% endif %}
            </select>
        </div>

        <!-- 1. General Panel -->
        <div class="nav-header">Main Console</div>
        <div class="nav-item is-active" data-tab-target="console">
            <span class="nav-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"></rect><rect x="14" y="3" width="7" height="5"></rect><rect x="14" y="12" width="7" height="9"></rect><rect x="3" y="16" width="7" height="5"></rect></svg>
            </span>
            <span>Dashboard Hub</span>
        </div>

        <!-- 2. Core Responders -->
        <div class="nav-header">Core Responders</div>
        <div class="nav-item" data-tab-target="bot-reply">
            <span class="nav-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M6 11V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"></path></svg>
            </span>
            <span>Autoreply Trigger Flows</span>
        </div>

        <div class="nav-item" data-tab-target="ai-agent">
            <span class="nav-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
            </span>
            <span>Intelligent AI Copilot</span>

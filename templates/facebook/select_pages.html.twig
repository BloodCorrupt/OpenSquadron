{% extends 'base.html.twig' %}

{% block title %}Select Facebook Page{% endblock %}

{% block stylesheets %}
<style>
    .select-pages-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .page-header h1 {
        margin: 0;
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    .page-header p {
        color: var(--text-muted);
        margin-top: 10px;
        font-size: 15px;
    }

    .pages-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .page-card {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 24px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }
    .page-card:hover {
        background: rgba(15, 23, 42, 0.6);
        border-color: var(--primary-accent);
        box-shadow: 0 10px 30px rgba(6, 182, 212, 0.15);
        transform: translateY(-4px);
    }

    .page-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-accent), var(--secondary-accent));
        opacity: 0;
        transition: opacity 0.3s;
    }
    .page-card:hover::before {
        opacity: 1;
    }

    .page-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(16, 185, 129, 0.1));
        border: 1px solid rgba(6, 182, 212, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-accent);
        font-weight: 700;
        font-size: 20px;
        margin-bottom: 16px;
    }

    .page-title {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin: 0 0 6px 0;
        line-height: 1.3;
    }

    .page-category {
        font-size: 12px;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.04);
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 16px;
    }

    .page-meta {
        font-size: 11px;
        color: var(--text-muted);
        margin-bottom: 24px;
        font-family: monospace;
    }

    .select-btn {
        width: 100%;
        padding: 12px 20px;
        border: none;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid var(--glass-border);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .page-card:hover .select-btn {
        background: linear-gradient(135deg, var(--primary-accent), var(--secondary-accent));
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
    }

    .no-pages-warning {
        text-align: center;
        padding: 50px 30px;
        background: rgba(15, 23, 42, 0.3);
        border: 1px dashed var(--glass-border);
        border-radius: 16px;
        margin-bottom: 40px;
    }
    .no-pages-warning h3 {
        font-size: 18px;
        color: #fff;
        margin-bottom: 10px;
    }
    .no-pages-warning p {
        color: var(--text-muted);
        max-width: 500px;
        margin: 0 auto 20px auto;
        font-size: 14px;
    }

    .actions-bar {
        display: flex;
        justify-content: center;
        gap: 16px;
    }
    .cancel-link {
        padding: 12px 24px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
    }
    .cancel-link:hover {
        background: rgba(255, 255, 255, 0.07);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.15);
    }
</style>
{% endblock %}

{% block body %}
<div class="select-pages-container">

    <div class="page-header">
        <h1>
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:28px; height:28px;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            Select Facebook Page
        </h1>
        <p>Choose the page you want to connect to OpenSquadron from your authorized list</p>
    </div>

    {% if pages is empty %}
        <div class="no-pages-warning">
            <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:48px; height:48px; display: inline-block; margin-bottom: 16px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            <h3>No Pages Found</h3>
            <p>We couldn't find any Facebook Pages associated with this account. Please make sure you are an administrator of at least one Facebook Page and have granted all page permissions during the authorization prompt.</p>
            <a href="{{ path('facebook_connect_show') }}" class="cancel-link" style="display: inline-block; margin-top: 10px;">Back to Credentials</a>
        </div>
    {% else %}
        <div class="pages-grid">
            {% for page in pages %}
                <div class="page-card">
                    <div>
                        <div class="page-avatar">
                            {{ page.name|slice(0,1)|upper }}
                        </div>
                        <h3 class="page-title">{{ page.name }}</h3>
                        {% if page.category is defined and page.category %}
                            <span class="page-category">{{ page.category }}</span>
                        {% endif %}
                        <div class="page-meta">ID: {{ page.id }}</div>
                    </div>
                    <form method="post" action="{{ path('facebook_connect_page_submit') }}">
                        <input type="hidden" name="pageId" value="{{ page.id }}">
                        <button type="submit" class="select-btn">Connect Page</button>
                    </form>
                </div>
            {% endfor %}
        </div>

        <div class="actions-bar">
            <a href="{{ path('facebook_connect_show') }}" class="cancel-link">
                Cancel & Start Over
            </a>
        </div>
    {% endif %}

</div>
{% endblock %}

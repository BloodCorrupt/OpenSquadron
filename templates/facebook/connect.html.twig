{% extends 'base.html.twig' %}

{% block title %}Facebook Page Connection (Beta) - OpenSquadron{% endblock %}

{% block stylesheets %}
<style>
    .config-wizard {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .page-header h1 {
        margin: 0;
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    .page-header p {
        color: var(--text-muted);
        margin-top: 10px;
        font-size: 15px;
    }
    .beta-badge {
        background: linear-gradient(135deg, #f59e0b, #ef4444);
        color: white;
        font-size: 10px;
        font-weight: 800;
        padding: 3px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
        animation: betaPulse 2s ease-in-out infinite;
    }
    @keyframes betaPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
        50% { box-shadow: 0 0 12px 4px rgba(245, 158, 11, 0.2); }
    }

    /* ───── Connected Pages List ───── */
    .connections-section {
        margin-bottom: 40px;
    }
    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .section-title .count-badge {
        background: rgba(6, 182, 212, 0.15);
        color: var(--primary-accent);
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid rgba(6, 182, 212, 0.3);
    }

    .conn-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 20px;
    }

    .conn-card {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 22px;
        transition: all 0.25s ease;
        position: relative;
        backdrop-filter: blur(10px);
    }
    .conn-card:hover {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
        transform: translateY(-2px);
    }

    .conn-card-top {
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
        gap: 14px;
        margin-bottom: 16px;
    }
    
    .conn-avatar-placeholder {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.2), rgba(99, 102, 241, 0.2));
        border: 1px solid rgba(6, 182, 212, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-accent);
        font-size: 20px;
        font-weight: bold;
        flex-shrink: 0;
    }

    .conn-info-wrapper {
        flex-grow: 1;
        min-width: 0;
    }

    .conn-label {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .conn-label-fallback {
        color: var(--text-muted);
        font-style: italic;
    }
    .conn-page-name {
        margin-top: 4px;
        font-size: 13px;
        color: var(--primary-accent);
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .conn-status {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 20px;
        margin-left: auto;
        flex-shrink: 0;
    }
    .conn-status.active {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .conn-details {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 18px;
        background: rgba(0, 0, 0, 0.15);
        padding: 12px 16px;
        border-radius: 8px;
    }
    .conn-detail {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 13px;
        gap: 10px;
    }
    .conn-detail-label {
        color: var(--text-muted);
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .conn-detail-value {
        color: #e2e8f0;
        font-family: monospace;
        font-size: 12px;
        word-break: break-all;
    }

    .conn-actions {
        display: flex;
        gap: 10px;
        border-top: 1px solid var(--glass-border);
        padding-top: 14px;
    }
    .conn-action-btn {
        flex: 1;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
    .conn-action-btn:hover {
        background: rgba(255, 255, 255, 0.06);
        color: #fff;
    }
    .conn-action-btn.edit-btn:hover {
        border-color: var(--primary-accent);
        color: var(--primary-accent);
    }
    .conn-action-btn.delete-btn:hover {
        border-color: #ef4444;
        color: #ef4444;
    }

    .empty-connections {
        text-align: center;
        padding: 50px 30px;
        color: var(--text-muted);
        background: rgba(15, 23, 42, 0.3);
        border-radius: 16px;
        border: 1px dashed var(--glass-border);
        backdrop-filter: blur(8px);
    }
    .empty-connections h3 {
        color: #fff;
        margin: 14px 0 8px;
        font-size: 18px;
    }

    .glass-card {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 40px;
        margin-bottom: 30px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .edit-banner {
        background: rgba(6, 182, 212, 0.08);
        border: 1px solid rgba(6, 182, 212, 0.2);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--primary-accent);
        font-size: 14px;
        font-weight: 600;
    }
    .edit-banner a {
        margin-left: auto;
        color: var(--text-muted);
        font-size: 13px;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        padding: 6px 14px;
        border-radius: 20px;
        transition: all 0.2s;
    }
    .edit-banner a:hover {
        color: #fff;
        background: rgba(255, 255, 255, 0.08);
    }
</style>
{% endblock %}

{% block body %}
<div class="config-wizard">

    <div class="page-header">
        <h1>
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px; height:28px;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            Facebook Messenger
            <span class="beta-badge">Beta</span>
        </h1>
        <p>Integrate Facebook Pages to receive, track and automate your customer messaging flows</p>
    </div>

    {# ───── Connected Pages Grid ───── #}
    <div class="connections-section">
        <div class="section-title">
            <span style="display: flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px; height:18px;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                <span>Active Page Connections</span>
            </span>
            <span class="count-badge">{{ connections|length }}</span>
        </div>

        {% if connections is empty %}
            <div class="empty-connections">
                <span style="display: block; margin-bottom: 12px; opacity: 0.4; color: var(--text-muted); text-align: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:48px; height:48px; display: inline-block;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </span>
                <h3>No Facebook Pages Linked</h3>
                <p>Configure Facebook settings and click connect to start routing Messenger conversations.</p>
            </div>
        {% else %}
            <div class="conn-grid">
                {% for conn in connections %}
                    <div class="conn-card" id="fb-conn-card-{{ conn.id }}">
                        <div class="conn-card-top">
                            <div class="conn-avatar-placeholder">
                                {{ (conn.pageName ?: conn.label ?: 'F')|slice(0, 1)|upper }}
                            </div>
                            <div class="conn-info-wrapper">
                                {% if conn.label %}
                                    <div class="conn-label">{{ conn.label }}</div>
                                {% else %}
                                    <div class="conn-label conn-label-fallback">Connection #{{ conn.id }}</div>
                                {% endif %}
                                {% if conn.pageName %}
                                    <div class="conn-page-name">
                                        📄 {{ conn.pageName }}
                                    </div>
                                {% endif %}
                            </div>
                            <span class="conn-status {{ conn.status }}">{{ conn.status }}</span>
                        </div>

                        <div class="conn-details">
                            <div class="conn-detail">
                                <span class="conn-detail-label">Page ID</span>
                                <span class="conn-detail-value">{{ conn.pageId }}</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">Linked On</span>
                                <span class="conn-detail-value">{{ conn.createdAt ? conn.createdAt|date('M d, Y') : '—' }}</span>
                            </div>
                        </div>

                        <div class="conn-actions">
                            <a href="{{ path('facebook_connect_edit', {id: conn.id}) }}" class="conn-action-btn edit-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                <span>Edit Label</span>
                            </a>
                            <form method="post" action="{{ path('facebook_connect_subscribe', {id: conn.id}) }}" style="flex: 1; display: flex; margin: 0; padding: 0;">
                                <button type="submit" class="conn-action-btn edit-btn" style="width: 100%;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                                    <span>Subscribe Webhook</span>
                                </button>
                            </form>
                            <button onclick="deleteFbConnection({{ conn.id }})" class="conn-action-btn delete-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <hr style="border: none; border-top: 1px solid var(--glass-border); margin: 40px 0;">

    {# ───── Add / Edit Form ───── #}
    {% if editConnection is defined and editConnection %}
        <div class="edit-banner">
            <span style="display: inline-flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px; height:14px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                <span>Modifying label for: {{ editConnection.label ?? ('Connection #' ~ editConnection.id) }}</span>
            </span>
            <a href="{{ path('facebook_connect_show') }}">✕ Cancel</a>
        </div>
        
        <form method="post" action="{{ path('facebook_connect_update', {id: editConnection.id}) }}" autocomplete="off" class="glass-card" style="max-width: 600px; margin: 0 auto;">
            <div class="form-group">
                <label for="label">Connection Label / Friendly Name</label>
                <input type="text" id="label" name="label" class="form-control"
                       value="{{ editConnection.label ?? '' }}" placeholder="e.g. Sales Account, Customer Support..." required autocomplete="off">
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                <div class="form-group" style="margin-bottom: 0;">
                    <label>Page Name</label>
                    <input type="text" class="form-control" value="{{ editConnection.pageName }}" disabled style="opacity: 0.6; cursor: not-allowed;">
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                    <label>Facebook Page ID</label>
                    <input type="text" class="form-control" value="{{ editConnection.pageId }}" disabled style="opacity: 0.6; cursor: not-allowed;">
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 30px;">
                Update Friendly Name
            </button>
        </form>
    {% else %}
        {% if setting and setting.appId and setting.encryptedAppSecret %}
            <form method="post" action="{{ path('facebook_connect') }}" autocomplete="off">
                <div class="glass-card" style="text-align: center; max-width: 550px; margin: 0 auto; padding: 45px 40px;">
                    <div style="margin-bottom: 24px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="var(--primary-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; display: inline-block;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </div>
                    <h3 style="color: #fff; font-size: 20px; font-weight: 700; margin-bottom: 12px;">Link Facebook Account</h3>
                    <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 30px; line-height: 1.6;">
                        Connect your Facebook Pages to route customer Messenger threads directly into your shared team inbox.
                    </p>

                    <div class="form-group" style="text-align: left; margin-bottom: 28px;">
                        <label for="label">Connection Label / Friendly Name <span style="font-weight: normal; color: var(--text-muted); font-size: 12px;">(Optional)</span></label>
                        <input type="text" id="label" name="label" class="form-control" placeholder="e.g. Support Inbox, Bot Account..." autocomplete="off">
                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 6px;">Used to help distinguish multiple linked pages.</div>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 16px 24px; border-radius: 30px;">
                        Connect Facebook Account
                    </button>
                </div>
            </form>
        {% else %}
            <div class="glass-card" style="text-align: center; max-width: 550px; margin: 0 auto; padding: 45px 40px; border-color: rgba(239, 68, 68, 0.2); background: rgba(239, 68, 68, 0.03);">
                <div style="margin-bottom: 24px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; display: inline-block;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </div>
                <h3 style="color: #fff; font-size: 20px; font-weight: 700; margin-bottom: 12px;">Configuration Required</h3>
                <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 30px; line-height: 1.6;">
                    To initiate a connection, you must configure your Facebook Developer App credentials (App ID & App Secret) in the global settings first.
                </p>
                <a href="{{ path('app_facebook_settings') }}" class="btn btn-primary" style="display: inline-block; padding: 14px 28px; border-radius: 30px; text-decoration: none; text-transform: uppercase; font-size: 14px;">
                    Configure Facebook Settings
                </a>
            </div>
        {% endif %}
    {% endif %}
</div>

<script>
function deleteFbConnection(id) {
    if (!confirm('Are you sure you want to remove this Facebook Page connection? This cannot be undone.')) return;

    fetch('/admin/facebook/connect/' + id + '/delete', { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const card = document.getElementById('fb-conn-card-' + id);
                if (card) {
                    card.style.transition = 'all 0.3s';
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.95)';
                    setTimeout(() => { 
                        card.remove(); 
                        // Refresh page if no connections left to show empty state
                        const grid = document.querySelector('.conn-grid');
                        if (grid && grid.children.length === 0) {
                            window.location.reload();
                        }
                    }, 300);
                }
                const badge = document.querySelector('.count-badge');
                if (badge) badge.textContent = parseInt(badge.textContent) - 1;
            } else {
                alert('Failed to delete connection.');
            }
        })
        .catch(() => alert('An error occurred while deleting.'));
}
</script>
{% endblock %}

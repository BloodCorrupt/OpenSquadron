{% extends 'base.html.twig' %}

{% block title %}Facebook Page Connection (Beta){% endblock %}

{% block stylesheets %}
<style>
    .config-wizard {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 40px;
    }
    .page-header h1 {
        margin: 0;
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    .page-header p {
        color: var(--text-muted);
        margin-top: 10px;
        font-size: 15px;
    }
    .beta-badge {
        background: linear-gradient(135deg, #f59e0b, #ef4444);
        color: white;
        font-size: 10px;
        font-weight: 800;
        padding: 3px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
        animation: betaPulse 2s ease-in-out infinite;
    }
    @keyframes betaPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
        50% { box-shadow: 0 0 12px 4px rgba(245, 158, 11, 0.2); }
    }

    /* ───── Connected Pages List ───── */
    .connections-section {
        margin-bottom: 40px;
    }
    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .section-title .count-badge {
        background: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .conn-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 16px;
    }

    .conn-card {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 22px;
        transition: all 0.25s;
        position: relative;
    }
    .conn-card:hover {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
        transform: translateY(-2px);
    }

    .conn-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
    }
    .conn-label {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
    }
    .conn-label-fallback {
        color: var(--text-muted);
        font-style: italic;
    }
    .conn-status {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 20px;
        flex-shrink: 0;
    }
    .conn-status.active {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .conn-details {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 16px;
    }
    .conn-detail {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
    }
    .conn-detail-label {
        color: var(--text-muted);
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        min-width: 110px;
    }
    .conn-detail-value {
        color: #60a5fa;
        font-family: monospace;
        font-size: 12px;
        word-break: break-all;
    }

    .conn-actions {
        display: flex;
        gap: 8px;
        border-top: 1px solid var(--glass-border);
        padding-top: 14px;
    }
    .conn-action-btn {
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.03);
        color: var(--text-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .conn-action-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
    }
    .conn-action-btn.edit-btn:hover {
        border-color: #60a5fa;
        color: #60a5fa;
    }
    .conn-action-btn.delete-btn:hover {
        border-color: #ef4444;
        color: #ef4444;
    }

    .empty-connections {
        text-align: center;
        padding: 40px;
        color: var(--text-muted);
        background: rgba(15, 23, 42, 0.3);
        border-radius: 12px;
        border: 1px dashed var(--glass-border);
    }
    .empty-connections h3 {
        color: #fff;
        margin: 10px 0 6px;
        font-size: 16px;
    }

    /* ───── Wizard Steps ───── */
    .wizard-step {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        position: relative;
    }
    .step-number {
        position: absolute;
        top: -15px;
        left: 30px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 14px;
        box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);
    }
    .step-title {
        margin-top: 5px;
        margin-bottom: 20px;
        font-size: 18px;
        color: #fff;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .endpoint-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .endpoint-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: background 0.3s;
    }
    .endpoint-item:hover {
        background: rgba(255, 255, 255, 0.06);
    }
    .endpoint-info { flex: 1; }
    .endpoint-label {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: bold;
        margin-bottom: 5px;
        letter-spacing: 0.5px;
    }
    .endpoint-value {
        font-family: monospace;
        color: #60a5fa;
        font-size: 13px;
        word-break: break-all;
    }
    .copy-btn {
        background: rgba(59, 130, 246, 0.1);
        color: #60a5fa;
        border: 1px solid rgba(59, 130, 246, 0.3);
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-left: 20px;
        white-space: nowrap;
    }
    .copy-btn:hover {
        background: #3b82f6;
        color: white;
    }

    .form-divider {
        border: none;
        border-top: 1px solid var(--glass-border);
        margin: 30px 0;
    }

    .edit-banner {
        background: rgba(59, 130, 246, 0.08);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 10px;
        padding: 14px 20px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #60a5fa;
        font-size: 14px;
        font-weight: 600;
    }
    .edit-banner a {
        margin-left: auto;
        color: var(--text-muted);
        font-size: 13px;
        text-decoration: none;
    }
    .edit-banner a:hover {
        color: #fff;
    }
</style>
{% endblock %}

{% block body %}
<div class="config-wizard">

    <div class="page-header">
        <h1>
            <svg viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:28px; height:28px;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            Facebook Messenger
            <span class="beta-badge">Beta</span>
        </h1>
        <p>Connect your Facebook Pages to receive and respond to Messenger conversations</p>
    </div>

    {# ───── Connected Pages Grid ───── #}
    <div class="connections-section">
        <div class="section-title">
            <span style="display: flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px; height:18px;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                <span>Connected Pages</span>
            </span>
            <span class="count-badge">{{ connections|length }}</span>
        </div>

        {% if connections is empty %}
            <div class="empty-connections">
                <span style="display: block; margin-bottom: 12px; opacity: 0.4; color: var(--text-muted); text-align: center;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:48px; height:48px; display: inline-block;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </span>
                <h3>No Pages Connected Yet</h3>
                <p>Add your first Facebook Page using the form below.</p>
            </div>
        {% else %}
            <div class="conn-grid">
                {% for conn in connections %}
                    <div class="conn-card" id="fb-conn-card-{{ conn.id }}">
                        <div class="conn-card-top">
                            <div>
                                {% if conn.label %}
                                    <div class="conn-label">{{ conn.label }}</div>
                                {% else %}
                                    <div class="conn-label conn-label-fallback">Connection #{{ conn.id }}</div>
                                {% endif %}
                                {% if conn.pageName %}
                                    <div style="margin-top: 6px; font-size: 14px; color: #60a5fa; font-weight: 600;">
                                        📄 {{ conn.pageName }}
                                    </div>
                                {% endif %}
                            </div>
                            <span class="conn-status {{ conn.status }}">{{ conn.status }}</span>
                        </div>

                        <div class="conn-details">
                            <div class="conn-detail">
                                <span class="conn-detail-label">Page ID</span>
                                <span class="conn-detail-value">{{ conn.pageId }}</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">App ID</span>
                                <span class="conn-detail-value">{{ conn.appId }}</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">Token</span>
                                <span class="conn-detail-value" style="color: var(--text-muted);">●●●●●●●● (encrypted)</span>
                            </div>
                            <div class="conn-detail">
                                <span class="conn-detail-label">Connected</span>
                                <span class="conn-detail-value" style="color: var(--text-muted);">{{ conn.createdAt ? conn.createdAt|date('M d, Y') : '—' }}</span>
                            </div>
                        </div>

                        <div class="conn-actions">
                            <a href="{{ path('facebook_connect_edit', {id: conn.id}) }}" class="conn-action-btn edit-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                <span>Edit</span>
                            </a>
                            <button onclick="deleteFbConnection({{ conn.id }})" class="conn-action-btn delete-btn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 12px; height: 12px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                <span>Delete</span>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <hr class="form-divider">

    {# ───── Add / Edit Form ───── #}
    {% if editConnection is defined and editConnection %}
        <div class="edit-banner">
            <span style="display: inline-flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px; height:14px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                <span>Editing Label: {{ editConnection.label ?? ('Connection #' ~ editConnection.id) }}</span>
            </span>
            <a href="{{ path('facebook_connect_show') }}">✕ Cancel</a>
        </div>
        <form method="post" action="{{ path('facebook_connect_update', {id: editConnection.id}) }}" autocomplete="off" class="glass-panel" style="padding: 40px;">
    {% else %}
        <form method="post" action="{{ path('facebook_connect') }}" autocomplete="off" class="glass-panel" style="padding: 40px;">
    {% endif %}

        <!-- Prevent browsers from autofilling -->
        <input style="display:none" type="text" name="fakeusernameremembered"/>
        <input style="display:none" type="password" name="fakepasswordremembered"/>

        <!-- Step 1: Input -->
        {% if editConnection is defined and editConnection %}
        <div class="wizard-step">
            <div class="step-number">1</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Update Connection Details
            </h3>

            <div class="form-group">
                <label>Connection Label</label>
                <input type="text" name="label" class="form-control"
                       value="{{ editConnection.label ?? '' }}" placeholder="e.g. Business Page, Support Automation..." autocomplete="off" required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Facebook Page ID</label>
                    <input type="text" class="form-control" value="{{ editConnection.pageId }}" disabled style="opacity: 0.6; cursor: not-allowed;">
                </div>
                <div class="form-group">
                    <label>Page Name</label>
                    <input type="text" class="form-control" value="{{ editConnection.pageName }}" disabled style="opacity: 0.6; cursor: not-allowed;">
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label>Facebook App ID</label>
                <input type="text" class="form-control" value="{{ editConnection.appId }}" disabled style="opacity: 0.6; cursor: not-allowed;">
            </div>
        </div>
        {% else %}
        <div class="wizard-step">
            <div class="step-number">1</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Facebook Login Credentials
            </h3>

            <div class="form-group">
                <label>Connection Label (Optional)</label>
                <input type="text" name="label" class="form-control"
                       placeholder="e.g. Business Page, Support Automation..." autocomplete="off">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Facebook App ID <span style="color: #60a5fa;">*</span></label>
                    <input type="text" name="appId" class="form-control"
                           placeholder="Enter your Facebook App ID..." required autocomplete="new-password">
                </div>
                <div class="form-group">
                    <label>Facebook App Secret <span style="color: #60a5fa;">*</span></label>
                    <input type="password" name="appSecret" class="form-control"
                           placeholder="Enter your Facebook App Secret..." required autocomplete="new-password">
                </div>
            </div>

            <div class="endpoint-list" style="margin-top: 20px;">
                <div class="endpoint-item" style="border: 1px solid rgba(59, 130, 246, 0.2); background: rgba(59, 130, 246, 0.03);">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Valid OAuth Redirect URI</div>
                        <input type="hidden" id="fb-url-oauth-callback" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('facebook_connect_callback') }}">
                        <div class="endpoint-value" style="color: #60a5fa;">{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('facebook_connect_callback') }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-oauth-callback')">Copy URL</button>
                </div>
            </div>
        </div>
        {% endif %}


        {% if editConnection is not defined or not editConnection %}
        <!-- Step 2: Webhook endpoints (only for new connections) -->
        <div class="wizard-step">
            <div class="step-number">2</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Map Webhook Endpoints
            </h3>
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">
                Copy these endpoints into your Meta App Dashboard → Messenger → Webhooks to establish the realtime bridge.
            </p>

            <div class="endpoint-list">
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Messenger Webhook Callback URL</div>
                        <input type="hidden" id="fb-url-webhook" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('facebook_webhook_verify') }}">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('facebook_webhook_verify') }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-webhook')">Copy URL</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Verify Token (auto-generated after save)</div>
                        <div class="endpoint-value" style="color: var(--text-muted);">A unique verify token will be generated when you save the connection. Come back to this page to copy it.</div>
                    </div>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Privacy Policy Compliance Route</div>
                        <input type="hidden" id="fb-url-privacy" value="{{ url('app_privacy')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_privacy')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-privacy')">Copy Policy URL</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Terms of Service Compliance Route</div>
                        <input type="hidden" id="fb-url-terms" value="{{ url('app_terms')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_terms')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-terms')">Copy Terms URL</button>
                </div>
            </div>
        </div>
        {% else %}
        <!-- Show verify token for existing connections -->
        <div class="wizard-step">
            <div class="step-number">2</div>
            <h3 class="step-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Webhook Configuration
            </h3>

            <div class="endpoint-list">
                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Messenger Webhook Callback URL</div>
                        <input type="hidden" id="fb-url-webhook" value="{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('facebook_webhook_verify') }}">
                        <div class="endpoint-value">{{ app.request.schemeAndHttpHost|replace({'http://': 'https://'}) }}{{ path('facebook_webhook_verify') }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-webhook')">Copy URL</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Cryptographic Verify Token</div>
                        <input type="hidden" id="fb-url-verify" value="{{ editConnection.verifyToken }}">
                        <div class="endpoint-value">{{ editConnection.verifyToken }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-verify')">Copy Token</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Privacy Policy Compliance Route</div>
                        <input type="hidden" id="fb-url-privacy" value="{{ url('app_privacy')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_privacy')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-privacy')">Copy Policy URL</button>
                </div>

                <div class="endpoint-item">
                    <div class="endpoint-info">
                        <div class="endpoint-label">Terms of Service Compliance Route</div>
                        <input type="hidden" id="fb-url-terms" value="{{ url('app_terms')|replace({'http://': 'https://'}) }}">
                        <div class="endpoint-value">{{ url('app_terms')|replace({'http://': 'https://'}) }}</div>
                    </div>
                    <button type="button" class="copy-btn" onclick="fbCopyToClipboard('fb-url-terms')">Copy Terms URL</button>
                </div>
            </div>
        </div>
        {% endif %}

        <div style="margin-top: 40px; text-align: center;">
            <button type="submit" class="btn btn-primary" style="padding: 16px 40px; font-size: 16px; border-radius: 30px; background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                {% if editConnection is defined and editConnection %}
                    UPDATE CONNECTION
                {% else %}
                    CONNECT WITH FACEBOOK
                {% endif %}
            </button>
        </div>
    </form>
</div>

<script>
function deleteFbConnection(id) {
    if (!confirm('Are you sure you want to remove this Facebook Page connection? This cannot be undone.')) return;

    fetch('/admin/facebook/connect/' + id + '/delete', { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const card = document.getElementById('fb-conn-card-' + id);
                if (card) {
                    card.style.transition = 'all 0.3s';
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.95)';
                    setTimeout(() => { card.remove(); }, 300);
                }
                const badge = document.querySelector('.count-badge');
                if (badge) badge.textContent = parseInt(badge.textContent) - 1;
            } else {
                alert('Failed to delete connection.');
            }
        })
        .catch(() => alert('An error occurred while deleting.'));
}

function fbCopyToClipboard(elementId) {
    var el = document.getElementById(elementId);
    navigator.clipboard.writeText(el.value).then(function() {
        alert("Copied: " + el.value);
    });
}
</script>
{% endblock %}

            body[data-theme="light"] [style*="color:#ffffff"],
            body[data-theme="light"] [style*="color: #ffffff"] {
                color: var(--text-header) !important;
            }

            /* Button border and background overrides for Light Mode */
            body[data-theme="light"] .btn-primary,
            body[data-theme="light"] .btn-create {
                background: linear-gradient(135deg, #0891b2, #0e7490) !important;
                border: 1px solid #0891b2 !important;
                color: #ffffff !important;
            }
            body[data-theme="light"] .btn-secondary,
            body[data-theme="light"] .btn-secondary-action {
                background: #ffffff !important;
                border: 1px solid #cbd5e1 !important;
                color: #1e293b !important;
                box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
            }
            body[data-theme="light"] .btn-secondary:hover,
            body[data-theme="light"] .btn-secondary-action:hover {
                background: #f8fafc !important;
                border-color: #94a3b8 !important;
            }
            body[data-theme="light"] .btn-danger,
            body[data-theme="light"] .btn-danger-action {
                background: #fef2f2 !important;
                border: 1px solid #fca5a5 !important;
                color: #b91c1c !important;
            }
            body[data-theme="light"] .btn-danger:hover,
            body[data-theme="light"] .btn-danger-action:hover {
                background: #fee2e2 !important;
                border-color: #f87171 !important;
            }

            /* ─── Light Mode Row Action Buttons Overrides ─── */
            body[data-theme="light"] .btn-row-action {
                background: #ffffff !important;
                border-color: #cbd5e1 !important;
                color: #64748b !important;
                box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
            }
            body[data-theme="light"] .btn-row-action:hover {
                background: #f8fafc !important;
                border-color: #94a3b8 !important;
                color: #1e293b !important;
            }
            body[data-theme="light"] .btn-row-action.edit-action {
                color: var(--primary-accent) !important;
                border-color: #cbd5e1 !important;
                background: #ffffff !important;
            }
            body[data-theme="light"] .btn-row-action.edit-action:hover {
                background: rgba(8, 145, 178, 0.08) !important;
                border-color: var(--primary-accent) !important;
                color: var(--primary-accent) !important;
            }
            /* Specifically for WhatsApp Bot Manager (where wa-primary inline style is used) */
            body[data-theme="light"] .btn-row-action.edit-action[style*="wa-primary"] {
                color: #059669 !important;
            }
            body[data-theme="light"] .btn-row-action.edit-action[style*="wa-primary"]:hover {
                background: rgba(5, 150, 105, 0.08) !important;
                border-color: #059669 !important;
                color: #059669 !important;
            }
            body[data-theme="light"] .btn-row-action.delete-action {
                color: #b91c1c !important;
                border-color: #fca5a5 !important;
                background: #fef2f2 !important;
            }
            body[data-theme="light"] .btn-row-action.delete-action:hover {
                background: #fee2e2 !important;
                border-color: #b91c1c !important;
                color: #b91c1c !important;
            }

            /* ═══════════════════════════════════════════════════════
               GLOBAL GLASS COMPONENT LIGHT MODE — high-contrast fixes
               Applies to all pages using .glass-modal, .btn-glass,
               .dynamic-grid-box, .radio-pill-group, .sandbox-panel etc.
            ═══════════════════════════════════════════════════════ */
            body[data-theme="light"] .page-title {
                background: linear-gradient(135deg, #0f172a, var(--primary-accent)) !important;
                -webkit-background-clip: text !important;
                -webkit-text-fill-color: transparent !important;
            }

            /* Nav items text color - make them legible in light mode instead of washed out gray */
            body[data-theme="light"] .nav-item,
            body[data-theme="light"] .dropdown-item {
                color: #334155 !important;
                font-weight: 600 !important;
            }
            body[data-theme="light"] .nav-item:hover,
            body[data-theme="light"] .dropdown-item:hover {
                color: #0f172a !important;
            }
            body[data-theme="light"] .nav-item.active {
                color: var(--primary-accent) !important;
                background-color: rgba(8, 145, 178, 0.1) !important;
            }

            /* File Input Button Light Mode */
            body[data-theme="light"] input[type="file"]::file-selector-button {
                background: #fff !important;
                border-color: rgba(15, 23, 42, 0.15) !important;
                color: var(--text-main) !important;
                box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
            }
            body[data-theme="light"] input[type="file"]::file-selector-button:hover {
                background: #f8fafc !important;
                border-color: var(--primary-accent) !important;
                color: var(--primary-accent) !important;
            }

            /* Default Avatar Visibility in Light Mode */
            body[data-theme="light"] .avatar-inner:not([class*="avatar-preset-"]) {
                background: linear-gradient(135deg, rgba(79, 70, 229, 0.15), rgba(8, 145, 178, 0.15)) !important;
                border-color: rgba(8, 145, 178, 0.3) !important;
                color: #0e7490 !important;
            }

            /* btn-glass: dark bg color invisible on white */
            body[data-theme="light"] .btn-glass {
                color: var(--text-main) !important;
                background: rgba(15, 23, 42, 0.05) !important;
                border-color: rgba(15, 23, 42, 0.15) !important;
            }
            body[data-theme="light"] .btn-glass:hover {
                background: rgba(15, 23, 42, 0.09) !important;
                border-color: rgba(15, 23, 42, 0.25) !important;
            }
            /* Keep colored variants legible */
            body[data-theme="light"] .btn-glass.btn-success {
                color: #fff !important;
                background: #059669 !important;
                border-color: #059669 !important;
            }
            body[data-theme="light"] .btn-glass.btn-success:hover {
                background: #047857 !important;
                border-color: #047857 !important;
            }
            body[data-theme="light"] .btn-glass.btn-primary-accent {
                color: var(--primary-accent) !important;
                background: rgba(8, 145, 178, 0.1) !important;
                border-color: var(--primary-accent) !important;
            }
            body[data-theme="light"] .btn-glass.btn-danger {
                color: #b91c1c !important;
                background: #fef2f2 !important;
                border-color: #fca5a5 !important;
            }

            /* Glass table */
            body[data-theme="light"] .glass-table th {
                background: rgba(15, 23, 42, 0.04) !important;
                color: var(--text-header) !important;
            }
            body[data-theme="light"] .glass-table th,
            body[data-theme="light"] .glass-table td {
                border-bottom: 1px solid rgba(15, 23, 42, 0.1) !important;
            }
            body[data-theme="light"] .glass-table tr:hover td {
                background: rgba(15, 23, 42, 0.02) !important;
            }

            /* Dynamic grid boxes (Headers, Queries, Cookies, Body Data) */
            body[data-theme="light"] .dynamic-grid-box {
                background: rgba(15, 23, 42, 0.03) !important;
                border-color: rgba(15, 23, 42, 0.12) !important;
            }
            body[data-theme="light"] .dynamic-grid-title {
                color: var(--text-header) !important;
            }

            /* Radio pill group (DEFAULT / FORM-DATA / JSON / BINARY) */
            body[data-theme="light"] .radio-pill-group {
                background: rgba(15, 23, 42, 0.06) !important;
                border-color: rgba(15, 23, 42, 0.12) !important;
            }
            body[data-theme="light"] .radio-pill:checked + .radio-pill-label {
                color: #fff !important;
            }

            /* Sandbox response panel */
            body[data-theme="light"] .sandbox-panel {
                background: rgba(15, 23, 42, 0.04) !important;
                border-color: rgba(8, 145, 178, 0.3) !important;
            }
            body[data-theme="light"] .sandbox-log-box {
                background: rgba(15, 23, 42, 0.05) !important;
                color: var(--text-main) !important;
            }

            /* Glass modal overlay — needs darker backdrop */
            body[data-theme="light"] .glass-modal {
                background: rgba(15, 23, 42, 0.55) !important;
            }
            body[data-theme="light"] .glass-modal-close:hover {
                color: var(--text-header) !important;
            }

            /* Panel card titles */
            body[data-theme="light"] .panel-card-title,
            body[data-theme="light"] .panel-card-title span {
                color: var(--text-header) !important;
            }

            /* Filter / search panels */
            body[data-theme="light"] .filter-panel {
                background: rgba(15, 23, 42, 0.03) !important;
                border-color: rgba(15, 23, 42, 0.1) !important;
            }

            /* Global Toast Component */
            .fb-toast {
                position: fixed;
                bottom: 24px;
                right: 24px;
                z-index: 9999;
                padding: 14px 20px;
                border-radius: 12px;
                font-size: 14px;
                font-weight: 600;
                color: #fff;
                display: none;
                align-items: center;
                gap: 10px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.3);
                animation: toastSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            }
            @keyframes toastSlideIn {
                from { transform: translateY(20px); opacity: 0; }
                to { transform: translateY(0); opacity: 1; }
            }
            .fb-toast.toast-success {
                background: rgba(16, 185, 129, 0.9) !important;
                border: 1px solid rgba(16, 185, 129, 0.2) !important;
            }
            .fb-toast.toast-error {
                background: rgba(239, 68, 68, 0.9) !important;
                border: 1px solid rgba(239, 68, 68, 0.2) !important;
            }
        </style>

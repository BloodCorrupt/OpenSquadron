                        </span> Admin Panel <span class="dropdown-caret">▼</span>
                    </div>
                    <div class="dropdown-menu">
                        <a href="{{ path('app_facebook_settings') }}" class="dropdown-item {% if 'facebook_settings' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                            </span> Facebook Settings
                        </a>
                        <a href="{{ path('app_smtp_settings') }}" class="dropdown-item {% if 'smtp_settings' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                            </span> SMTP Settings
                        </a>
                        <a href="{{ path('app_branding_settings') }}" class="dropdown-item {% if 'branding_settings' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                            </span> Branding &amp; Domains
                        </a>
                        {% if app.user.accountType == 'super_admin' %}
                        <a href="{{ path('app_cloudflare_settings') }}" class="dropdown-item {% if 'cloudflare_settings' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path></svg>
                            </span> Cloudflare Settings
                        </a>
                        <a href="{{ path('app_server_accounts_index') }}" class="dropdown-item {% if 'server_accounts' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                            </span> Server Accounts
                        </a>
                        {% endif %}
                        {% if app.user.accountType == 'admin' %}
                        <a href="{{ path('app_reseller_clients_index') }}" class="dropdown-item {% if 'reseller_clients' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                            </span> Client Management
                        </a>
                        {% endif %}
                        <a href="{{ path('app_subscription_packages_index') }}" class="dropdown-item {% if 'subscription_packages' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                            </span> Subscription Packages
                        </a>
                        {% if is_granted('PERM_TEAM_MANAGE') %}
                        <a href="{{ path('app_team_roles') }}" class="dropdown-item {% if 'team_roles' in app.request.attributes.get('_route')|default('') %}active{% endif %}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                            </span> Team Roles
                        </a>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
            </div>

            <div class="topbar-right" style="gap: 15px;">
                {% if app.user %}
                    <!-- Notification Bell -->
                    <div class="bell-btn" onclick="alert('No new notifications.')">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        <div class="bell-badge">0</div>
                    </div>

                    <!-- Profile Dropdown -->
                    <div class="profile-container">
                        <button class="avatar-btn" id="profileDropdownBtn">
                            {% if app.user.avatar %}
                                {% if 'preset:' in app.user.avatar %}
                                    {% set presetName = app.user.avatar|replace({'preset:': ''}) %}
                                    <div class="avatar-inner avatar-preset-{{ presetName }}">
                                        {{ (app.user.name ?: app.user.email)|slice(0, 1)|upper }}
                                    </div>
                                {% else %}
                                    <img src="{{ '/' ~ app.user.avatar }}" alt="Avatar" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(6, 182, 212, 0.4);">
                                {% endif %}
                            {% else %}
                                <div class="avatar-inner">
                                    {{ (app.user.name ?: app.user.email)|slice(0, 1)|upper }}
                                </div>
                            {% endif %}
                        </button>
                        <div class="profile-dropdown-menu" id="profileDropdownMenu">
                            <!-- User Info Header -->
                            <div style="padding: 14px 18px; border-bottom: 1px solid rgba(255, 255, 255, 0.06); display: flex; flex-direction: column; gap: 3px;">
                                <div style="font-weight: 600; color: #fff; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    {{ app.user.name|default('Operator Identity') }}
                                </div>
                                <div style="font-size: 12px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    {{ app.user.email }}
                                </div>
                            </div>
                            <!-- 1. Profile Settings -->
                            <a href="{{ path('app_accounts_edit_self') }}" class="profile-dropdown-item">
                                <span class="nav-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                </span>
                                Profile Settings
                            </a>
                            <!-- 2. Security & Access -->
                            <a href="{{ path('app_profile_security') }}" class="profile-dropdown-item">
                                <span class="nav-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                                </span>
                                Security & Access
                            </a>
                            <!-- 3. API & Webhooks -->
                            <a href="{{ path('app_profile_developer') }}" class="profile-dropdown-item">
                                <span class="nav-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                                </span>
                                API & Webhooks
                            </a>
                            <!-- 4. Sign Out -->
                            <a href="{{ path('app_logout') }}" class="profile-dropdown-item logout-option">
                                <span class="nav-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                                </span>
                                Sign Out
                            </a>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
        
        <div class="main-wrapper">
            <div class="content-container">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}
                
                {% block body %}{% endblock %}
            </div>
        </div>
        
        <script>
            function copyToClipboard(elementId) {
                var copyText = document.getElementById(elementId);
                copyText.select();
                copyText.setSelectionRange(0, 99999);
                navigator.clipboard.writeText(copyText.value).then(function() {
                    alert("Copied: " + copyText.value);
                }, function(err) {
                    console.error('Async: Could not copy text: ', err);
                });
            }

            // Dropdown click-to-open and click-to-close behavior
            document.querySelectorAll('.dropdown-trigger').forEach(function(trigger) {
                trigger.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var parent = trigger.closest('.nav-dropdown');
                    var isOpen = parent.classList.contains('is-open');
                    
                    // Close all other dropdowns
                    document.querySelectorAll('.nav-dropdown').forEach(function(d) {
                        d.classList.remove('is-open');
                    });
                    
                    // Close profile dropdown
                    var profileContainer = document.querySelector('.profile-container');
                    if (profileContainer) {
                        profileContainer.classList.remove('is-open');
                    }
                    
                    // Toggle the current one
                    if (!isOpen) {
                        parent.classList.add('is-open');
                    }
                });
            });

            // Profile dropdown logic
            var profileBtn = document.getElementById('profileDropdownBtn');
            var profileContainer = profileBtn ? profileBtn.closest('.profile-container') : null;
            if (profileBtn && profileContainer) {
                profileBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var isOpen = profileContainer.classList.contains('is-open');
                    
                    // Close normal navigation dropdowns
                    document.querySelectorAll('.nav-dropdown').forEach(function(d) {
                        d.classList.remove('is-open');
                    });
                    
                    if (isOpen) {
                        profileContainer.classList.remove('is-open');
                    } else {
                        profileContainer.classList.add('is-open');
                    }
                });
            }

            // Close dropdowns when clicking outside
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.nav-dropdown')) {
                    document.querySelectorAll('.nav-dropdown').forEach(function(d) {
                        d.classList.remove('is-open');
                    });
                }
                if (profileContainer && !e.target.closest('.profile-container')) {
                    profileContainer.classList.remove('is-open');
                }
                // Custom select outside click handler
                if (!e.target.closest('.custom-glass-select-wrapper')) {
                    document.querySelectorAll('.custom-glass-select-wrapper').forEach(w => {
                        w.classList.remove('is-active');
                    });
                }
            });

            // ─── Hamburger Menu Toggle ───
            var hamburgerBtn = document.getElementById('hamburgerBtn');
            var mainTopbar = document.getElementById('mainTopbar');
            var hamburgerIcon = document.getElementById('hamburgerIcon');
            var hamburgerCloseIcon = document.getElementById('hamburgerCloseIcon');
            if (hamburgerBtn && mainTopbar) {
                hamburgerBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var isOpen = mainTopbar.classList.toggle('mobile-open');
                    hamburgerIcon.style.display = isOpen ? 'none' : 'block';
                    hamburgerCloseIcon.style.display = isOpen ? 'block' : 'none';
                });
            }

            // ─── Left Sidebar Mobile Toggle ───
            document.addEventListener('click', function(e) {
                var toggle = e.target.closest('.sidebar-mobile-toggle');
                if (toggle) {
                    var parent = toggle.closest('.manager-nav');
                    if (parent) {
                        parent.classList.toggle('is-expanded');
                    }
                }
            });

            // ─── Custom Glass Select Replacement Script ───
            function initCustomSelect(select) {
                if (select.getAttribute('data-custom-select') === 'true') return;
                select.setAttribute('data-custom-select', 'true');

                // Keep reference to selected option
                let selectedOption = select.options[select.selectedIndex] || select.options[0];
                let triggerText = selectedOption ? selectedOption.textContent : '';

                // Create wrapper
                const wrapper = document.createElement('div');
                wrapper.className = 'custom-glass-select-wrapper';
                
                // Copy safe layout classes
                const originalClasses = select.className.split(' ');
                originalClasses.forEach(cls => {
                    if (cls && 
                        cls !== 'form-control' && 
                        cls !== 'hidden-native-select' && 
                        cls !== 'glass-input' && 
                        cls !== 'glass-select' &&
                        cls !== 'sidebar-select' &&
                        cls !== 'toolbar-select' &&
                        cls !== 'sidebar-filter-select' &&
                        !cls.startsWith('menu-') &&
                        !cls.startsWith('btn-') &&
                        !cls.startsWith('ui-') &&
                        !cls.startsWith('df-') &&
                        !cls.startsWith('bc-') &&
                        !cls.startsWith('seq-') &&
                        !cls.startsWith('rcn-') &&
                        !cls.startsWith('conn-') &&
                        !cls.endsWith('-type') &&
                        !cls.endsWith('-freq') &&
                        !cls.endsWith('-delay') &&
                        !cls.endsWith('-template') &&
                        !cls.endsWith('-status') &&
                        !cls.endsWith('-method') &&
                        !cls.endsWith('-trigger')
                    ) {
                        wrapper.classList.add(cls);
                    }
                });

                // Create trigger
                const trigger = document.createElement('div');
                trigger.className = 'custom-glass-select-trigger';
                trigger.setAttribute('tabindex', '0');
                
                const triggerLabel = document.createElement('span');
                triggerLabel.className = 'custom-glass-select-label';
                triggerLabel.textContent = triggerText;
                
                const triggerChevron = document.createElement('span');
                triggerChevron.className = 'custom-glass-select-chevron';
                triggerChevron.innerHTML = `<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'></polyline></svg>`;
                
                trigger.appendChild(triggerLabel);
                trigger.appendChild(triggerChevron);
                wrapper.appendChild(trigger);

                // Create options container
                const optionsContainer = document.createElement('div');
                optionsContainer.className = 'custom-glass-select-options';
                wrapper.appendChild(optionsContainer);

                // Re-build custom option list
                function buildOptions() {
                    optionsContainer.innerHTML = '';
                    const children = select.children;

                    for (let i = 0; i < children.length; i++) {
                        const child = children[i];
                        if (child.tagName === 'OPTGROUP') {
                            const groupLabel = document.createElement('div');
                            groupLabel.className = 'custom-glass-select-group-label';
                            groupLabel.textContent = child.label;
                            optionsContainer.appendChild(groupLabel);

                            const groupOptions = child.querySelectorAll('option');
                            groupOptions.forEach(opt => {
                                createOptionItem(opt);
                            });
                        } else if (child.tagName === 'OPTION') {
                            createOptionItem(child);
                        }
                    }
                }

                function createOptionItem(opt) {
                    const optItem = document.createElement('div');
                    optItem.className = 'custom-glass-select-option';
                    optItem.textContent = opt.textContent;
                    optItem.setAttribute('data-value', opt.value);
                    
                    if (opt.selected) {
                        optItem.classList.add('is-selected');
                    }

                    optItem.addEventListener('click', (e) => {
                        e.stopPropagation();
                        
                        select.value = opt.value;
                        select.dispatchEvent(new Event('change', { bubbles: true }));
                        select.dispatchEvent(new Event('input', { bubbles: true }));
                        
                        triggerLabel.textContent = opt.textContent;
                        optionsContainer.querySelectorAll('.custom-glass-select-option').forEach(item => {
                            item.classList.remove('is-selected');
                        });
                        optItem.classList.add('is-selected');
                        wrapper.classList.remove('is-active');
                    });

                    optionsContainer.appendChild(optItem);
                }

                buildOptions();

                // Open dropdown
                trigger.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const isActive = wrapper.classList.contains('is-active');
                    
                    document.querySelectorAll('.custom-glass-select-wrapper').forEach(w => {
                        w.classList.remove('is-active');
                    });

                    if (!isActive) {
                        buildOptions();
                        wrapper.classList.add('is-active');
                        
                        // Smart position layout helper (up or down depending on viewport)
                        setTimeout(() => {
                            const rect = optionsContainer.getBoundingClientRect();
                            if (rect.bottom > window.innerHeight && rect.top > rect.height) {
                                optionsContainer.style.top = 'auto';
                                optionsContainer.style.bottom = 'calc(100% + 6px)';
                            } else {
                                optionsContainer.style.top = 'calc(100% + 6px)';
                                optionsContainer.style.bottom = 'auto';
                            }
                        }, 0);
                    }
                });

                // Focus & keys helper
                trigger.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        trigger.click();
                    } else if (e.key === 'Escape') {
                        wrapper.classList.remove('is-active');
                    }
                });

                // Dynamic selector updates
                select.addEventListener('change', () => {
                    const activeOpt = select.options[select.selectedIndex];
                    if (activeOpt) {
                        triggerLabel.textContent = activeOpt.textContent;
                        optionsContainer.querySelectorAll('.custom-glass-select-option').forEach(item => {
                            if (item.getAttribute('data-value') === activeOpt.value) {
                                item.classList.add('is-selected');
                            } else {
                                item.classList.remove('is-selected');
                            }
                        });
                    }
                });

                // Wrap and hide native select
                select.parentNode.insertBefore(wrapper, select);
                select.classList.add('hidden-native-select');
                wrapper.appendChild(select);
            }

            function initAllCustomSelects() {
                document.querySelectorAll('select:not(.hidden-native-select)').forEach(select => {
                    initCustomSelect(select);
                });
            }

            function setupCustomSelectMutationObserver() {
                const observer = new MutationObserver((mutations) => {
                    let shouldInit = false;
                    mutations.forEach(mutation => {
                        if (mutation.addedNodes.length) {
                            mutation.addedNodes.forEach(node => {
                                if (node.nodeType === Node.ELEMENT_NODE) {
                                    if (node.tagName === 'SELECT' && !node.classList.contains('hidden-native-select')) {
                                        shouldInit = true;
                                    } else if (node.querySelectorAll) {
                                        const found = node.querySelectorAll('select:not(.hidden-native-select)');
                                        if (found.length) {
                                            shouldInit = true;
                                        }
                                    }
                                }
                            });
                        }
                    });
                    if (shouldInit) {
                        initAllCustomSelects();
                    }
                });
                observer.observe(document.body, { childList: true, subtree: true });
            }

            // Bind events
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', () => {
                    initAllCustomSelects();
                    setupCustomSelectMutationObserver();
                });
            } else {
                initAllCustomSelects();
                setupCustomSelectMutationObserver();
            }
        </script>
        {% block javascripts %}{% endblock %}
    </body>
</html>

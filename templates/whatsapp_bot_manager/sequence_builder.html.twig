    // ───────── DOM Elements ─────────
    const elView = document.getElementById('fb-viewport');
    const elStage = document.getElementById('fb-stage');
    const elNodes = document.getElementById('fb-nodes');
    const elEdges = document.getElementById('fb-edges');
    const elInspectorTitle = document.getElementById('fb-inspector-title');
    const elInspectorType = document.getElementById('fb-inspector-type');
    const elInspectorBody = document.getElementById('fb-inspector-body');

    // ───────── Canvas Navigation (Pan/Zoom) ─────────
    let panState = null;
    elView.addEventListener('mousedown', (e) => {
        if (e.target !== elView && e.target !== elEdges) return;
        panState = { startX: e.clientX, startY: e.clientY, viewX: state.viewport.x, viewY: state.viewport.y };
        elView.classList.add('is-panning');
    });

    window.addEventListener('mousemove', (e) => {
        if (!panState) return;
        state.viewport.x = panState.viewX + (e.clientX - panState.startX);
        state.viewport.y = panState.viewY + (e.clientY - panState.startY);
        applyTransform();
    });

    window.addEventListener('mouseup', () => {
        if (panState) { panState = null; elView.classList.remove('is-panning'); }
    });

    elView.addEventListener('wheel', (e) => {
        e.preventDefault();
        const dir = e.deltaY > 0 ? -1 : 1;
        zoomAt(e.clientX, e.clientY, dir * 0.08);
    }, { passive: false });

    function zoomAt(cx, cy, delta) {
        const before = clientToCanvas(cx, cy);
        const newScale = Math.max(0.4, Math.min(1.8, state.viewport.scale + delta));
        state.viewport.scale = newScale;
        const after = clientToCanvas(cx, cy);
        state.viewport.x += (after.x - before.x) * newScale;
        state.viewport.y += (after.y - before.y) * newScale;
        applyTransform();
    }

    function applyTransform() {
        elStage.style.transform = `translate(${state.viewport.x}px, ${state.viewport.y}px) scale(${state.viewport.scale})`;
    }

    function clientToCanvas(clientX, clientY) {
        const rect = elView.getBoundingClientRect();
        return {
            x: (clientX - rect.left - state.viewport.x) / state.viewport.scale,
            y: (clientY - rect.top - state.viewport.y) / state.viewport.scale,
        };
    }

    function canvasToClient(x, y) {
        const rect = elView.getBoundingClientRect();
        return {
            x: x * state.viewport.scale + state.viewport.x + rect.left,
            y: y * state.viewport.scale + state.viewport.y + rect.top,
        };
    }

    document.getElementById('fb-zoom-in').onclick = () => zoomAt(window.innerWidth/2, window.innerHeight/2, 0.1);
    document.getElementById('fb-zoom-out').onclick = () => zoomAt(window.innerWidth/2, window.innerHeight/2, -0.1);
    document.getElementById('fb-zoom-fit').onclick = () => {
        state.viewport = { x: 80, y: 100, scale: 1 };
        applyTransform();
    };

    // ───────── Add / Select Nodes ─────────
    function addNode(type, x, y) {
        const id = uid();
        const node = { id, type, x, y, data: Object.assign({}, BLOCKS[type].defaults || {}) };
        state.nodes.set(id, node);
        state.selection = { node: id, edge: null };
        state.dirty = true;
        renderAll();
        return node;
    }

    // ───────── Rendering Canvas ─────────
    function renderAll() {
        renderNodes();
        renderEdges();
        renderInspector();
    }

    function renderNodes() {
        elNodes.innerHTML = '';
        state.nodes.forEach(node => {
            const block = BLOCKS[node.type];
            if (!block) return;
            const card = document.createElement('div');
            card.className = 'fb-node';
            card.dataset.id = node.id;
            card.dataset.type = node.type;
            card.style.left = node.x + 'px';
            card.style.top = node.y + 'px';
            if (state.selection.node === node.id) card.classList.add('is-selected');

            card.innerHTML = `
                <div class="fb-node-header">
                    <div class="fb-node-title-group">
                        <span class="fb-node-icon">${block.icon}</span>
                        <span class="fb-node-title">${block.label}</span>
                    </div>
                </div>
                <div class="fb-node-body">
                    ${block.render(node.data).replace(/DYNAMIC_ID/g, node.id)}
                </div>
            `;
            elNodes.appendChild(card);
        });
    }

    function renderEdges() {
        elEdges.innerHTML = '';
        state.edges.forEach(edge => {
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            const start = portPos(edge.source, 'out', edge.sourceHandle);
            const end = portPos(edge.target, 'in', edge.targetHandle);
            if (!start || !end) return;

            path.setAttribute('d', bezier(start.x + 10000, start.y + 10000, end.x + 10000, end.y + 10000));
            path.dataset.id = edge.id;
            if (state.selection.edge === edge.id) path.classList.add('is-selected');

            path.addEventListener('mousedown', (e) => {
                e.stopPropagation();
                state.selection = { node: null, edge: edge.id };
                renderAll();
            });
            elEdges.appendChild(path);
        });
    }

    function portPos(nodeId, role, portId) {
        const node = state.nodes.get(nodeId);
        if (!node) return null;

        const nodeEl = elNodes.querySelector(`.fb-node[data-id="${nodeId}"]`);
        if (nodeEl) {
            let selector = `.fb-port[data-role="${role}"]`;
            if (portId) selector += `[data-port-id="${portId}"]`;
            const portEl = nodeEl.querySelector(selector);
            if (portEl) {
                const portRect = portEl.getBoundingClientRect();
                const nodeRect = nodeEl.getBoundingClientRect();
                return {
                    x: node.x + (portRect.left - nodeRect.left + portRect.width / 2) / state.viewport.scale,
                    y: node.y + (portRect.top - nodeRect.top + portRect.height / 2) / state.viewport.scale
                };
            }
        }

        if (role === 'in') {
            return { x: node.x, y: node.y + 36 };
        } else {
            return { x: node.x + 240, y: node.y + 60 };
        }
    }

    function bezier(x1, y1, x2, y2) {
        const dx = Math.abs(x2 - x1) * 0.5;
        return `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}`;
    }

    // ───────── Inspector Panel ─────────
    function renderInspector() {
        const nodeId = state.selection.node;
        if (!nodeId) {
            elInspectorTitle.textContent = 'Block Properties';
            elInspectorType.textContent = 'No block selected';
            elInspectorBody.innerHTML = `
                <div style="text-align: center; color: var(--fb-text-muted); padding: 40px 10px;">
                    <div style="display: flex; justify-content: center; margin-bottom: 12px; opacity: 0.4; color: var(--primary-accent);">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px;"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"></path><path d="M13 13l6 6"></path></svg>
                    </div>
                    Select a card block on the canvas to configure its settings.
                </div>
            `;
            return;
        }

        const node = state.nodes.get(nodeId);
        const block = BLOCKS[node.type];
        elInspectorTitle.textContent = block.label;
        elInspectorType.textContent = 'Block ID: ' + node.id;
        elInspectorBody.innerHTML = '';

        const forms = block.inspector(node.data, (updatedData) => {
            node.data = Object.assign({}, node.data, updatedData);
            state.dirty = true;
            renderNodes();
            renderEdges();
        });
        elInspectorBody.appendChild(forms);
    }

    // ───────── Drag Nodes & Draw Connections ─────────
    let dragNode = null;
    let connect = null;

    elNodes.addEventListener('mousedown', (e) => {
        const portEl = e.target.closest('.fb-port');
        if (portEl) {
            if (portEl.dataset.role !== 'out') return;
            e.stopPropagation();
            const node = state.nodes.get(portEl.dataset.nodeId);
            const portId = portEl.dataset.portId;
            const start = portPos(node.id, 'out', portId);
            connect = {
                fromId: node.id,
                fromPortId: portId,
                startX: start.x,
                startY: start.y,
                curX: start.x,
                curY: start.y,
            };
            elView.classList.add('is-connecting');
            highlightInputPorts(true);
            renderTempEdge();
            return;
        }

        const nodeEl = e.target.closest('.fb-node');
        if (!nodeEl) return;
        e.stopPropagation();
        const node = state.nodes.get(nodeEl.dataset.id);
        if (!node) return;
        state.selection = { node: node.id, edge: null };
        renderAll();
        const start = clientToCanvas(e.clientX, e.clientY);
        dragNode = { id: node.id, dx: start.x - node.x, dy: start.y - node.y };
        nodeEl.classList.add('is-dragging');
    });

    window.addEventListener('mousemove', (e) => {
        if (dragNode) {
            const p = clientToCanvas(e.clientX, e.clientY);
            const node = state.nodes.get(dragNode.id);
            if (node) {
                node.x = p.x - dragNode.dx;
                node.y = p.y - dragNode.dy;
                state.dirty = true;
                renderNodes();
                renderEdges();
            }
        }
        if (connect) {
            const p = clientToCanvas(e.clientX, e.clientY);
            connect.curX = p.x;
            connect.curY = p.y;
            renderTempEdge();
        }
    });

    window.addEventListener('mouseup', (e) => {
        if (dragNode) {
            document.querySelectorAll('.fb-node.is-dragging').forEach(n => n.classList.remove('is-dragging'));
            dragNode = null;
        }
        if (connect) {
            const port = document.elementFromPoint(e.clientX, e.clientY)?.closest('.fb-port.is-in');
            if (port) {
                const targetId = port.dataset.nodeId;
                const targetPortId = port.dataset.portId || 'in';
                if (targetId !== connect.fromId) {
                    state.edges = state.edges.filter(ed => !(ed.source === connect.fromId && ed.sourceHandle === connect.fromPortId));
                    state.edges.push({
                        id: 'e_' + Math.random().toString(36).slice(2, 8),
                        source: connect.fromId,
                        sourceHandle: connect.fromPortId,
                        target: targetId,
                        targetHandle: targetPortId,
                    });
                    state.dirty = true;
                }
                connect = null;
                elView.classList.remove('is-connecting');
                highlightInputPorts(false);
                removeTempEdge();
                renderEdges();
            } else {
                const pos = clientToCanvas(e.clientX, e.clientY);
                openContextMenu(e.clientX, e.clientY, connect.fromId, connect.fromPortId, pos.x, pos.y);
                connect = null;
                elView.classList.remove('is-connecting');
                highlightInputPorts(false);
                removeTempEdge();
            }
        }
    });

    function highlightInputPorts(on) {
        document.querySelectorAll('.fb-port.is-in').forEach(p => {
            p.style.boxShadow = on ? '0 0 10px var(--fb-secondary-accent)' : 'none';
        });
    }

    function renderTempEdge() {
        if (!connect) return;
        let path = elEdges.querySelector('path.is-temp');
        if (!path) {
            path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.classList.add('is-temp');
            elEdges.appendChild(path);
        }
        path.setAttribute('d', bezier(
            connect.startX + 10000, connect.startY + 10000,
            connect.curX + 10000, connect.curY + 10000
        ));
    }
    function removeTempEdge() {
        elEdges.querySelectorAll('path.is-temp').forEach(p => p.remove());
    }

    // Keyboard backspace/delete node
    window.addEventListener('keydown', (e) => {
        if (e.target.matches('input, textarea, select')) return;
        if (e.key === 'Delete' || e.key === 'Backspace') {
            if (state.selection.node) {
                const id = state.selection.node;
                const node = state.nodes.get(id);
                if (node && node.type !== 'start' && node.type !== 'sequence_campaign') {
                    state.nodes.delete(id);
                    state.edges = state.edges.filter(ed => ed.source !== id && ed.target !== id);
                    state.selection = { node: null, edge: null };
                    state.dirty = true;
                    renderAll();
                }
            } else if (state.selection.edge) {
                state.edges = state.edges.filter(ed => ed.id !== state.selection.edge);
                state.selection = { node: null, edge: null };
                state.dirty = true;
                renderAll();
            }
        }
    });

    // ───────── Context Menu block list popup ─────────
    const elCtxMenu = document.getElementById('fb-context-menu');
    const elCtxSearch = document.getElementById('fb-ctx-search');
    const elCtxList = document.getElementById('fb-ctx-list');

    function openContextMenu(clientX, clientY, fromId, fromPortId, canvasX, canvasY) {
        state.ctxMenuOrigin = { fromId, fromPortId, canvasX, canvasY };
        renderContextMenuList('');
        elCtxMenu.style.display = 'flex';
        elCtxMenu.style.left = clientX + 'px';
        elCtxMenu.style.top = clientY + 'px';
        setTimeout(() => elCtxSearch.focus(), 50);
    }

    function closeContextMenu() {
        elCtxMenu.style.display = 'none';
        state.ctxMenuOrigin = null;
    }

    function renderContextMenuList(query) {
        elCtxList.innerHTML = '';
        const q = query.toLowerCase().trim();

        Object.entries(BLOCKS).forEach(([type, block]) => {
            if (type === 'start' || type === 'sequence_campaign') return;
            if (q && !block.label.toLowerCase().includes(q)) return;

            const item = document.createElement('div');
            item.className = 'fb-ctx-item';
            item.innerHTML = `
                <div class="fb-ctx-icon" style="background:rgba(255,255,255,0.05);">${block.icon}</div>
                <span>${escapeHtml(block.label)}</span>
            `;
            item.onclick = () => {
                const newNode = addNode(type, state.ctxMenuOrigin.canvasX - 10, state.ctxMenuOrigin.canvasY - 30);
                if (state.ctxMenuOrigin.fromId) {
                    state.edges.push({
                        id: 'e_' + Math.random().toString(36).slice(2, 8),
                        source: state.ctxMenuOrigin.fromId,
                        sourceHandle: state.ctxMenuOrigin.fromPortId,
                        target: newNode.id,
                        targetHandle: 'in'
                    });
                }
                state.dirty = true;
                closeContextMenu();
                renderAll();
            };
            elCtxList.appendChild(item);
        });
    }

    elCtxSearch.oninput = (e) => renderContextMenuList(e.target.value);

    window.addEventListener('mousedown', (e) => {
        if (elCtxMenu.style.display === 'flex' && !elCtxMenu.contains(e.target)) {
            closeContextMenu();
        }
    });

    // ───────── Save visual sequence campaign ─────────
    document.getElementById('fb-save-flow').onclick = () => {
        const campaignName = document.getElementById('seq-campaign-name').value.trim();
        if (!campaignName) {
            showToast('Sequence Campaign Name is required.', 'error');
            return;
        }

        const payload = {
            id: state.currentId || null,
            name: campaignName,
            trigger: document.getElementById('seq-trigger').value,
            preferredTime: document.getElementById('seq-delivery-time').value,
            timezone: document.getElementById('seq-timezone').value,
            messageTag: 'NON_PROMOTIONAL_SUBSCRIPTION',
            allowReentry: document.getElementById('seq-allow-reentry').checked,
            connectionId: '{{ connection.id }}',
            graph: {
                nodes: Array.from(state.nodes.values()).map(n => ({
                    id: n.id, type: n.type, x: Math.round(n.x), y: Math.round(n.y), data: n.data || {}
                })),
                edges: state.edges.map(e => ({
                    id: e.id, source: e.source, sourceHandle: e.sourceHandle, target: e.target, targetHandle: e.targetHandle
                })),
                viewport: state.viewport
            }
        };

        const btn = document.getElementById('fb-save-flow');
        btn.disabled = true;
        btn.textContent = 'Saving…';

        fetch(SAVE_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                showToast('Sequence saved successfully!', 'success');
                state.dirty = false;
                // Update the ID with the DB-assigned integer ID
                if (res.sequence && res.sequence.id) {
                    state.currentId = res.sequence.id;
                    // Update URL so subsequent saves update the same entity
                    const newUrl = new URL(window.location);
                    newUrl.searchParams.set('id', res.sequence.id);
                    window.history.replaceState({}, '', newUrl);
                }
            } else {
                showToast('Save failed: ' + (res.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Save error: ' + err.message, 'error'))
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = `
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px; display: inline-block; vertical-align: -2px; margin-right: 6px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                Save Sequence Campaign
            `;
        });
    };

    // Helper functions
    function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
    function uid() { return 'n' + (state.nextId++) + '_' + Math.random().toString(36).slice(2, 7); }
    function wrapField(label, input, help) {
        const g = document.createElement('div');
        g.className = 'fb-form-group';
        const l = document.createElement('label');
        l.textContent = label;
        g.appendChild(l);
        g.appendChild(input);
        if (help) {
            const h = document.createElement('div');
            h.className = 'fb-help';
            h.innerHTML = help;
            g.appendChild(h);
        }
        return g;
    }
    function showToast(msg, kind) {
        const t = document.getElementById('fb-toast');
        t.textContent = msg;
        t.className = 'fb-toast is-shown ' + (kind ? 'is-' + kind : '');
        clearTimeout(showToast._t);
        showToast._t = setTimeout(() => { t.className = 'fb-toast'; }, 2400);
    }

    // ───────── Bootstrap Initialize ─────────
    function init() {
        if (initialGraph && Array.isArray(initialGraph.nodes) && initialGraph.nodes.length > 0) {
            initialGraph.nodes.forEach(n => {
                state.nodes.set(n.id, {
                    id: n.id,
                    type: n.type,
                    x: n.x || 0,
                    y: n.y || 0,
                    data: n.data || {}
                });
                const m = /^n(\d+)/.exec(n.id || '');
                if (m) state.nextId = Math.max(state.nextId, parseInt(m[1], 10) + 1);
            });
            (initialGraph.edges || []).forEach(e => {
                state.edges.push({
                    id: e.id || ('e_' + Math.random().toString(36).slice(2, 8)),
                    source: e.source,
                    sourceHandle: e.sourceHandle || 'out',
                    target: e.target,
                    targetHandle: e.targetHandle || 'in'
                });
            });
            state.viewport = initialGraph.viewport || { x: 80, y: 100, scale: 1 };
        } else {
            // Seed defaults: Start Bot Flow -> New Sequence Campaign -> Send Message After
            const startNode = addNode('start', 60, 200);
            const campaignNode = addNode('sequence_campaign', 380, 200);
            const delayNode = addNode('send_message_after', 700, 200);
            
            state.edges.push({
                id: 'e_init_1',
                source: startNode.id,
                sourceHandle: 'subscribe_to_sequence',
                target: campaignNode.id,
                targetHandle: 'in'
            });
            state.edges.push({
                id: 'e_init_2',
                source: campaignNode.id,
                sourceHandle: 'schedule_message',
                target: delayNode.id,
                targetHandle: 'in'
            });
            state.viewport = { x: 80, y: 100, scale: 1 };
        }
        applyTransform();
        renderAll();
    }

    init();
})();
</script>
{% endblock %}

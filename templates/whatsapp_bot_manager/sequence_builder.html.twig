{% extends 'empty.html.twig' %}

{% block title %}Sequence Flow Builder - WhatsApp Bot Manager{% endblock %}

{% block max_width %}none{% endblock %}

{% block stylesheets %}
<style>
    /* ─── Dark-themed Glassmorphic Flow Builder Base ─── */
    :root {
        --fb-bg: #0b1329;
        --fb-border: var(--glass-border);
        --fb-text-main: var(--text-main);
        --fb-text-muted: var(--text-muted);
        --fb-card-bg: rgba(15, 23, 42, 0.6);
        --fb-active-border: #10b981; /* WhatsApp primary green */
        --fb-secondary-accent: #34d399; /* WhatsApp secondary green */
    }

    body {
        font-family: 'Inter', sans-serif;
        background: var(--fb-bg);
        margin: 0;
        overflow: hidden;
    }

    .fb-shell {
        display: grid;
        grid-template-columns: 340px 1fr 340px;
        gap: 0;
        height: 100vh;
        background: var(--fb-bg);
        color: var(--fb-text-main);
    }

    /* ─── Left Sidebar (Configure Drip Sequence) ─── */
    .fb-sidebar {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(20px);
        border-right: 1px solid var(--fb-border);
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        z-index: 10;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.3);
    }
    .fb-sidebar-header {
        padding: 20px;
        border-bottom: 1px solid var(--fb-border);
    }
    .fb-sidebar-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--fb-text-main);
        margin: 0 0 4px 0;
    }
    .fb-sidebar-subtitle {
        font-size: 12px;
        color: var(--fb-text-muted);
        margin: 0;
    }
    .fb-sidebar-body {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
    }
    .fb-sidebar-body::-webkit-scrollbar { width: 5px; }
    .fb-sidebar-body::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 4px; }

    /* ─── Middle Canvas Area ─── */
    .fb-canvas-container {
        position: relative;
        height: 100%;
        overflow: hidden;
        background-color: #0b1329;
        background-image: 
            radial-gradient(rgba(255, 255, 255, 0.08) 1.5px, transparent 1.5px),
            radial-gradient(rgba(255, 255, 255, 0.08) 1.5px, transparent 1.5px);
        background-size: 24px 24px;
        background-position: 0 0, 12px 12px;
    }

    .fb-floating-header {
        position: absolute;
        top: 20px;
        left: 20px;
        right: 20px;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        pointer-events: none;
    }
    .fb-floating-back {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid var(--fb-border);
        color: var(--fb-text-main);
        padding: 8px 16px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        pointer-events: auto;
        text-decoration: none;
    }
    .fb-floating-back:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--fb-active-border);
        transform: translateX(-2px);
    }
    .fb-top-actions {
        display: flex;
        gap: 10px;
        pointer-events: auto;
    }

    .fb-action-btn {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid var(--fb-border);
        color: var(--fb-text-main);
        padding: 8px 16px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }
    .fb-action-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--fb-active-border);
    }
    .fb-action-btn.primary {
        background: var(--fb-active-border);
        color: #fff;
        border-color: var(--fb-active-border);
    }
    .fb-action-btn.primary:hover {
        background: #059669;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    /* ─── Canvas Viewport & Node Stage ─── */
    .fb-viewport {
        position: absolute;
        inset: 0;
        cursor: grab;
    }
    .fb-viewport.is-panning { cursor: grabbing; }
    .fb-viewport.is-connecting { cursor: crosshair; }
    .fb-stage {
        position: absolute;
        top: 0; left: 0;
        width: 1px; height: 1px;
        transform-origin: 0 0;
        will-change: transform;
    }
    
    .fb-edges {
        position: absolute;
        top: -10000px; left: -10000px;
        width: 20000px; height: 20000px;
        pointer-events: none;
        overflow: visible;
    }
    .fb-edges path {
        fill: none;
        stroke: #64748b;
        stroke-width: 2.5;
        pointer-events: stroke;
        cursor: pointer;
        transition: stroke 0.15s;
    }
    .fb-edges path.is-selected {
        stroke: var(--fb-active-border);
        stroke-width: 3.5;
    }
    .fb-edges path:hover {
        stroke: #94a3b8;
    }
    .fb-edges path.is-temp {
        stroke: var(--fb-active-border);
        stroke-dasharray: 6 4;
        animation: fb-dash 0.6s linear infinite;
    }
    @keyframes fb-dash { to { stroke-dashoffset: -20; } }

    /* ─── Flow Builder Nodes ─── */
    .fb-node {
        position: absolute;
        width: 240px;
        background: rgba(15, 23, 42, 0.75);
        backdrop-filter: blur(10px);
        border: 1px solid var(--fb-border);
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        font-size: 13px;
        color: var(--fb-text-main);
        user-select: none;
        cursor: grab;
        padding-bottom: 8px;
        box-sizing: border-box;
        transition: box-shadow 0.15s, border-color 0.15s;
        border-top: 4px solid #cbd5e1;
    }
    .fb-node:hover {
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    }
    .fb-node.is-selected {
        border-color: var(--fb-active-border) !important;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.25), 0 15px 40px rgba(0, 0, 0, 0.5);
    }
    .fb-node.is-dragging { cursor: grabbing; }

    .fb-node-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        border-bottom: 1px dashed var(--fb-border);
        font-weight: 700;
        gap: 8px;
    }
    .fb-node-title-group {
        display: flex;
        align-items: center;
        gap: 8px;
        overflow: hidden;
    }
    .fb-node-icon {
        display: inline-flex !important;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .fb-node-title {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .fb-node-body {
        padding: 12px 14px;
        font-size: 12px;
        color: var(--fb-text-muted);
        line-height: 1.5;
        min-height: 24px;
    }
    .fb-node-preview {
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 70px;
        overflow: hidden;
        color: var(--fb-text-main);
    }
    .fb-empty {
        font-style: italic;
        opacity: 0.65;
    }

    .fb-node-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 6px 14px;
        font-size: 11px;
        font-weight: 600;
        color: var(--fb-text-muted);
        position: relative;
    }

    /* Accent top borders */
    .fb-node[data-type="start"] { border-top-color: #3b82f6; }
    .fb-node[data-type="sequence_campaign"] { border-top-color: #10b981; }
    .fb-node[data-type="send_message_after"] { border-top-color: #ec4899; }
    .fb-node[data-type="send_text"] { border-top-color: var(--fb-secondary-accent); }
    .fb-node[data-type="send_image"] { border-top-color: #a3e635; }
    .fb-node[data-type="send_template"] { border-top-color: #fde047; }
    .fb-node[data-type="http_api"] { border-top-color: #fb923c; }
    .fb-node[data-type="condition"] { border-top-color: #a78bfa; }

    .fb-port {
        position: absolute;
        width: 12px;
        height: 12px;
        background: rgba(15, 23, 42, 0.9);
        border: 2px solid var(--fb-active-border);
        border-radius: 50%;
        cursor: crosshair;
        transition: transform 0.1s, background 0.1s;
        z-index: 200;
    }
    .fb-port:hover {
        transform: scale(1.4);
        background: var(--fb-active-border);
    }
    .fb-port.is-in {
        left: -7px;
        top: 24px;
        border-color: var(--fb-secondary-accent);
    }
    .fb-port.is-in:hover {
        background: var(--fb-secondary-accent);
    }
    .fb-port.is-out {
        right: -7px;
    }

    /* ─── Inspector panel (Right Sidebar) ─── */
    .fb-inspector {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(20px);
        border-left: 1px solid var(--fb-border);
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        z-index: 10;
        box-shadow: -4px 0 20px rgba(0, 0, 0, 0.3);
    }
    .fb-inspector-header {
        padding: 20px;
        border-bottom: 1px solid var(--fb-border);
        font-weight: 700;
        font-size: 15px;
        color: var(--fb-text-main);
    }
    .fb-inspector-body {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
    }
    
    .fb-form-group {
        margin-bottom: 18px;
    }
    .fb-form-group label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--fb-text-muted);
        margin-bottom: 6px;
    }
    .fb-input, .fb-textarea, .fb-select {
        width: 100%;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--fb-border);
        color: var(--fb-text-main);
        padding: 10px 12px;
        border-radius: 8px;
        font-family: inherit;
        font-size: 13px;
        box-sizing: border-box;
        outline: none;
        transition: all 0.2s;
    }
    .fb-input:focus, .fb-textarea:focus, .fb-select:focus {
        background: rgba(0, 0, 0, 0.3);
        border-color: var(--fb-active-border);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
    }
    .fb-textarea {
        resize: vertical;
        min-height: 100px;
    }
    .fb-help {
        font-size: 11px;
        color: var(--fb-text-muted);
        margin-top: 4px;
        line-height: 1.4;
    }

    /* ─── Context Menu (Floating block selector) ─── */
    .fb-ctx-menu {
        position: fixed;
        z-index: 10000;
        width: 240px;
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(15px);
        border: 1px solid var(--fb-border);
        border-radius: 12px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        display: none;
        flex-direction: column;
        overflow: hidden;
    }
    .fb-ctx-search {
        padding: 10px;
        border-bottom: 1px solid var(--fb-border);
        background: rgba(0,0,0,0.1);
    }
    .fb-ctx-list {
        max-height: 300px;
        overflow-y: auto;
    }
    .fb-ctx-item {
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        font-size: 13px;
        color: var(--fb-text-main);
        transition: background 0.15s;
    }
    .fb-ctx-item:hover {
        background: rgba(255, 255, 255, 0.05);
    }
    .fb-ctx-item.is-cancel {
        border-top: 1px solid var(--fb-border);
        color: #f87171;
    }
    .fb-ctx-icon {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        display: grid;
        place-items: center;
        font-size: 12px;
    }

    .fb-toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #0f172a;
        color: #ffffff;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s, transform 0.25s;
        z-index: 10000;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    }
    .fb-toast.is-shown { opacity: 1; transform: translateX(-50%) translateY(0); }
    .fb-toast.is-success { border-left: 4px solid var(--fb-secondary-accent); }
    .fb-toast.is-error { border-left: 4px solid #ef4444; }

    /* Zoom Controls */
    .fb-controls {
        position: absolute;
        right: 20px;
        top: 80px;
        z-index: 100;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .fb-control-btn {
        width: 36px;
        height: 36px;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid var(--fb-border);
        color: var(--fb-text-main);
        border-radius: 8px;
        display: grid;
        place-items: center;
        cursor: pointer;
        font-size: 16px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
    .fb-control-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--fb-active-border);
    }

    .click-body {
        display: flex;
        justify-content: center;
        padding: 8px;
    }
    .hand-cursor-icon {
        font-size: 18px;
        cursor: pointer;
    }
</style>
{% endblock %}

{% block body %}
<div class="fb-shell">
    <!-- Left Sidebar: Configure Sequence Metadata -->
    <div class="fb-sidebar">
        <div class="fb-sidebar-header">
            <h2 class="fb-sidebar-title">Configure Drip Sequence</h2>
            <p class="fb-sidebar-subtitle">Configure campaign constraints and default delivery windows.</p>
        </div>
        <div class="fb-sidebar-body">
            <div class="fb-form-group">
                <label for="seq-campaign-name">Sequence Campaign Name</label>
                <input type="text" id="seq-campaign-name" class="fb-input" value="{{ sequence.name }}" placeholder="e.g. Day 1 Warmup">
            </div>

            <div class="fb-form-group">
                <label for="seq-trigger">Trigger Event</label>
                <select id="seq-trigger" class="fb-select">
                    <option value="NEW_SUBSCRIBER" {% if sequence.trigger|default('NEW_SUBSCRIBER') == 'NEW_SUBSCRIBER' %}selected{% endif %}>On New Subscriber Onboarding</option>
                    <option value="CUSTOM_TRIGGER" {% if sequence.trigger|default('NEW_SUBSCRIBER') == 'CUSTOM_TRIGGER' %}selected{% endif %}>Custom / Manual Trigger</option>
                </select>
                <div class="fb-help">Specifies the event that starts this drip campaign.</div>
            </div>

            <div class="fb-form-group">
                <label for="seq-delivery-time">Preferred Delivery Time Window</label>
                <select id="seq-delivery-time" class="fb-select">
                    <option value="anytime" {% if sequence.preferredTime == 'anytime' %}selected{% endif %}>Send Anytime (Immediate)</option>
                    <option value="business_hours" {% if sequence.preferredTime == 'business_hours' %}selected{% endif %}>Business Hours (9 AM - 6 PM)</option>
                    <option value="daytime" {% if sequence.preferredTime == 'daytime' %}selected{% endif %}>Daytime (8 AM - 10 PM)</option>
                </select>
                <div class="fb-help">Messages scheduled outside the window will queue until the window re-opens.</div>
            </div>

            <div class="fb-form-group">
                <label for="seq-timezone">Time Zone</label>
                <select id="seq-timezone" class="fb-select">
                    <option value="UTC" {% if sequence.timezone == 'UTC' %}selected{% endif %}>UTC (GMT+0)</option>
                    <option value="America/New_York" {% if sequence.timezone == 'America/New_York' %}selected{% endif %}>Eastern Time (EST/EDT)</option>
                    <option value="Europe/London" {% if sequence.timezone == 'Europe/London' %}selected{% endif %}>London (GMT/BST)</option>
                    <option value="Asia/Dhaka" {% if sequence.timezone == 'Asia/Dhaka' %}selected{% endif %}>Bangladesh (GMT+6)</option>
                </select>
            </div>

            <div class="fb-form-group" style="margin-top: 24px;">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input type="checkbox" id="seq-allow-reentry" style="width:16px; height:16px;" {% if sequence.allowReentry %}checked{% endif %}>
                    <span style="font-weight:600; text-transform:none;">Allow Re-entry Only After Completion</span>
                </label>
                <div class="fb-help" style="margin-left: 24px; margin-top: 6px;">Subscribers won't be added again while the sequence is actively running.</div>
            </div>
            
            <div style="margin-top: 30px; display: flex; flex-direction: column; gap: 10px;">
                <button type="button" class="fb-action-btn primary" id="fb-save-flow" style="justify-content: center; width: 100%;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px; display: inline-block; vertical-align: -2px; margin-right: 6px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    Save Sequence Campaign
                </button>
                <a href="{{ path('app_whatsapp_bot_manager', {connectionId: connection.id}) }}" class="fb-action-btn" style="justify-content: center; text-decoration: none;">
                    Close Editor
                </a>
            </div>
        </div>
    </div>

    <!-- Middle Area: Canvas -->
    <div class="fb-canvas-container">
        <!-- Floating Header -->
        <div class="fb-floating-header">
            <a href="{{ path('app_whatsapp_bot_manager', {connectionId: connection.id}) }}" class="fb-floating-back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:16px; height:16px;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 19"></polyline></svg>
                <span>Back to Bot Manager</span>
            </a>
            
            <div class="fb-top-actions">
                <span style="background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(12px); border: 1px solid var(--fb-border); color: #fff; padding: 8px 16px; border-radius: 20px; font-size: 12px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px;">
                    <span style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; box-shadow: 0 0 8px #10b981;"></span>
                    <span>WhatsApp Phone: {{ connection.label|default(connection.phoneNumber) }}</span>
                </span>
            </div>
        </div>

        <!-- Zoom fit tools -->
        <div class="fb-controls">
            <button class="fb-control-btn" id="fb-zoom-in" title="Zoom In">+</button>
            <button class="fb-control-btn" id="fb-zoom-out" title="Zoom Out">−</button>
            <button class="fb-control-btn" id="fb-zoom-fit" title="Fit Screen">⛶</button>
        </div>

        <!-- The actual viewport stage -->
        <div class="fb-viewport" id="fb-viewport">
            <div class="fb-stage" id="fb-stage">
                <!-- SVG edges canvas -->
                <svg class="fb-edges" id="fb-edges"></svg>
                
                <!-- Draggable node blocks -->
                <div id="fb-nodes"></div>
            </div>
        </div>
    </div>

    <!-- Right Sidebar: Block settings Inspector -->
    <div class="fb-inspector">
        <div class="fb-inspector-header">
            <div style="font-weight: 700; font-size: 14px;" id="fb-inspector-title">Block Properties</div>
            <div style="font-size: 11px; color: var(--fb-text-muted); margin-top: 4px;" id="fb-inspector-type">No block selected</div>
        </div>
        <div class="fb-inspector-body" id="fb-inspector-body">
            <div style="text-align: center; color: var(--fb-text-muted); padding: 40px 10px;">
                <div style="display: flex; justify-content: center; margin-bottom: 12px; opacity: 0.4; color: var(--primary-accent);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px;"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"></path><path d="M13 13l6 6"></path></svg>
                </div>
                Select a card block on the canvas to configure its settings.
            </div>
        </div>
    </div>
</div>

<!-- Floating Edge Context Menu -->
<div class="fb-ctx-menu" id="fb-context-menu">
    <div class="fb-ctx-search">
        <input type="text" id="fb-ctx-search" class="fb-input" placeholder="Search message blocks..." style="padding: 6px 10px; font-size: 12px;">
    </div>
    <div class="fb-ctx-list" id="fb-ctx-list"></div>
</div>

<div id="fb-toast" class="fb-toast">Notification</div>
{% endblock %}

{% block javascripts %}
<script>
(() => {
    // ───────── State Initialization ─────────
    const SAVE_URL = '{{ path('app_whatsapp_bot_sequence_save') }}';
    const state = {
        currentId: '{{ sequence.id }}',
        meta: {
            name: '{{ sequence.name|escape('js') }}',
            trigger: '{{ sequence.trigger|default('NEW_SUBSCRIBER') }}',
            preferredTime: '{{ sequence.preferredTime }}',
            timezone: '{{ sequence.timezone }}',
            allowReentry: {{ sequence.allowReentry ? 'true' : 'false' }},
            isActive: {{ sequence.isActive ? 'true' : 'false' }},
        },
        nodes: new Map(),
        edges: [],
        viewport: { x: 80, y: 100, scale: 1 },
        selection: { node: null, edge: null },
        dirty: false,
        nextId: 1,
        templates: {{ templates|default([])|json_encode|raw }},
        httpApis: {{ httpApis|default([])|json_encode|raw }},
           // ───────── Blocks palette catalog definitions ─────────
    const BLOCKS = {
        start: {
            label: 'Start Bot Flow',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>',
            defaults: {},
            render: () => `
                <div class="click-body" style="height: 50px; display: flex; align-items: center; justify-content: center; opacity: 0.8; color: var(--fb-text-main);">

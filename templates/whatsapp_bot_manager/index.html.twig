    {# 1. Bot Reply Settings Content Pane #}
    <div class="manager-content-pane" id="pane-bot-reply">
        {% if connections is not empty %}
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M6 11V9a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"></path></svg>
                    <span>Trigger-Based Autoreplies</span>
                </h1>
                <div class="content-subtitle">Manage keyword triggers and interactive automated conversations builder flows.</div>
            </div>
            
            <a href="{{ path('app_whatsapp_bot_flows', {id: 'new', connectionId: connection ? connection.id : ''}) }}" class="btn-action btn-create">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                <span>Create Flow</span>
            </a>
        </div>

        {# Toolbar filters #}
        <div class="toolbar-row">
            <div class="toolbar-left">
                <select class="toolbar-select">
                    <option value="all">All Folders</option>
                </select>
                <div class="toolbar-search">
                    <svg viewBox="0 0 24 24" fill="none" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="text" id="flow-search" placeholder="Search flows...">
                </div>
            </div>
        </div>

        <div class="table-container">
            <table class="custom-table" id="flows-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">#</th>
                        <th style="width: 140px;">Unique ID</th>
                        <th>Reference Name</th>
                        <th style="width: 240px;">Keywords</th>
                        <th style="width: 130px; text-align: center;">Status</th>
                        <th style="width: 180px; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% if flows is empty %}
                        <tr>
                            <td colspan="6" class="no-data-row">No autoreply flows created. Click "Create Flow" to get started.</td>
                        </tr>
                    {% else %}
                        {% for flow in flows %}
                            <tr data-flow-id="{{ flow.id }}" class="flow-row">
                                <td style="opacity: 0.6;">{{ loop.index }}</td>
                                <td style="font-family: monospace; font-size: 12px; color: var(--wa-primary);">
                                    OS-FLOW-{{ flow.id }}
                                </td>
                                <td>
                                    <div style="font-weight: 700; font-size: 14px;">{{ flow.name }}</div>
                                    <div class="match-mode-badge">{{ flow.matchMode }}</div>
                                </td>
                                <td>
                                    {% if flow.getKeywordList() is empty %}
                                        <span style="opacity: 0.5; font-style: italic;">None</span>
                                    {% else %}
                                        {% for kw in flow.getKeywordList() %}
                                            <span class="keyword-tag">{{ kw }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </td>
                                <td style="text-align: center;">
                                    <label class="switch-toggle" title="Toggle flow active state">
                                        <input type="checkbox" {% if flow.isActive() %}checked{% endif %} onchange="toggleFlowStatus({{ flow.id }}, this.checked)">
                                        <span class="slider-round"></span>
                                    </label>
                                </td>
                                <td>
                                    <div class="row-actions" style="justify-content: flex-end;">
                                        <a href="{{ path('app_whatsapp_bot_flows', {id: flow.id, connectionId: connection ? connection.id : ''}) }}" class="btn-row-action edit-action" title="Edit flow">
                                            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                        </a>
                                        <button onclick="cloneFlow({{ flow.id }})" class="btn-row-action clone-action" title="Clone flow">
                                            <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                        </button>
                                        <a href="{{ path('app_whatsapp_bot_flows_export', {id: flow.id}) }}" class="btn-row-action export-action" title="Export flow">
                                            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                        </a>
                                        <button onclick="deleteFlow({{ flow.id }})" class="btn-row-action delete-action" title="Delete flow">
                                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>

    {# 2. Intelligent AI Copilot Content Pane #}
    <div class="manager-content-pane" id="pane-ai-agent">
        {% if connections is not empty %}
        {% set copilotSettings = settings['copilot-settings'] ?? {} %}
        {% set enableIntentRouting = copilotSettings.enableIntentRouting ?? false %}
        {% set intentCampaign = copilotSettings.intentCampaign ?? '' %}
        {% set routingProtocol = copilotSettings.routingProtocol ?? 'omnipresent' %}
        {% set deepContext = copilotSettings.deepContext ?? false %}
        {% set suspendOffHours = copilotSettings.suspendOffHours ?? false %}
        {% set humanEscalation = copilotSettings.humanEscalation ?? false %}
        {% set typingIndicator = copilotSettings.typingIndicator ?? false %}
        {% set replyBuffer = copilotSettings.replyBuffer ?? 0 %}
        {% set reasoningDepth = copilotSettings.reasoningDepth ?? 'standard' %}

        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    <span>Intelligent AI Copilot Console</span>
                </h1>
                <div class="content-subtitle">Deploy a context-grounded, multi-agent response coordinator with cognitive routing and transmission logic.</div>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 960px; gap: 28px;">
            <!-- Row 1: Autonomous Response Activation Toggle -->
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; border-bottom: 1px solid var(--glass-border); padding-bottom: 20px;">
                <div>
                    <div style="font-weight: 700; color: #fff; font-size: 16px; display: flex; align-items: center; gap: 8px;">
                        <span style="display: inline-block; width: 8px; height: 8px; background: var(--wa-primary); border-radius: 50%; box-shadow: 0 0 8px var(--wa-primary);"></span>
                        <span>Activate Autonomous Response Engine</span>
                    </div>
                    <div class="form-helper" style="margin-top: 4px;">Directly handle incoming WhatsApp customer messages with context-grounded LLM completions.</div>
                </div>
                <label class="switch-toggle" style="margin: 0; scale: 1.1;">
                    <input type="checkbox" id="ai-agent-active" {% if connection and connection.isAiActive() %}checked{% endif %}>
                    <span class="slider-round"></span>
                </label>
            </div>

            <!-- Row 2: Two columns - Context Selector & Intent Detection Toggle -->
            <div class="form-row">
                <!-- Column 2.1: Grounding Knowledge Context Selector -->
                <div class="form-group">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <label class="form-label" for="ai-agent-context-select">Grounding Knowledge Context</label>
                        <a href="{{ path('app_ai_settings') }}" style="font-size: 13px; text-decoration: none; color: var(--wa-accent); font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
                            <span>+ Configure Context Profiles</span>
                        </a>
                    </div>
                    <div class="form-helper" style="margin-bottom: 4px;">Select the knowledge-base profile, system instructions, and boundaries constraint.</div>
                    <select id="ai-agent-context-select" class="glass-input" style="width: 100%; height: 42px;">
                        <option value="">-- No Context Profile (Use Connection Default) --</option>
                        {% for ctx in contexts %}
                            <option value="{{ ctx.id }}" {% if connection and connection.getActiveContext() and connection.getActiveContext().getId() == ctx.id %}selected{% endif %}>
                                {{ ctx.name }} {% if ctx.getAgentRole() %}({{ ctx.getAgentRole() }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Column 2.2: Cognitive Intent Routing Toggle -->
                <div class="form-group" style="justify-content: space-between; border-left: 1px dashed var(--glass-border); padding-left: 20px;">
                    <div>
                        <label class="form-label" style="display: flex; justify-content: space-between; align-items: center;">
                            <span>Cognitive Intent Routing</span>
                            <label class="switch-toggle" style="margin: 0; scale: 0.95;">
                                <input type="checkbox" id="ai-enable-intent-routing" {% if enableIntentRouting %}checked{% endif %}>
                                <span class="slider-round"></span>
                            </label>
                        </label>
                        <div class="form-helper" style="margin-top: 6px;">Evaluate incoming requests to identify explicit customer intents, routing queries dynamically.</div>
                    </div>

                    <!-- Hidden sub-field: Intent Campaign ID Input -->
                    <div class="form-group" id="intent-campaign-group" style="display: none; margin-top: 10px;">
                        <label class="form-label" for="ai-intent-campaign" style="font-size: 13px; color: #94a3b8;">Primary Intent Campaign Mapping</label>
                        <input type="text" id="ai-intent-campaign" class="glass-input" placeholder="e.g. general_inquiries_v2" value="{{ intentCampaign }}" style="height: 38px; font-size: 13px;">
                    </div>
                </div>
            </div>

            <!-- Row 3: Engine Routing Protocol Select (Omnipresent vs Fallback) -->
            <div class="form-group" style="border-top: 1px dashed var(--glass-border); padding-top: 20px;">
                <label class="form-label">Engine Routing Protocol</label>
                <div class="form-helper" style="margin-bottom: 12px;">Configure how the AI responder coordinates and intervenes with pre-defined automation flow triggers.</div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px;">
                    <!-- Card 1: Omnipresent Mode -->
                    <label class="console-card" style="cursor: pointer; padding: 15px; margin: 0; display: flex; flex-direction: row; gap: 12px; align-items: flex-start; transition: all 0.25s; border-color: {% if routingProtocol == 'omnipresent' %}var(--wa-primary){% else %}var(--glass-border){% endif %}; background: {% if routingProtocol == 'omnipresent' %}rgba(16, 185, 129, 0.08){% else %}rgba(30, 41, 59, 0.3){% endif %};" id="label-protocol-omni">
                        <input type="radio" name="ai-routing-protocol" value="omnipresent" style="margin-top: 4px;" {% if routingProtocol == 'omnipresent' %}checked{% endif %} onclick="selectRoutingProtocol('omnipresent')">
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-weight: 700; color: #fff; font-size: 14px;">Omnipresent Responder Mode</span>
                            <span style="font-size: 12px; color: var(--text-muted); line-height: 1.4;">AI engine intercepts and handles all inbound user queries, bypassing standard flows.</span>
                        </div>
                    </label>
                    <!-- Card 2: Fallback Co-Pilot Mode -->
                    <label class="console-card" style="cursor: pointer; padding: 15px; margin: 0; display: flex; flex-direction: row; gap: 12px; align-items: flex-start; transition: all 0.25s; border-color: {% if routingProtocol == 'fallback' %}var(--wa-primary){% else %}var(--glass-border){% endif %}; background: {% if routingProtocol == 'fallback' %}rgba(16, 185, 129, 0.08){% else %}rgba(30, 41, 59, 0.3){% endif %};" id="label-protocol-fallback">
                        <input type="radio" name="ai-routing-protocol" value="fallback" style="margin-top: 4px;" {% if routingProtocol == 'fallback' %}checked{% endif %} onclick="selectRoutingProtocol('fallback')">
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-weight: 700; color: #fff; font-size: 14px;">Fallback Co-Pilot Mode</span>
                            <span style="font-size: 12px; color: var(--text-muted); line-height: 1.4;">Only trigger the AI engine when no keyword or dynamic flow trigger-match is found.</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Row 4: 2x2 Toggle Cards Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; border-top: 1px dashed var(--glass-border); padding-top: 20px;">
                <!-- Card 1: Enable Deep Conversational Context -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Deep Conversational Context</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Maintains cohesive multi-turn dialogue memory across long customer threads.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-deep-context" {% if deepContext %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <!-- Card 2: Suspend Responses Outside Operating Hours -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Suspend Responses in Off-Hours</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Silences autonomous replies outside set business operating hours.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-suspend-off-hours" {% if suspendOffHours %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <!-- Card 3: Automated Handoff & Human Escalation -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Automated Handoff Escalation</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Instantly assigns chats to standard departments/agents upon manual handoff flags.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-human-escalation" {% if humanEscalation %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <!-- Card 4: Simulate Typing Indicator State -->
                <div class="glass-form-card" style="padding: 16px; display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 12px; margin: 0; background: rgba(30, 41, 59, 0.15);">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Simulate Typing Indicator State</div>
                        <div class="form-helper" style="margin-top: 4px; font-size: 12px; line-height: 1.3;">Shows native chat 'typing...' status to customer before transmitting responses.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0; flex-shrink: 0; scale: 0.9;">
                        <input type="checkbox" id="ai-typing-indicator" {% if typingIndicator %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>
            </div>

            <!-- Row 5: Buffers & Depth dropdowns -->
            <div class="form-row" style="border-top: 1px dashed var(--glass-border); padding-top: 20px;">
                <!-- Delay/Buffer -->
                <div class="form-group">
                    <label class="form-label" for="ai-reply-buffer">Response Transmission Buffer (Seconds)</label>
                    <div class="form-helper" style="margin-bottom: 4px;">Configures realistic typing intervals before response is dispatched. Max 60s.</div>
                    <div style="position: relative; display: block; width: 100%; box-sizing: border-box;">
                        <input type="number" id="ai-reply-buffer" class="glass-input" min="0" max="60" value="{{ replyBuffer }}" style="box-sizing: border-box !important; width: 100%; padding-right: 42px; height: 42px;">
                        <span style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); font-size: 13px; color: var(--text-muted); font-weight: 600;">sec</span>
                    </div>
                </div>

                <!-- Cognitive Level / Reasoning Engine Depth -->
                <div class="form-group">
                    <label class="form-label" for="ai-reasoning-depth">Cognitive Reasoning Engine Depth</label>
                    <div class="form-helper" style="margin-bottom: 4px;">Sets conversational thinking complexity depth for response formulation.</div>
                    <select id="ai-reasoning-depth" class="glass-input" style="width: 100%; height: 42px;">
                        <option value="standard" {% if reasoningDepth == 'standard' %}selected{% endif %}>Standard (Lowest Latency)</option>
                        <option value="enhanced" {% if reasoningDepth == 'enhanced' %}selected{% endif %}>Enhanced (Balanced Precision)</option>
                        <option value="deep" {% if reasoningDepth == 'deep' %}selected{% endif %}>Deep Reasoning (Complex Workflows)</option>
                    </select>
                </div>
            </div>

            <!-- Row 6: Form actions -->
            <div style="display: flex; justify-content: flex-end; border-top: 1px solid var(--glass-border); padding-top: 20px; margin-top: 5px;">
                <button type="button" class="btn-action btn-create" id="btn-save-ai-agent-settings" onclick="saveAiAgentSettings()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                    <span>Save AI Agent Settings</span>
                </button>
            </div>
        </div>
        {% endif %}
    </div>

    {# 3. Official Broadcast Campaigns Content Pane #}
    <div class="manager-content-pane" id="pane-broadcast-campaigns">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
                    <span>Official Broadcast Campaigns</span>
                </h1>
                <div class="content-subtitle">Coordinate and review bulk template message marketing broadcast campaigns sent to opted-in subscribers.</div>
            </div>
            <button class="btn-action btn-create" onclick="addBroadcastRow()">New Broadcast Campaign</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="broadcasts-table">
                    <thead>
                        <tr>
                            <th>Campaign Name</th>
                            <th>Select Meta Template</th>
                            <th>Status</th>
                            <th>Sent</th>
                            <th>Delivered</th>
                            <th style="width: 80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in settings['broadcast-campaigns'] %}
                        <tr class="broadcast-row">
                            <td><input type="text" class="glass-input bc-name" style="width:100%" value="{{ item.name }}"></td>
                            <td>
                                <select class="glass-input bc-template" style="width:100%">
                                    <option value="monthly_newsletter" {% if item.template == 'monthly_newsletter' %}selected{% endif %}>monthly_newsletter (UTILITY)</option>
                                    <option value="flash_sale" {% if item.template == 'flash_sale' %}selected{% endif %}>flash_sale (MARKETING)</option>
                                    {% for template in templates %}
                                        <option value="{{ template.name }}" {% if item.template == template.name %}selected{% endif %}>{{ template.name }} ({{ template.category }})</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <span class="keyword-tag" style="background: {% if item.status == 'SENT' %}rgba(16,185,129,0.1){% else %}rgba(245,158,11,0.1){% endif %}; border-color: {% if item.status == 'SENT' %}rgba(16,185,129,0.2){% else %}rgba(245,158,11,0.2){% endif %}; color: {% if item.status == 'SENT' %}#10b981{% else %}#f59e0b{% endif %};">
                                    {{ item.status }}
                                </span>
                            </td>
                            <td>{{ item.sentCount }}</td>
                            <td>{{ item.deliveredCount }}</td>
                            <td>
                                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveBroadcastCampaigns()">Save Broadcast Campaigns</button>
            </div>
        </div>
    </div>

    {# 4. Drip Sequences Content Pane #}
    <div class="manager-content-pane" id="pane-drip-sequences">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    <span>Drip Sequences & Delays</span>
                </h1>
                <div class="content-subtitle">Queue automated, delayed messages scheduled to run after custom user trigger dates.</div>
            </div>
            <button class="btn-action btn-create" onclick="addSequenceRow()">Add Delayed Drip</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="sequences-table">
                    <thead>
                        <tr>
                            <th>Sequence Campaign Name</th>
                            <th style="width: 140px;">Steps Count</th>
                            <th style="width: 100px; text-align: center;">Active Status</th>
                            <th style="width: 110px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in sequences %}
                        {% set seqId = item.id %}
                        <tr class="sequence-row" data-seq-id="{{ seqId }}">
                            <td>
                                <input type="hidden" class="seq-id" value="{{ seqId }}">
                                <input type="text" class="glass-input seq-name" style="width:100%" value="{{ item.name }}">
                            </td>
                            <td style="font-family: monospace; color: var(--wa-primary); font-weight: 600; vertical-align: middle;">
                                {{ item.stepsCount|default(0) }} steps
                            </td>
                            <td style="text-align: center; vertical-align: middle;">
                                <label class="switch-toggle">
                                    <input type="checkbox" class="seq-active" {% if item.isActive %}checked{% endif %}>
                                    <span class="slider-round"></span>
                                </label>
                            </td>
                            <td>
                                <div class="row-actions" style="justify-content: flex-end;">
                                    <a href="{{ path('app_whatsapp_bot_sequence_builder') }}?id={{ seqId }}&connectionId={{ connection ? connection.id : '' }}" class="btn-row-action edit-action" title="Build Sequence Flow" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: var(--wa-primary); background: rgba(255,255,255,0.02); transition: all 0.2s;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                    </a>
                                    <button class="btn-row-action delete-action" onclick="deleteSequenceById('{{ seqId }}', this.closest('tr'))" title="Delete Sequence" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: #f87171; background: rgba(255,255,255,0.02); transition: all 0.2s;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveDripSequences()">Save Drip Sequences</button>
            </div>
        </div>
    </div>

    {# 5. Approved Meta Templates Content Pane #}
    <div class="manager-content-pane" id="pane-templates">
        {% if connections is not empty %}
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                    <span>Approved Meta Templates</span>
                </h1>
                <div class="content-subtitle">Create and manage WhatsApp message templates. New templates require Meta review.</div>
            </div>
            
            <div class="row-actions">
                <button class="btn-action btn-secondary-action" id="syncBtn" onclick="syncTemplates()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                    Sync Templates
                </button>
                <div class="template-create-dropdown-container" style="position: relative; display: inline-block;">
                    <button class="btn-action btn-create" id="btn-create-dropdown-trigger" style="display: flex; align-items: center; gap: 6px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        <span>Create</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 12px; height: 12px; margin-left: 2px;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="template-dropdown-menu" id="create-template-dropdown" style="display: none; position: absolute; top: 105%; right: 0; background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(25px); border: 1px solid var(--glass-border); border-radius: 12px; padding: 6px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); z-index: 1000; min-width: 230px; text-align: left;">
                        <div class="template-dropdown-item" onclick="openTemplateComposerModal('mixed')" style="padding: 10px 14px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; color: var(--wa-primary);"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
                            Mixed Template
                        </div>
                        <div class="template-dropdown-item" onclick="openTemplateComposerModal('wp')" style="padding: 10px 14px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; color: var(--wa-primary);"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                            WP Template
                        </div>
                        <div class="template-dropdown-item" onclick="openTemplateComposerModal('carousel_media')" style="padding: 10px 14px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; color: var(--wa-primary);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                            Carousel Media Template
                        </div>
                        <div class="template-dropdown-item" onclick="openTemplateComposerModal('carousel_product')" style="padding: 10px 14px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; color: var(--wa-primary);"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                            Carousel Product Template
                        </div>
                        <div class="template-dropdown-item" onclick="openTemplateComposerModal('default')" style="padding: 10px 14px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px; color: var(--wa-primary);"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                            Default Template
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Notice box for messages #}
        <div class="notice-box" id="templates-notice"></div>

        {# Grid showing all templates #}
        <div class="templates-grid">
            {% for template in templates %}
                <div class="template-card">
                    <div class="template-header">
                        <div>
                            <div class="template-name">{{ template.name }}</div>
                            <div class="template-meta">{{ template.category|capitalize }} &bull; {{ template.language }}</div>
                        </div>
                        <span class="badge badge-{{ template.status|lower }}">{{ template.status }}</span>
                    </div>
                    
                    {% set bodyText = '' %}
                    {% set headerText = '' %}
                    {% set footerText = '' %}
                    {% for comp in template.components %}
                        {% if comp.type == 'BODY' %}{% set bodyText = comp.text %}{% endif %}
                        {% if comp.type == 'HEADER' and comp.format == 'TEXT' %}{% set headerText = comp.text %}{% endif %}
                        {% if comp.type == 'FOOTER' %}{% set footerText = comp.text %}{% endif %}
                    {% endfor %}
                    
                    {% if headerText %}
                        <div style="font-size: 11px; color: var(--wa-primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">{{ headerText }}</div>
                    {% endif %}
                    <div class="template-body">{{ bodyText ?: 'No body text' }}</div>
                    {% if footerText %}
                        <div style="font-size: 11px; color: #64748b; font-style: italic;">{{ footerText }}</div>
                    {% endif %}
                </div>
            {% else %}
                <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    <h3>No templates yet</h3>
                    <p>Create a template above, or click "Sync Templates" to pull your approved templates from Meta.</p>
                </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    {# 6. Captured Forms & Inputs Content Pane #}
    <div class="manager-content-pane" id="pane-structured-inputs">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    <span>Captured Forms & Inputs</span>
                </h1>
                <div class="content-subtitle">Design structured capture forms that prompt users for details and parse values inside conversation variables.</div>
            </div>
            <button class="btn-action btn-create" onclick="addInputRow()">Add Custom Variable</button>
        </div>

        <div class="glass-form-card">
            <div class="table-container">
                <table class="custom-table" id="inputs-table">
                    <thead>
                        <tr>
                            <th>Variable Field Name</th>
                            <th style="width: 200px;">Data Type</th>
                            <th>Capture Message Prompt</th>
                            <th style="width: 80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in settings['structured-inputs'] %}
                        <tr class="input-row">
                            <td><input type="text" class="glass-input ui-name" style="width:100%; font-family:monospace;" value="{{ item.fieldName }}"></td>
                            <td>
                                <select class="glass-input ui-type" style="width:100%">
                                    <option value="EMAIL" {% if item.dataType == 'EMAIL' %}selected{% endif %}>Email Address</option>
                                    <option value="TEXT" {% if item.dataType == 'TEXT' %}selected{% endif %}>Free-form Text</option>
                                    <option value="PHONE" {% if item.dataType == 'PHONE' %}selected{% endif %}>Phone Number</option>
                                    <option value="NUMBER" {% if item.dataType == 'NUMBER' %}selected{% endif %}>Numeric Value</option>
                                </select>
                            </td>
                            <td><input type="text" class="glass-input ui-prompt" style="width:100%" value="{{ item.prompt }}"></td>
                            <td>
                                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveStructuredInputs()">Save Structured Inputs</button>
            </div>
        </div>
    </div>

    {# 7. In-App Dynamic Flows Content Pane #}
    <div class="manager-content-pane" id="pane-dynamic-flows">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                    <span>In-App Dynamic Flows</span>
                </h1>
                <div class="content-subtitle">WhatsApp-native multi-step interactive forms inside chat threads.</div>
            </div>
            <button class="btn-action btn-create" onclick="addFlowRow()">Create Dynamic Flow</button>
        </div>

        <div class="glass-form-card">

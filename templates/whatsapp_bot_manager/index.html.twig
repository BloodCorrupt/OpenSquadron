<script>
    const activeConnectionId = '{{ connection ? connection.id : "" }}';
    let sequencesList = {{ sequences|json_encode|raw }};

    // Webhooks compatibility
    let rawWebhooks = {{ settings['outbound-webhooks']|default([])|json_encode|raw }};
    let globalOutboundWebhooks = [];
    if (rawWebhooks) {
        if (Array.isArray(rawWebhooks)) {
            globalOutboundWebhooks = rawWebhooks;
        } else if (typeof rawWebhooks === 'object' && rawWebhooks.url) {
            globalOutboundWebhooks = [{
                name: 'Default Webhook',
                url: rawWebhooks.url,
                triggers: rawWebhooks.events || [],
                sendData: ['SUBSCRIBER_ID', 'SUBSCRIBER_NAME']

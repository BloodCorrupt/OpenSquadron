{% extends 'base.html.twig' %}

{% block title %}WhatsApp Bot Manager - OpenSquadron{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --wa-primary: #10b981;
        --wa-primary-rgb: 16, 185, 129;
        --wa-dark-green: #075e54;
        --wa-light-green: #25d366;
        --wa-teal: #128c7e;
        --wa-accent: #34d399;
    }

    /* Template Dropdown Styles */
    .template-dropdown-item {
        color: #cbd5e1 !important;
        font-size: 13px !important;
        font-weight: 600 !important;
        cursor: pointer;
        border-radius: 8px;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }
    .template-dropdown-item:hover {
        background: rgba(16, 185, 129, 0.15) !important;
        color: #fff !important;
    }
    .template-dropdown-item svg {
        transition: transform 0.2s;
    }
    .template-dropdown-item:hover svg {
        transform: scale(1.1);
    }

    /* Premium Two-column layout */
    .manager-shell {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 30px;
        margin-top: 20px;
        min-height: calc(100vh - 180px);
    }

    /* Grouped Left Nav Sidebar Panel */
    .manager-nav {
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 20px 15px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        height: fit-content;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    }
    .manager-nav .nav-header {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 1px;
        margin-top: 14px;
        margin-bottom: 6px;
        padding-left: 12px;
        opacity: 0.8;
    }
    .manager-nav .nav-header:first-of-type {
        margin-top: 0;
    }
    .manager-nav .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 10px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
        cursor: pointer;
        user-select: none;
    }
    .manager-nav .nav-item:hover {
        color: var(--text-main);
        background: rgba(255, 255, 255, 0.04);
        transform: translateX(2px);
    }
    .manager-nav .nav-item.is-active {
        color: var(--text-main);
        background: rgba(16, 185, 129, 0.12);
        border-color: rgba(16, 185, 129, 0.25);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.08);
    }
    .manager-nav .nav-item.is-disabled {
        opacity: 0.45;
        cursor: not-allowed !important;
    }
    .manager-nav .nav-item.is-disabled:hover {
        color: var(--text-muted) !important;
        background: transparent !important;
        transform: none !important;
        border-color: transparent !important;
        box-shadow: none !important;
    }
    .manager-nav .nav-item-icon {
        font-size: 16px;
        display: flex;
        align-items: center;
    }
    .manager-nav .nav-item-icon svg {
        width: 16px;
        height: 16px;
    }
    .manager-nav .nav-item-status {
        margin-left: auto;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.05);
        letter-spacing: 0.2px;
    }
    .manager-nav .nav-item.is-active .nav-item-status {
        background: rgba(16, 185, 129, 0.25);
        color: var(--wa-accent);
    }

    /* Right Content Panels */
    .manager-content-pane {
        display: none;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 30px;
        flex-direction: column;
        gap: 24px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .manager-content-pane.is-active {
        display: flex;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed var(--glass-border);
        padding-bottom: 18px;
    }
    .content-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .content-title svg {
        width: 24px;
        height: 24px;
        color: var(--wa-primary);
    }
    .content-subtitle {
        font-size: 15px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* Glass Console Grid Hub */
    .console-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 10px;
    }
    @media (min-width: 1921px) {
        .content-container {
            max-width: 1800px !important;
        }
        .console-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }
    @media (max-width: 1200px) {
        .console-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    .console-card {
        background: rgba(30, 41, 59, 0.3);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .console-card:hover {
        background: rgba(30, 41, 59, 0.55);
        border-color: rgba(16, 185, 129, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.08);
    }
    .console-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, transparent, rgba(16, 185, 129, 0.6), transparent);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .console-card:hover::before {
        opacity: 1;
    }
    .console-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .console-icon-wrapper {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: var(--wa-primary);
        transition: all 0.2s;
    }
    .console-card:hover .console-icon-wrapper {
        background: var(--wa-primary);
        color: #0f172a;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
    }
    .console-icon-wrapper svg {
        width: 20px;
        height: 20px;
    }
    .console-card-title {
        font-size: 16px;
        font-weight: 700;
        color: #f8fafc;
    }
    .console-card-status {
        margin-left: auto;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-muted);
    }
    .console-card:hover .console-card-status {
        background: rgba(16, 185, 129, 0.2);
        color: var(--wa-accent);
    }
    .console-card-desc {
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.5;
        flex: 1;
    }
    .console-card-action {
        font-size: 14px;
        font-weight: 600;
        color: var(--wa-primary);
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 5px;
    }
    .console-card-action svg {
        width: 14px;
        height: 14px;
        transition: transform 0.2s;
    }
    .console-card:hover .console-card-action svg {
        transform: translateX(3px);
    }
    .console-card.is-disabled {
        opacity: 0.5;
        cursor: not-allowed !important;
        pointer-events: none;
    }
    .console-card.is-disabled:hover {
        transform: none !important;
        border-color: var(--glass-border) !important;
        box-shadow: none !important;
        background: rgba(30, 41, 59, 0.3) !important;
    }
    .console-card.is-disabled::before { display: none; }
    .console-card.is-disabled .console-card-status {
        background: rgba(245, 158, 11, 0.12);
        color: #fbbf24;
        border: 1px solid rgba(245, 158, 11, 0.25);
    }

    /* Premium forms and inputs */
    .glass-form-card {
        background: rgba(15, 23, 42, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 0;
    }
    .form-label {
        font-size: 15px;
        font-weight: 600;
        color: #cbd5e1;
    }
    .form-label span {
        color: var(--wa-primary);
    }
    .form-helper {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.4;
    }
    .glass-input, .glass-textarea, .form-control {
        box-sizing: border-box !important;
        width: 100%;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 10px 14px;
        color: #fff;
        font-size: 15px;
        outline: none;
        transition: all 0.2s;
    }
    .glass-input:focus, .glass-textarea:focus, .form-control:focus {
        border-color: var(--wa-primary);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
    }
    .glass-textarea {
        resize: vertical;
        min-height: 100px;
    }

    /* Mobile WhatsApp Chat Simulator (Highly Premium) */
    .preview-container {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
    }
    .form-side {
        flex: 1;
        min-width: 320px;
    }
    .preview-side {
        width: 300px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
    .iphone-shell {
        width: 270px;
        height: 480px;
        border: 8px solid #334155;
        border-radius: 36px;
        background: #0b141a; /* WhatsApp Dark Mode Background */
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .iphone-header {
        height: 50px;
        background: #1f2c34; /* WhatsApp dark header */
        border-bottom: 1px solid rgba(255,255,255,0.03);
        display: flex;
        align-items: center;
        padding: 0 15px;
        font-size: 13px;
        font-weight: 700;
        color: #e9edef;
        gap: 10px;
    }
    .wa-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #00a884;
        display: grid;
        place-items: center;
        color: #fff;
        font-weight: bold;
        font-size: 13px;
    }
    .iphone-body {
        flex: 1;
        padding: 15px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        background-color: #0b141a;
        background-image: radial-gradient(circle, rgba(255,255,255,0.015) 1px, transparent 1px);
        background-size: 16px 16px;
    }
    .iphone-content {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        overflow-y: auto;
        justify-content: flex-end;
        margin-bottom: 10px;
    }

    /* WhatsApp custom bubble bubbles */
    .wa-bubble-received {
        background: #202c33;
        border-radius: 0 10px 10px 10px;
        padding: 8px 12px;
        font-size: 12px;
        color: #e9edef;
        line-height: 1.4;
        align-self: flex-start;
        max-width: 85%;
        box-shadow: 0 1px 1px rgba(0,0,0,0.1);
        position: relative;
    }
    .wa-bubble-sent {
        background: #005c4b; /* WhatsApp dark sent bubble */
        border-radius: 10px 0 10px 10px;
        padding: 8px 12px;
        font-size: 12px;
        color: #e9edef;
        line-height: 1.4;
        align-self: flex-end;
        max-width: 85%;
        box-shadow: 0 1px 1px rgba(0,0,0,0.1);
    }
    .wa-bubble-time {
        font-size: 9px;
        color: #8696a0;
        text-align: right;
        margin-top: 4px;
        display: block;
    }

    /* Quick Reply presets inside chat */
    .wa-interactive-buttons {
        display: flex;
        flex-direction: column;
        gap: 5px;
        width: 100%;
        margin-top: 6px;
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 6px;
    }
    .wa-btn {
        background: rgba(255, 255, 255, 0.05);
        color: #00a884;
        font-size: 12px;
        font-weight: 600;
        padding: 8px;
        border-radius: 6px;
        text-align: center;
        width: 100%;
        border: 1px solid rgba(255,255,255,0.05);
        cursor: pointer;
        transition: background 0.2s;
    }
    .wa-btn:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    /* Table styles */
    .table-container {
        overflow-x: auto;
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.15);
    }
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 15px;
    }
    .custom-table th {
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid var(--glass-border);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 13px;
        color: var(--text-muted);
        letter-spacing: 0.5px;
    }
    .custom-table td {
        padding: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-main);
        vertical-align: middle;
    }
    .custom-table tr:last-child td {
        border-bottom: none;
    }
    .custom-table tr:hover td {
        background: rgba(255, 255, 255, 0.01);
    }

    /* Toolbar search and filter Row */
    .toolbar-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }
    .toolbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        max-width: 600px;
    }
    .toolbar-search {
        position: relative;
        flex: 1;
    }
    .toolbar-search input {
        width: 100%;
        padding: 10px 14px 10px 36px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        font-size: 15px;
        color: #fff;
        outline: none;
        transition: all 0.2s;
    }
    .toolbar-search input:focus {
        border-color: var(--wa-primary);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
    }
    .toolbar-search .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 14px;
        height: 14px;
        stroke: #fff;
        opacity: 0.5;
        pointer-events: none;
        fill: none;
        stroke-width: 2.2;
    }
    .toolbar-select {
        padding: 10px 14px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        font-size: 15px;
        color: #fff;
        outline: none;
        cursor: pointer;
        min-width: 140px;
    }

    .btn-action {
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent;
        color: #fff;
        text-decoration: none;
        user-select: none;
    }
    .btn-create {
        background: var(--wa-primary);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);
    }
    .btn-create:hover {
        background: #059669;
        transform: translateY(-1px);
    }
    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
    }
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
    }
    .btn-secondary-action {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: #e2e8f0;
    }
    .btn-secondary-action:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }
    .btn-secondary-action.loading svg {
        animation: spin 1s linear infinite;
    }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    /* Switch toggle */
    .switch-toggle {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 22px;
        vertical-align: middle;
    }
    .switch-toggle input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        transition: .3s;
        border-radius: 34px;
    }
    .slider-round:before {
        position: absolute;
        content: "";
        height: 14px;
        width: 14px;
        left: 3px;
        bottom: 3px;
        background-color: #64748b;
        transition: .3s;
        border-radius: 50%;
    }
    .switch-toggle input:checked + .slider-round {
        background-color: rgba(16, 185, 129, 0.2);
        border-color: rgba(16, 185, 129, 0.4);
    }
    .switch-toggle input:checked + .slider-round:before {
        transform: translateX(22px);
        background-color: var(--wa-primary);
    }

    .keyword-tag {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 6px;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: var(--wa-accent);
        font-size: 13px;
        font-weight: 600;
        margin-right: 4px;
        margin-bottom: 4px;
    }
    .match-mode-badge {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.05);
        padding: 2px 6px;
        border-radius: 4px;
        display: inline-block;
        margin-top: 4px;
    }

    .row-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .btn-row-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        cursor: pointer;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-muted);
        transition: all 0.15s;
        text-decoration: none;
    }
    .btn-row-action:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.15);
    }
    .btn-row-action svg {
        width: 14px;
        height: 14px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2;
    }
    .btn-row-action.edit-action:hover {
        border-color: var(--wa-primary);
        color: var(--wa-primary);
        background: rgba(16, 185, 129, 0.05);
    }
    .btn-row-action.delete-action:hover {
        border-color: #ef4444;
        color: #ef4444;
        background: rgba(239, 68, 68, 0.05);
    }
    .btn-row-action.clone-action:hover {
        border-color: #f59e0b;
        color: #f59e0b;
        background: rgba(245, 158, 11, 0.05);
    }
    .btn-row-action.export-action:hover {
        border-color: #10b981;
        color: #10b981;
        background: rgba(16, 185, 129, 0.05);
    }

    .no-data-row {
        text-align: center;
        color: var(--text-muted);
        padding: 40px !important;
        font-style: italic;
    }

    /* Toast system */
    .fb-toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #0f172a;
        color: #ffffff;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s, transform 0.25s;
        z-index: 10000;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
        border: 1px solid var(--glass-border);
    }
    .fb-toast.is-shown { opacity: 1; transform: translateX(-50%) translateY(0); }
    .fb-toast.is-success { border-left: 4px solid #10b981; }
    .fb-toast.is-error { border-left: 4px solid #ef4444; }

    select.form-control option, select.toolbar-select option, select option {
        background-color: #0f172a !important;
        color: #f8fafc !important;
    }

    /* Premium Glass Modal Form styling */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(15, 23, 42, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        padding: 20px;
    }
    .modal-overlay.is-active, .modal-overlay.open {
        opacity: 1;
        pointer-events: auto;
    }
    .modal-card {
        background: rgba(30, 41, 59, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.4);
        width: 100%;
        max-width: 900px;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        transform: scale(0.95);
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden;
    }
    .modal-overlay.is-active .modal-card, .modal-overlay.open .modal-card {
        transform: scale(1);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .modal-title {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
    }
    .modal-close-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
    }
    .modal-close-btn:hover {
        color: #fff;
    }
    .modal-close-btn svg {
        width: 20px;
        height: 20px;
    }
    .modal-body {
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding: 16px 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(15, 23, 42, 0.2);
    }
    .switch-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }
    .switch-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-main);
    }
    .switch-container {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 22px;
        margin: 0 !important;
        flex-shrink: 0 !important;
    }
    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }
    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.1);
        transition: .3s;
        border-radius: 34px;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 14px;
        width: 14px;
        left: 3px;
        bottom: 3px;
        background-color: #a0aec0;
        transition: .3s;
        border-radius: 50%;
    }
    .toggle-switch input:checked + .toggle-slider {
        background-color: rgba(16, 185, 129, 0.2);
        border-color: rgba(16, 185, 129, 0.4);
    }
    .toggle-switch input:checked + .toggle-slider:before {
        transform: translateX(22px);
        background-color: #10b981;
    }
    .toggle-switch-blue input:checked + .toggle-slider {
        background-color: rgba(6, 182, 212, 0.2);
        border-color: rgba(6, 182, 212, 0.4);
    }
    .toggle-switch-blue input:checked + .toggle-slider:before {
        transform: translateX(22px);
        background-color: var(--primary-accent);
    }
    .form-group-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .form-group-card {
        border: 1px dashed rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 14px;
        background: rgba(15, 23, 42, 0.15);
    }
    .modal-input {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #fff;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 13px;
        width: 100%;
        box-sizing: border-box;
    }
    .modal-input:focus {
        border-color: var(--primary-accent);
        outline: none;
    }
    .modal-close {
        background: rgba(255,255,255,0.08);
        border: none;
        color: #fff;
        width: 32px; height: 32px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
    }
    .modal-close:hover { background: rgba(255,255,255,0.15); }
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--glass-border);
    }
    .btn-cancel {
        background: rgba(255,255,255,0.06);
        color: #ccc;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
        transition: background 0.2s;
    }
    .btn-cancel:hover { background: rgba(255,255,255,0.12); }

    .notice-box {
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 15px;
        margin-bottom: 20px;
        display: none;
    }
    .notice-box.success { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.4); color: #34d399; }
    .notice-box.error   { background: rgba(239,68,68,0.15);  border: 1px solid rgba(239,68,68,0.4);  color: #f87171; }

    /* Templates Grid Styling */
    .templates-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }
    .template-card {
        background: rgba(15, 23, 42, 0.3);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: all 0.3s;
    }
    .template-card:hover {
        background: rgba(15, 23, 42, 0.5);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }
    .template-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
    }
    .template-name {
        font-size: 15px;
        font-weight: 600;
        color: #fff;
        word-break: break-all;
    }
    .template-meta {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 2px;
    }
    .badge {
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: 700;
        white-space: nowrap;
        flex-shrink: 0;
        text-transform: uppercase;
    }
    .badge-approved  { background: rgba(16,185,129,0.15);  color: #34d399; border: 1px solid rgba(16,185,129,0.3); }
    .badge-pending   { background: rgba(234,179,8,0.15);   color: #f59e0b; border: 1px solid rgba(234,179,8,0.3); }
    .badge-rejected  { background: rgba(239,68,68,0.15);   color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
    .badge-disabled  { background: rgba(100,116,139,0.15); color: #94a3b8; border: 1px solid rgba(100,116,139,0.3); }

    .template-body {
        font-size: 15px;
        color: #cbd5e1;
        background: rgba(0,0,0,0.2);
        padding: 12px;
        border-radius: 8px;
        white-space: pre-wrap;
        line-height: 1.5;
        flex: 1;
        border: 1px solid rgba(255,255,255,0.03);
    }
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 40px;
        color: var(--text-muted);
        background: rgba(15, 23, 42, 0.3);
        border-radius: 12px;
        border: 1px dashed var(--glass-border);
    }
    .empty-state svg {
        margin-bottom: 16px;
        opacity: 0.4;
        color: var(--wa-primary);
    }
    .empty-state h3 { color: #fff; margin: 0 0 8px; font-size: 18px; }

    .var-hint {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 6px;
        align-items: center;
    }
    .var-chip {
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.3);
        color: var(--wa-accent);
        padding: 3px 9px;
        border-radius: 20px;
        font-size: 12px;
        cursor: pointer;
        transition: background 0.2s;
        font-weight: 700;
    }
    .var-chip:hover { background: rgba(16,185,129,0.2); }

    /* Custom Floating Widget Website Preview */
    .mock-floating-bubble {
        position: absolute;
        bottom: 15px;
        right: 15px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        color: #fff;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        background: var(--wa-primary);
        transition: all 0.3s;
    }

    .sidebar-mobile-toggle {
        display: none;
    }

    @media (max-width: 768px) {
        .sidebar-mobile-toggle {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            padding: 10px 14px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            border: 1px solid var(--glass-border);
        }
        
        .manager-nav:not(.is-open) > :not(.sidebar-mobile-toggle) {
            display: none !important;
        }
        
        .manager-nav.is-open .sidebar-mobile-toggle svg:last-of-type {
            transform: rotate(180deg);
        }
        
        .manager-shell {
            grid-template-columns: 1fr;
            gap: 20px;
            margin-top: 15px;
        }
        
        .manager-nav {
            padding: 15px;
            gap: 8px;
        }
        
        .manager-content-pane {
            padding: 12px 10px !important;
            min-width: 0;
            overflow: hidden;
            gap: 16px;
        }
        
        .content-header {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
            padding-bottom: 12px;
        }
        
        .content-header .row-actions, .content-header div:last-child {
            width: 100%;
        }
        
        .content-header .btn-action {
            width: 100%;
            justify-content: center;
        }
        
        .console-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .toolbar-row {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }
        
        .toolbar-left {
            flex-direction: column;
            align-items: stretch;
            width: 100%;
            max-width: none;
            gap: 10px;
        }
        
        .toolbar-search {
            width: 100%;
        }
        
        .toolbar-select {
            width: 100%;
        }
        
        .btn-create, .btn-action {
            width: 100%;
            justify-content: center;
        }
        
        .preview-container {
            flex-direction: column-reverse;
            align-items: center;
            gap: 25px;
        }
        
        .form-side {
            width: 100%;
            min-width: 0;
        }
        
        .preview-side {
            width: 100%;
            align-items: center;
        }
        
        .custom-table th, .custom-table td {
            padding: 10px 12px;
            font-size: 13.5px;
        }
        
        .templates-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .form-row {
            grid-template-columns: 1fr;
            gap: 15px;
        }
        
        .glass-form-card {
            padding: 12px !important;
            gap: 15px;
        }
    }
    
    /* ─── Light Mode Theme Style Overrides ─── */
    body[data-theme="light"] .modal-card {
        background: rgba(255, 255, 255, 0.98) !important;
        border-color: #cbd5e1 !important;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
        color: #1e293b !important;
    }
    body[data-theme="light"] .modal-header {
        border-bottom-color: #e5e5e5 !important;
    }
    body[data-theme="light"] .modal-title {
        color: #0f172a !important;
    }
    body[data-theme="light"] .modal-close {
        background: rgba(0, 0, 0, 0.05) !important;
        color: #1e293b !important;
    }
    body[data-theme="light"] .modal-close:hover {
        background: rgba(0, 0, 0, 0.1) !important;
    }
    body[data-theme="light"] .modal-close-btn {
        color: #64748b !important;
    }
    body[data-theme="light"] .modal-close-btn:hover {
        color: #ef4444 !important;
    }
    body[data-theme="light"] .modal-body {
        color: #1e293b !important;
    }
    body[data-theme="light"] .modal-footer {
        background: #f8fafc !important;
        border-top-color: #e5e5e5 !important;
    }
    body[data-theme="light"] .modal-input {
        background: #ffffff !important;
        border-color: #cbd5e1 !important;
        color: #1e293b !important;
        box-sizing: border-box !important;
    }
    body[data-theme="light"] .modal-input:focus {
        border-color: var(--primary-accent) !important;
        box-shadow: 0 0 0 3px rgba(8, 145, 178, 0.12) !important;
    }
    body[data-theme="light"] .btn-cancel {
        background: rgba(0, 0, 0, 0.05) !important;
        color: #475569 !important;
        border: 1px solid #cbd5e1 !important;
    }
    body[data-theme="light"] .btn-cancel:hover {
        background: rgba(0, 0, 0, 0.08) !important;
        color: #1e293b !important;
    }
    body[data-theme="light"] select option,
    body[data-theme="light"] select.form-control option,
    body[data-theme="light"] select.toolbar-select option {
        background-color: #ffffff !important;
        color: #1e293b !important;
    }
    body[data-theme="light"] #outbound-webhook-modal div[style*="background: rgba(0,0,0,0.15)"],
    body[data-theme="light"] #outbound-webhook-modal div[style*="background:rgba(0,0,0,0.15)"] {
        background: #f8fafc !important;
        border-color: #cbd5e1 !important;
    }
    body[data-theme="light"] #outbound-webhook-modal span[style*="color: #fff"],
    body[data-theme="light"] #outbound-webhook-modal span[style*="color:#fff"] {
        color: #1e293b !important;
    }
    body[data-theme="light"] #createTemplateModal div[style*="color: #94a3b8"],
    body[data-theme="light"] #createTemplateModal div[style*="color:#94a3b8"] {
        color: #475569 !important;
    }
    body[data-theme="light"] .toggle-slider {
        background-color: #cbd5e1 !important;
        border-color: #cbd5e1 !important;
    }
    body[data-theme="light"] .toggle-switch input:checked + .toggle-slider {
        background-color: rgba(16, 185, 129, 0.2) !important;
        border-color: rgba(16, 185, 129, 0.4) !important;
    }
    body[data-theme="light"] .toggle-switch-blue input:checked + .toggle-slider {
        background-color: rgba(6, 182, 212, 0.2) !important;
        border-color: rgba(6, 182, 212, 0.4) !important;
    }
</style>
{% endblock %}

{% block body %}
<div class="manager-shell">
    {# ───────── Left Sidebar Navigation (Grouped Layout) ───────── #}
    <div class="manager-nav">
        <div class="sidebar-mobile-toggle">
            <span>
                <svg viewBox="0 0 24 24" style="width: 16px; height: 16px; stroke-width: 2.5;"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                Menu Options
            </span>
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="nav-header">WhatsApp Account</div>
        <div style="margin-bottom: 10px; padding: 0 10px;">
            <select id="whatsapp-conn-selector" class="form-control" style="background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); color: #fff; padding: 8px 12px; border-radius: 8px; font-size: 15px; width: 100%; height: 38px;" onchange="changeConnection(this.value)">
                {% if connections is empty %}
                    <option value="">No Accounts Connected</option>
                {% else %}
                    {% for conn in connections %}
                        <option value="{{ conn.id }}" {% if connection and connection.id == conn.id %}selected{% endif %}>
                            {{ conn.label ?: conn.phoneNumber ?: 'Unnamed Connection (' ~ conn.id ~ ')' }}
                        </option>
                    {% endfor %}
                {% endif %}
            </select>
        </div>

        <!-- Group 1: Main Console -->
        <div class="nav-header">Main Console</div>
        <div class="nav-item is-active" data-tab-target="console">
            <span class="nav-item-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"></rect><rect x="14" y="3" width="7" height="5"></rect><rect x="14" y="12" width="7" height="9"></rect><rect x="3" y="16" width="7" height="5"></rect></svg>
            </span>
            <span>Dashboard Hub</span>
        </div>

        <!-- Group 2: Core Responders -->

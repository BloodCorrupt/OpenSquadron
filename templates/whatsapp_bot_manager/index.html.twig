            </span>
            <span>Growth & Web Widgets</span>
        </div>
    </div>

    {# ───────── Right Content Panels ───────── #}

    {# 0. Centralized Dashboard Hub Panel #}
    <div class="manager-content-pane is-active" id="pane-console">
        <div class="content-header">
            <div>

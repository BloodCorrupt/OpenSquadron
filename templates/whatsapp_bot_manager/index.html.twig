    <div id="modal-widget" class="modal-backdrop" style="display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
        <div class="glass-form-card" style="width: 500px; padding: 24px; position:relative;">
            <h3 style="margin-top:0;">Create Web Widget</h3>
            <div class="form-group">
                <label class="form-label">Widget Name *</label>
                <input type="text" id="widget-name" class="glass-input" style="width:100%" placeholder="e.g. Homepage Bubble">
            </div>
            <div class="form-group">
                <label class="form-label">Widget Type *</label>
                <select id="widget-type" class="glass-input" style="width:100%">
                    <option value="floating_bubble">Floating Chat Bubble</option>
                    <option value="qr_code">QR Code Plugin</option>
                </select>
            </div>
            <div style="display:flex; justify-content:flex-end; gap: 12px; margin-top:20px;">
                <button class="btn-action" style="background:transparent; border:1px solid rgba(255,255,255,0.2);" onclick="document.getElementById('modal-widget').style.display='none'">Cancel</button>
                <button class="btn-action btn-create" onclick="saveWidget()">Create Widget</button>
            </div>
        </div>
    </div>

    <script>
        function openCreateBroadcastModal() {
            document.getElementById('bc-name').value = '';
            document.getElementById('bc-type').value = 'anytime';
            document.getElementById('bc-template').value = '';
            document.getElementById('bc-custom-message').value = '';
            toggleBcTemplate();
            document.getElementById('modal-broadcast').style.display = 'flex';
        }

        function toggleBcTemplate() {
            const type = document.getElementById('bc-type').value;
            const templateGroup = document.getElementById('bc-template-group');
            const customMessageGroup = document.getElementById('bc-custom-message-group');
            if (type === '24_hours') {
                templateGroup.style.display = 'none';
                customMessageGroup.style.display = 'block';
            } else {
                templateGroup.style.display = 'block';
                customMessageGroup.style.display = 'none';
            }
        }

        function saveBroadcast() {
            const name = document.getElementById('bc-name').value.trim();
            const type = document.getElementById('bc-type').value;
            const template = document.getElementById('bc-template').value;
            const customMessage = document.getElementById('bc-custom-message').value.trim();

            if (!name) return showToast('Campaign Name is required', 'error');
            if (type === 'anytime' && !template) return showToast('Template is required for Anytime broadcasts', 'error');
            if (type === '24_hours' && !customMessage) return showToast('Message Text is required for 24 Hours broadcasts', 'error');

            fetch('/whatsapp-bot-manager/broadcasts/save', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    connectionId: activeConnectionId,
                    campaignName: name,
                    broadcastType: type,
                    templateName: type === 'anytime' ? template : null,
                    customMessage: type === '24_hours' ? customMessage : null
                })
            }).then(r => r.json()).then(res => {
                if (res.success) {
                    showToast('Broadcast created!', 'success');
                    location.reload();
                } else {
                    showToast(res.error, 'error');
                }
            });
        }

        function deleteBroadcast(id) {
            if(!confirm('Delete this broadcast campaign?')) return;
            fetch('/whatsapp-bot-manager/broadcasts/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({id})
            }).then(r=>r.json()).then(res => {
                if(res.success) location.reload();
            });
        }

        function openCreateWidgetModal() {
            document.getElementById('widget-name').value = '';
            document.getElementById('widget-type').value = 'floating_bubble';
            document.getElementById('modal-widget').style.display = 'flex';
        }

        function saveWidget() {
            const name = document.getElementById('widget-name').value.trim();
            const type = document.getElementById('widget-type').value;

            if (!name) return showToast('Widget Name is required', 'error');

            fetch('/whatsapp-bot-manager/widgets/save', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    connectionId: activeConnectionId,
                    widgetName: name,
                    widgetType: type
                })
            }).then(r => r.json()).then(res => {
                if (res.success) {
                    showToast('Widget created!', 'success');
                    location.reload();
                } else {
                    showToast(res.error, 'error');
                }
            });
        }

        function deleteWidget(id) {
            if(!confirm('Delete this widget?')) return;
            fetch('/whatsapp-bot-manager/widgets/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({id})
            }).then(r=>r.json()).then(res => {
                if(res.success) location.reload();
            });
        }

        let reportLogsCached = [];

        function viewCampaignReport(id) {
            document.getElementById('report-log-search').value = '';
            const tbody = document.querySelector('#report-logs-table tbody');
            tbody.innerHTML = '<tr><td colspan="10" style="text-align:center; padding: 20px; color:#64748b;">Loading report data...</td></tr>';
            
            document.getElementById('modal-report').style.display = 'flex';

            fetch(`/whatsapp-bot-manager/broadcasts/${id}/report`)
                .then(r => r.json())
                .then(res => {
                    if (!res.success) {
                        tbody.innerHTML = `<tr><td colspan="10" style="text-align:center; padding: 20px; color:#ef4444;">${res.error}</td></tr>`;
                        return;
                    }

                    const c = res.campaign;
                    document.getElementById('report-campaign-title').textContent = `${c.name} (${c.type === 'anytime' ? 'Anytime' : '24 Hours'})`;
                    document.getElementById('report-template').textContent = c.template;
                    
                    // Status Badge
                    const statusBadge = document.getElementById('report-status-badge');
                    statusBadge.innerHTML = `<span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:#10b981;"></span> ${c.status}`;
                    
                    // Message Count
                    document.getElementById('report-message-count').textContent = c.processed;

                    // Metrics Rows
                    const total = c.processed || 1;
                    const procPct = Math.round((c.processed / total) * 100);
                    const delPct = Math.round((c.delivered / total) * 100);
                    const opnPct = Math.round((c.opened / total) * 100);
                    const unrPct = Math.round((c.unreached / total) * 100);

                    // Text fields
                    document.getElementById('metric-processed-txt').textContent = `Sent (${procPct}%)`;
                    document.getElementById('metric-processed-ratio').textContent = `${c.processed}/${total}`;
                    document.getElementById('metric-processed-bar').style.width = `${procPct}%`;

                    document.getElementById('metric-delivered-txt').textContent = `Delivered (${delPct}%)`;
                    document.getElementById('metric-delivered-ratio').textContent = `${c.delivered}/${total}`;
                    document.getElementById('metric-delivered-bar').style.width = `${delPct}%`;

                    document.getElementById('metric-opened-txt').textContent = `Opened (${opnPct}%)`;
                    document.getElementById('metric-opened-ratio').textContent = `${c.opened}/${total}`;
                    document.getElementById('metric-opened-bar').style.width = `${opnPct}%`;

                    document.getElementById('metric-unreached-txt').textContent = `Unreached (${unrPct}%)`;
                    document.getElementById('metric-unreached-ratio').textContent = `${c.unreached}/${total}`;
                    document.getElementById('metric-unreached-bar').style.width = `${unrPct}%`;

                    // Download Button
                    document.getElementById('report-download-btn').setAttribute('href', `/whatsapp-bot-manager/broadcasts/${id}/report/download`);

                    // Populate Logs
                    reportLogsCached = res.logs;
                    renderReportLogs(reportLogsCached);
                });
        }

        function renderReportLogs(logs) {
            const tbody = document.querySelector('#report-logs-table tbody');
            tbody.innerHTML = '';
            if (logs.length === 0) {
                tbody.innerHTML = '<tr><td colspan="10" style="text-align:center; padding: 20px; color:#64748b;">No subscriber logs found.</td></tr>';
                return;
            }

            logs.forEach(log => {
                const tr = document.createElement('tr');
                tr.style.borderBottom = '1px solid #f1f5f9';
                
                let statusColor = '#3b82f6';
                let statusBg = 'rgba(59, 130, 246, 0.1)';
                if (log.status === 'Delivered') {
                    statusColor = '#10b981';
                    statusBg = 'rgba(16, 185, 129, 0.1)';
                } else if (log.status === 'Failed') {
                    statusColor = '#ef4444';
                    statusBg = 'rgba(239, 68, 68, 0.1)';
                }

                tr.innerHTML = `
                    <td style="padding:10px 8px;">${log.index}</td>
                    <td style="padding:10px 8px; font-weight:700;">${log.chatId}</td>
                    <td style="padding:10px 8px;">${log.name}</td>
                    <td style="padding:10px 8px;">
                        <span style="display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:700; color:${statusColor}; background:${statusBg};">${log.status}</span>
                    </td>
                    <td style="padding:10px 8px;">${log.sentAt}</td>
                    <td style="padding:10px 8px;">${log.deliveredAt}</td>
                    <td style="padding:10px 8px;">${log.openedAt}</td>
                    <td style="padding:10px 8px;">${log.failedAt}</td>
                    <td style="padding:10px 8px; font-family:monospace; font-size:11px; color:#64748b;">${log.messageId}</td>
                    <td style="padding:10px 8px; color:#ef4444; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${log.error}">${log.error}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterReportLogs() {
            const query = document.getElementById('report-log-search').value.toLowerCase().trim();
            if (query === '') {
                renderReportLogs(reportLogsCached);
                return;
            }

            const filtered = reportLogsCached.filter(log => {
                return log.chatId.toLowerCase().includes(query) || 
                       log.name.toLowerCase().includes(query) || 
                       log.status.toLowerCase().includes(query) ||
                       log.error.toLowerCase().includes(query);
            });
            renderReportLogs(filtered);
        }
    </script>
{% endblock %}

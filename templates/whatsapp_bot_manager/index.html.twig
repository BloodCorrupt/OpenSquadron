    // Categories Multi-select Logic
    let selectedCategories = [];
    function toggleCategoryDropdown() {
        const dropdown = document.querySelector('.multi-select-dropdown');
        dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
    }
    
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.multi-select-container')) {
            const dropdown = document.querySelector('.multi-select-dropdown');
            if(dropdown) dropdown.style.display = 'none';
        }
    });

    document.querySelectorAll('.ms-option').forEach(opt => {
        opt.addEventListener('click', function() {
            const val = this.dataset.val;
            if (!selectedCategories.includes(val)) {
                selectedCategories.push(val);
                updateCategoryTags();
            }
            document.querySelector('.multi-select-dropdown').style.display = 'none';
        });
    });

    function updateCategoryTags() {
        const tagsContainer = document.querySelector('.multi-select-tags');
        document.getElementById('flow-categories-hidden').value = JSON.stringify(selectedCategories);
        
        if (selectedCategories.length === 0) {
            tagsContainer.innerHTML = '<span style="color:var(--text-muted); padding:4px;">Select categories...</span>';
            return;
        }

        tagsContainer.innerHTML = '';
        selectedCategories.forEach(cat => {
            const tag = document.createElement('div');
            tag.style.cssText = 'background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.5); color: #60a5fa; padding: 2px 8px; border-radius: 4px; font-size: 12px; display: flex; align-items: center; gap: 6px;';
            tag.innerHTML = `
                <span>${cat}</span>
                <span style="cursor:pointer; font-weight:bold; font-size:14px; margin-left:4px;" onclick="removeCategory('${cat}', event)">&times;</span>
            `;
            tagsContainer.appendChild(tag);
        });
    }

    function removeCategory(cat, event) {
        event.stopPropagation();
        selectedCategories = selectedCategories.filter(c => c !== cat);
        updateCategoryTags();
    }

    function toggleFlowMode(mode) {
        if (mode === 'builder') {
            document.getElementById('wa-form-builder-canvas').style.display = 'flex';
            document.getElementById('wa-form-json-editor').style.display = 'none';
        } else {
            document.getElementById('wa-form-builder-canvas').style.display = 'none';
            document.getElementById('wa-form-json-editor').style.display = 'block';
        }
    }
</script>


                    <div class="console-card-action" style="color: #f59e0b;">
                        <span>Manage Flows</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 8. Action Button Presets -->
                <div class="console-card" onclick="switchTab('action-buttons')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(20, 184, 166, 0.1); color: #14b8a6; border-color: rgba(20, 184, 166, 0.2);">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        </div>
                        <span class="console-card-title">Action Button Presets</span>
                        <span class="console-card-status">Active</span>
                    </div>
                    <p class="console-card-desc">Configure quick-action presets, quick replies, and redirect links rendered in custom simulated previews.</p>
                    <div class="console-card-action" style="color: #14b8a6;">
                        <span>Edit Presets</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 9. eCommerce Automations -->
                <div class="console-card" onclick="switchTab('ecommerce-automations')">
                    <div class="console-card-header">
                        <div class="console-icon-wrapper" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.2);">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                        </div>
                        <span class="console-card-title">eCommerce Sync</span>
                        <span class="console-card-status">Active</span>
                    </div>
                    <p class="console-card-desc">Sync with WooCommerce & Shopify sites to trigger abandoned cart recovery templates and transaction notifications.</p>
                    <div class="console-card-action">
                        <span>Setup Integrations</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </div>

                <!-- 10. Outbound Streams & Webhooks -->

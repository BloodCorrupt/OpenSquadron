                <table class="custom-table" id="flows-grid-table">
                    <thead>
                        <tr>
                            <th>Flow Name</th>
                            <th>Flow ID Reference</th>
                            <th>Status Badge</th>
                            <th style="width: 80px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in settings['dynamic-flows'] %}

    function openTemplateComposerModal(type) {
        document.getElementById('tpl-type').value = type;
        const defaultFields = document.getElementById('default-template-fields');
        const customFields = document.getElementById('custom-template-fields');
        const titleEl = document.querySelector('#createTemplateModal .modal-title');
        
        // Hide dropdown
        const dropdown = document.getElementById('create-template-dropdown');
        if (dropdown) dropdown.style.display = 'none';

        // Clear existing fields
        document.getElementById('tpl-name').value = '';
        document.getElementById('tpl-category').value = 'MARKETING';
        document.getElementById('tpl-language').value = 'en_US';
        document.getElementById('tpl-header').value = '';
        document.getElementById('tpl-body').value = '';
        document.getElementById('tpl-footer').value = '';
        customFields.innerHTML = '';

        if (type === 'default') {
            defaultFields.style.display = 'block';
            customFields.style.display = 'none';
            titleEl.textContent = 'Create Message Template';
        } else {
            defaultFields.style.display = 'none';
            customFields.style.display = 'block';
            
            if (type === 'mixed') {
                titleEl.textContent = 'Create Mixed Template';
                renderMixedTemplateFields();
            } else if (type === 'wp') {
                titleEl.textContent = 'Create WP Template';
                renderWpTemplateFields();
            } else if (type === 'carousel_media') {
                titleEl.textContent = 'Create Carousel Media Template';
                renderCarouselMediaFields();
            } else if (type === 'carousel_product') {
                titleEl.textContent = 'Create Carousel Product Template';
                renderCarouselProductFields();
            }
        }

        document.getElementById('createTemplateModal').classList.add('open');
    }


    // ───────── AI Agent Saver ─────────
    function saveAiAgentSettings() {
        const aiActive = document.getElementById('ai-agent-active').checked;
        const activeContextId = document.getElementById('ai-agent-context-select').value;
        
        // Advanced settings
        const enableIntentRouting = document.getElementById('ai-enable-intent-routing').checked;
        const intentCampaign = document.getElementById('ai-intent-campaign').value;
        const checkedProtocol = document.querySelector('input[name="ai-routing-protocol"]:checked');
        const routingProtocol = checkedProtocol ? checkedProtocol.value : 'omnipresent';
        const deepContext = document.getElementById('ai-deep-context').checked;
        const suspendOffHours = document.getElementById('ai-suspend-off-hours').checked;
        const humanEscalation = document.getElementById('ai-human-escalation').checked;
        const typingIndicator = document.getElementById('ai-typing-indicator').checked;
        const replyBuffer = parseInt(document.getElementById('ai-reply-buffer').value) || 0;
        const reasoningDepth = document.getElementById('ai-reasoning-depth').value;
        const ecomContextEnabled = document.getElementById('ai-ecom-context-enabled').checked;

        const btn = document.getElementById('btn-save-ai-agent-settings');

        btn.disabled = true;
        btn.innerHTML = '<span>Saving...</span>';

        // 1. Save Core Database settings (Active context and state)
        const dbFormData = new FormData();
        dbFormData.append('connectionId', activeConnectionId);
        dbFormData.append('configType', 'agent');
        dbFormData.append('aiActive', aiActive ? '1' : '0');
        dbFormData.append('ecomContextEnabled', ecomContextEnabled ? '1' : '0');
        dbFormData.append('activeContextId', activeContextId);

        // 2. Save Advanced Copilot parameters to JSON
        const jsonSettings = {
            enableIntentRouting,
            intentCampaign,
            routingProtocol,
            deepContext,
            suspendOffHours,
            humanEscalation,
            typingIndicator,
            replyBuffer,
            reasoningDepth
        };
        const jsonFormData = new FormData();
        jsonFormData.append('connectionId', activeConnectionId);
        jsonFormData.append('type', 'copilot-settings');
        jsonFormData.append('data', JSON.stringify(jsonSettings));

        // Let's run both fetch requests concurrently
        Promise.all([
            fetch('{{ path('app_whatsapp_bot_ai_agent_save') }}', {
                method: 'POST',
                body: dbFormData
            }).then(res => res.json()),
            fetch('{{ path('app_whatsapp_bot_save_settings') }}', {
                method: 'POST',
                body: jsonFormData
            }).then(res => res.json())
        ])
        .then(([dbRes, jsonRes]) => {
            if (dbRes.success && jsonRes.success) {
                showToast('Advanced AI Copilot settings synced successfully!', 'success');
                const statusBadge = document.getElementById('ai-nav-status');
                if (statusBadge) {
                    statusBadge.textContent = aiActive ? 'ON' : 'OFF';
                }
            } else {
                const errMsg = (!dbRes.success ? dbRes.error : '') || (!jsonRes.success ? jsonRes.error : '') || 'Unknown error';
                showToast('Failed to save settings: ' + errMsg, 'error');
            }
        })
        .catch(err => {
            showToast('Save error: ' + err.message, 'error');
        })
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px; height:16px; margin-right:4px;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg> <span>Save AI Agent Settings</span>';
        });
    }


    function openOutboundWebhookModal(index = null) {
        editingWebhookIndex = index;
        const nameInput = document.getElementById('outbound-webhook-name');
        const urlInput = document.getElementById('outbound-webhook-url');
        const titleEl = document.getElementById('outbound-webhook-modal-title');

        document.querySelectorAll('.outbound-webhook-trigger-cb').forEach(cb => cb.checked = false);
        document.querySelectorAll('.outbound-webhook-send-cb').forEach(cb => cb.checked = false);

        if (index !== null) {
            const item = globalOutboundWebhooks[index];
            titleEl.textContent = 'Edit Out-bound Webhook';
            nameInput.value = item.name || '';
            urlInput.value = item.url || '';

            if (item.triggers) {
                item.triggers.forEach(val => {
                    const cb = document.querySelector(`.outbound-webhook-trigger-cb[value="${val}"]`);
                    if (cb) cb.checked = true;
                });
            }
            if (item.sendData) {
                item.sendData.forEach(val => {
                    const cb = document.querySelector(`.outbound-webhook-send-cb[value="${val}"]`);
                    if (cb) cb.checked = true;
                });
            }
        } else {
            titleEl.textContent = 'Out-bound Webhook';
            nameInput.value = '';
            urlInput.value = '';
        }

        document.getElementById('outbound-webhook-modal').classList.add('open');
    }

    function closeOutboundWebhookModal() {
        document.getElementById('outbound-webhook-modal').classList.remove('open');
    }

    function saveOutboundWebhookModal() {
        const name = document.getElementById('outbound-webhook-name').value.trim();
        const url = document.getElementById('outbound-webhook-url').value.trim();

        if (!name || !url) {
            showToast('Please provide a name and outbound webhook URL.', 'error');
            return;
        }

        const triggers = [];
        document.querySelectorAll('.outbound-webhook-trigger-cb:checked').forEach(cb => {
            triggers.push(cb.value);
        });

        const sendData = [];
        document.querySelectorAll('.outbound-webhook-send-cb:checked').forEach(cb => {
            sendData.push(cb.value);
        });

        const webhookData = { name, url, triggers, sendData };

        if (editingWebhookIndex !== null) {
            globalOutboundWebhooks[editingWebhookIndex] = webhookData;
        } else {
            globalOutboundWebhooks.push(webhookData);
        }

        closeOutboundWebhookModal();
        postSettingsSave('outbound-webhooks', globalOutboundWebhooks);
        renderOutboundWebhooksTable();

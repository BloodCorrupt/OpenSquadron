    // 7. Whatsapp Flows Form Builder Logic
    function addFormElement(type) {
        const canvas = document.getElementById('wa-form-builder-canvas');
        const placeholder = document.getElementById('wa-form-builder-placeholder');
        if (placeholder) {
            placeholder.style.display = 'none';
        }

        const elId = 'elem_' + Math.random().toString(36).substr(2, 9);
        const wrapper = document.createElement('div');
        wrapper.className = 'wa-form-element';
        wrapper.id = elId;
        wrapper.style.cssText = 'background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 15px; position: relative; cursor: grab;';
        
        let contentHtml = '';
        if (type === 'text') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Text Input</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%; margin-bottom:8px;">
                <input type="text" class="glass-input" placeholder="Placeholder text" style="width:100%; font-size:12px; color:rgba(255,255,255,0.5);">
            `;
        } else if (type === 'number') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Number Input</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%; margin-bottom:8px;">
                <input type="text" class="glass-input" placeholder="Placeholder text" style="width:100%; font-size:12px; color:rgba(255,255,255,0.5);">
            `;
        } else if (type === 'email') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Email Input</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%; margin-bottom:8px;">
            `;
        } else if (type === 'radio') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Radio Group</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%; margin-bottom:8px;">
                <textarea class="glass-input" placeholder="Options (one per line)" style="width:100%; min-height:60px; font-size:12px; color:rgba(255,255,255,0.8);"></textarea>
            `;
        } else if (type === 'checkbox') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Checkbox Group</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%; margin-bottom:8px;">
                <textarea class="glass-input" placeholder="Options (one per line)" style="width:100%; min-height:60px; font-size:12px; color:rgba(255,255,255,0.8);"></textarea>
            `;
        } else if (type === 'dropdown') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Dropdown</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%; margin-bottom:8px;">
                <textarea class="glass-input" placeholder="Options (one per line)" style="width:100%; min-height:60px; font-size:12px; color:rgba(255,255,255,0.8);"></textarea>
            `;
        } else if (type === 'date') {
            contentHtml = `
                <div style="font-weight:600; margin-bottom:10px; color:#fff;">Date Picker</div>
                <input type="text" class="glass-input" placeholder="Field Label" style="width:100%;">
            `;
        }

        wrapper.innerHTML = `
            <div style="position:absolute; top:10px; right:10px; cursor:pointer; color:rgba(255,255,255,0.5);" onclick="this.parentElement.remove(); checkEmptyBuilder();">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </div>
            ${contentHtml}
            <div style="margin-top:10px; display:flex; align-items:center; gap:8px;">
                <label class="switch-toggle" style="margin:0;">
                    <input type="checkbox">
                    <span class="slider-round"></span>
                </label>
                <span style="font-size:12px; color:rgba(255,255,255,0.6);">Required field</span>
            </div>
        `;
        canvas.appendChild(wrapper);
    }

    function checkEmptyBuilder() {
        const canvas = document.getElementById('wa-form-builder-canvas');
        if (canvas.querySelectorAll('.wa-form-element').length === 0) {
            const placeholder = document.getElementById('wa-form-builder-placeholder');
            if (placeholder) placeholder.style.display = 'block';
        }
    }

    function clearFormBuilder() {
        if(confirm('Are you sure you want to clear the form canvas?')) {
            const canvas = document.getElementById('wa-form-builder-canvas');
            canvas.querySelectorAll('.wa-form-element').forEach(el => el.remove());
            checkEmptyBuilder();
        }
    }


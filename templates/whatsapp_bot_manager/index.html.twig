    function insertVar(variable) {
        const ta = document.getElementById('tpl-body');
        const start = ta.selectionStart, end = ta.selectionEnd;
        ta.value = ta.value.substring(0, start) + variable + ta.value.substring(end);
        ta.selectionStart = ta.selectionEnd = start + variable.length;
        ta.focus();
        updateCount();
    }

    function showNotice(pane, type, msg) {
        const el = document.getElementById(pane + '-notice');
        el.className = 'notice-box ' + type;
        el.textContent = msg;
        el.style.display = 'block';
        el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function getCustomComponents() {
        const type = document.getElementById('tpl-type').value;
        if (type === 'default') return null;

        const components = [];

        if (type === 'mixed') {
            const bodyText = document.getElementById('mixed-body').value.trim();
            const headerType = document.getElementById('mixed-header-type').value;
            const headerVal = document.getElementById('mixed-header-value').value.trim();
            const footerText = document.getElementById('mixed-footer').value.trim();
            
            // Add Header
            if (headerVal) {
                if (headerType === 'TEXT') {
                    components.push({
                        type: 'HEADER',
                        format: 'TEXT',
                        text: headerVal
                    });
                } else {
                    components.push({
                        type: 'HEADER',
                        format: headerType,
                        example: {
                            header_handle: [headerVal]
                        }
                    });
                }
            }

            // Add Body
            components.push({
                type: 'BODY',
                text: bodyText
            });

            // Add Footer
            if (footerText) {
                components.push({
                    type: 'FOOTER',
                    text: footerText
                });
            }

            // Add Buttons
            const buttons = [];
            document.querySelectorAll('.mixed-btn-row').forEach(row => {
                const bText = row.querySelector('.btn-text').value.trim();
                const bType = row.querySelector('select.btn-type').value;
                const bVal = row.querySelector('.btn-value').value.trim();
                
                if (bText) {
                    if (bType === 'QUICK_REPLY') {
                        buttons.push({ type: 'QUICK_REPLY', text: bText });
                    } else if (bType === 'URL') {
                        buttons.push({ type: 'URL', text: bText, url: bVal });
                    }
                }
            });
            if (buttons.length > 0) {
                components.push({
                    type: 'BUTTONS',
                    buttons: buttons
                });
            }
        } else if (type === 'wp') {
            const bodyText = document.getElementById('wp-body').value.trim();
            const wpUrl = document.getElementById('wp-url').value.trim();
            const btnLabel = document.getElementById('wp-btn-label').value.trim() || 'View Post';

            components.push({
                type: 'BODY',
                text: bodyText
            });

            components.push({
                type: 'BUTTONS',
                buttons: [
                    {
                        type: 'URL',
                        text: btnLabel,
                        url: wpUrl
                    }
                ]
            });
        } else if (type === 'carousel_media') {
            const cards = [];
            document.querySelectorAll('.carousel-card-item').forEach(cardRow => {
                const imgUrl = cardRow.querySelector('.card-image-url').value.trim();
                const bodyText = cardRow.querySelector('.card-body-text').value.trim();
                const btnLabel = cardRow.querySelector('.card-btn-text').value.trim();
                
                const cardComponents = [];
                if (imgUrl) {
                    cardComponents.push({
                        type: 'HEADER',
                        format: 'IMAGE',
                        example: {
                            header_handle: [imgUrl]
                        }
                    });
                }
                cardComponents.push({
                    type: 'BODY',
                    text: bodyText
                });
                if (btnLabel) {
                    cardComponents.push({
                        type: 'BUTTONS',
                        buttons: [
                            { type: 'QUICK_REPLY', text: btnLabel }
                        ]
                    });
                }
                cards.push({ components: cardComponents });
            });
            components.push({
                type: 'CAROUSEL',
                cards: cards
            });
        } else if (type === 'carousel_product') {
            const catalogId = document.getElementById('catalog-id').value.trim();
            const cards = [];
            document.querySelectorAll('.product-card-item').forEach(cardRow => {
                const retailerId = cardRow.querySelector('.retailer-id').value.trim();
                const cardComponents = [
                    {
                        type: 'BODY',
                        text: 'Check out our featured product!'
                    }
                ];
                cards.push({ retailer_id: retailerId, components: cardComponents });
            });
            components.push({
                type: 'CAROUSEL',
                cards: cards
            });
        }

        return components;
    }

    function submitTemplate() {
        const type     = document.getElementById('tpl-type').value;
        const name     = document.getElementById('tpl-name').value.trim();
        const category = document.getElementById('tpl-category').value;
        const language = document.getElementById('tpl-language').value;

        if (!name) {
            showNotice('modal', 'error', 'Template name is required.');
            return;
        }

        const customComponents = getCustomComponents();
        let body = '';
        let header = '';
        let footer = '';

        if (type === 'default') {
            header = document.getElementById('tpl-header').value.trim();
            body   = document.getElementById('tpl-body').value.trim();
            footer = document.getElementById('tpl-footer').value.trim();

            if (!body) {
                showNotice('modal', 'error', 'Body text is required.');
                return;
            }
        } else {
            // For custom ones, make sure they filled out required parts
            if (customComponents.length === 0) {
                showNotice('modal', 'error', 'Please complete the custom template configuration fields.');
                return;
            }
            body = 'CUSTOM_PAYLOAD'; // dummy body for simple DB storage
        }

        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<svg style="animation:spin 1s linear infinite; margin-right: 6px;" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg> Submitting...';

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);
        formData.append('name', name);
        formData.append('category', category);
        formData.append('language', language);
        formData.append('header', header);
        formData.append('body', body);
        formData.append('footer', footer);

        if (customComponents) {
            formData.append('customComponents', JSON.stringify(customComponents));
        }

        fetch('{{ path('app_whatsapp_bot_templates_create') }}', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeTemplateModal();
                    showNotice('templates', 'success', data.message + ' Refreshing list in 2 seconds...');
                    setTimeout(() => window.location.reload(), 2000);
                } else {
                    showNotice('modal', 'error', 'Error: ' + data.error);
                }
            })
            .catch(() => showNotice('modal', 'error', 'An unexpected error occurred.'))
            .finally(() => {
                btn.disabled = false;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg> Submit to Meta';
            });
    }

    function syncTemplates() {
        const btn = document.getElementById('syncBtn');
        btn.classList.add('loading');
        btn.disabled = true;

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);

        fetch('{{ path('app_whatsapp_bot_templates_sync') }}', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotice('templates', 'success', data.message);
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showNotice('templates', 'error', 'Sync failed: ' + data.error);
                }
            })
            .catch(() => showNotice('templates', 'error', 'An error occurred during sync.'))
            .finally(() => {
                btn.classList.remove('loading');
                btn.disabled = false;
            });
    }


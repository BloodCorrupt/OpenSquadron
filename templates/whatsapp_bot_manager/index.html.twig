    {# 8. Action Button Presets Content Pane #}
    <div class="manager-content-pane" id="pane-action-buttons">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                    <span>Action Button Settings</span>
                </h1>
                <div class="content-subtitle">Configure automated quick-action templates and system-level event responders.</div>
            </div>
            
            <div class="dropdown-options-container" style="position: relative; display: inline-block;">
                <button class="btn-action btn-secondary" onclick="toggleOptionsDropdown(event)" style="display:flex; align-items:center; gap:8px;">
                    <span>Options</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
                <div id="options-dropdown-menu" style="display:none; position: absolute; right:0; top:42px; background: rgba(15, 23, 42, 0.95); border: 1px solid var(--glass-border); border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.5); z-index:100; min-width: 180px; padding: 6px 0;">
                    <a href="javascript:void(0)" onclick="bulkTogglePresets(true)" style="display:block; padding: 10px 16px; color:#fff; font-size:13px; text-decoration:none; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.background='transparent'">Enable All Presets</a>
                    <a href="javascript:void(0)" onclick="bulkTogglePresets(false)" style="display:block; padding: 10px 16px; color:#fff; font-size:13px; text-decoration:none; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.background='transparent'">Disable All Presets</a>
                </div>
            </div>
        </div>

        <div class="preview-container">
            <div class="form-side" style="width:60%; display:flex; flex-direction:column; gap:20px;">
                <div class="presets-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 15px; width: 100%;">
                    {% for item in actionButtons %}
                    <div class="preset-card {% if item.isEnabled %}is-active{% endif %}" data-key="{{ item.buttonKey }}" onclick="openPresetConfig('{{ item.buttonKey }}')" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 18px 16px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; transition: all 0.25s ease; position: relative;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div class="preset-icon-wrapper" style="width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s;
                                {% if item.isEnabled %}
                                    background: rgba(18, 140, 126, 0.15); color: #128c7e; border: 1px solid rgba(18, 140, 126, 0.25);
                                {% else %}
                                    background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.05);
                                {% endif %}">
                                {% if item.buttonKey == 'get-started' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width: 16px; height: 16px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                {% elseif item.buttonKey == 'no-match' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><path d="M18.85 15.08a9 9 0 0 0-2.28-7.57M13.73 21a2 2 0 0 1-3.46 0M3 3l18 18M9 9v0a6 6 0 0 0 6 6v0M4.27 4.27a6 6 0 0 0 0 7.46"></path></svg>
                                {% elseif item.buttonKey == 'location-reply' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                {% elseif item.buttonKey == 'unsubscribe' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                                {% elseif item.buttonKey == 'resubscribe' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                                {% elseif item.buttonKey == 'chat-with-human' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
                                {% elseif item.buttonKey == 'chat-with-bot' %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4M8 16h.01M16 16h.01M9 2v3M15 2v3"></path></svg>
                                {% endif %}
                            </div>
                            <div>
                                <div class="preset-label" style="font-weight: 600; color: #fff; font-size: 13px; margin-bottom: 2px;">{{ item.buttonLabel }}</div>
                                <div style="font-size: 11px; color: var(--text-muted);">
                                    {% if item.replyType == 'flow' %}
                                        Triggers Chat Flow
                                    {% elseif item.replyType == 'text' %}
                                        Sends Text Reply
                                    {% else %}
                                        No action configured
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        
                        <label class="switch-toggle" onclick="event.stopPropagation();" style="margin: 0;">
                            <input type="checkbox" class="preset-toggle" data-key="{{ item.buttonKey }}" {% if item.isEnabled %}checked{% endif %} onchange="togglePresetActive('{{ item.buttonKey }}', this.checked)">
                            <span class="slider-round"></span>
                        </label>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <!-- WhatsApp Chat Preview with Interactive Buttons -->
            <div class="preview-side" style="width:35%;">
                <div class="form-label">WhatsApp Live Mock Preview</div>
                <div class="iphone-shell">
                    <div class="iphone-header">
                        <div class="wa-avatar">OS</div>
                        <span>{{ connection ? connection.label ?: 'WhatsApp Bot' : 'WhatsApp Bot' }}</span>
                    </div>
                    <div class="iphone-body">
                        <div class="iphone-content">
                            <!-- Template card preview -->
                            <div class="wa-bubble-received">
                                <div>Hi there! Please select an action option below:</div>
                                <div class="wa-bubble-time">10:42 AM</div>
                                
                                <div class="wa-interactive-buttons" id="preview-buttons-container">
                                    <!-- Dynamic buttons render here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Preset Configuration Modal -->
    <div class="glass-modal-backdrop" id="preset-config-modal-backdrop" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(10px); z-index: 1050; align-items: center; justify-content: center;">
        <div class="glass-form-card" style="width: 500px; padding: 25px; border-radius: 16px; border: 1px solid var(--glass-border); box-shadow: 0 15px 35px rgba(0,0,0,0.6); position: relative;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--glass-border); padding-bottom: 12px; margin-bottom: 20px;">
                <h3 style="font-size: 15px; font-weight: 700; color: #fff; margin: 0;" id="preset-modal-title">Configure Preset Button</h3>
                <button class="btn-row-action delete-action" onclick="closePresetConfigModal()" style="border:none; background:none; cursor:pointer; color:var(--text-muted);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </div>
            
            <input type="hidden" id="preset-edit-key">
            
            <div class="form-group" style="margin-bottom:15px;">
                <label class="form-label">Button Status</label>
                <div style="display:flex; align-items:center; gap:10px;">
                    <label class="switch-toggle" style="margin: 0;">
                        <input type="checkbox" id="preset-edit-enabled">
                        <span class="slider-round"></span>
                    </label>
                    <span style="font-size:12px; color:var(--text-muted);">Enable action handler for this trigger event</span>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:15px;">
                <label class="form-label" for="preset-edit-label">Custom Button Label</label>
                <input type="text" id="preset-edit-label" class="glass-input" style="width:100%;">
            </div>

            <div class="form-group" style="margin-bottom:15px;">
                <label class="form-label" for="preset-edit-reply-type">Action Handler Type</label>
                <select id="preset-edit-reply-type" class="glass-input" style="width:100%;" onchange="togglePresetReplyFields()">
                    <option value="none">None (Disabled)</option>
                    <option value="flow">Trigger Bot Flow</option>
                    <option value="text">Send Reply Message</option>
                </select>
            </div>

            <div class="form-group" id="preset-flow-field-container" style="display:none; margin-bottom:15px;">
                <label class="form-label" for="preset-edit-flow">Target Chat Bot Flow</label>
                <select id="preset-edit-flow" class="glass-input" style="width:100%;">
                    <option value="">-- Select Flow --</option>
                    {% for flow in flows %}
                        {% if flow.isActive %}
                            <option value="{{ flow.id }}">{{ flow.name }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>

            <div class="form-group" id="preset-text-field-container" style="display:none; margin-bottom:15px;">
                <label class="form-label" for="preset-edit-text">Reply Text Message</label>
                <textarea id="preset-edit-text" class="glass-textarea" style="width:100%; height:80px;"></textarea>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px; border-top: 1px solid var(--glass-border); padding-top:15px;">
                <button class="btn-action btn-secondary" onclick="closePresetConfigModal()">Cancel</button>
                <button class="btn-action btn-create" onclick="savePresetConfig()">Save Configuration</button>
            </div>
        </div>
    </div>

    {# 9. eCommerce Automations Content Pane #}
    <div class="manager-content-pane" id="pane-ecommerce-automations">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                    <span>eCommerce Automations</span>
                </h1>
                <div class="content-subtitle">Connect WooCommerce and Shopify to automate cart recovery notifications and purchase details templates.</div>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 680px;">
            <!-- Abandoned Cart Configuration Card -->
            <div style="display: flex; flex-direction: column; gap: 15px; border-bottom: 1px solid var(--glass-border); padding-bottom: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Abandoned Cart Reminders</div>
                        <div class="form-helper">Toggle whether order cart abandonment triggers template reminders.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0;">
                        <input type="checkbox" id="cart-active" {% if settings['ecommerce-automations'].abandonedCartActive %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="cart-delay">Drip Timer Delay</label>
                        <select id="cart-delay" class="glass-input">
                            <option value="30 minutes" {% if settings['ecommerce-automations'].abandonedCartDelay == '30 minutes' %}selected{% endif %}>30 Minutes</option>
                            <option value="1 hour" {% if settings['ecommerce-automations'].abandonedCartDelay == '1 hour' %}selected{% endif %}>1 Hour</option>
                            <option value="24 hours" {% if settings['ecommerce-automations'].abandonedCartDelay == '24 hours' %}selected{% endif %}>24 Hours</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="cart-template">Selected Template</label>
                        <select id="cart-template" class="glass-input">
                            <option value="abandoned_cart_reminder" {% if settings['ecommerce-automations'].abandonedCartTemplate == 'abandoned_cart_reminder' %}selected{% endif %}>abandoned_cart_reminder</option>
                            {% for template in templates %}
                                <option value="{{ template.name }}" {% if settings['ecommerce-automations'].abandonedCartTemplate == template.name %}selected{% endif %}>{{ template.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>

            <!-- Order Confirmation Card -->
            <div style="display: flex; flex-direction: column; gap: 15px; padding-top: 10px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <div style="font-weight: 700; color: #fff; font-size: 14px;">Order Purchase Confirmations</div>
                        <div class="form-helper">Toggle order details updates push to client threads.</div>
                    </div>
                    <label class="switch-toggle" style="margin: 0;">
                        <input type="checkbox" id="order-active" {% if settings['ecommerce-automations'].orderConfirmationActive %}checked{% endif %}>
                        <span class="slider-round"></span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="form-label" for="order-template">Confirmation Template</label>
                    <select id="order-template" class="glass-input">
                        <option value="order_confirmation_official" {% if settings['ecommerce-automations'].orderConfirmationTemplate == 'order_confirmation_official' %}selected{% endif %}>order_confirmation_official</option>
                        {% for template in templates %}
                            <option value="{{ template.name }}" {% if settings['ecommerce-automations'].orderConfirmationTemplate == template.name %}selected{% endif %}>{{ template.name }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; margin-top: 10px;">
                <button class="btn-action btn-create" onclick="saveEcommerceAutomations()">Save eCommerce Config</button>
            </div>
        </div>
    </div>

    {# 10. Outbound Streams & Webhooks Content Pane #}
    <div class="manager-content-pane" id="pane-outbound-streams">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><circle cx="12" cy="19" r="2"></circle></svg>
                    <span>Outbound Streams & Webhooks</span>
                </h1>
                <div class="content-subtitle">Publish unified real-time conversation message payloads securely to your target external CRMs.</div>
            </div>
        </div>

        <div class="glass-form-card" style="max-width: 680px;">
            <div class="form-group">
                <label class="form-label" for="webhook-url">Target Stream Endpoint URL</label>
                <div class="form-helper" style="margin-bottom: 6px;">The server address where OpenSquadron will publish real-time HTTP POST JSON event updates.</div>
                <input type="url" id="webhook-url" class="glass-input" style="font-family:monospace;" placeholder="https://api.yourcrm.com/v1/webhook" value="{{ settings['outbound-streams'].webhookUrl }}">
            </div>

            <div class="form-group" style="margin-top:10px;">
                <label class="form-label">Subscribed Stream Events</label>
                <div class="form-helper" style="margin-bottom: 12px;">Toggle which event payloads are pushed to the target webhook stream.</div>
                
                <div style="display:flex; flex-direction:column; gap:12px; background:rgba(0,0,0,0.15); border-radius:8px; padding:15px; border:1px solid var(--glass-border);">
                    <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                        <input type="checkbox" class="webhook-event-cb" value="message_received" {% if 'message_received' in settings['outbound-streams'].activeEvents %}checked{% endif %} style="accent-color: var(--wa-primary);">
                        <span style="font-size:13px; color:#fff; font-weight:600;">Message Received (Incoming customer messages)</span>
                    </label>
                    <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                        <input type="checkbox" class="webhook-event-cb" value="message_sent" {% if 'message_sent' in settings['outbound-streams'].activeEvents %}checked{% endif %} style="accent-color: var(--wa-primary);">
                        <span style="font-size:13px; color:#fff; font-weight:600;">Message Sent (Bot response updates)</span>
                    </label>
                    <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                        <input type="checkbox" class="webhook-event-cb" value="opt_in" {% if 'opt_in' in settings['outbound-streams'].activeEvents %}checked{% endif %} style="accent-color: var(--wa-primary);">
                        <span style="font-size:13px; color:#fff; font-weight:600;">Opt In Triggered (Subscriber opt-ins)</span>
                    </label>
                    <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                        <input type="checkbox" class="webhook-event-cb" value="opt_out" {% if 'opt_out' in settings['outbound-streams'].activeEvents %}checked{% endif %} style="accent-color: var(--wa-primary);">
                        <span style="font-size:13px; color:#fff; font-weight:600;">Opt Out Triggered (Subscriber unsubscribes)</span>
                    </label>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end;">
                <button class="btn-action btn-create" onclick="saveOutboundStreams()">Save Webhook Stream</button>
            </div>
        </div>
    </div>

    {# 11. Growth & Web Widgets Content Pane #}
    <div class="manager-content-pane" id="pane-growth-widgets">
        <div class="content-header">
            <div>
                <h1 class="content-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                    <span>Growth & Web Widgets</span>
                </h1>
                <div class="content-subtitle">Deploy custom floating chat bubbles and click-to-chat QR code plugins on external websites.</div>
            </div>
        </div>

        <div class="preview-container">
            <div class="form-side glass-form-card">
                <div class="form-group">
                    <label class="form-label" for="widget-phone">WhatsApp Target Phone Number</label>
                    <input type="text" id="widget-phone" class="glass-input" value="{{ settings['growth-widgets'].phoneNumber }}" oninput="updateWidgetPreview()">
                </div>

                <div class="form-group">
                    <label class="form-label" for="widget-welcome">Welcome Message Bubble Text</label>
                    <textarea id="widget-welcome" class="glass-textarea" oninput="updateWidgetPreview()">{{ settings['growth-widgets'].welcomeMessage }}</textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="widget-color">Widget Accent Color</label>
                        <input type="color" id="widget-color" class="glass-input" style="height:42px; padding:4px;" value="{{ settings['growth-widgets'].bubbleColor }}" oninput="updateWidgetPreview()">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="widget-position">Widget Float Position</label>
                        <select id="widget-position" class="glass-input" onchange="updateWidgetPreview()">
                            <option value="right" {% if settings['growth-widgets'].position == 'right' %}selected{% endif %}>Right Side Float</option>
                            <option value="left" {% if settings['growth-widgets'].position == 'left' %}selected{% endif %}>Left Side Float</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Integration Embed Script Code</label>
                    <textarea class="glass-textarea" style="font-family:monospace; font-size:11px;" readonly id="widget-embed-code"></textarea>
                </div>

                <div style="display:flex; justify-content:flex-end;">
                    <button class="btn-action btn-create" onclick="saveGrowthWidgets()">Save Widget Config</button>
                </div>
            </div>

            <!-- Custom Website Live Mock Preview -->
            <div class="preview-side">
                <div class="form-label">Interactive Website Preview</div>
                <div style="width: 270px; height: 380px; border-radius: 12px; border:1px solid var(--glass-border); background: #0f172a; display:flex; flex-direction:column; justify-content:space-between; position:relative; overflow:hidden; padding:15px; box-shadow: 0 10px 25px rgba(0,0,0,0.3);">
                    <!-- Header -->
                    <div style="display:flex; align-items:center; gap:8px; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:10px;">
                        <div style="width:10px; height:10px; border-radius:50%; background:#ef4444;"></div>
                        <div style="width:10px; height:10px; border-radius:50%; background:#f59e0b;"></div>
                        <div style="width:10px; height:10px; border-radius:50%; background:#10b981;"></div>
                        <span style="font-size:10px; color:var(--text-muted); margin-left:10px; font-family:monospace;">yoursite.com</span>
                    </div>
                    <!-- Body -->
                    <div style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; padding:10px; gap:8px;">
                        <h4 style="color:#fff; font-size:13px; margin:0;">Home Page Mockup</h4>
                        <p style="color:var(--text-muted); font-size:10px; line-height:1.4;">Floating chat widgets render at the bottom of target websites, prompting customer click-to-chats.</p>
                    </div>
                    
                    <!-- Floating Widget bubble -->
                    <div id="mock-floating-widget" class="mock-floating-bubble">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px; height:18px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

{# ───────── Create Template Modal Overlay ───────── #}
<div class="modal-overlay" id="createTemplateModal">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Create Message Template</h2>
            <button class="modal-close" onclick="closeTemplateModal()">&times;</button>
        </div>

        <div style="background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.2); border-radius: 8px; padding: 12px 14px; margin-bottom: 20px; font-size: 13px; color: #94a3b8; line-height: 1.4;">
            <strong style="color: var(--wa-primary);">Note:</strong> Templates require Meta review before they can be used. UTILITY templates are typically approved within minutes.
        </div>

        <div class="notice-box" id="modal-notice"></div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" for="tpl-name">Template Name <span>*</span></label>
                <input type="text" id="tpl-name" class="form-control" placeholder="e.g. order_confirmation" oninput="this.value = this.value.toLowerCase().replace(/[^a-z0-9_]/g,'')">
                <p class="form-hint">Lowercase letters, numbers, underscores only.</p>
            </div>
            <div class="form-group">
                <label class="form-label" for="tpl-category">Category <span>*</span></label>
                <select id="tpl-category" class="form-control">
                    <option value="UTILITY">UTILITY</option>
                    <option value="MARKETING">MARKETING</option>
                    <option value="AUTHENTICATION">AUTHENTICATION</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" for="tpl-language">Language <span>*</span></label>
            <select id="tpl-language" class="form-control">
                <option value="en_US">English (US)</option>
                <option value="en_GB">English (UK)</option>
                <option value="ar">Arabic</option>
                <option value="es">Spanish</option>
                <option value="hi">Hindi</option>
                <option value="bn">Bengali</option>
                <option value="pt_BR">Portuguese (Brazil)</option>
                <option value="fr">French</option>
                <option value="id">Indonesian</option>
                <option value="tr">Turkish</option>
                <option value="zh_CN">Chinese (Simplified)</option>
                <option value="ur">Urdu</option>
            </select>
        </div>

        <input type="hidden" id="tpl-type" value="default">

        <div id="default-template-fields">
            <div class="form-group">
                <label class="form-label" for="tpl-header">Header <small style="font-weight:400; opacity: 0.6;">(optional)</small></label>
                <input type="text" id="tpl-header" class="form-control" placeholder="e.g. Order Update" maxlength="60">
            </div>

            <div class="form-group">
                <label class="form-label" for="tpl-body">Body Text <span>*</span></label>
                <textarea id="tpl-body" class="form-control" placeholder="Type your message here. Use {{1}}, {{2}} for variables." maxlength="1024" oninput="updateCount()"></textarea>
                <div class="char-count"><span id="bodyCount">0</span> / 1024</div>
                <div class="var-hint">
                    <span style="font-size: 12px; color: #64748b; margin-right: 4px;">Insert variable:</span>
                    <span class="var-chip" onclick="insertVar('{{1}}')">{{1}}</span>
                    <span class="var-chip" onclick="insertVar('{{2}}')">{{2}}</span>
                    <span class="var-chip" onclick="insertVar('{{3}}')">{{3}}</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="tpl-footer">Footer <small style="font-weight:400; opacity: 0.6;">(optional)</small></label>
                <input type="text" id="tpl-footer" class="form-control" placeholder="e.g. Reply STOP to unsubscribe" maxlength="60">
            </div>
        </div>

        <div id="custom-template-fields" style="display: none; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border); border-radius: 12px; padding: 16px; margin-bottom: 20px;">
            <!-- Rendered dynamically by javascript -->
        </div>

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeTemplateModal()">Cancel</button>
            <button class="btn-action btn-create" id="submitBtn" onclick="submitTemplate()">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                Submit to Meta
            </button>
        </div>
    </div>
</div>

<div id="toast" class="fb-toast">Message</div>

<script>
    const activeConnectionId = '{{ connection ? connection.id : "" }}';
    let sequencesList = {{ sequences|json_encode|raw }};

    function showToast(msg, type = 'success') {
        const el = document.getElementById('toast');
        el.textContent = msg;
        el.className = 'fb-toast is-shown ' + (type === 'success' ? 'is-success' : 'is-error');
        setTimeout(() => el.classList.remove('is-shown'), 3000);
    }

    // Save Settings AJAX Helper
    function postSettingsSave(type, dataStructure) {
        if (!activeConnectionId) {
            showToast('Please connect a WhatsApp account first.', 'error');
            return;
        }

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);
        formData.append('type', type);
        formData.append('data', JSON.stringify(dataStructure));

        fetch('{{ path('app_whatsapp_bot_save_settings') }}', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Settings saved successfully!', 'success');
            } else {
                showToast('Failed to save settings: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Save error: ' + err.message, 'error'));
    }

    // 3. Broadcast Campaigns Saver
    function addBroadcastRow() {
        const tr = document.createElement('tr');
        tr.className = 'broadcast-row';
        tr.innerHTML = `
            <td><input type="text" class="glass-input bc-name" style="width:100%"></td>
            <td>
                <select class="glass-input bc-template" style="width:100%">
                    <option value="monthly_newsletter" selected>monthly_newsletter (UTILITY)</option>
                    <option value="flash_sale">flash_sale (MARKETING)</option>
                    {% for template in templates %}
                        <option value="{{ template.name }}">{{ template.name }} ({{ template.category }})</option>
                    {% endfor %}
                </select>
            </td>
            <td><span class="keyword-tag" style="background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.2); color: #f59e0b;">SCHEDULED</span></td>
            <td>0</td>
            <td>0</td>
            <td>
                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </td>
        `;
        document.querySelector('#broadcasts-table tbody').appendChild(tr);
    }

    function saveBroadcastCampaigns() {
        const rows = [];
        document.querySelectorAll('.broadcast-row').forEach(tr => {
            const name = tr.querySelector('.bc-name').value.trim();
            const template = tr.querySelector('select.bc-template').value;
            if (name !== '') {
                rows.push({ name, template, status: 'SCHEDULED', sentCount: 0, deliveredCount: 0 });
            }
        });
        postSettingsSave('broadcast-campaigns', rows);
    }

    // 4. Drip Sequences Saver
    function addSequenceRow() {
        const tr = document.createElement('tr');
        tr.className = 'sequence-row';
        tr.innerHTML = `
            <td>
                <input type="hidden" class="seq-id" value="">
                <input type="text" class="glass-input seq-name" style="width:100%" placeholder="e.g. Campaign Name">
            </td>
            <td style="font-family: monospace; color: var(--wa-primary); font-weight: 600; vertical-align: middle;">
                0 steps
            </td>
            <td style="text-align: center; vertical-align: middle;">
                <label class="switch-toggle">
                    <input type="checkbox" class="seq-active" checked>
                    <span class="slider-round"></span>
                </label>
            </td>
            <td>
                <div class="row-actions" style="justify-content: flex-end;">
                    <span class="btn-row-action edit-action" title="Save first to build flow" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: var(--wa-primary); opacity: 0.4; cursor: not-allowed; background: rgba(255,255,255,0.02); transition: all 0.2s;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    </span>
                    <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()" title="Delete Sequence" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: #f87171; background: rgba(255,255,255,0.02); transition: all 0.2s;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; height: 14px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                    </button>
                </div>
            </td>
        `;
        document.querySelector('#sequences-table tbody').appendChild(tr);
    }

    function deleteSequenceById(seqId, rowEl) {
        if (!seqId) {
            rowEl.remove();
            return;
        }
        if (!confirm('Are you sure you want to delete this sequence?')) return;
        fetch('{{ path('app_whatsapp_bot_sequence_delete') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sequenceId: seqId })
        }).then(r => r.json()).then(data => {
            if (data.success) {
                rowEl.remove();
                sequencesList = sequencesList.filter(s => s.id != seqId);
                showToast('Sequence deleted successfully.', 'success');
            } else {
                showToast(data.error || 'Delete failed.', 'error');
            }
        }).catch(() => showToast('Network error deleting sequence.', 'error'));
    }

    function saveDripSequences() {
        const rows = document.querySelectorAll('.sequence-row');
        let pending = 0;
        let errors = 0;
        rows.forEach(tr => {
            const id = tr.querySelector('.seq-id').value;
            const name = tr.querySelector('.seq-name').value.trim();
            const isActive = tr.querySelector('.seq-active').checked;
            if (name === '') return;

            const existing = (sequencesList || []).find(s => String(s.id) === String(id));
            const payload = {
                connectionId: activeConnectionId,
                id: id || null,
                name: name,
                trigger: existing ? existing.trigger : 'NEW_SUBSCRIBER',
                preferredTime: existing ? existing.preferredTime : 'anytime',
                timezone: existing ? existing.timezone : 'UTC',
                messageTag: existing ? existing.messageTag : 'NON_PROMOTIONAL_SUBSCRIPTION',
                allowReentry: existing ? existing.allowReentry : false,
                isActive: isActive,
                graph: existing ? existing.graph : null
            };
            pending++;
            fetch('{{ path('app_whatsapp_bot_sequence_save') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(r => r.json()).then(data => {
                if (data.success && data.sequence) {
                    tr.querySelector('.seq-id').value = data.sequence.id;
                    const idx = sequencesList.findIndex(s => String(s.id) === String(data.sequence.id));
                    if (idx >= 0) {
                        sequencesList[idx] = data.sequence;
                    } else {
                        sequencesList.push(data.sequence);
                    }
                    // Refresh edit link
                    const actionsDiv = tr.querySelector('.row-actions');
                    const editEl = actionsDiv.querySelector('.edit-action');
                    if (editEl && editEl.tagName !== 'A') {
                        const a = document.createElement('a');
                        a.href = `{{ path('app_whatsapp_bot_sequence_builder') }}?id=${data.sequence.id}&connectionId=${activeConnectionId}`;
                        a.className = editEl.className;
                        a.title = 'Build Sequence Flow';
                        a.style.cssText = editEl.style.cssText;
                        a.style.opacity = '1';
                        a.style.cursor = 'pointer';
                        a.innerHTML = editEl.innerHTML;
                        editEl.replaceWith(a);
                    }
                } else {
                    errors++;
                }
                pending--;
                if (pending === 0) {
                    showToast(errors ? 'Some sequences failed to save.' : 'Sequences saved!', errors ? 'error' : 'success');
                }
            }).catch(() => {
                errors++;
                pending--;
                if (pending === 0) {
                    showToast('Network error saving sequences.', 'error');
                }
            });
        });
        if (pending === 0) {
            showToast('No sequences to save.', 'info');
        }
    }

    // 6. Captured Forms & Inputs Saver
    function addInputRow() {
        const tr = document.createElement('tr');
        tr.className = 'input-row';
        tr.innerHTML = `
            <td><input type="text" class="glass-input ui-name" style="width:100%; font-family:monospace;"></td>
            <td>
                <select class="glass-input ui-type" style="width:100%">
                    <option value="EMAIL" selected>Email Address</option>
                    <option value="TEXT">Free-form Text</option>
                    <option value="PHONE">Phone Number</option>
                    <option value="NUMBER">Numeric Value</option>
                </select>
            </td>
            <td><input type="text" class="glass-input ui-prompt" style="width:100%"></td>
            <td>
                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </td>
        `;
        document.querySelector('#inputs-table tbody').appendChild(tr);
    }

    function saveStructuredInputs() {
        const rows = [];
        document.querySelectorAll('.input-row').forEach(tr => {
            const fieldName = tr.querySelector('.ui-name').value.trim();
            const dataType = tr.querySelector('select.ui-type').value;
            const prompt = tr.querySelector('.ui-prompt').value.trim();
            if (fieldName !== '' && prompt !== '') {
                rows.push({ fieldName, dataType, prompt });
            }
        });
        postSettingsSave('structured-inputs', rows);
    }

    // 7. In-App Dynamic Flows Saver
    function addFlowRow() {
        const tr = document.createElement('tr');
        tr.className = 'flow-grid-row';
        tr.innerHTML = `
            <td><input type="text" class="glass-input df-name" style="width:100%"></td>
            <td><input type="text" class="glass-input df-id" style="width:100%; font-family:monospace;"></td>
            <td>
                <select class="glass-input df-status" style="width:100%">
                    <option value="PUBLISHED" selected>PUBLISHED</option>
                    <option value="DRAFT">DRAFT</option>
                </select>
            </td>
            <td>
                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </td>
        `;
        document.querySelector('#flows-grid-table tbody').appendChild(tr);
    }

    function saveDynamicFlows() {
        const rows = [];
        document.querySelectorAll('.flow-grid-row').forEach(tr => {
            const name = tr.querySelector('.df-name').value.trim();
            const flowId = tr.querySelector('.df-id').value.trim();
            const status = tr.querySelector('select.df-status').value;
            if (name !== '' && flowId !== '') {
                rows.push({ name, flowId, status });
            }
        });
        postSettingsSave('dynamic-flows', rows);
    }

    // 8. Action Buttons Saver & Live Previewer
    function addButtonRow() {
        const tr = document.createElement('tr');
        tr.className = 'btn-row';
        tr.innerHTML = `
            <td><input type="text" class="glass-input btn-label" style="width:100%" oninput="updateButtonsPreview()"></td>
            <td>
                <select class="glass-input btn-type" style="width:100%" onchange="updateButtonsPreview()">
                    <option value="quick_reply" selected>Quick Reply</option>
                    <option value="url">Web URL</option>
                </select>
            </td>
            <td><input type="text" class="glass-input btn-val" style="width:100%"></td>
            <td>
                <button class="btn-row-action delete-action" onclick="this.closest('tr').remove(); updateButtonsPreview();"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
            </td>
        `;
        document.querySelector('#buttons-table tbody').appendChild(tr);
        updateButtonsPreview();
    }

    // 8. Action Buttons Manager & Saver
    let globalActionButtons = {{ actionButtons|default([])|json_encode|raw }};

    function toggleOptionsDropdown(event) {
        event.stopPropagation();
        const menu = document.getElementById('options-dropdown-menu');
        if (menu) {
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
    }

    document.addEventListener('click', () => {
        const menu = document.getElementById('options-dropdown-menu');
        if (menu) menu.style.display = 'none';
    });

    function openPresetConfig(key) {
        const item = globalActionButtons.find(x => x.buttonKey === key);
        if (!item) return;

        document.getElementById('preset-edit-key').value = key;
        document.getElementById('preset-modal-title').textContent = `Configure Preset: ${item.buttonLabel}`;
        document.getElementById('preset-edit-enabled').checked = item.isEnabled;
        document.getElementById('preset-edit-label').value = item.buttonLabel;
        document.getElementById('preset-edit-reply-type').value = item.replyType;
        document.getElementById('preset-edit-flow').value = item.flowId || '';
        document.getElementById('preset-edit-text').value = item.replyText || '';

        togglePresetReplyFields();

        const modal = document.getElementById('preset-config-modal-backdrop');
        modal.style.display = 'flex';
    }

    function closePresetConfigModal() {
        document.getElementById('preset-config-modal-backdrop').style.display = 'none';
    }

    function togglePresetReplyFields() {
        const replyType = document.getElementById('preset-edit-reply-type').value;
        const flowContainer = document.getElementById('preset-flow-field-container');
        const textContainer = document.getElementById('preset-text-field-container');

        if (replyType === 'flow') {
            flowContainer.style.display = 'block';
            textContainer.style.display = 'none';
        } else if (replyType === 'text') {
            flowContainer.style.display = 'none';
            textContainer.style.display = 'block';
        } else {
            flowContainer.style.display = 'none';
            textContainer.style.display = 'none';
        }
    }

    function savePresetConfig() {
        const key = document.getElementById('preset-edit-key').value;
        const item = globalActionButtons.find(x => x.buttonKey === key);
        if (!item) return;

        item.isEnabled = document.getElementById('preset-edit-enabled').checked;
        item.buttonLabel = document.getElementById('preset-edit-label').value.trim();
        item.replyType = document.getElementById('preset-edit-reply-type').value;
        item.flowId = document.getElementById('preset-edit-flow').value ? parseInt(document.getElementById('preset-edit-flow').value) : null;
        item.replyText = document.getElementById('preset-edit-text').value.trim();

        if (item.replyType === 'flow' && !item.flowId) {
            showToast('Please select a target chat flow.', 'error');
            return;
        }
        if (item.replyType === 'text' && !item.replyText) {
            showToast('Please enter a reply message.', 'error');
            return;
        }

        // Update UI
        updatePresetCardUI(item);
        closePresetConfigModal();

        // Save
        saveActionButtonsBackend();
    }

    function togglePresetActive(key, isEnabled) {
        const item = globalActionButtons.find(x => x.buttonKey === key);
        if (!item) return;

        item.isEnabled = isEnabled;
        updatePresetCardUI(item);
        saveActionButtonsBackend();
    }

    function updatePresetCardUI(item) {
        const card = document.querySelector(`.preset-card[data-key="${item.buttonKey}"]`);
        if (!card) return;

        if (item.isEnabled) {
            card.classList.add('is-active');
        } else {
            card.classList.remove('is-active');
        }

        // Update card description text
        let desc = 'No action configured';
        if (item.replyType === 'flow') desc = 'Triggers Chat Flow';
        else if (item.replyType === 'text') desc = 'Sends Text Reply';
        card.querySelector('.preset-label').nextElementSibling.textContent = desc;

        // Update icon styling
        const iconWrapper = card.querySelector('.preset-icon-wrapper');
        if (item.isEnabled) {
            iconWrapper.style.background = 'rgba(18, 140, 126, 0.15)';
            iconWrapper.style.color = '#128c7e';
            iconWrapper.style.border = '1px solid rgba(18, 140, 126, 0.25)';
        } else {
            iconWrapper.style.background = 'rgba(255,255,255,0.03)';
            iconWrapper.style.color = 'rgba(255,255,255,0.3)';
            iconWrapper.style.border = '1px solid rgba(255,255,255,0.05)';
        }

        // Update toggle state
        const toggle = card.querySelector('.preset-toggle');
        if (toggle) toggle.checked = item.isEnabled;

        // Refresh WhatsApp mock live preview
        updateButtonsPreview();
    }

    function updateButtonsPreview() {
        const container = document.getElementById('preview-buttons-container');
        if (!container) return;
        container.innerHTML = '';

        let count = 0;
        globalActionButtons.forEach(item => {
            if (item.isEnabled) {
                count++;
                const btnEl = document.createElement('div');
                btnEl.className = 'wa-btn';
                btnEl.innerHTML = (item.replyType === 'flow' ? '💬 ' : '🔗 ') + item.buttonLabel;
                container.appendChild(btnEl);
            }
        });

        if (count === 0) {
            const btnEl = document.createElement('div');
            btnEl.className = 'wa-btn';
            btnEl.style.color = 'rgba(255,255,255,0.2)';
            btnEl.innerHTML = 'No active options';
            container.appendChild(btnEl);
        }
    }

    function bulkTogglePresets(isEnabled) {
        globalActionButtons.forEach(item => {
            item.isEnabled = isEnabled;
            updatePresetCardUI(item);
        });
        saveActionButtonsBackend();
    }

    function saveActionButtonsBackend() {
        if (!activeConnectionId) {
            showToast('Please connect a WhatsApp connection first.', 'error');
            return;
        }

        const formData = new FormData();
        formData.append('connectionId', activeConnectionId);
        formData.append('data', JSON.stringify(globalActionButtons));

        fetch('/whatsapp-bot-manager/action-buttons/save', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Action button configurations saved!', 'success');
            } else {
                showToast('Failed to save settings: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Save error: ' + err.message, 'error'));
    }

    // Initialize mock preview on document load
    document.addEventListener('DOMContentLoaded', () => {
        updateButtonsPreview();
    });

    // 9. eCommerce Automations Saver
    function saveEcommerceAutomations() {
        const abandonedCartActive = document.getElementById('cart-active').checked;
        const abandonedCartDelay = document.getElementById('cart-delay').value;
        const abandonedCartTemplate = document.getElementById('cart-template').value;
        const orderConfirmationActive = document.getElementById('order-active').checked;
        const orderConfirmationTemplate = document.getElementById('order-template').value;
        postSettingsSave('ecommerce-automations', { abandonedCartActive, abandonedCartDelay, abandonedCartTemplate, orderConfirmationActive, orderConfirmationTemplate });
    }

    // 10. Outbound Streams Saver
    function saveOutboundStreams() {
        const webhookUrl = document.getElementById('webhook-url').value.trim();
        const activeEvents = [];
        document.querySelectorAll('.webhook-event-cb:checked').forEach(cb => {
            activeEvents.push(cb.value);
        });
        postSettingsSave('outbound-streams', { webhookUrl, activeEvents });
    }

    // 11. Growth Widget Previewer & Saver
    function updateWidgetPreview() {
        const phone = document.getElementById('widget-phone').value;
        const welcome = document.getElementById('widget-welcome').value;
        const color = document.getElementById('widget-color').value;
        const pos = document.getElementById('widget-position').value;

        const bubble = document.getElementById('mock-floating-widget');
        if (bubble) {
            bubble.style.backgroundColor = color;
            if (pos === 'left') {
                bubble.style.left = '15px';
                bubble.style.right = 'auto';
            } else {
                bubble.style.right = '15px';
                bubble.style.left = 'auto';
            }
        }

        const embedCode = `<!-- OpenSquadron WhatsApp Growth Widget Embed -->\n<div class="opensquadron-whatsapp-widget"\n  data-connection-id="${activeConnectionId}"\n  data-phone="${phone}"\n  data-welcome="${welcome.replace(/"/g, '&quot;')}"\n  data-color="${color}"\n  data-position="${pos}">\n</div>\n<script src="https://opensquadron.io/js/whatsapp-widget.js" async defer><\/script>`;
        const textarea = document.getElementById('widget-embed-code');
        if (textarea) textarea.value = embedCode;
    }

    function saveGrowthWidgets() {
        const phoneNumber = document.getElementById('widget-phone').value.trim();
        const welcomeMessage = document.getElementById('widget-welcome').value.trim();
        const bubbleColor = document.getElementById('widget-color').value;
        const position = document.getElementById('widget-position').value;
        const embedCode = document.getElementById('widget-embed-code').value;
        postSettingsSave('growth-widgets', { phoneNumber, welcomeMessage, bubbleColor, position, embedCode });
    }

    // ───────── Tab Switcher Logic ─────────
    function switchTab(tabId) {
        // Toggle Nav Items
        document.querySelectorAll('.manager-nav .nav-item[data-tab-target]').forEach(el => {
            if (el.getAttribute('data-tab-target') === tabId) {
                el.classList.add('is-active');
            } else {
                el.classList.remove('is-active');
            }
        });

        // Toggle Content Panes
        document.querySelectorAll('.manager-content-pane').forEach(el => {
            if (el.id === 'pane-' + tabId) {
                el.classList.add('is-active');
                el.style.display = 'flex';
            } else {
                el.classList.remove('is-active');
                el.style.display = 'none';
            }
        });

        // Trigger previews when tab is opened
        if (tabId === 'growth-widgets') {
            updateWidgetPreview();
        } else if (tabId === 'action-buttons') {
            updateButtonsPreview();
        }

        // Save selection to URL params
        const url = new URL(window.location);
        url.searchParams.set('tab', tabId);
        window.history.replaceState({}, '', url);
    }

    // Set active tab on load
    document.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const tab = params.get('tab') || 'console';
        switchTab(tab);
    });

    // Wire click listeners
    document.querySelectorAll('.manager-nav .nav-item[data-tab-target]').forEach(el => {
        el.addEventListener('click', () => {
            if (el.classList.contains('is-disabled')) return;
            switchTab(el.getAttribute('data-tab-target'));
        });
    });

    // ───────── Bot Reply Logic ─────────
    function toggleFlowStatus(id, active) {
        fetch(`/whatsapp-bot-manager/flows/${id}/toggle`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isActive: active })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast(active ? 'Flow enabled successfully.' : 'Flow disabled successfully.', 'success');
            } else {
                showToast('Failed to toggle status: ' + (data.error || 'Unknown error'), 'error');
                const checkbox = document.querySelector(`.flow-row[data-flow-id="${id}"] .switch-toggle input`);
                if (checkbox) checkbox.checked = !active;
            }
        })
        .catch(err => {
            showToast('Toggle error: ' + err.message, 'error');
            const checkbox = document.querySelector(`.flow-row[data-flow-id="${id}"] .switch-toggle input`);
            if (checkbox) checkbox.checked = !active;
        });
    }

    function cloneFlow(id) {
        if (!confirm('Are you sure you want to clone this flow?')) return;
        
        fetch(`/whatsapp-bot-manager/flows/${id}/clone`, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Flow cloned successfully!', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast('Clone failed: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Clone error: ' + err.message, 'error'));
    }

    function deleteFlow(id) {
        if (!confirm('Are you sure you want to delete this flow? This action is irreversible.')) return;
        
        fetch(`/whatsapp-bot-manager/flows/${id}/delete`, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showToast('Flow deleted successfully!', 'success');
                const row = document.querySelector(`.flow-row[data-flow-id="${id}"]`);
                if (row) {
                    row.remove();
                    const remaining = document.querySelectorAll('.flow-row');
                    if (remaining.length === 0) {
                        window.location.reload();
                    }
                }
            } else {
                showToast('Delete failed: ' + (data.error || 'Unknown error'), 'error');
            }
        })
        .catch(err => showToast('Delete error: ' + err.message, 'error'));
    }

    // Search filter interaction
    const flowSearchInput = document.getElementById('flow-search');
    if (flowSearchInput) {
        flowSearchInput.oninput = (e) => {
            const q = e.target.value.toLowerCase().trim();
            document.querySelectorAll('.flow-row').forEach(row => {
                const name = row.querySelector('td:nth-child(3)').textContent.toLowerCase();
                const keywords = row.querySelector('td:nth-child(4)').textContent.toLowerCase();
                if (name.includes(q) || keywords.includes(q)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        };
    }

    // ───────── Dropdown Toggling Logic ─────────
    document.addEventListener('DOMContentLoaded', () => {
        const trigger = document.getElementById('btn-create-dropdown-trigger');
        const dropdown = document.getElementById('create-template-dropdown');

        if (trigger && dropdown) {
            trigger.addEventListener('click', (e) => {
                e.stopPropagation();
                const isShown = dropdown.style.display === 'block';
                dropdown.style.display = isShown ? 'none' : 'block';
            });

            document.addEventListener('click', (e) => {
                if (!trigger.contains(e.target) && !dropdown.contains(e.target)) {
                    dropdown.style.display = 'none';
                }
            });
        }

        // Mobile Sidebar Toggling Logic
        const navToggle = document.querySelector('.sidebar-mobile-toggle');
        const managerNav = document.querySelector('.manager-nav');
        if (navToggle && managerNav) {
            navToggle.addEventListener('click', () => {
                managerNav.classList.toggle('is-open');
            });
            // Also close it when a menu option (nav-item) is clicked
            document.querySelectorAll('.manager-nav .nav-item').forEach(item => {
                item.addEventListener('click', () => {
                    managerNav.classList.remove('is-open');
                });
            });
        }
    });


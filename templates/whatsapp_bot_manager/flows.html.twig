<div class="fb-toast" id="fb-toast"></div>

{# Persistence JSON payload blocks #}
<script id="fb-flows-data" type="application/json">{{ flowsJson|json_encode|raw }}</script>
<script id="fb-templates-data" type="application/json">
[
{% for tpl in templates %}
    {"name": {{ tpl.name|json_encode|raw }}, "language": {{ tpl.language|json_encode|raw }}}{% if not loop.last %},{% endif %}
{% endfor %}
]
</script>

{# ───────── Flow Canvas Javascript Application ───────── #}
<script>
(function(){
    'use strict';

    // ───────── State Machine ─────────
    const state = {
        flows: JSON.parse(document.getElementById('fb-flows-data').textContent || '[]'),
        templates: JSON.parse(document.getElementById('fb-templates-data').textContent || '[]'),
        customFields: [],
        currentId: null,
        meta: { name: 'Untitled flow', keywords: '', matchMode: 'exact', isActive: true },
        nodes: new Map(),   // id -> { id, type, x, y, data }
        edges: [],          // [{ id, source, sourceHandle, target, targetHandle }]
        selection: { node: null, edge: null },
        viewport: { x: 80, y: 100, scale: 1 },
        nextId: 1,
        connecting: null,   // { fromId, fromPortId, startX, startY, curX, curY }
        ctxMenuOrigin: null, // { fromId, fromPortId, canvasX, canvasY }
        dirty: false,
    };

    const SAVE_URL = '{{ path('app_whatsapp_bot_flows_save') }}';
    const DELETE_URL_TEMPLATE = '{{ path('app_whatsapp_bot_flows_delete', {id: 0}) }}';

    // ─── Blocks Catalog definitions ───
    const BLOCKS = {
        start: {
            label: 'Flow Entry Point',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>',
            defaults: {},
            render: () => `
                <div class="fb-node-meta-box">
                    <div class="meta-label">Bot trigger keywords</div>
                    <div class="meta-val" id="node-meta-kw">--</div>
                    <div class="meta-label" style="margin-top:8px;">Keyword matching type</div>
                    <div class="meta-val" id="node-meta-match">Exact keyword match</div>
                </div>
            `,
            inspector: (d, onChange) => {
                const wrap = document.createDocumentFragment();

                const name = document.createElement('input');
                name.type = 'text'; name.className = 'fb-input';
                name.placeholder = 'My Flow Name';
                name.value = state.meta.name || '';
                name.oninput = () => {
                    state.meta.name = name.value;
                    state.dirty = true;
                };
                wrap.appendChild(wrapField('Flow Name', name));

                const kw = document.createElement('input');
                kw.type = 'text'; kw.className = 'fb-input';
                kw.placeholder = 'e.g. hi, hello';
                kw.value = state.meta.keywords || '';
                kw.oninput = () => {
                    state.meta.keywords = kw.value;
                    state.dirty = true;
                    const nodeKw = document.getElementById('node-meta-kw');
                    if (nodeKw) nodeKw.textContent = kw.value || 'None';
                };
                wrap.appendChild(wrapField('Trigger Keywords', kw, 'Comma separated keywords (e.g. hi, hello)'));

                const match = document.createElement('select');
                match.className = 'fb-select';
                match.innerHTML = `
                    <option value="exact">Exact keyword match</option>
                    <option value="contains">Contains match</option>
                    <option value="starts_with">Starts with match</option>
                `;
                match.value = state.meta.matchMode || 'exact';
                match.onchange = () => {
                    state.meta.matchMode = match.value;
                    state.dirty = true;
                    const nodeMatch = document.getElementById('node-meta-match');
                    if (nodeMatch) {
                        let label = 'Exact keyword match';
                        if (match.value === 'contains') label = 'Contains match';
                        else if (match.value === 'starts_with') label = 'Starts with match';
                        nodeMatch.textContent = label;
                    }
                };
                wrap.appendChild(wrapField('Matching Mode', match));

                const activeWrap = document.createElement('div');
                activeWrap.style.cssText = 'display:flex;align-items:center;gap:8px;margin-top:12px;';
                const act = document.createElement('input');
                act.type = 'checkbox';
                act.checked = state.meta.isActive;
                act.onchange = () => {
                    state.meta.isActive = act.checked;
                    state.dirty = true;
                };
                const actLbl = document.createElement('label');
                actLbl.textContent = 'Active and Enabled';
                actLbl.style.margin = '0';
                activeWrap.appendChild(act);
                activeWrap.appendChild(actLbl);
                wrap.appendChild(activeWrap);

                return wrap;
            },
        },
        send_text: {
            label: 'Message Body',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>',
            defaults: { text: '' },
            render: (d) => d.text
                ? '<div class="fb-node-preview">' + escapeHtml(d.text) + '</div>'
                : '<div class="fb-empty">Click to add a message…</div>',
            inspector: (d, onChange) => {
                const ta = document.createElement('textarea');
                ta.className = 'fb-textarea';
                ta.rows = 5;
                ta.placeholder = 'Hi! Thanks for messaging us…';
                ta.value = d.text || '';
                ta.oninput = () => onChange({ text: ta.value });
                return wrapField('Message Body', ta, 'Sent as a plain WhatsApp text message.');
            },
        },
        send_image: {
            label: 'Image Media',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>',
            defaults: { url: '', caption: '' },
            render: (d) => d.url
                ? '<div class="fb-node-preview" style="font-family:monospace;font-size:11px;">' + escapeHtml(truncate(d.url, 40)) + '</div>'
                : '<div class="fb-empty">Add an image URL…</div>',
            inspector: (d, onChange) => {
                const wrap = document.createDocumentFragment();
                const u = document.createElement('input');
                u.type = 'text'; u.className = 'fb-input';
                u.placeholder = 'https://example.com/image.jpg';
                u.value = d.url || '';
                u.oninput = () => onChange({ url: u.value });
                wrap.appendChild(wrapField('Image URL', u, 'Must be publicly reachable HTTPS so Meta can fetch it.'));

                const c = document.createElement('input');
                c.type = 'text'; c.className = 'fb-input';
                c.placeholder = 'Optional caption';
                c.value = d.caption || '';
                c.oninput = () => onChange({ caption: c.value });
                wrap.appendChild(wrapField('Caption', c));
                return wrap;
            },
        },
        send_audio: {
            label: 'Audio Player',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>',
            defaults: { url: '' },
            render: (d) => d.url
                ? '<div class="fb-node-preview" style="font-family:monospace;font-size:11px;">' + escapeHtml(truncate(d.url, 40)) + '</div>'
                : '<div class="fb-empty">Add audio file URL…</div>',
            inspector: (d, onChange) => {
                const u = document.createElement('input');
                u.type = 'text'; u.className = 'fb-input';
                u.placeholder = 'https://example.com/audio.mp3';
                u.value = d.url || '';
                u.oninput = () => onChange({ url: u.value });
                return wrapField('Audio URL', u, 'Must be public .mp3, .ogg, or .m4a format.');
            }
        },
        send_video: {
            label: 'Video Player',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>',
            defaults: { url: '' },
            render: (d) => d.url
                ? '<div class="fb-node-preview" style="font-family:monospace;font-size:11px;">' + escapeHtml(truncate(d.url, 40)) + '</div>'
                : '<div class="fb-empty">Add video URL…</div>',
            inspector: (d, onChange) => {
                const u = document.createElement('input');
                u.type = 'text'; u.className = 'fb-input';
                u.placeholder = 'https://example.com/video.mp4';
                u.value = d.url || '';
                u.oninput = () => onChange({ url: u.value });
                return wrapField('Video URL', u, 'Must be public .mp4 format.');
            }
        },
        send_file: {
            label: 'Document Attachment',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>',
            defaults: { url: '' },
            render: (d) => d.url
                ? '<div class="fb-node-preview" style="font-family:monospace;font-size:11px;">' + escapeHtml(truncate(d.url, 40)) + '</div>'
                : '<div class="fb-empty">Add document URL…</div>',
            inspector: (d, onChange) => {
                const u = document.createElement('input');
                u.type = 'text'; u.className = 'fb-input';
                u.placeholder = 'https://example.com/document.pdf';
                u.value = d.url || '';
                u.oninput = () => onChange({ url: u.value });
                return wrapField('Document/File URL', u, 'Must be public .pdf, .docx, .zip, etc.');
            }
        },
        send_location: {
            label: 'Location Pin',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>',
            defaults: { latitude: '', longitude: '', name: '', address: '' },
            render: (d) => d.name
                ? '<div class="fb-node-preview"><strong>' + escapeHtml(d.name) + '</strong></div>'
                : '<div class="fb-empty">Enter location coordinates…</div>',
            inspector: (d, onChange) => {
                const wrap = document.createDocumentFragment();
                const lat = document.createElement('input');
                lat.type = 'text'; lat.className = 'fb-input'; lat.placeholder = 'e.g. 23.8103';
                lat.value = d.latitude || '';
                lat.oninput = () => onChange({ latitude: lat.value });
                wrap.appendChild(wrapField('Latitude', lat));

                const lon = document.createElement('input');
                lon.type = 'text'; lon.className = 'fb-input'; lon.placeholder = 'e.g. 90.4125';
                lon.value = d.longitude || '';
                lon.oninput = () => onChange({ longitude: lon.value });
                wrap.appendChild(wrapField('Longitude', lon));

                const nm = document.createElement('input');
                nm.type = 'text'; nm.className = 'fb-input'; nm.placeholder = 'e.g. OpenSquadron HQ';
                nm.value = d.name || '';
                nm.oninput = () => onChange({ name: nm.value });
                wrap.appendChild(wrapField('Place Name', nm));

                const adr = document.createElement('input');
                adr.type = 'text'; adr.className = 'fb-input'; adr.placeholder = 'e.g. Dhaka, Bangladesh';
                adr.value = d.address || '';
                adr.oninput = () => onChange({ address: adr.value });
                wrap.appendChild(wrapField('Full Address', adr));
                return wrap;
            }
        },
        ai_reply: {
            label: 'AI Responder',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line></svg>',
            defaults: { prompt: '' },
            render: (d) => d.prompt
                ? '<div class="fb-node-preview">' + escapeHtml(d.prompt) + '</div>'
                : '<div class="fb-empty">AI prompt instructions…</div>',
            inspector: (d, onChange) => {
                const ta = document.createElement('textarea');
                ta.className = 'fb-textarea';
                ta.rows = 4;
                ta.placeholder = 'You are a helpful customer support agent for OpenSquadron…';
                ta.value = d.prompt || '';
                ta.oninput = () => onChange({ prompt: ta.value });
                return wrapField('AI Agent Prompt', ta, 'The bot will execute a completion using this prompt when triggered.');
            }
        },
        user_input: {
            label: 'Form Data Input',
            icon: '<svg viewBox="0 0 24 24" class="fb-svg-icon"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>',
            defaults: { question: '', variable: '' },
            render: (d) => d.question
                ? '<div class="fb-node-preview">Save reply as: <strong style="color:var(--fb-active-border);">' + escapeHtml(d.variable) + '</strong></div>'
                : '<div class="fb-empty">Save response to variable…</div>',
            inspector: (d, onChange) => {
                const wrap = document.createDocumentFragment();
                const q = document.createElement('input');
                q.type = 'text'; q.className = 'fb-input'; q.placeholder = 'What is your email address?';
                q.value = d.question || '';
                q.oninput = () => onChange({ question: q.value });
                wrap.appendChild(wrapField('Question text', q));

                // Container for selector & inline creator card
                const varContainer = document.createElement('div');
                varContainer.style.display = 'flex';
                varContainer.style.flexDirection = 'column';
                varContainer.style.gap = '8px';

                // Select element
                const sel = document.createElement('select');
                sel.className = 'fb-select';
                sel.style.width = '100%';

                // Function to rebuild select options
                function populateOptions() {
                    sel.innerHTML = '<option value="">-- Select Variable --</option>';
                    (state.customFields || []).forEach(cf => {
                        const opt = document.createElement('option');
                        opt.value = cf.name;
                        opt.textContent = `${cf.name} (${cf.type})`;
                        sel.appendChild(opt);
                    });
                    sel.value = d.variable || '';
                }
                populateOptions();

                sel.onchange = () => {
                    onChange({ variable: sel.value });
                };

                varContainer.appendChild(sel);

                // "＋ Create Field On-the-Fly" button
                const btnCreate = document.createElement('button');
                btnCreate.type = 'button';
                btnCreate.className = 'fb-node-set-btn';
                btnCreate.style.marginTop = '4px';
                btnCreate.style.display = 'flex';
                btnCreate.style.alignItems = 'center';
                btnCreate.style.justifyContent = 'center';
                btnCreate.style.gap = '4px';
                btnCreate.style.padding = '8px 12px';
                btnCreate.style.background = 'rgba(6, 182, 212, 0.1)';
                btnCreate.style.border = '1px solid rgba(6, 182, 212, 0.2)';
                btnCreate.style.color = 'var(--primary-accent)';
                btnCreate.style.borderRadius = '8px';
                btnCreate.style.fontSize = '12px';
                btnCreate.style.fontWeight = '600';
                btnCreate.style.cursor = 'pointer';
                btnCreate.innerHTML = `
                    <svg viewBox="0 0 24 24" style="width:12px; height:12px; stroke: currentColor; fill: none; stroke-width: 2.5;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    <span>Create Field On-the-Fly</span>
                `;

                // Inline form card for creating field on-the-fly
                const inlineCard = document.createElement('div');
                inlineCard.style.display = 'none';
                inlineCard.style.padding = '12px';
                inlineCard.style.background = 'rgba(255, 255, 255, 0.02)';
                inlineCard.style.border = '1px solid var(--glass-border)';
                inlineCard.style.borderRadius = '8px';
                inlineCard.style.marginTop = '8px';
                inlineCard.style.flexDirection = 'column';
                inlineCard.style.gap = '10px';

                inlineCard.innerHTML = `
                    <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2px;">New Custom Field</div>
                    <div>
                        <input type="text" placeholder="Field name (e.g. user_email)" class="fb-input" style="font-size:12px; height:34px;" id="inline-cf-name">
                    </div>
                    <div>
                        <select class="fb-select" style="font-size:12px; height:34px;" id="inline-cf-type">
                            <option value="TEXT">TEXT</option>
                            <option value="NUMBER">NUMBER</option>
                            <option value="EMAIL">EMAIL</option>
                            <option value="PHONE">PHONE</option>
                            <option value="BOOLEAN">BOOLEAN</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px;">
                        <button type="button" id="inline-cf-cancel" style="background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); padding: 4px 10px; border-radius: 6px; font-size: 11px; color:#fff; cursor:pointer;">Cancel</button>
                        <button type="button" id="inline-cf-save" style="background: linear-gradient(135deg, var(--primary-accent) 0%, #0891b2 100%); border: none; padding: 4px 10px; border-radius: 6px; font-size: 11px; color:#fff; font-weight:600; cursor:pointer;">Save</button>
                    </div>
                `;

                btnCreate.onclick = () => {
                    const isVisible = inlineCard.style.display === 'flex';
                    inlineCard.style.display = isVisible ? 'none' : 'flex';
                };

                varContainer.appendChild(btnCreate);
                varContainer.appendChild(inlineCard);

                // Form elements event listeners inside the inline card
                const inputName = inlineCard.querySelector('#inline-cf-name');
                const selectType = inlineCard.querySelector('#inline-cf-type');
                const btnCancel = inlineCard.querySelector('#inline-cf-cancel');
                const btnSave = inlineCard.querySelector('#inline-cf-save');

                // Standardize input name on keyup/input
                inputName.addEventListener('input', function(e) {
                    let val = e.target.value;
                    let cleaned = val.toLowerCase().replace(/[^a-z0-9_]/g, '_').replace(/_+/g, '_');
                    if (cleaned !== val) {
                        e.target.value = cleaned;
                    }
                });

                btnCancel.onclick = () => {
                    inlineCard.style.display = 'none';
                    inputName.value = '';
                    selectType.value = 'TEXT';
                };

                btnSave.onclick = () => {
                    const cfName = inputName.value.trim();
                    if (!cfName) {
                        showToast('Field name is required.', 'error');
                        return;
                    }

                    btnSave.disabled = true;
                    btnSave.textContent = 'Saving...';

                    const formData = new FormData();
                    formData.append('name', cfName);
                    formData.append('type', selectType.value);
                    formData.append('description', 'Created on-the-fly from Visual Flow Builder');

                    fetch('/settings/custom-fields/save', {
                        method: 'POST',
                        body: formData
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showToast(data.message || 'Custom Field created!', 'success');
                            // Add newly created field to the state
                            const newField = {
                                name: cfName,
                                type: selectType.value,
                                description: 'Created on-the-fly from Visual Flow Builder'
                            };
                            if (!state.customFields) state.customFields = [];
                            state.customFields.push(newField);
                            
                            // Re-populate and select it
                            populateOptions();
                            sel.value = cfName;
                            onChange({ variable: cfName });

                            // Close inline card
                            inlineCard.style.display = 'none';
                            inputName.value = '';
                            selectType.value = 'TEXT';
                        } else {
                            showToast(data.error || 'Failed to create Custom Field.', 'error');
                        }
                    })
                    .catch(err => {
                        showToast('Error: ' + err.message, 'error');
                    })
                    .finally(() => {
                        btnSave.disabled = false;
                        btnSave.textContent = 'Save';
                    });
                };

                wrap.appendChild(wrapField('Save in Variable', varContainer, 'Stores the user input into database custom fields.'));
                return wrap;
            }
        },

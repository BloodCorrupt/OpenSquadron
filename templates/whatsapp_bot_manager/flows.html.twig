                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
                    </div>
                    <span>Routing Logic</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="delay">

    // ───────── Utility Helpers ─────────
    function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
    function truncate(s, n) { return s.length > n ? s.slice(0, n) + '…' : s; }
    function uid() { return 'n' + (state.nextId++) + '_' + Math.random().toString(36).slice(2, 7); }
    function wrapField(label, input, help) {
        const g = document.createElement('div');
        g.className = 'fb-form-group';
        const l = document.createElement('label');
        l.textContent = label;
        g.appendChild(l);
        g.appendChild(input);
        if (help) {
            const h = document.createElement('div');
            h.className = 'fb-help';
            h.innerHTML = help;
            g.appendChild(h);
        }
        return g;
    }
    function showToast(msg, kind) {
        const t = document.getElementById('fb-toast');
        t.textContent = msg;
        t.className = 'fb-toast is-shown ' + (kind ? 'is-' + kind : '');
        clearTimeout(showToast._t);
        showToast._t = setTimeout(() => { t.className = 'fb-toast'; }, 2400);
    }

    // ───────── DOM Elements ─────────
    const elNodes   = document.getElementById('fb-nodes');
    const elEdges   = document.getElementById('fb-edges');
    const elStage   = document.getElementById('fb-stage');
    const elView    = document.getElementById('fb-viewport');
    const elInsp    = document.getElementById('fb-inspector');

    function applyTransform() {
        const v = state.viewport;
        elStage.style.transform = `translate(${v.x}px, ${v.y}px) scale(${v.scale})`;
        drawMinimap();
    }

    function renderAll() {
        renderNodes();
        renderEdges();
        renderInspector();
        applyTransform();
    }

    function renderNodes() {
        elNodes.innerHTML = '';
        for (const node of state.nodes.values()) {
            const block = BLOCKS[node.type];
            if (!block) continue;
            const el = document.createElement('div');
            el.className = 'fb-node';
            el.dataset.type = node.type;
            el.dataset.id = node.id;
            el.style.left = node.x + 'px';
            el.style.top  = node.y + 'px';
            if (state.selection.node === node.id) el.classList.add('is-selected');

            // Dynamic header rendering
            let nodeHtml = `
                <div class="fb-node-header">
                    <div class="fb-node-title-group">
                        <span class="fb-node-icon">${block.icon}</span>
                        <span class="fb-node-title">${escapeHtml(block.label)}</span>
                    </div>
            `;
            if (node.type === 'start') {
                nodeHtml += `<button class="fb-node-set-btn" onclick="window.fbOpenSettingsModal(event)">Set</button>`;
            }
            nodeHtml += `</div>`;

            // Node body content
            let bodyHtml = block.render(node.data || {});
            // Inject dynamic ID into templates that need it
            bodyHtml = bodyHtml.replaceAll('DYNAMIC_ID', node.id);
            nodeHtml += `<div class="fb-node-body">${bodyHtml}</div>`;

            // Footer layout details (Ports)
            if (node.type === 'start') {
                nodeHtml += `
                    <div class="fb-node-footer">
                        <span>Compose Next Message</span>
                        <div class="fb-port is-out" data-role="out" data-port-id="out" data-node-id="${node.id}"></div>
                    </div>
                `;
            } else if (node.type === 'send_text' || node.type === 'send_image' || node.type === 'send_audio' || node.type === 'send_video' || node.type === 'send_file' || node.type === 'send_location' || node.type === 'send_template' || node.type === 'cta_button' || node.type === 'ai_reply' || node.type === 'condition' || node.type === 'delay' || node.type === 'sequence' || node.type === 'random_num' || node.type === 'user_input' || node.type === 'whatsapp_flows' || node.type === 'appointment' || node.type === 'http_api') {
                nodeHtml += `
                    <div class="fb-node-footer">
                        <span>Next</span>
                        <div class="fb-port is-out" data-role="out" data-port-id="out" data-node-id="${node.id}"></div>
                    </div>
                    <div class="fb-port is-in" data-role="in" data-port-id="in" data-node-id="${node.id}"></div>
                    <div class="port-in-label">In</div>
                `;
            } else if (node.type === 'interactive') {
                nodeHtml += `
                    <div class="fb-port is-in" data-role="in" data-port-id="in" data-node-id="${node.id}"></div>
                    <div class="port-in-label">Reply</div>
                `;
            } else if (node.type === 'quick_reply') {
                nodeHtml += `
                    <div class="fb-node-footer">
                        <span>Sections</span>
                        <div class="fb-port is-out" data-role="out" data-port-id="sections" data-node-id="${node.id}"></div>
                    </div>
                    <div class="fb-port is-in" data-role="in" data-port-id="in" data-node-id="${node.id}"></div>
                    <div class="port-in-label">Message</div>
                `;
            } else if (node.type === 'section') {
                nodeHtml += `
                    <div class="fb-node-footer">
                        <span>Rows</span>
                        <div class="fb-port is-out" data-role="out" data-port-id="rows" data-node-id="${node.id}"></div>
                    </div>
                    <div class="fb-port is-in" data-role="in" data-port-id="in" data-node-id="${node.id}"></div>
                    <div class="port-in-label">Reply</div>
                `;
            } else if (node.type === 'row') {
                nodeHtml += `
                    <div class="fb-node-footer">
                        <span>Next</span>
                        <div class="fb-port is-out" data-role="out" data-port-id="next" data-node-id="${node.id}"></div>
                    </div>
                    <div class="fb-port is-in" data-role="in" data-port-id="in" data-node-id="${node.id}"></div>
                    <div class="port-in-label">Reply</div>
                `;
            }

            el.innerHTML = nodeHtml;
            elNodes.appendChild(el);
        }

        // Fill dynamic metadata variables on the trigger node
        const nodeMetaKw = document.getElementById('node-meta-kw');
        const nodeMetaMatch = document.getElementById('node-meta-match');
        if (nodeMetaKw) nodeMetaKw.textContent = state.meta.keywords || 'None';
        if (nodeMetaMatch) {
            let label = 'Exact keyword match';
            if (state.meta.matchMode === 'contains') label = 'Contains match';
            else if (state.meta.matchMode === 'starts_with') label = 'Starts with match';
            nodeMetaMatch.textContent = label;
        }
    }

    // Resolves accurate coordinates of any port center using DOM dimensions relative to scale stage
    function portPos(nodeId, role, portId) {
        const el = document.querySelector(`.fb-port[data-node-id="${nodeId}"][data-role="${role}"][data-port-id="${portId}"]`);
        if (el) {
            const stageRect = elStage.getBoundingClientRect();
            const portRect = el.getBoundingClientRect();
            const x = (portRect.left + portRect.width / 2 - stageRect.left) / state.viewport.scale;
            const y = (portRect.top + portRect.height / 2 - stageRect.top) / state.viewport.scale;
            return { x: x + 10000, y: y + 10000 };
        }
        // Coordinate fallback if DOM elements are rendering asynchronously
        const node = state.nodes.get(nodeId);
        if (!node) return { x: 10000, y: 10000 };
        let xOffset = 0;
        let yOffset = 30;
        if (role === 'out') {
            xOffset = 240;
            if (portId === 'buttons') yOffset = 80;
            else if (portId === 'list_messages') yOffset = 110;
            else if (portId === 'ecommerce') yOffset = 140;
            else if (portId === 'sections') yOffset = 80;
            else if (portId === 'rows') yOffset = 80;
        }
        return {
            x: node.x + xOffset + 10000,
            y: node.y + yOffset + 10000
        };
    }

    function bezier(x1, y1, x2, y2) {
        const dx = Math.max(45, Math.abs(x2 - x1) * 0.55);
        return `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}`;
    }

    function renderEdges() {
        Array.from(elEdges.querySelectorAll('path:not(.is-temp)')).forEach(p => p.remove());
        for (const edge of state.edges) {
            const src = state.nodes.get(edge.source);
            const tgt = state.nodes.get(edge.target);
            if (!src || !tgt) continue;
            
            const sp = portPos(edge.source, 'out', edge.sourceHandle || 'out');
            const tp = portPos(edge.target, 'in', edge.targetHandle || 'in');
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.setAttribute('d', bezier(sp.x, sp.y, tp.x, tp.y));
            path.setAttribute('marker-end', 'url(#arrow)');
            path.dataset.id = edge.id;
            if (state.selection.edge === edge.id) path.classList.add('is-selected');
            
            path.addEventListener('click', (e) => {
                e.stopPropagation();
                state.selection = { node: null, edge: edge.id };
                renderAll();
            });
            elEdges.appendChild(path);
        }
    }

    function renderInspector() {
        elInsp.innerHTML = '';
        const sel = state.selection;
        if (sel.node || sel.edge) {
            if (window.innerWidth <= 768 && window.fbSwitchMobileTab) {
                window.fbSwitchMobileTab('inspector');
            }
        }
        if (sel.node) {
            const node = state.nodes.get(sel.node);
            if (!node) return;
            const block = BLOCKS[node.type];
            const head = document.createElement('div');
            head.style.cssText = 'display:flex;align-items:center;gap:10px;margin-bottom:18px;';
            head.innerHTML = `<div class="fb-pi-icon" style="background:rgba(255,255,255,0.05);color:var(--fb-active-border);width:36px;height:36px;font-size:18px;border:1px solid var(--fb-border);">${block.icon}</div>
                <div><div style="font-weight:700;color:var(--fb-text-main);">${escapeHtml(block.label)}</div>
                <div style="font-size:11px;color:var(--fb-text-muted);">ID: ${escapeHtml(node.id)}</div></div>`;
            elInsp.appendChild(head);

            const body = block.inspector(node.data || {}, (patch) => {
                node.data = Object.assign({}, node.data, patch);
                state.dirty = true;
                renderNodes();
                renderEdges(); // Instantly update dynamic paths if port labels/heights shift
            });
            elInsp.appendChild(body);

            if (node.type !== 'start') {
                const del = document.createElement('button');
                del.className = 'fb-tb-btn btn-danger';
                del.style.cssText = 'margin-top:16px;width:100%; display:flex; align-items:center; justify-content:center; gap:8px;';
                del.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg><span>Delete node</span>`;
                del.onclick = () => {
                    state.nodes.delete(node.id);
                    state.edges = state.edges.filter(e => e.source !== node.id && e.target !== node.id);
                    state.selection = { node: null, edge: null };
                    state.dirty = true;
                    renderAll();
                };
                elInsp.appendChild(del);
            }
            return;
        }

        if (sel.edge) {
            const e = state.edges.find(ed => ed.id === sel.edge);
            if (!e) return;
            elInsp.innerHTML = `
                <div style="margin-bottom:18px;">
                    <div style="font-weight:700;color:var(--fb-text-main);margin-bottom:6px;">Connection</div>
                    <div style="font-size:12px;color:var(--fb-text-muted);background:rgba(0,0,0,0.2);padding:8px 10px;border-radius:6px;border:1px solid var(--fb-border);">
                        <strong>Source:</strong> ${escapeHtml(e.source)} [${escapeHtml(e.sourceHandle)}]<br>
                        <strong>Target:</strong> ${escapeHtml(e.target)} [${escapeHtml(e.targetHandle)}]
                    </div>
                </div>
            `;
            const del = document.createElement('button');
            del.className = 'fb-tb-btn btn-danger';
            del.style.cssText = 'width:100%; display:flex; align-items:center; justify-content:center; gap:8px;';
            del.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg><span>Delete connection</span>`;
            del.onclick = () => {
                state.edges = state.edges.filter(x => x.id !== e.id);
                state.selection = { node: null, edge: null };
                state.dirty = true;
                renderAll();
            };
            elInsp.appendChild(del);
            return;
        }

        elInsp.innerHTML = `
            <div class="fb-empty-state">
                <span class="fb-empty-state-emoji">🛠️</span>
                Select a node or connection on the canvas to edit its variables.
            </div>
        `;
    }

    // ───────── Stage Panning & Zoom Controls ─────────
    function clientToCanvas(cx, cy) {
        const rect = elView.getBoundingClientRect();
        return {
            x: (cx - rect.left - state.viewport.x) / state.viewport.scale,
            y: (cy - rect.top  - state.viewport.y) / state.viewport.scale,
        };
    }

    elView.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        
        // Check if right click was on a node
        const nodeEl = e.target.closest('.fb-node');
        if (nodeEl) {
            const nodeId = nodeEl.dataset.id;
            const node = state.nodes.get(nodeId);
            if (node && node.type !== 'start') {
                closeContextMenu();
                openNodeContextMenu(e.clientX, e.clientY, nodeId);
                return;
            }
            return;
        }

        // Click was on the canvas background
        closeNodeContextMenu();
        const pos = clientToCanvas(e.clientX, e.clientY);
        openContextMenu(e.clientX, e.clientY, null, null, pos.x, pos.y);
    });

    let panState = null;
    elView.addEventListener('mousedown', (e) => {
        if (e.target.closest('.fb-node, .fb-port, path')) return;
        panState = { x: e.clientX, y: e.clientY, vx: state.viewport.x, vy: state.viewport.y };
        elView.classList.add('is-panning');
        state.selection = { node: null, edge: null };
        renderAll();
    });
    window.addEventListener('mousemove', (e) => {
        if (!panState) return;
        state.viewport.x = panState.vx + (e.clientX - panState.x);
        state.viewport.y = panState.vy + (e.clientY - panState.y);
        applyTransform();
    });
    window.addEventListener('mouseup', () => {
        if (panState) { panState = null; elView.classList.remove('is-panning'); }
    });

    elView.addEventListener('wheel', (e) => {
        e.preventDefault();
        const dir = e.deltaY > 0 ? -1 : 1;
        zoomAt(e.clientX, e.clientY, dir * 0.08);
    }, { passive: false });

    function zoomAt(cx, cy, delta) {
        const before = clientToCanvas(cx, cy);
        const newScale = Math.max(0.4, Math.min(1.8, state.viewport.scale + delta));
        state.viewport.scale = newScale;
        const after = clientToCanvas(cx, cy);
        state.viewport.x += (after.x - before.x) * newScale;
        state.viewport.y += (after.y - before.y) * newScale;
        applyTransform();
    }

    document.getElementById('fb-zoom-fit').onclick = fitToScreen;

    function fitToScreen() {
        if (state.nodes.size === 0) {
            state.viewport = { x: 80, y: 100, scale: 1 };
            applyTransform();
            return;
        }
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const n of state.nodes.values()) {
            minX = Math.min(minX, n.x); minY = Math.min(n.y, n.y);
            maxX = Math.max(maxX, n.x + 240); maxY = Math.max(maxY, n.y + 120);
        }
        const rect = elView.getBoundingClientRect();
        const pad = 60;
        const sx = (rect.width  - pad*2) / (maxX - minX);
        const sy = (rect.height - pad*2) / (maxY - minY);
        const scale = Math.max(0.4, Math.min(1.2, Math.min(sx, sy)));
        state.viewport.scale = scale;
        state.viewport.x = pad - minX * scale;
        state.viewport.y = pad - minY * scale;
        applyTransform();
    }

    // ───────── Draggable Palette Interactions ─────────
    document.querySelectorAll('.fb-palette-item').forEach(el => {
        el.addEventListener('dragstart', e => {
            e.dataTransfer.setData('text/fb-block', el.dataset.block);
            e.dataTransfer.effectAllowed = 'copy';
        });
    });
    elView.addEventListener('dragover', e => { e.preventDefault(); e.dataTransfer.dropEffect = 'copy'; });
    elView.addEventListener('drop', e => {
        e.preventDefault();
        const type = e.dataTransfer.getData('text/fb-block');
        if (!type || !BLOCKS[type]) return;
        if (type === 'start' && hasStartNode()) {
            showToast('Only one Start node allowed.', 'error');
            return;
        }
        const pos = clientToCanvas(e.clientX, e.clientY);
        addNode(type, pos.x - 120, pos.y - 25);
    });

    // Search blocks filter box interaction
    document.getElementById('fb-search-blocks').oninput = (e) => {
        const q = e.target.value.toLowerCase().trim();
        document.querySelectorAll('.fb-palette-item').forEach(item => {
            const label = item.querySelector('span').textContent.toLowerCase();
            if (label.includes(q)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    };

    function hasStartNode() {
        for (const n of state.nodes.values()) if (n.type === 'start') return true;
        return false;
    }

    function addNode(type, x, y) {
        const id = uid();
        const node = {
            id, type, x, y,
            data: Object.assign({}, BLOCKS[type].defaults || {}),
        };
        state.nodes.set(id, node);
        state.selection = { node: id, edge: null };
        state.dirty = true;
        renderAll();
        return node;
    }

    // ───────── Port Connection Hooks & Dragging ─────────
    let dragNode = null;
    let connect  = null;

    elNodes.addEventListener('mousedown', (e) => {
        const portEl = e.target.closest('.fb-port');
        if (portEl) {
            if (portEl.dataset.role !== 'out') return;
            e.stopPropagation();
            const node = state.nodes.get(portEl.dataset.nodeId);
            const portId = portEl.dataset.portId;
            const start = portPos(node.id, 'out', portId);
            connect = {
                fromId: node.id,
                fromPortId: portId,
                startX: start.x - 10000,
                startY: start.y - 10000,
                curX: start.x - 10000,
                curY: start.y - 10000,
            };
            elView.classList.add('is-connecting');
            highlightInputPorts(true);
            renderTempEdge();
            return;
        }

        const nodeEl = e.target.closest('.fb-node');
        if (!nodeEl) return;
        e.stopPropagation();
        const node = state.nodes.get(nodeEl.dataset.id);
        if (!node) return;
        state.selection = { node: node.id, edge: null };
        renderAll();
        const start = clientToCanvas(e.clientX, e.clientY);
        dragNode = { id: node.id, dx: start.x - node.x, dy: start.y - node.y };
        nodeEl.classList.add('is-dragging');
    });

    window.addEventListener('mousemove', (e) => {
        if (dragNode) {
            const p = clientToCanvas(e.clientX, e.clientY);
            const node = state.nodes.get(dragNode.id);
            if (node) {
                node.x = p.x - dragNode.dx;
                node.y = p.y - dragNode.dy;
                state.dirty = true;
                renderNodes();
                renderEdges();
                drawMinimap();
            }
        }
        if (connect) {
            const p = clientToCanvas(e.clientX, e.clientY);
            connect.curX = p.x;
            connect.curY = p.y;
            renderTempEdge();
        }
    });

    window.addEventListener('mouseup', (e) => {
        if (dragNode) {
            document.querySelectorAll('.fb-node.is-dragging').forEach(n => n.classList.remove('is-dragging'));
            dragNode = null;
        }
        if (connect) {
            const port = document.elementFromPoint(e.clientX, e.clientY)?.closest('.fb-port.is-in');
            if (port) {
                const targetId = port.dataset.nodeId;
                const targetPortId = port.dataset.portId || 'in';
                if (targetId !== connect.fromId) {
                    // Remove existing edge matching source-port combination
                    state.edges = state.edges.filter(ed => !(ed.source === connect.fromId && ed.sourceHandle === connect.fromPortId));
                    if (!state.edges.find(ed => ed.source === connect.fromId && ed.sourceHandle === connect.fromPortId && ed.target === targetId && ed.targetHandle === targetPortId)) {
                        state.edges.push({
                            id: 'e_' + Math.random().toString(36).slice(2, 8),
                            source: connect.fromId,
                            sourceHandle: connect.fromPortId,
                            target: targetId,
                            targetHandle: targetPortId,
                        });
                        state.dirty = true;
                    }
                }
                connect = null;
                elView.classList.remove('is-connecting');
                highlightInputPorts(false);
                removeTempEdge();
                renderEdges();
                drawMinimap();
            } else {
                // Drag-release in empty space: trigger searchable context menu
                const pos = clientToCanvas(e.clientX, e.clientY);
                openContextMenu(e.clientX, e.clientY, connect.fromId, connect.fromPortId, pos.x, pos.y);
                
                // Clear connect properties and clean UI
                connect = null;
                elView.classList.remove('is-connecting');
                highlightInputPorts(false);
                removeTempEdge();
            }
        }
    });

    function highlightInputPorts(on) {
        document.querySelectorAll('.fb-port.is-in').forEach(p => {
            p.classList.toggle('is-target-eligible', on);
        });
    }

    function renderTempEdge() {
        if (!connect) return;
        let path = elEdges.querySelector('path.is-temp');
        if (!path) {
            path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.classList.add('is-temp');
            elEdges.appendChild(path);
        }
        path.setAttribute('d', bezier(
            connect.startX + 10000, connect.startY + 10000,
            connect.curX + 10000, connect.curY + 10000
        ));
    }
    function removeTempEdge() {
        elEdges.querySelectorAll('path.is-temp').forEach(p => p.remove());
    }

    // Keyboard backspace/delete hook to remove nodes
    window.addEventListener('keydown', (e) => {
        if (e.target.matches('input, textarea, select')) return;
        if (e.key === 'Delete' || e.key === 'Backspace') {
            if (state.selection.node) {
                const id = state.selection.node;
                const node = state.nodes.get(id);
                if (node && node.type !== 'start') {
                    state.nodes.delete(id);
                    state.edges = state.edges.filter(ed => ed.source !== id && ed.target !== id);
                    state.selection = { node: null, edge: null };
                    state.dirty = true;
                    renderAll();
                }
            } else if (state.selection.edge) {
                state.edges = state.edges.filter(ed => ed.id !== state.selection.edge);
                state.selection = { node: null, edge: null };
                state.dirty = true;
                renderAll();
            }
        }
    });

    // ───────── Modal Dialog Box bindings ─────────
    const overlay = document.getElementById('fb-settings-modal-overlay');
    
    window.fbOpenSettingsModal = function(event) {
        if (event) event.stopPropagation();
        document.getElementById('fb-modal-name').value = state.meta.name;
        document.getElementById('fb-modal-keywords').value = state.meta.keywords;
        document.getElementById('fb-modal-match').value = state.meta.matchMode;
        document.getElementById('fb-modal-active').checked = state.meta.isActive;
        overlay.style.display = 'flex';
    };

    function closeSettingsModal() {
        overlay.style.display = 'none';
    }

    document.getElementById('fb-modal-close').onclick = closeSettingsModal;
    document.getElementById('fb-modal-cancel').onclick = closeSettingsModal;
    document.getElementById('fb-modal-save').onclick = () => {
        state.meta.name = document.getElementById('fb-modal-name').value;
        state.meta.keywords = document.getElementById('fb-modal-keywords').value;
        state.meta.matchMode = document.getElementById('fb-modal-match').value;
        state.meta.isActive = document.getElementById('fb-modal-active').checked;
        state.dirty = true;
        closeSettingsModal();
        renderNodes();
        showToast('Trigger settings updated. Save the flow to apply.', 'success');
    };

    // ───────── Searchable Drag-Release Context Menu Logic ─────────
    const elCtxMenu = document.getElementById('fb-context-menu');
    const elCtxSearch = document.getElementById('fb-ctx-search');
    const elCtxList = document.getElementById('fb-ctx-list');

    function openContextMenu(clientX, clientY, fromId, fromPortId, canvasX, canvasY) {
        state.ctxMenuOrigin = { fromId, fromPortId, canvasX, canvasY };
        renderContextMenuList('');
        elCtxMenu.style.display = 'flex';

        // Constrain bounding coordinates within screen borders
        const menuWidth = 250;
        const menuHeight = 350;
        let left = clientX;
        let top = clientY;
        if (left + menuWidth > window.innerWidth) left = window.innerWidth - menuWidth - 10;
        if (top + menuHeight > window.innerHeight) top = window.innerHeight - menuHeight - 10;

        elCtxMenu.style.left = left + 'px';
        elCtxMenu.style.top = top + 'px';

        // Focus search box instantly
        setTimeout(() => {
            elCtxSearch.value = '';
            elCtxSearch.focus();
        }, 50);
    }

    function closeContextMenu() {
        elCtxMenu.style.display = 'none';
        state.ctxMenuOrigin = null;
    }

    function renderContextMenuList(query) {
        elCtxList.innerHTML = '';
        const q = query.toLowerCase().trim();

        // Populate catalog blocks except 'start' trigger
        Object.entries(BLOCKS).forEach(([type, block]) => {
            if (type === 'start') return;
            if (q && !block.label.toLowerCase().includes(q)) return;

            const item = document.createElement('div');
            item.className = 'fb-ctx-item';

            let catClass = 'pi-messages';
            if (type === 'user_input' || type === 'whatsapp_flows' || type === 'appointment') catClass = 'pi-collection';
            else if (type === 'interactive' || type === 'send_template' || type === 'cta_button') catClass = 'pi-interactive';
            else if (type === 'condition' || type === 'delay' || type === 'sequence' || type === 'random_num') catClass = 'pi-control';
            else if (type === 'http_api') catClass = 'pi-control';

            item.innerHTML = `
                <div class="fb-ctx-icon ${catClass}">${block.icon}</div>
                <span>${escapeHtml(block.label)}</span>
            `;
            item.onclick = () => {
                // Instantly spawn node centered at release point (slightly adjusted for port alignment)
                const newNode = addNode(type, state.ctxMenuOrigin.canvasX - 10, state.ctxMenuOrigin.canvasY - 30);
                
                if (state.ctxMenuOrigin.fromId) {
                    // Clear existing edges from this same sourcePort
                    state.edges = state.edges.filter(ed => !(ed.source === state.ctxMenuOrigin.fromId && ed.sourceHandle === state.ctxMenuOrigin.fromPortId));
                    
                    // Establish connection
                    state.edges.push({
                        id: 'e_' + Math.random().toString(36).slice(2, 8),
                        source: state.ctxMenuOrigin.fromId,
                        sourceHandle: state.ctxMenuOrigin.fromPortId,
                        target: newNode.id,
                        targetHandle: 'in'
                    });
                }
                state.dirty = true;
                closeContextMenu();
                renderAll();
            };
            elCtxList.appendChild(item);
        });

        // Add Cancel option
        if (!q || 'cancel'.includes(q)) {
            const cancelItem = document.createElement('div');
            cancelItem.className = 'fb-ctx-item is-cancel';
            cancelItem.innerHTML = `
                <div class="fb-ctx-icon">❌</div>
                <span>Cancel</span>
            `;
            cancelItem.onclick = closeContextMenu;
            elCtxList.appendChild(cancelItem);
        }
    }

    elCtxSearch.oninput = (e) => {
        renderContextMenuList(e.target.value);
    };

    const elNodeCtxMenu = document.getElementById('fb-node-context-menu');
    let contextNodeId = null;

    function openNodeContextMenu(clientX, clientY, nodeId) {
        contextNodeId = nodeId;
        elNodeCtxMenu.style.display = 'flex';

        // Constrain coordinates within screen borders
        const menuWidth = 140;
        const menuHeight = 85;
        let left = clientX;
        let top = clientY;
        if (left + menuWidth > window.innerWidth) left = window.innerWidth - menuWidth - 10;
        if (top + menuHeight > window.innerHeight) top = window.innerHeight - menuHeight - 10;

        elNodeCtxMenu.style.left = left + 'px';
        elNodeCtxMenu.style.top = top + 'px';
    }

    function closeNodeContextMenu() {
        elNodeCtxMenu.style.display = 'none';
        contextNodeId = null;
    }

    function deleteNode(nodeId) {
        const node = state.nodes.get(nodeId);
        if (!node || node.type === 'start') return;
        state.nodes.delete(nodeId);
        state.edges = state.edges.filter(e => e.source !== nodeId && e.target !== nodeId);
        if (state.selection.node === nodeId) {
            state.selection = { node: null, edge: null };
        }
        state.dirty = true;
        renderAll();
        showToast('Node deleted successfully.', 'success');
    }

    function cloneNode(nodeId) {
        const node = state.nodes.get(nodeId);
        if (!node || node.type === 'start') return;
        const newId = uid();
        const newData = JSON.parse(JSON.stringify(node.data || {}));
        const clonedNode = {
            id: newId,
            type: node.type,
            x: node.x + 40,
            y: node.y + 40,
            data: newData
        };
        state.nodes.set(newId, clonedNode);
        state.selection = { node: newId, edge: null };
        state.dirty = true;
        renderAll();
        showToast('Node cloned successfully.', 'success');
    }

    document.getElementById('fb-node-ctx-delete').onclick = () => {
        if (contextNodeId) deleteNode(contextNodeId);
        closeNodeContextMenu();
    };

    document.getElementById('fb-node-ctx-clone').onclick = () => {
        if (contextNodeId) cloneNode(contextNodeId);
        closeNodeContextMenu();
    };

    window.addEventListener('mousedown', (e) => {
        if (elCtxMenu.style.display === 'flex' && !elCtxMenu.contains(e.target)) {
            closeContextMenu();
        }
        if (elNodeCtxMenu.style.display === 'flex' && !elNodeCtxMenu.contains(e.target)) {
            closeNodeContextMenu();
        }
    });

    // ───────── Mini-map Visual Renderer ─────────
    const minimap = document.getElementById('fb-minimap');
    function drawMinimap() {
        const rect = minimap.getBoundingClientRect();
        const dpr = window.devicePixelRatio || 1;
        if (minimap.width !== rect.width * dpr) {
            minimap.width  = rect.width  * dpr;
            minimap.height = rect.height * dpr;
        }
        const ctx = minimap.getContext('2d');
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, rect.width, rect.height);

        if (state.nodes.size === 0) {
            ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.font = '11px Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText('Empty Canvas', rect.width / 2, rect.height / 2 + 4);
            return;
        }

        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const n of state.nodes.values()) {
            minX = Math.min(minX, n.x); minY = Math.min(minY, n.y);
            maxX = Math.max(maxX, n.x + 240); maxY = Math.max(maxY, n.y + 120);
        }
        const padW = 20, padH = 20;
        const w = maxX - minX, h = maxY - minY;
        const scale = Math.min((rect.width - padW) / w, (rect.height - padH) / h);
        const ox = (rect.width  - w * scale) / 2 - minX * scale;
        const oy = (rect.height - h * scale) / 2 - minY * scale;

        // Draw connections
        ctx.strokeStyle = 'rgba(148, 163, 184, 0.4)';
        ctx.lineWidth = 1;
        for (const ed of state.edges) {
            const s = state.nodes.get(ed.source);
            const t = state.nodes.get(ed.target);
            if (!s || !t) continue;
            ctx.beginPath();
            ctx.moveTo(s.x * scale + 240 * scale + ox, s.y * scale + 25 * scale + oy);
            ctx.lineTo(t.x * scale + ox,                t.y * scale + 25 * scale + oy);
            ctx.stroke();
        }
        for (const n of state.nodes.values()) {
            ctx.fillStyle = n.type === 'start' ? 'rgba(6, 182, 212, 0.6)' : 'rgba(255, 255, 255, 0.15)';
            ctx.fillRect(n.x * scale + ox, n.y * scale + oy, 240 * scale, 60 * scale);
        }

        // Draw viewport rect bounds
        const view = elView.getBoundingClientRect();
        const vx = (-state.viewport.x / state.viewport.scale) * scale + ox;
        const vy = (-state.viewport.y / state.viewport.scale) * scale + oy;
        const vw = (view.width  / state.viewport.scale) * scale;
        const vh = (view.height / state.viewport.scale) * scale;
        ctx.strokeStyle = 'rgba(6, 182, 212, 0.8)';
        ctx.lineWidth = 1;
        ctx.strokeRect(vx, vy, vw, vh);
    }

    // ───────── Flows Selector & Close bindings ─────────
    const flowSelector = document.getElementById('fb-flow-selector');
    flowSelector.onchange = (e) => {
        const val = e.target.value;
        if (val === 'new') {
            newFlow();
        } else {
            loadFlow(parseInt(val, 10));
        }
    };

    document.getElementById('fb-btn-close').onclick = () => {
        if (window.self !== window.top) {
            window.parent.postMessage({ type: 'close_flow_builder' }, '*');
        } else {
            window.location.href = '{{ path('app_whatsapp_bot_manager', {connectionId: connection ? connection.id : ''}) }}';
        }
    };

    document.getElementById('fb-save-flow').onclick = saveFlow;

    // ───────── Persistence Loader / Saver ─────────
    function newFlow() {
        state.currentId = null;
        state.meta = { name: 'Untitled flow', keywords: '', matchMode: 'exact', isActive: true };
        state.nodes.clear();
        state.edges = [];
        state.selection = { node: null, edge: null };
        state.viewport = { x: 80, y: 100, scale: 1 };
        state.dirty = false;
        
        // Seed new flows with a trigger node
        addNode('start', 60, 100);
        flowSelector.value = 'new';
        renderAll();
    }

    function loadFlow(id) {
        if (state.dirty && !confirm('You have unsaved changes. Discard them?')) {
            flowSelector.value = state.currentId || 'new';
            return;
        }
        const f = state.flows.find(x => x.id === id);
        if (!f) return;
        state.currentId = f.id;
        state.meta = {
            name: f.name || '',
            keywords: (f.keywords || []).join(', '),
            matchMode: f.matchMode || 'exact',
            isActive: !!f.isActive,
        };
        state.nodes.clear();
        state.edges = [];

        if (f.graph && Array.isArray(f.graph.nodes) && f.graph.nodes.length) {
            for (const n of f.graph.nodes) {
                state.nodes.set(n.id, {
                    id: n.id,
                    type: n.type,
                    x: n.x || 0,
                    y: n.y || 0,
                    data: n.data || {},
                });
            }
            for (const e of (f.graph.edges || [])) {
                state.edges.push({
                    id: e.id || ('e_' + Math.random().toString(36).slice(2, 8)),
                    source: e.source,
                    sourceHandle: e.sourceHandle || 'out',
                    target: e.target,
                    targetHandle: e.targetHandle || 'in',
                });
            }
            state.viewport = f.graph.viewport || { x: 80, y: 100, scale: 1 };
        } else if (Array.isArray(f.legacyActions)) {
            // Traverse/migrate legacy flat lists to clean dynamic cards
            const startId = uid();
            state.nodes.set(startId, { id: startId, type: 'start', x: 60, y: 60, data: {} });
            let prev = startId, y = 60;
            for (const act of f.legacyActions) {
                if (!act || !BLOCKS[act.type]) continue;
                y += 180;
                const id = uid();
                const data = Object.assign({}, BLOCKS[act.type].defaults || {}, act);
                delete data.type;
                state.nodes.set(id, { id, type: act.type, x: 60, y, data });
                state.edges.push({
                    id: 'e_' + Math.random().toString(36).slice(2, 8),
                    source: prev, sourceHandle: 'out', target: id, targetHandle: 'in',
                });
                prev = id;
            }
            state.viewport = { x: 80, y: 100, scale: 1 };
        } else {
            const startId = uid();
            state.nodes.set(startId, { id: startId, type: 'start', x: 60, y: 60, data: {} });
            state.viewport = { x: 80, y: 100, scale: 1 };
        }

        state.selection = { node: null, edge: null };
        state.dirty = false;
        flowSelector.value = id;
        renderAll();
    }

    function saveFlow() {
        if (!state.meta.name.trim()) { showToast('Flow name is required.', 'error'); return; }
        if (!state.meta.keywords.trim()) { showToast('At least one trigger keyword is required.', 'error'); return; }
        if (!hasStartNode()) { showToast('Add a Start node to the canvas.', 'error'); return; }

        const payload = {
            id: state.currentId,
            name: state.meta.name.trim(),
            keywords: state.meta.keywords,
            matchMode: state.meta.matchMode,
            isActive: state.meta.isActive,
            connectionId: '{{ connection ? connection.id : "" }}',
            graph: {
                nodes: Array.from(state.nodes.values()).map(n => ({
                    id: n.id, type: n.type, x: Math.round(n.x), y: Math.round(n.y), data: n.data || {},
                })),
                edges: state.edges.map(e => ({
                    id: e.id, source: e.source, sourceHandle: e.sourceHandle, target: e.target, targetHandle: e.targetHandle,
                })),
                viewport: state.viewport,
            },
        };

        const btn = document.getElementById('fb-save-flow');
        btn.disabled = true;
        btn.textContent = '⏳ Saving…';

        fetch(SAVE_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        })
        .then(r => r.json())
        .then(res => {
            if (!res.success) throw new Error(res.error || 'Save failed');
            const saved = res.flow;
            const idx = state.flows.findIndex(f => f.id === saved.id);
            if (idx >= 0) {
                state.flows[idx] = saved;
            } else {
                state.flows.unshift(saved);
                // Add new option to dropdown list
                const opt = document.createElement('option');
                opt.value = saved.id;
                opt.textContent = saved.name;
                flowSelector.appendChild(opt);
            }
            state.currentId = saved.id;
            flowSelector.value = saved.id;
            state.dirty = false;
            showToast('Flow saved successfully.', 'success');

            renderAll();
        })
        .catch(err => showToast('Save failed: ' + err.message, 'error'))
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '💾 Save';
        });
    }

    // Mobile responsiveness handlers
    function initMobileHandlers() {
        const mobileControls = document.querySelector('.fb-mobile-controls');
        if (!mobileControls) return;
        
        const tabs = document.querySelectorAll('.fb-mobile-tab-btn');
        const sidebar = document.querySelector('.fb-sidebar');
        const inspector = document.querySelector('.fb-inspector');
        
        function switchTab(targetTab) {
            tabs.forEach(btn => {
                const isActive = btn.dataset.mobileTab === targetTab;
                btn.classList.toggle('is-active', isActive);
            });
            
            if (targetTab === 'palette') {
                sidebar.classList.add('is-visible');
                inspector.classList.remove('is-visible');
            } else if (targetTab === 'inspector') {
                sidebar.classList.remove('is-visible');
                inspector.classList.add('is-visible');
            } else {
                sidebar.classList.remove('is-visible');
                inspector.classList.remove('is-visible');
            }
        }
        
        tabs.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                switchTab(btn.dataset.mobileTab);
            });
        });
        
        // Handle click outside sidebar or inspector on mobile to dismiss
        document.addEventListener('click', (e) => {
            if (window.innerWidth > 768) return;
            if (!sidebar.contains(e.target) && !inspector.contains(e.target) && !mobileControls.contains(e.target)) {
                if (sidebar.classList.contains('is-visible') || inspector.classList.contains('is-visible')) {
                    switchTab('canvas');
                }
            }
        });
        
        window.fbSwitchMobileTab = switchTab;
    }

    // Bootstrap init
    function init() {
        initMobileHandlers();
        let maxNum = 0;
        state.flows.forEach(f => {
            (f.graph?.nodes || []).forEach(n => {
                const m = /^n(\d+)/.exec(n.id || '');
                if (m) maxNum = Math.max(maxNum, parseInt(m[1], 10));
            });
        });
        state.nextId = maxNum + 1;

        // Fetch custom fields from the backend JSON endpoint
        fetch('/settings/custom-fields/json')
            .then(res => res.json())
            .then(data => {
                state.customFields = data;
            })
            .catch(err => console.error('Error loading custom fields:', err));

        const params = new URLSearchParams(window.location.search);
        const flowIdParam = params.get('id');
        if (flowIdParam === 'new') {
            newFlow();
        } else if (flowIdParam) {
            const parsedId = parseInt(flowIdParam, 10);
            if (state.flows.some(f => f.id === parsedId)) {
                loadFlow(parsedId);
            } else {
                newFlow();
            }
        } else if (state.flows.length > 0) {
            loadFlow(state.flows[0].id);
        } else {
            newFlow();
        }
    }

    elEdges.addEventListener('click', () => {
        state.selection = { node: null, edge: null };
        renderAll();
    });

    init();
    window.addEventListener('resize', drawMinimap);
})();
</script>

                    </div>
                    <span>Random Selector</span>
                </div>
            </div>

            {# Category: Integrations #}
            <div class="fb-palette-category">
                <div class="fb-category-title">Integrations</div>
                <div class="fb-palette-item" draggable="true" data-block="http_api">
                    <div class="fb-pi-icon pi-control" style="background: rgba(251, 146, 60, 0.12); color: #fb923c;">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
                    </div>
                    <span>HTTP API Request</span>
                </div>
            </div>
        </div>
    </div>

    {# ───────── Middle Visual Canvas ───────── #}
    <div class="fb-canvas-container" id="fb-canvas-wrap">
        
        {# Redesigned Flow Action Controls #}
        
        <button class="fb-floating-back" id="fb-btn-close" title="Back to Manager">
            ← Back
        </button>

        <div class="fb-action-panel">
            <div class="fb-phone-badge">
                <div class="fb-phone-dot"></div>
                {% if connection %}
                    <span>{{ connection.label ? connection.label|upper : 'WHATSAPP +' ~ connection.phoneNumberId }}</span>
                {% else %}
                    <span>WHATSAPP BOT</span>
                {% endif %}
            </div>

            <div class="fb-action-buttons">
                <button class="fb-action-btn" id="fb-zoom-fit" title="Zoom Fit">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><polyline points="8 3 3 3 3 8"></polyline><polyline points="16 3 21 3 21 8"></polyline><polyline points="8 21 3 21 3 16"></polyline><polyline points="16 21 21 21 21 16"></polyline></svg>
                    Zoom Fit
                </button>
                <button class="fb-action-btn primary" id="fb-save-flow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    Save Flow
                </button>
            </div>
        </div>

        {# SVG Connection edges & drag grid stage #}
        <div class="fb-viewport" id="fb-viewport">
            <div class="fb-stage" id="fb-stage">
                <svg class="fb-edges" id="fb-edges">
                    <defs>
                        <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                            <path d="M 0 1.5 L 8 5 L 0 8.5 z" fill="#94a3b8" />
                        </marker>
                    </defs>
                </svg>
                <div id="fb-nodes"></div>
            </div>
        </div>

        {# Minimap overlay #}
        <div class="fb-minimap"><canvas id="fb-minimap"></canvas></div>
    </div>

    {# ───────── Right Inspector Panel ───────── #}
    <div class="fb-inspector">
        <div class="fb-inspector-header">
            <span>Inspector</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 16px; height: 16px; opacity: 0.8;"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
        </div>
        <div class="fb-inspector-body" id="fb-inspector">
            <div class="fb-empty-state">
                <span class="fb-empty-state-emoji" style="display: block; margin-bottom: 12px; opacity: 0.6; color: var(--primary-accent);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px;"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
                </span>
                Select a node or connection on the canvas to edit its variables.
            </div>
        </div>
    </div>
</div>

{# Trigger Settings Modal #}
<div class="fb-settings-overlay" id="fb-settings-modal-overlay">
    <div class="fb-settings-modal">
        <div class="fb-modal-header">
            <span>Trigger Configuration</span>
            <button style="background:none;border:none;cursor:pointer;font-size:16px;color:#fff;" id="fb-modal-close">×</button>

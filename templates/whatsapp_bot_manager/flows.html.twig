                    </div>
                    <span>Location Pin</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="ai_reply">
                    <div class="fb-pi-icon pi-messages">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line></svg>
                    </div>
                    <span>AI Responder</span>
                </div>
            </div>

            {# Category: Form Capture #}
            <div class="fb-palette-category">
                <div class="fb-category-title">Form Capture</div>
                <div class="fb-palette-item" draggable="true" data-block="user_input">
                    <div class="fb-pi-icon pi-collection">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                    </div>
                    <span>Form Data Input</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="whatsapp_flows">
                    <div class="fb-pi-icon pi-collection">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><path d="M13 6h3a2 2 0 0 1 2 2v7"></path><line x1="6" y1="9" x2="6" y2="21"></line></svg>
                    </div>
                    <span>WhatsApp Flow</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="appointment">
                    <div class="fb-pi-icon pi-collection">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </div>
                    <span>Booking Calendar</span>
                </div>
            </div>

            {# Category: Interactive Menus #}
            <div class="fb-palette-category">
                <div class="fb-category-title">Interactive Menus</div>
                <div class="fb-palette-item" draggable="true" data-block="interactive">
                    <div class="fb-pi-icon pi-interactive">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
                    </div>
                    <span>Selection Menu</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="send_template">
                    <div class="fb-pi-icon pi-interactive">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                    </div>
                    <span>Message Template</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="cta_button">
                    <div class="fb-pi-icon pi-interactive">
                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    </div>
                    <span>Call-to-Action Link</span>
                </div>
            </div>

            {# Category: Smart Routing #}

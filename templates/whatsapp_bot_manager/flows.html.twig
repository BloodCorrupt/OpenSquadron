                        <svg viewBox="0 0 24 24" class="fb-svg-icon"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
                    </div>
                    <span>Sequence Drip</span>
                </div>
                <div class="fb-palette-item" draggable="true" data-block="random_num">

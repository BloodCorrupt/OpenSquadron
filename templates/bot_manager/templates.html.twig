{% extends 'base.html.twig' %}

{% block title %}Message Templates - Bot Manager{% endblock %}

{% block stylesheets %}
<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .page-title { font-size: 24px; font-weight: 600; color: #fff; margin: 0; }
    .header-actions { display: flex; gap: 10px; }

    .btn-primary {
        background: var(--primary-accent);
        color: #000;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: opacity 0.2s;
        font-size: 14px;
    }
    .btn-primary:hover { opacity: 0.85; }

    .btn-secondary {
        background: rgba(255,255,255,0.07);
        color: var(--secondary-accent);
        border: 1px solid rgba(16,185,129,0.4);
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        font-size: 14px;
    }
    .btn-secondary:hover { background: rgba(16,185,129,0.1); }
    .btn-secondary.loading svg { animation: spin 1s linear infinite; }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    .templates-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }

    .template-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .template-header { display: flex; justify-content: space-between; align-items: flex-start; }
    .template-name { font-size: 15px; font-weight: 600; color: #fff; word-break: break-all; }
    .template-meta { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

    .badge {
        font-size: 11px;
        padding: 3px 9px;
        border-radius: 20px;
        font-weight: 600;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .badge-approved  { background: rgba(16,185,129,0.2);  color: #10b981; }
    .badge-pending   { background: rgba(234,179,8,0.2);   color: #eab308; }
    .badge-rejected  { background: rgba(239,68,68,0.2);   color: #ef4444; }
    .badge-disabled  { background: rgba(100,116,139,0.2); color: #64748b; }

    .template-body {
        font-size: 13px;
        color: #cbd5e1;
        background: rgba(0,0,0,0.2);
        padding: 10px 12px;
        border-radius: 8px;
        white-space: pre-wrap;
        line-height: 1.5;
        flex: 1;
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 40px;
        color: var(--text-muted);
        background: var(--glass-bg);
        border-radius: 12px;
        border: 1px dashed var(--glass-border);
    }
    .empty-state svg { margin-bottom: 16px; opacity: 0.4; }
    .empty-state h3 { color: #fff; margin: 0 0 8px; font-size: 18px; }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(6px);
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
        background: #0f1929;
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        width: 95%;
        max-width: 600px;
        padding: 30px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        max-height: 90vh;
        overflow-y: auto;
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .modal-title { font-size: 20px; font-weight: 700; color: #fff; margin: 0; }
    .modal-close {
        background: rgba(255,255,255,0.08);
        border: none;
        color: #fff;
        width: 32px; height: 32px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
    }
    .modal-close:hover { background: rgba(255,255,255,0.15); }

    .form-group { margin-bottom: 18px; }
    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-muted);
        margin-bottom: 6px;
    }
    .form-label span { color: var(--primary-accent); }
    .form-control {
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 10px 14px;
        border-radius: 8px;
        font-family: inherit;
        font-size: 14px;
        box-sizing: border-box;
        transition: border-color 0.2s;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary-accent);
    }
    textarea.form-control { resize: vertical; min-height: 100px; }
    select.form-control option { background: #0f1929; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .form-hint { font-size: 12px; color: #64748b; margin-top: 4px; }
    .char-count { font-size: 11px; color: #64748b; text-align: right; margin-top: 4px; }

    .var-hint {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 6px;
    }
    .var-chip {
        background: rgba(6,182,212,0.1);
        border: 1px solid rgba(6,182,212,0.3);
        color: var(--primary-accent);
        padding: 3px 9px;
        border-radius: 20px;
        font-size: 12px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .var-chip:hover { background: rgba(6,182,212,0.2); }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--glass-border);
    }
    .btn-cancel {
        background: rgba(255,255,255,0.06);
        color: #ccc;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
    }

    #notice {
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 14px;
        margin-bottom: 20px;
        display: none;
    }
    #notice.success { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.4); color: #10b981; }
    #notice.error   { background: rgba(239,68,68,0.15);  border: 1px solid rgba(239,68,68,0.4);  color: #ef4444; }
</style>
{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1 class="page-title">Message Templates</h1>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 14px;">Create and manage WhatsApp message templates. New templates require Meta review.</p>
    </div>
    <div class="header-actions">
        <button class="btn-secondary" id="syncBtn" onclick="syncTemplates()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
            Sync Templates
        </button>
        <button class="btn-primary" onclick="openModal()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Create Template
        </button>
    </div>
</div>

<div id="notice"></div>

<div class="templates-grid">
    {% for template in templates %}
        <div class="template-card">
            <div class="template-header">
                <div>
                    <div class="template-name">{{ template.name }}</div>
                    <div class="template-meta">{{ template.category|capitalize }} &bull; {{ template.language }}</div>
                </div>
                <span class="badge badge-{{ template.status|lower }}">{{ template.status }}</span>
            </div>
            
            {% set bodyText = '' %}
            {% set headerText = '' %}
            {% set footerText = '' %}
            {% for comp in template.components %}
                {% if comp.type == 'BODY' %}{% set bodyText = comp.text %}{% endif %}
                {% if comp.type == 'HEADER' and comp.format == 'TEXT' %}{% set headerText = comp.text %}{% endif %}
                {% if comp.type == 'FOOTER' %}{% set footerText = comp.text %}{% endif %}
            {% endfor %}
            
            {% if headerText %}
                <div style="font-size: 12px; color: var(--primary-accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">{{ headerText }}</div>
            {% endif %}
            <div class="template-body">{{ bodyText ?: 'No body text' }}</div>
            {% if footerText %}
                <div style="font-size: 12px; color: #64748b; font-style: italic;">{{ footerText }}</div>
            {% endif %}
        </div>
    {% else %}
        <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            <h3>No templates yet</h3>
            <p>Create a template below, or click "Sync Templates" to pull your existing ones from Meta.</p>
        </div>
    {% endfor %}
</div>

<!-- Create Template Modal -->
<div class="modal-overlay" id="createModal">
    <div class="modal-box">
        <div class="modal-header">
            <h2 class="modal-title">Create Message Template</h2>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>

        <div style="background: rgba(6,182,212,0.08); border: 1px solid rgba(6,182,212,0.2); border-radius: 8px; padding: 12px 14px; margin-bottom: 20px; font-size: 13px; color: #94a3b8;">
            <strong style="color: var(--primary-accent);">ℹ️ Note:</strong> Templates require Meta review before they can be used. UTILITY and AUTHENTICATION templates are typically approved faster than MARKETING.
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" for="tpl-name">Template Name <span>*</span></label>
                <input type="text" id="tpl-name" class="form-control" placeholder="e.g. order_confirmation" oninput="this.value = this.value.toLowerCase().replace(/[^a-z0-9_]/g,'')">
                <p class="form-hint">Lowercase letters, numbers, underscores only.</p>
            </div>
            <div class="form-group">
                <label class="form-label" for="tpl-category">Category <span>*</span></label>
                <select id="tpl-category" class="form-control">
                    <option value="UTILITY">UTILITY</option>
                    <option value="MARKETING">MARKETING</option>
                    <option value="AUTHENTICATION">AUTHENTICATION</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" for="tpl-language">Language <span>*</span></label>
            <select id="tpl-language" class="form-control">
                <option value="en_US">English (US)</option>
                <option value="en_GB">English (UK)</option>
                <option value="ar">Arabic</option>
                <option value="es">Spanish</option>
                <option value="hi">Hindi</option>
                <option value="bn">Bengali</option>
                <option value="pt_BR">Portuguese (Brazil)</option>
                <option value="fr">French</option>
                <option value="id">Indonesian</option>
                <option value="tr">Turkish</option>
                <option value="zh_CN">Chinese (Simplified)</option>
                <option value="ur">Urdu</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label" for="tpl-header">Header <small style="font-weight:400;">(optional)</small></label>
            <input type="text" id="tpl-header" class="form-control" placeholder="e.g. Order Update" maxlength="60">
        </div>

        <div class="form-group">
            <label class="form-label" for="tpl-body">Body Text <span>*</span></label>
            <textarea id="tpl-body" class="form-control" placeholder="Type your message here. Use {{1}}, {{2}} for variables." maxlength="1024" oninput="updateCount()"></textarea>
            <div class="char-count"><span id="bodyCount">0</span> / 1024</div>
            <div class="var-hint">
                <span style="font-size: 12px; color: #64748b; margin-right: 4px;">Insert variable:</span>
                <span class="var-chip" onclick="insertVar('{{1}}')">{{1}}</span>
                <span class="var-chip" onclick="insertVar('{{2}}')">{{2}}</span>
                <span class="var-chip" onclick="insertVar('{{3}}')">{{3}}</span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" for="tpl-footer">Footer <small style="font-weight:400;">(optional)</small></label>
            <input type="text" id="tpl-footer" class="form-control" placeholder="e.g. Reply STOP to unsubscribe" maxlength="60">
        </div>

        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <button class="btn-primary" id="submitBtn" onclick="submitTemplate()">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                Submit to Meta
            </button>
        </div>
    </div>
</div>

<script>
function openModal() {
    document.getElementById('createModal').classList.add('open');
}
function closeModal() {
    document.getElementById('createModal').classList.remove('open');
}

function updateCount() {
    const val = document.getElementById('tpl-body').value;
    document.getElementById('bodyCount').textContent = val.length;
}

function insertVar(variable) {
    const ta = document.getElementById('tpl-body');
    const start = ta.selectionStart, end = ta.selectionEnd;
    ta.value = ta.value.substring(0, start) + variable + ta.value.substring(end);
    ta.selectionStart = ta.selectionEnd = start + variable.length;
    ta.focus();
    updateCount();
}

function submitTemplate() {
    const name     = document.getElementById('tpl-name').value.trim();
    const category = document.getElementById('tpl-category').value;
    const language = document.getElementById('tpl-language').value;
    const header   = document.getElementById('tpl-header').value.trim();
    const body     = document.getElementById('tpl-body').value.trim();
    const footer   = document.getElementById('tpl-footer').value.trim();

    if (!name || !body) {
        showNotice('error', 'Template name and body text are required.');
        return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg> Submitting...';

    const formData = new FormData();
    formData.append('name', name);
    formData.append('category', category);
    formData.append('language', language);
    formData.append('header', header);
    formData.append('body', body);
    formData.append('footer', footer);

    fetch('{{ path('app_bot_templates_create') }}', { method: 'POST', body: formData })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                closeModal();
                showNotice('success', data.message + ' Refreshing in 2 seconds...');
                setTimeout(() => window.location.reload(), 2000);
            } else {
                showNotice('error', 'Error: ' + data.error);
            }
        })
        .catch(() => showNotice('error', 'An unexpected error occurred.'))
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg> Submit to Meta';
        });
}

function syncTemplates() {
    const btn = document.getElementById('syncBtn');
    btn.classList.add('loading');
    btn.disabled = true;

    fetch('{{ path('app_bot_templates_sync') }}', { method: 'POST' })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showNotice('success', data.message);
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showNotice('error', 'Sync failed: ' + data.error);
            }
        })
        .catch(() => showNotice('error', 'An error occurred during sync.'))
        .finally(() => {
            btn.classList.remove('loading');
            btn.disabled = false;
        });
}

function showNotice(type, msg) {
    const el = document.getElementById('notice');
    el.className = type;
    el.textContent = msg;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// Close modal on overlay click
document.getElementById('createModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Bot Reply Builder - Bot Manager{% endblock %}

{% block stylesheets %}
<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    
    .builder-container {
        display: flex;
        gap: 20px;
        height: calc(100vh - 180px);
    }
    
    .sidebar {
        width: 300px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    
    .sidebar-header {
        padding: 15px;
        border-bottom: 1px solid var(--glass-border);
        font-weight: 600;
        color: #fff;
    }
    
    .sidebar-content {
        padding: 15px;
        flex: 1;
        overflow-y: auto;
    }
    
    .canvas-area {
        flex: 1;
        background: rgba(0, 0, 0, 0.2);
        border: 1px dashed var(--glass-border);
        border-radius: 12px;
        padding: 40px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .block {
        width: 100%;
        max-width: 400px;
        background: var(--bg-gradient-end);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        cursor: grab;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        position: relative;
    }
    
    .block.trigger-block {
        border-top: 4px solid var(--secondary-accent);
    }
    
    .block.action-block {
        border-top: 4px solid var(--primary-accent);
    }
    
    .block-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        font-weight: 600;
        color: #fff;
    }
    
    .block-input {
        width: 100%;
        background: rgba(0,0,0,0.2);
        border: 1px solid var(--glass-border);
        color: #fff;
        padding: 8px 12px;
        border-radius: 6px;
        font-family: inherit;
        font-size: 14px;
        margin-top: 5px;
        box-sizing: border-box;
    }
    
    .draggable-item {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--glass-border);
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 10px;
        cursor: grab;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .draggable-item:hover {
        background: rgba(255,255,255,0.1);
    }
    
    .connector {
        width: 2px;
        height: 20px;
        background: var(--primary-accent);
        margin-bottom: 15px;
    }
    
    .save-btn {
        background: var(--primary-accent);
        color: #000;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
    }
    
    .flow-list {
        margin-bottom: 20px;
    }
    
    .flow-item {
        padding: 10px;
        background: rgba(0,0,0,0.2);
        border-radius: 6px;
        margin-bottom: 5px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
    }
    
    .flow-item:hover {
        background: rgba(255,255,255,0.1);
    }
    
    .delete-block {
        position: absolute;
        top: 10px;
        right: 10px;
        background: none;
        border: none;
        color: var(--error-color);
        cursor: pointer;
    }
</style>
{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1 class="page-title">Bot Reply Builder</h1>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 14px;">Drag and drop actions to create an automated reply flow.</p>
    </div>
    <button class="save-btn" onclick="saveFlow()">Save Flow</button>
</div>

<div class="builder-container">
    <div class="sidebar">
        <div class="sidebar-header">Existing Flows</div>
        <div class="sidebar-content flow-list">
            {% for flow in flows %}
                <div class="flow-item" onclick="loadFlow('{{ flow.triggerKeyword }}', {{ flow.flowData|json_encode() }})">
                    <span>{{ flow.triggerKeyword }}</span>
                    <span style="color: {{ flow.isActive ? 'var(--secondary-accent)' : 'var(--error-color)' }}">&bull;</span>
                </div>
            {% else %}
                <div style="color: #888; font-size: 13px;">No flows yet. Create one!</div>
            {% endfor %}
            
            <button onclick="newFlow()" style="width: 100%; margin-top: 10px; background: rgba(255,255,255,0.1); border: 1px dashed var(--glass-border); color: #fff; padding: 8px; border-radius: 6px; cursor: pointer;">+ New Flow</button>
        </div>
        
        <div class="sidebar-header" style="border-top: 1px solid var(--glass-border);">Action Blocks</div>
        <div class="sidebar-content">
            <div class="draggable-item" draggable="true" ondragstart="drag(event, 'send_text')">
                <span style="color: var(--primary-accent);">📝</span> Send Text
            </div>
            <!-- Future feature blocks can be added here -->
        </div>
    </div>
    
    <div class="canvas-area" id="canvas" ondrop="drop(event)" ondragover="allowDrop(event)">
        <!-- Trigger Block (Always at the top) -->
        <div class="block trigger-block" id="trigger-block">
            <div class="block-header">
                <span style="color: var(--secondary-accent);">⚡</span> Keyword Trigger
            </div>
            <label style="font-size: 12px; color: var(--text-muted);">If user sends keyword:</label>
            <input type="text" id="trigger-keyword" class="block-input" placeholder="e.g. hello">
        </div>
        
        <div id="actions-container" style="width: 100%; display: flex; flex-direction: column; align-items: center;">
            <!-- Actions will be dropped here -->
        </div>
    </div>
</div>

<script>
    let currentActions = [];

    function allowDrop(ev) {
        ev.preventDefault();
    }

    function drag(ev, type) {
        ev.dataTransfer.setData("type", type);
    }

    function drop(ev) {
        ev.preventDefault();
        const type = ev.dataTransfer.getData("type");
        if (type === 'send_text') {
            addAction({ type: 'send_text', text: '' });
        }
    }

    function addAction(action) {
        const index = currentActions.length;
        currentActions.push(action);
        renderActions();
    }
    
    function removeAction(index) {
        currentActions.splice(index, 1);
        renderActions();
    }
    
    function updateAction(index, value) {
        currentActions[index].text = value;
    }

    function renderActions() {
        const container = document.getElementById('actions-container');
        container.innerHTML = '';
        
        currentActions.forEach((action, index) => {
            const connector = document.createElement('div');
            connector.className = 'connector';
            container.appendChild(connector);
            
            const block = document.createElement('div');
            block.className = 'block action-block';
            
            block.innerHTML = `
                <button class="delete-block" onclick="removeAction(${index})">&times;</button>
                <div class="block-header">
                    <span style="color: var(--primary-accent);">📝</span> Send Text
                </div>
                <label style="font-size: 12px; color: var(--text-muted);">Message to send:</label>
                <textarea class="block-input" rows="3" onchange="updateAction(${index}, this.value)" placeholder="Type message...">${action.text}</textarea>
            `;
            container.appendChild(block);
        });
    }

    function saveFlow() {
        const keyword = document.getElementById('trigger-keyword').value.trim();
        if (!keyword) {
            alert('Please enter a trigger keyword.');
            return;
        }
        
        const payload = {
            keyword: keyword,
            actions: currentActions,
            isActive: true
        };
        
        fetch('{{ path('app_bot_flows_save') }}', {
            method: 'POST',
            body: JSON.stringify(payload),
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert('Flow saved successfully!');
                window.location.reload();
            } else {
                alert('Error saving flow: ' + data.error);
            }
        });
    }
    
    function loadFlow(keyword, actions) {
        document.getElementById('trigger-keyword').value = keyword;
        currentActions = actions || [];
        renderActions();
    }
    
    function newFlow() {
        document.getElementById('trigger-keyword').value = '';
        currentActions = [];
        renderActions();
    }
</script>
{% endblock %}

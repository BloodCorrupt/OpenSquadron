# .env.example
# Copy this file to .env and edit it before running docker compose
# IMPORTANT: Never commit the actual .env file to git!

# App Settings
APP_ENV=prod
APP_SECRET=ChangeThisToSomethingRandom
APP_PORT=6969
APP_CODE_PATH=.

# Database Settings
DB_NAME=opensquadron
DB_USER=opensquadron
DB_PASSWORD=SecureDatabasePassword!
DB_ROOT_PASSWORD=SecureRootPassword!

# phpMyAdmin Settings
PMA_PORT=8081

# Cloudflare Tunnel Settings (For docker-compose.cf.yml only)
CLOUDFLARE_TUNNEL_TOKEN=your_token_here

# -----------------------------------------------------
# Symfony Application Settings
# -----------------------------------------------------
# The base URI used by CLI commands (e.g. sync_db.bat)
DEFAULT_URI=http://localhost

# Database Connection String for Local XAMPP/PHP. 
# (NOTE: When running Docker, docker-compose.yml overrides this automatically)
DATABASE_URL=mysql://root:@127.0.0.1:3306/opensquadron?serverVersion=10.4.32-MariaDB&charset=utf8mb4

# WhatsApp API Configuration

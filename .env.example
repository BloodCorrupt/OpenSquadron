# .env.example
# Copy this file to .env and edit it before running docker compose
# IMPORTANT: Never commit the actual .env file to git!

# App Settings
APP_ENV=prod
APP_SECRET=ChangeThisToSomethingRandom
APP_PORT=6969

# Database Settings
DB_NAME=opensquadron
DB_USER=opensquadron
DB_PASSWORD=SecureDatabasePassword!
DB_ROOT_PASSWORD=SecureRootPassword!

# phpMyAdmin Settings
PMA_PORT=8081
